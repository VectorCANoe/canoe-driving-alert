test-results/
*.result
*.xml
coverage/
*.vtestreport

# Vector CANoe
*.cfg.bak
Logging/
*.logging
*.blf
*.asc

# CANoe outputs (canoe/ 구조로 이전)
canoe/logging/*.blf
canoe/logging/*.asc
canoe/logging/*.mf4
canoe/logging/test-results/
