# Temporary files
*.tmp
*.bak
*~
*.swp
*.swo
~$*.xlsx
**/~$*.xlsx

# OS specific
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.iml
*.sublime-project
*.sublime-workspace

# Build artifacts
build/
dist/
*.o
*.exe
*.dll
*.so
*.dylib

