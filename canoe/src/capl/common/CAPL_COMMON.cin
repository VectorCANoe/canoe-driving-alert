int ethHasBoundaryServiceContext(int routeActive, int alertLevel)
{
  if (routeActive == 1 || alertLevel > 0)
  {
    return 1;
  }

  return 0;
}

int ethDiagBoundaryStage(int routeActive,
                         int alertLevel,
                         int boundaryAlive,
                         int warningPathStatus,
                         int failSafeMode)
{
  int serviceContext;

  serviceContext = ethHasBoundaryServiceContext(routeActive, alertLevel);
  if (serviceContext == 0)
  {
    return 0;
  }
  if (boundaryAlive == 0)
  {
    return 3;
  }
  if (failSafeMode >= 2 || warningPathStatus >= 2)
  {
    return 3;
  }
  if (failSafeMode == 1 || warningPathStatus == 1)
  {
    return 2;
  }

  return 1;
}

int ethDiagStageToSecurityFault(int diagStage)
{
  if (diagStage >= 3)
  {
    return 2;
  }
  if (diagStage == 2)
  {
    return 1;
  }

  return 0;
}

int ethDiagStageToPolicy(int diagStage)
{
  if (diagStage >= 3)
  {
    return 2;
  }
  if (diagStage == 2)
  {
    return 1;
  }

  return 0;
}

void ethClearFrame(char frame[], int frameLen)
{
  int i;

  for (i = 0; i < frameLen; i = i + 1)
  {
    frame[i] = 0;
  }
}

void ethInitFrame(char frame[], int msgId, int payloadLen)
{
  ethClearFrame(frame, payloadLen + 2);
  frame[0] = (char)(msgId & 0xFF);
  frame[1] = (char)((msgId >> 8) & 0xFF);
}

int ethFrameMsgId(char frame[], dword count)
{
  if (count < 2)
  {
    return -1;
  }

  return (((int)frame[1] & 0xFF) << 8) | ((int)frame[0] & 0xFF);
}

int ethFramePayloadLen(dword count)
{
  if (count < 2)
  {
    return 0;
  }
  return (int)(count - 2);
}

void ethSetU8(char frame[], int payloadIndex, int value)
{
  frame[payloadIndex + 2] = (char)(value & 0xFF);
}

int ethGetU8(char frame[], int payloadIndex)
{
  return ((int)frame[payloadIndex + 2] & 0xFF);
}

void ethSetU16Le(char frame[], int payloadIndex, int value)
{
  frame[payloadIndex + 2] = (char)(value & 0xFF);
  frame[payloadIndex + 3] = (char)((value >> 8) & 0xFF);
}

int ethGetU16Le(char frame[], int payloadIndex)
{
  int lo;
  int hi;

  lo = ((int)frame[payloadIndex + 2] & 0xFF);
  hi = ((int)frame[payloadIndex + 3] & 0xFF);
  return lo | (hi << 8);
}

void ethSetS16Le(char frame[], int payloadIndex, int value)
{
  ethSetU16Le(frame, payloadIndex, value & 0xFFFF);
}

int ethGetS16Le(char frame[], int payloadIndex)
{
  int value;

  value = ethGetU16Le(frame, payloadIndex);
  if (value >= 32768)
  {
    value = value - 65536;
  }
  return value;
}

dword ethBackboneGroupIp()
{
  return IpGetAddressAsNumber("239.0.2.1");
}

dword ethGetDefaultIpAddress()
{
  return ethBackboneGroupIp();
}

long ethOpenNodeSocket(int localPort)
{
  long socket;

  socket = UdpOpen(0, localPort);
  if (socket == ethInvalidSocket())
  {
    write("[ETH] open failed port=%d err=%d", localPort, IpGetLastError());
  }
  return socket;
}

long ethOpenNodeSocketAt(dword localIp, int localPort)
{
  long socket;

  socket = UdpOpen(localIp, localPort);
  if (socket == ethInvalidSocket())
  {
    write("[ETH] open failed ip=%u port=%d err=%d", localIp, localPort, IpGetLastError());
  }
  return socket;
}

long ethOpenDefaultSocket()
{
  return ethOpenNodeSocket(ethBackbonePort());
}

void ethCloseSocket(long socket)
{
  if (socket != ethInvalidSocket())
  {
    UdpClose(socket);
  }
}

/* Transient/expected socket errors -- suppress write() to prevent RT kernel crash.
   997   WSA_IO_PENDING        overlapped I/O pending (normal async op)
   995   WSA_OPERATION_ABORTED operation aborted on measurement stop
   10038 WSAENOTSOCK           socket already closed
   10051 WSAENETUNREACH        Ethernet channel not yet configured (main crash cause)
   10064 WSAEHOSTDOWN          simulated host down
   10065 WSAEHOSTUNREACH       no route to multicast group
   10054 WSAECONNRESET         UDP reset on receive side
   10040 WSAEMSGSIZE           frame too large (keep visible)
   10013 WSAEACCES             multicast join permission denied (keep visible) */
int ethIsTransientError(int err)
{
  if (err == 997)   { return 1; }
  if (err == 995)   { return 1; }
  if (err == 10038) { return 1; }
  if (err == 10051) { return 1; }
  if (err == 10064) { return 1; }
  if (err == 10065) { return 1; }
  if (err == 10054) { return 1; }
  return 0;
}

int ethArmReceive(long socket, char rxBuffer[], int rxBufferSize)
{
  int result;
  int lastError;

  if (socket == ethInvalidSocket() || rxBufferSize <= 0)
  {
    return -1;
  }

  result = UdpReceiveFrom(socket, rxBuffer, rxBufferSize);
  if (result != 0)
  {
    lastError = IpGetLastSocketError(socket);
    if (ethIsTransientError(lastError) == 0)
    {
      write("[ETH] recv error=%d", lastError);
    }
  }
  return result;
}

int ethStartReceiver(long socket, char rxBuffer[], int rxBufferSize)
{
  int result;

  if (socket == ethInvalidSocket())
  {
    return -1;
  }

  result = ipJoinMulticastGroup(socket, 1, ethBackboneGroupIp());
  if (result != 0)
  {
    if (ethIsTransientError(result) == 0)
    {
      write("[ETH] join multicast failed result=%d", result);
    }
  }

  return ethArmReceive(socket, rxBuffer, rxBufferSize);
}

int ethSendFrame(long socket, dword targetIp, int msgId, char frame[], int payloadLen)
{
  int frameLen;
  int result;
  int lastError;

  if (socket == ethInvalidSocket())
  {
    return -1;
  }
  if (targetIp == ethInvalidIp())
  {
    targetIp = ethBackboneGroupIp();
  }

  frame[0] = (char)(msgId & 0xFF);
  frame[1] = (char)((msgId >> 8) & 0xFF);
  frameLen = payloadLen + 2;
  result = UdpSendTo(socket, targetIp, ethBackbonePort(), frame, frameLen);
  if (result != 0)
  {
    lastError = IpGetLastSocketError(socket);
    if (ethIsTransientError(lastError) == 0)
    {
      write("[ETH] send failed msg=0x%X port=%d err=%d",
            msgId,
            ethBackbonePort(),
            lastError);
    }
  }
  return result;
}
