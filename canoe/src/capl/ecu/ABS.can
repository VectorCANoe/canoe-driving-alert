includes
{
  #include "..\\common\\CAPL_COMMON.cin"
}

variables
{
  msTimer tAbsCycle;
  int gBrakePressure;
  int gBrakeMode;
  int gAbsActive;
  int gWheelSpdFL;
  int gWheelSpdFR;
  int gWheelSpdRL;
  int gWheelSpdRR;
  dword gBrakeStatusRxMs;
  dword gWheelSpeedRxMs;
  int gLastBrakeInputStale;
  int gLastWheelInputStale;
  int gLastCtrlState;
  int gLastSlipLevel;
  int gLastPressureCmd;
}

void traceAbsInputHealth(int brakeInputStale, int wheelInputStale)
{
  if (brakeInputStale != gLastBrakeInputStale)
  {
    write("[ABS] brake input %s", brakeInputStale == 1 ? "stale" : "restored");
    gLastBrakeInputStale = brakeInputStale;
  }

  if (wheelInputStale != gLastWheelInputStale)
  {
    write("[ABS] wheel-speed input %s", wheelInputStale == 1 ? "stale" : "restored");
    gLastWheelInputStale = wheelInputStale;
  }
}

void publishAbsState()
{
  message frmAbsStateMsg mAbs;
  int brakePressure;
  int brakeMode;
  int absActive;
  int wheelSpdFL;
  int wheelSpdRL;
  int wheelSpdRR;
  int brakeInputStale;
  int wheelInputStale;
  int avgRearSpeed;
  int slipLevel;
  int pressureCmd;

  brakeInputStale = (ethIsRecentTick(gBrakeStatusRxMs, 300) == 1) ? 0 : 1;
  wheelInputStale = (ethIsRecentTick(gWheelSpeedRxMs, 300) == 1) ? 0 : 1;
  traceAbsInputHealth(brakeInputStale, wheelInputStale);

  brakePressure = gBrakePressure;
  brakeMode = gBrakeMode;
  absActive = gAbsActive;
  wheelSpdFL = gWheelSpdFL;
  wheelSpdRL = gWheelSpdRL;
  wheelSpdRR = gWheelSpdRR;
  if (brakeInputStale == 1)
  {
    brakePressure = 0;
    brakeMode = 0;
    absActive = 0;
  }
  if (wheelInputStale == 1)
  {
    wheelSpdFL = 0;
    wheelSpdRL = 0;
    wheelSpdRR = 0;
  }

  avgRearSpeed = (wheelSpdRL + wheelSpdRR) / 2;
  slipLevel = 0;
  if (absActive == 1)
  {
    slipLevel = clampRange(brakePressure - 80, 0, 63);
    if (avgRearSpeed < wheelSpdFL)
    {
      slipLevel = clampRange(slipLevel + (wheelSpdFL - avgRearSpeed), 0, 63);
    }
  }

  pressureCmd = (absActive == 1) ? brakePressure : 0;

  mAbs.AbsCtrlState = (absActive == 1) ? 2 : ((brakeMode > 0) ? 1 : 0);
  mAbs.AbsSlipLevel = slipLevel;
  mAbs.AbsPressureCmd = clampRange(pressureCmd, 0, 255);
  output(mAbs);

  if (mAbs.AbsCtrlState != gLastCtrlState ||
      mAbs.AbsSlipLevel != gLastSlipLevel ||
      mAbs.AbsPressureCmd != gLastPressureCmd)
  {
    write("[ABS] state=%d slip=%d cmd=%d pressure=%d mode=%d rearAvg=%d",
          mAbs.AbsCtrlState,
          mAbs.AbsSlipLevel,
          mAbs.AbsPressureCmd,
          brakePressure,
          brakeMode,
          avgRearSpeed);
    gLastCtrlState = mAbs.AbsCtrlState;
    gLastSlipLevel = mAbs.AbsSlipLevel;
    gLastPressureCmd = mAbs.AbsPressureCmd;
  }
}

on start
{
  gBrakePressure = 0;
  gBrakeMode = 0;
  gAbsActive = 0;
  gWheelSpdFL = 0;
  gWheelSpdFR = 0;
  gWheelSpdRL = 0;
  gWheelSpdRR = 0;
  gBrakeStatusRxMs = 0;
  gWheelSpeedRxMs = 0;
  gLastBrakeInputStale = 0;
  gLastWheelInputStale = 0;
  gLastCtrlState = -1;
  gLastSlipLevel = -1;
  gLastPressureCmd = -1;
  setTimer(tAbsCycle, 100);
  write("[ABS] start");
}

on timer tAbsCycle
{

  publishAbsState();
  setTimer(tAbsCycle, 100);
}

on message frmBrakeStatusMsg
{
  gBrakePressure = clampRange((int)this.BrakePressure, 0, 255);
  gBrakeMode = clampRange((int)this.BrakeMode, 0, 3);
  gAbsActive = clampRange((int)this.AbsActive, 0, 1);
  gBrakeStatusRxMs = getSimulationTimeMs();
}

on message frmWheelSpeedMsg
{
  gWheelSpdFL = clampRange((int)this.WheelSpdFL, 0, 255);
  gWheelSpdFR = clampRange((int)this.WheelSpdFR, 0, 255);
  gWheelSpdRL = clampRange((int)this.WheelSpdRL, 0, 255);
  gWheelSpdRR = clampRange((int)this.WheelSpdRR, 0, 255);
  gWheelSpeedRxMs = getSimulationTimeMs();
}

on stopMeasurement
{
  cancelTimer(tAbsCycle);
}
