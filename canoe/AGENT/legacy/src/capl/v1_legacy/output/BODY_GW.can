includes{}variables{  msTimer tBodyCycle;  msTimer tBodyBase100;  int gBodyAliveCnt;}on start{  gBodyAliveCnt = 0;  /* Ambient ownership is moved to BCM_AMBIENT_CTRL. Keep tBodyCycle as     a lightweight BODY_GW housekeeping tick at 50ms. */  setTimer(tBodyCycle, 50);  setTimer(tBodyBase100, 100);  write("[BODY_GW] start");}on timer tBodyCycle{  setTimer(tBodyCycle, 50);}on timer tBodyBase100{  message frmHazardControlMsg mHazard;  message frmWindowControlMsg mWindow;  message frmDriverStateMsg mDriver;  message frmDoorStateMsg mDoorState;  message frmLampControlMsg mLamp;  message frmWiperStateMsg mWiper;  message frmSeatBeltStateMsg mSeatBelt;  message frmCabinAirStateMsg mCabinAir;  message frmBodyHealthMsg mHealth;  message frmHvacStateMsg mHvacState;  message frmHvacActuatorMsg mHvacAct;  message frmMirrorStateMsg mMirror;  message frmSeatStateMsg mSeatState;  message frmSeatControlMsg mSeatCtrl;  message frmDoorControlMsg mDoorCtrl;  message frmBcmDiagReqMsg mBcmDiagReq;  message frmImmobilizerStateMsg mImmobilizer;  message frmAlarmStateMsg mAlarm;  message frmBodyGatewayStateMsg mBodyGwState;  message frmBodyComfortStateMsg mComfort;  int warningState;  int hazardActive;  int driverStateLevel;  warningState = (int)@Core::warningState;  hazardActive = ((int)@Core::selectedAlertLevel >= 6) ? 1 : 0;  if (warningState < 0)  {    warningState = 0;  }  if (warningState > 2)  {    warningState = 2;  }  driverStateLevel = warningState;  mHazard.HazardSwitch = hazardActive;  mHazard.HazardState = hazardActive;  output(mHazard);  mWindow.WindowCommand = 0;  mWindow.WindowState = 0;  output(mWindow);  mDriver.DriverStateLevel = driverStateLevel;  mDriver.DriverStateInfo = driverStateLevel;  output(mDriver);  mDoorState.DoorStateMask = 0;  mDoorState.DoorLockState = 1;  mDoorState.ChildLockState = 0;  mDoorState.DoorOpenWarn = 0;  output(mDoorState);  mLamp.HeadLampState = (hazardActive == 1) ? 2 : 1;  mLamp.TailLampState = 1;  mLamp.TurnLampState = 0;  mLamp.HazardLampReq = hazardActive;  output(mLamp);  mWiper.FrontWiperState = 0;  mWiper.RearWiperState = 0;  mWiper.WiperInterval = 0;  output(mWiper);  mSeatBelt.DriverSeatBelt = 1;  mSeatBelt.PassengerSeatBelt = 1;  mSeatBelt.RearSeatBelt = 3;  mSeatBelt.SeatBeltWarnLvl = (hazardActive == 1) ? 1 : 0;  output(mSeatBelt);  mCabinAir.CabinTemp = 24;  mCabinAir.AirQualityIndex = 90;  output(mCabinAir);  mHealth.BodyAliveCnt = gBodyAliveCnt & 0xFF;  mHealth.BodyDiagState = 0;  mHealth.BodyFailCode = 0;  output(mHealth);  mHvacState.CabinSetTemp = 23;  mHvacState.BlowerLevel = 5;  mHvacState.AcCompressorOn = 1;  output(mHvacState);  mHvacAct.VentMode = 2;  mHvacAct.RecircMode = 0;  mHvacAct.DefogMode = 0;  mHvacAct.FanRpmStep = 80;  output(mHvacAct);  mMirror.MirrorFoldState = 0;  mMirror.MirrorHeatState = 0;  mMirror.MirrorAdjustAxis = 0;  output(mMirror);  mSeatState.DriverSeatPos = 120;  mSeatState.PassengerSeatPos = 118;  output(mSeatState);  mSeatCtrl.DriverSeatCmd = 0;  mSeatCtrl.PassengerSeatCmd = 0;  mSeatCtrl.SeatHeatLevel = 0;  mSeatCtrl.SeatVentLevel = 0;  output(mSeatCtrl);  mDoorCtrl.DoorControlCmd = 0;  mDoorCtrl.ChildLockCmd = 0;  output(mDoorCtrl);  mBcmDiagReq.BcmDiagServiceId = 0x22;  mBcmDiagReq.BcmDiagDidHigh = 0xF1;  mBcmDiagReq.BcmDiagDidLow = 0x90;  output(mBcmDiagReq);  mImmobilizer.ImmobilizerState = 1;  mImmobilizer.KeyAuthState = 1;  output(mImmobilizer);  mAlarm.AlarmArmState = 1;  mAlarm.IntrusionDetect = 0;  output(mAlarm);  mBodyGwState.BodyGwRouteState = 1;  mBodyGwState.BodyGwHealth = 0;  output(mBodyGwState);  mComfort.ComfortProfile = 1;  mComfort.ComfortStatus = 0;  mComfort.ComfortError = 0;  output(mComfort);  gBodyAliveCnt = (gBodyAliveCnt + 1) & 0xFF;  setTimer(tBodyBase100, 100);}