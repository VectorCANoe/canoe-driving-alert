includes{}variables{  msTimer tIviCycle;  msTimer tIviBase50;  int gLastWarningTextCode;  int gInfoAliveCnt;  int gIviBaseTick;  int gEmsBlinkPhase;  int gAmbientPulsePhase;  int gIcFlowPhase;  int gVehicleObjectPos;}int clampRange(int value, int minValue, int maxValue){  if (value < minValue)  {    return minValue;  }  if (value > maxValue)  {    return maxValue;  }  return value;}on start{  gLastWarningTextCode = -1;  gInfoAliveCnt = 0;  gIviBaseTick = 0;  gEmsBlinkPhase = 0;  gAmbientPulsePhase = 0;  gIcFlowPhase = 0;  gVehicleObjectPos = 0;  setTimer(tIviCycle, 10);  setTimer(tIviBase50, 50);  write("[IVI_GW] start");}on timer tIviCycle{  int alertLevel;  int alertType;  int timeoutClear;  int emergencyType;  int emergencyDirection;  int warningTextCode;  message frmClusterWarningMsg mCluster;  alertLevel = (int)@Core::selectedAlertLevel;  alertType = (int)@Core::selectedAlertType;  timeoutClear = (int)@Core::timeoutClear;  emergencyType = (int)@V2X::emergencyType;  emergencyDirection = (int)@V2X::emergencyDirection;  if (alertLevel < 0 || alertLevel > 7)  {    alertLevel = 0;  }  if (alertType < 0 || alertType > 7)  {    alertType = 0;  }  if (emergencyType < 0 || emergencyType > 2)  {    emergencyType = 0;  }  if (emergencyDirection < 0 || emergencyDirection > 3)  {    emergencyDirection = 0;  }  timeoutClear = (timeoutClear == 1) ? 1 : 0;  if (timeoutClear == 1 || alertLevel == 0)  {    warningTextCode = 0;  }  else if (alertLevel >= 6)  {    if (emergencyType == 2)    {      warningTextCode = 200 + emergencyDirection;    }    else    {      warningTextCode = 100 + emergencyDirection;    }  }  else if (alertType == 5)  {    warningTextCode = 31;  }  else if (alertType == 6)  {    warningTextCode = 32;  }  else  {    warningTextCode = (alertType * 10) + alertLevel;  }  if (warningTextCode != gLastWarningTextCode)  {    @Cluster::warningTextCode = warningTextCode;    mCluster.WarningTextCode = warningTextCode;    output(mCluster);    gLastWarningTextCode = warningTextCode;  }  setTimer(tIviCycle, 10);}on timer tIviBase50{  message frmClusterBaseStateMsg mBase;  message frmClusterThemeMsg mTheme;  message frmHmiPopupStateMsg mPopup;  message frmAudioFocusMsg mAudio;  message frmVoiceAssistStateMsg mVoice;  message frmMediaStateMsg mMediaState;  message frmCallStateMsg mCallState;  message frmPhoneProjectionMsg mProjection;  message frmClusterNotifMsg mNotif;  message frmMediaMetaMsg mMedia;  message frmSpeechTtsStateMsg mTts;  message frmClusterSyncStateMsg mSync;  message frmInfotainmentHealthMsg mHealth;  int speed;  int driveState;  int alertLevel;  int alertType;  int baseZoneContext;  int roadZoneColorCode;  int roadFlowDirection;  int renderMode;  int renderColor;  int renderPattern;  int renderTextCode;  int renderDirection;  int vehicleMotionStep;  speed = clampRange((int)@Core::vehicleSpeedNorm, 0, 255);  driveState = clampRange((int)@Core::driveStateNorm, 0, 3);  alertLevel = clampRange((int)@Core::selectedAlertLevel, 0, 7);  alertType = clampRange((int)@Core::selectedAlertType, 0, 15);  baseZoneContext = clampRange((int)@Core::baseZoneContext, 0, 4);  renderMode = clampRange((int)@Body::ambientMode, 0, 7);  renderColor = clampRange((int)@Body::ambientColor, 0, 15);  renderPattern = clampRange((int)@Body::ambientPattern, 0, 15);  renderTextCode = clampRange((int)@Cluster::warningTextCode, 0, 65535);  mBase.ClusterSpeed = speed;  mBase.ClusterGear = driveState;  mBase.ClusterStatus = alertLevel;  output(mBase);  mTheme.ThemeMode = (alertLevel > 0) ? 1 : 0;  mTheme.ClusterBrightness = (alertLevel > 0) ? 28 : 20;  output(mTheme);  mPopup.PopupType = alertType;  mPopup.PopupPriority = clampRange(alertLevel, 0, 7);  mPopup.PopupActive = (alertLevel > 0) ? 1 : 0;  output(mPopup);  mAudio.AudioFocusOwner = (alertLevel > 0) ? 1 : 0;  mAudio.AudioDuckingLvl = (alertLevel > 0) ? 4 : 1;  output(mAudio);  mVoice.VoiceAssistState = 1;  mVoice.WakeWordState = 1;  output(mVoice);  mMediaState.MediaSource = 1;  mMediaState.MediaState = 1;  mMediaState.MuteState = 0;  mMediaState.VolumeLevel = 30;  output(mMediaState);  mCallState.CallState = 0;  mCallState.MicMute = 0;  mCallState.SignalQuality = 10;  mCallState.BtDeviceCount = 1;  output(mCallState);  mProjection.ProjectionType = 1;  mProjection.ProjectionState = 1;  output(mProjection);  mNotif.ClusterNotifType = alertType;  mNotif.ClusterNotifArg = alertLevel;  output(mNotif);  mMedia.MediaTrackType = 1;  mMedia.MediaRepeatMode = 0;  mMedia.MediaShuffleMode = 0;  mMedia.MediaRemainTime = 120;  output(mMedia);  mTts.TtsState = 0;  mTts.TtsPriority = 0;  mTts.TtsQueueDepth = 0;  output(mTts);  mSync.ClusterSyncState = 1;  mSync.ClusterSyncError = 0;  mSync.ClusterSyncAge = 10;  output(mSync);  gIviBaseTick = gIviBaseTick + 1;  if ((gIviBaseTick % 2) == 0)  {    mHealth.InfoAliveCnt = gInfoAliveCnt & 0xFF;    mHealth.InfoDiagState = 0;    mHealth.InfoFailCode = 0;    output(mHealth);    gInfoAliveCnt = (gInfoAliveCnt + 1) & 0xFF;  }  if (baseZoneContext == 1)  {    roadZoneColorCode = 1;  }  else if (baseZoneContext == 2)  {    roadZoneColorCode = 2;  }  else if (baseZoneContext == 3 || baseZoneContext == 4)  {    roadZoneColorCode = 3;  }  else  {    roadZoneColorCode = 0;  }  if (baseZoneContext == 3)  {    roadFlowDirection = 1;  }  else if (baseZoneContext == 4)  {    roadFlowDirection = 2;  }  else  {    roadFlowDirection = 0;  }  vehicleMotionStep = 2;  if (roadZoneColorCode == 1)  {    vehicleMotionStep = 1;  }  else if (roadZoneColorCode == 2)  {    vehicleMotionStep = 4;  }  else if (roadZoneColorCode == 3)  {    vehicleMotionStep = 6;  }  if (roadFlowDirection == 2)  {    gVehicleObjectPos = gVehicleObjectPos - vehicleMotionStep;    if (gVehicleObjectPos < 0)    {      gVehicleObjectPos = gVehicleObjectPos + 101;    }  }  else  {    gVehicleObjectPos = gVehicleObjectPos + vehicleMotionStep;    if (gVehicleObjectPos > 100)    {      gVehicleObjectPos = gVehicleObjectPos - 101;    }  }  if (alertLevel >= 6)  {    gEmsBlinkPhase = 1 - gEmsBlinkPhase;  }  else  {    gEmsBlinkPhase = 0;  }  if (alertType == 4)  {    gAmbientPulsePhase = (gAmbientPulsePhase + 1) & 3;  }  else  {    gAmbientPulsePhase = 0;  }  if (alertType == 5 || alertType == 6)  {    gIcFlowPhase = (gIcFlowPhase + 1) & 7;  }  else  {    gIcFlowPhase = 0;  }  if (renderTextCode >= 100 && renderTextCode <= 203)  {    renderDirection = renderTextCode % 100;  }  else if (alertType == 5)  {    renderDirection = 1;  }  else if (alertType == 6)  {    renderDirection = 2;  }  else  {    renderDirection = 0;  }  renderDirection = clampRange(renderDirection, 0, 3);  @UiRender::renderMode = renderMode;  @UiRender::renderColor = renderColor;  @UiRender::renderPattern = renderPattern;  @UiRender::renderTextCode = renderTextCode;  @UiRender::renderDirection = renderDirection;  @UiRender::roadZoneColorCode = roadZoneColorCode;  @UiRender::roadFlowDirection = roadFlowDirection;  @UiRender::vehicleObjectPos = clampRange(gVehicleObjectPos, 0, 100);  @UiRender::emsBlinkPhase = gEmsBlinkPhase;  @UiRender::ambientPulsePhase = gAmbientPulsePhase;  @UiRender::icFlowPhase = gIcFlowPhase;  @UiRender::activeAlertType = clampRange(alertType, 0, 7);  setTimer(tIviBase50, 50);}