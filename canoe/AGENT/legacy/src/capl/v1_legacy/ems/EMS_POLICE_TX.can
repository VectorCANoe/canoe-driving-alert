includes{}variables{  msTimer tPoliceCycle;  int gPrevDispatch;}on start{  gPrevDispatch = 0;  setTimer(tPoliceCycle, 100);  write("[EMS_POLICE_TX] start");}on timer tPoliceCycle{  message frmEmergencyBroadcastMsg mBcast;  int dispatch;  dispatch = (int)@V2X::policeDispatch;  if (dispatch < 0) dispatch = 0;  if (dispatch > 1) dispatch = 1;  if (dispatch == 1 && gPrevDispatch == 0)  {    /* rising edge: police dispatch activated */    /* v1 sysvar path (panel/legacy compat) */    @V2X::emergencyType      = 1;    @V2X::alertState         = 1;    @V2X::sourceId           = 1;    @V2X::eta                = 30;    @V2X::emergencyDirection = 0;    /* v2: broadcast CAN frame on ETH backbone via eth_backbone_can_stub.dbc (CANoe Ethernet) */    mBcast.VehicleType = 1;    mBcast.Status      = 1;    mBcast.SourceId    = 1;    mBcast.EtaSeconds  = 30;    mBcast.Direction   = 0;    output(mBcast);    write("[EMS_POLICE_TX] ACTIVE  type=1 src=1 eta=30");  }  else if (dispatch == 0 && gPrevDispatch == 1)  {    /* falling edge: clear if police still owns the channel */    if ((int)@V2X::sourceId == 1)    {      /* v1 sysvar path */      @V2X::alertState = 0;      /* v2: broadcast CLEAR frame on ETH backbone via eth_backbone_can_stub.dbc */      mBcast.VehicleType = 1;      mBcast.Status      = 0;      mBcast.SourceId    = 1;      mBcast.EtaSeconds  = 0;      mBcast.Direction   = 0;      output(mBcast);      write("[EMS_POLICE_TX] CLEAR");    }  }  gPrevDispatch = dispatch;  setTimer(tPoliceCycle, 100);}