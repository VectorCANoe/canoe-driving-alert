includes{}variables{  msTimer tGazeCycle;  int gPrevGaze;}on start{  gPrevGaze = 0;  setTimer(tGazeCycle, 50);  write("[DRIVER_STATE_CTRL] start");}on timer tGazeCycle{  message frmDriverStateMsg mDrv;  int gazeActive;  gazeActive = (int)@Driver::gazeActive;  if (gazeActive < 0) gazeActive = 0;  if (gazeActive > 1) gazeActive = 1;  /* rising edge 0->1: gaze restored, release Level3 warning */  if (gazeActive == 1 && gPrevGaze == 0)  {    @Core::warningState = 0;    write("[DRIVER_STATE_CTRL] gaze restored -> warning cleared");  }  gPrevGaze = gazeActive;  mDrv.DriverStateLevel = gazeActive;  mDrv.DriverStateInfo  = 0;  output(mDrv);  setTimer(tGazeCycle, 50);}