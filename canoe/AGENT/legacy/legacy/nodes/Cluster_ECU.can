/* * Cluster_ECU.can — Instrument Cluster Warning Display * * 역할: *   - Cluster_Warning CAN (0x221) 수신 → 경고 종류에 따라 텍스트 출력 *   - 긴급차량 접근 시: 차종 + 방향 + 양보 유도 문구 표시 (Req_021, Req_029) *   - 구간 경고 시: 해당 구간 경고 문구 표시 *   - 경고 해제 시: 정상 상태로 복귀 (Req_004, Req_026) * * Panel 표시 구조 (CANoe Panel에서 Static Text로 연결): *   - 경고 텍스트 영역: 2줄 (메인 메시지 + 보조 메시지) *   - 긴급 경고 시: 배경색 변경 (빨강 테두리) *   - 방향 인디케이터: 화살표 아이콘 (Direction 값 기반) * * V-Model: SWE.3 (구현) * Req 추적: Req_019 (종류 표시), Req_020 (방향 표시), Req_021 (양보 문구), *           Req_040 (문구 간결성), Req_043 (경고 문구 간결성) */includes{}variables{  /* WarningType 상수 (DBC VAL_ 기준) */  const int WARN_NONE       = 0;  const int WARN_SCHOOLZONE = 1;  const int WARN_HIGHWAY    = 2;  const int WARN_IC_GUIDE   = 3;  const int WARN_POLICE     = 4;  const int WARN_AMBULANCE  = 5;  /* Direction 상수 */  const int DIR_FRONT = 0;  const int DIR_LEFT  = 1;  const int DIR_RIGHT = 2;  const int DIR_REAR  = 3;  /* 현재 표시 중인 경고 */  int gCurrentWarning = 0;}/*============================================================ * 초기화 *============================================================*/on start{  write("[Cluster_ECU] node start -- normal driving");  write("[Cluster_ECU] -----------------------------------");  write("[Cluster_ECU] Status: normal driving");  write("[Cluster_ECU] -----------------------------------");}/*============================================================ * Cluster_Warning CAN 수신 (0x221) * Civ_Node Alert Arbiter 결과 표시 * Req_005: 경고 발생 이유 운전자가 이해 가능한 형태로 표시 *============================================================*/on message Cluster_Warning{  int warnType;  int active;  int emgVeh;  int direction;  warnType  = this.WarningType;  active    = this.WarningActive;  emgVeh    = this.EmergencyVehicle;  direction = this.Direction;  if (warnType == gCurrentWarning && active == 1)    return; /* 동일 경고 반복 수신 -> 무시 (Req_006: 반복 억제) */  gCurrentWarning = (active == 1) ? warnType : WARN_NONE;  write("[Cluster_ECU] ===================================");  switch (warnType)  {    case WARN_NONE:      write("[Cluster_ECU] Status: normal driving");      break;    case WARN_SCHOOLZONE:      if (active == 1)      {        write("[Cluster_ECU] [!] SCHOOL ZONE SPEED WARNING [!]");        write("[Cluster_ECU] SpeedLimit: 30 km/h  Reduce speed");      }      else      {        write("[Cluster_ECU] school zone warning cleared");      }      break;    case WARN_HIGHWAY:      if (active == 1)      {        write("[Cluster_ECU] [!] HIGHWAY ATTENTION WARNING [!]");        write("[Cluster_ECU] Check steering input");      }      else      {        write("[Cluster_ECU] highway warning cleared");      }      break;    case WARN_IC_GUIDE:      if (active == 1)      {        if (direction == 0) /* LeftExit */          write("[Cluster_ECU] <- IC EXIT: LEFT");        else          write("[Cluster_ECU] -> IC EXIT: RIGHT");        write("[Cluster_ECU] Check ambient direction guide");      }      else      {        write("[Cluster_ECU] IC guide cleared");      }      break;    case WARN_POLICE:      if (active == 1)      {        write("[Cluster_ECU] ** POLICE EMERGENCY **");        writeDirectionMsg(direction);        write("[Cluster_ECU] > Move right -- yield to emergency vehicle");      }      else      {        write("[Cluster_ECU] POLICE emergency cleared");        write("[Cluster_ECU] Resuming normal driving");      }      break;    case WARN_AMBULANCE:      if (active == 1)      {        write("[Cluster_ECU] ** AMBULANCE EMERGENCY **");        writeDirectionMsg(direction);        write("[Cluster_ECU] > Yield NOW -- save a life");      }      else      {        write("[Cluster_ECU] AMBULANCE emergency cleared");        write("[Cluster_ECU] Resuming normal driving");      }      break;    default:      write("[Cluster_ECU] Unknown warning type (%d)", warnType);      break;  }  write("[Cluster_ECU] ===================================");}/*============================================================ * 방향 문구 출력 헬퍼 * Req_020: 긴급차량 진행 방향 정보 표시 *============================================================*/void writeDirectionMsg(int dir){  switch (dir)  {    case DIR_FRONT: write("[Cluster_ECU] approach: FRONT"); break;    case DIR_LEFT:  write("[Cluster_ECU] approach: LEFT");  break;    case DIR_RIGHT: write("[Cluster_ECU] approach: RIGHT"); break;    case DIR_REAR:  write("[Cluster_ECU] approach: REAR");  break;    default:        write("[Cluster_ECU] approach: UNKNOWN"); break;  }}