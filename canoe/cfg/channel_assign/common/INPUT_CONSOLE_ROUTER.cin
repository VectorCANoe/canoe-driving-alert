int mapZoneDistancePresetIdx(int idx)
{
  idx = clampRange(idx, 0, 4);
  switch (idx)
  {
    case 0: return 0;
    case 1: return 30;
    case 2: return 60;
    case 3: return 120;
    default: return 200;
  }
}

int mapSpeedLimitPresetIdx(int idx)
{
  idx = clampRange(idx, 0, 4);
  switch (idx)
  {
    case 0: return 30;
    case 1: return 50;
    case 2: return 80;
    case 3: return 100;
    default: return 120;
  }
}

int inputConsoleScenarioCompatIsActive()
{
  return (((int)@Test::scenarioCommand) != 0 ||
          clampRange((int)@Test::scenarioCommandAck, 0, 255) != 0 ||
          clampRange((int)@Test::scenarioActiveId, 0, 255) != 0 ||
          clampRange((int)@Test::scenarioSettledId, 0, 255) != 0 ||
          clampRange((int)@Test::scenarioEvaluatedId, 0, 255) != 0 ||
          clampRange((int)@Test::testScenario, 0, 255) != 0 ||
          clampRange((int)@Test::scenarioStopReq, 0, 1) != 0);
}

int calcInputConsoleCompatEtaFromPanelPos(int pos)
{
  pos = clampRange(pos, 0, 7);
  if (pos <= 0)
  {
    return 255;
  }
  return clampRange((8 - pos) * 4, 1, 60);
}

void clearInputConsoleManualCompat()
{
  @Test::compatPoliceDispatch = 0;
  @Test::compatAmbulanceDispatch = 0;
  @Test::compatEmergencyDirection = 0;
  @Test::compatEmergencyEta = 255;
  @Test::compatEmergencySourceId = 255;
}

void resetInputConsoleManualBaseline()
{
  @Cmd::ignitionCmd = 0;
  @Cmd::driveStateCmd = 0;
  @Cmd::vehicleSpeedCmd = 0;
  @Cmd::throttlePedalPct = 0;
  @Cmd::brakePedalPct = 0;
  @Cmd::steeringAngleCmd = 0;
  @Cmd::cruiseStateCmd = 0;
  @Cmd::cruiseSetSpeedCmd = 0;
  @Cmd::ambientModeCmd = 0;
  @Body::ambientMode = 0;
  @Cmd::doorLockCmd = 0;
  @Cmd::doorOpenCmd = 0;
  @Cmd::windowCmd = 0;
  @Cmd::wiperCmd = 0;
  @Cmd::turnSignalCmd = 0;
  @Inject::crossOn = 0;
  @Inject::crossOff = 0;
  @Inject::emergencyActiveCmd = 0;
  @Inject::emergencyType = 0;
  @Inject::emergencyDirection = 0;
  @Inject::emergencyEtaSec = 0;
  @Inject::emergencySourceId = 0;
  @Test::driverBeltOff = 0;
  @Test::passengerBeltOff = 0;
  @Test::seatBeltOverride = 0;
  clearInputConsoleManualCompat();
}

void publishInputConsoleManualCompat()
{
  int policePos;
  int ambulancePos;
  int manualAlertOverride;
  int manualEmergencyAlertCmd;
  int emergencyType;
  int emergencyDirection;
  int emergencyEta;
  int emergencySourceId;
  int policeDispatch;
  int ambulanceDispatch;

  if (inputConsoleScenarioCompatIsActive() == 1)
  {
    return;
  }

  policePos = clampRange((int)@V2X::policePos, 0, 7);
  ambulancePos = clampRange((int)@V2X::ambulancePos, 0, 7);
  manualAlertOverride = clampRange((int)@Inject::manualAlertOverrideCmd, 0, 255);
  if (manualAlertOverride == 0 && (((int)@Inject::emergencyActiveCmd) > 0))
  {
    manualAlertOverride = 1;
  }
  manualEmergencyAlertCmd = clampRange((int)@Inject::emergencyActiveCmd, 0, 1);
  policeDispatch = 0;
  ambulanceDispatch = 0;
  emergencyType = clampRange((int)@Inject::emergencyType, 0, 2);
  emergencyDirection = clampRange((int)@Inject::emergencyDirection, 0, 3);
  emergencyEta = clampRange((int)@Inject::emergencyEtaSec, 0, 255);
  emergencySourceId = clampRange((int)@Inject::emergencySourceId, 0, 255);
  if (emergencySourceId == 0)
  {
    emergencySourceId = 255;
  }

  if (manualEmergencyAlertCmd == 1 || manualAlertOverride > 0)
  {
    if (emergencyType == 0)
    {
      emergencyType = 2;
    }
    if (emergencyEta == 0 || emergencyEta == 255)
    {
      emergencyEta = 20;
    }
    if (emergencySourceId == 0 || emergencySourceId == 255)
    {
      emergencySourceId = (emergencyType == 1) ? 1 : 2;
    }
    policeDispatch = (emergencyType == 1) ? 1 : 0;
    ambulanceDispatch = (emergencyType == 2) ? 1 : 0;
  }
  else if (ambulancePos > 0 || policePos > 0)
  {
    emergencyDirection = 0;
    if (ambulancePos >= policePos)
    {
      ambulanceDispatch = 1;
      emergencyEta = calcInputConsoleCompatEtaFromPanelPos(ambulancePos);
      emergencySourceId = 2;
    }
    else
    {
      policeDispatch = 1;
      emergencyEta = calcInputConsoleCompatEtaFromPanelPos(policePos);
      emergencySourceId = 1;
    }
  }

  if (policeDispatch == 1 || ambulanceDispatch == 1)
  {
    @Test::compatPoliceDispatch = policeDispatch;
    @Test::compatAmbulanceDispatch = ambulanceDispatch;
    @Test::compatEmergencyDirection = emergencyDirection;
    @Test::compatEmergencyEta = emergencyEta;
    @Test::compatEmergencySourceId = emergencySourceId;
  }
  else
  {
    clearInputConsoleManualCompat();
  }
}

void refreshSeatBeltOverrideFromPanel()
{
  int driverBeltOff;
  int passengerBeltOff;
  int seatBeltOverride;

  driverBeltOff = (((int)@Test::driverBeltOff) > 0) ? 1 : 0;
  passengerBeltOff = (((int)@Test::passengerBeltOff) > 0) ? 1 : 0;
  seatBeltOverride = 0;

  if (driverBeltOff == 1)
  {
    seatBeltOverride += 1;
  }
  if (passengerBeltOff == 1)
  {
    seatBeltOverride += 2;
  }

  @Test::seatBeltOverride = seatBeltOverride;
}

on sysvar Inject::zoneDistancePresetIdx
{
  @Inject::zoneDistance = mapZoneDistancePresetIdx((int)@Inject::zoneDistancePresetIdx);
  publishInputConsoleManualCompat();
}

on sysvar Inject::speedLimitPresetIdx
{
  @Inject::speedLimit = mapSpeedLimitPresetIdx((int)@Inject::speedLimitPresetIdx);
  publishInputConsoleManualCompat();
}

