              (int)@Core::decelAssistReq == 1 &&
              level == 7 &&
              type == 2 &&
              (int)@Core::failSafeMode == 0) ? 1 : 0;
  }
  else if (gCurrentScenarioId == 214)
  {
    result = (level == 5 &&
              type == 3 &&
              (int)@Core::failSafeMode == 0) ? 1 : 0;
  }
  else if (gCurrentScenarioId == 215)
  {
    result = (level == 6 &&
              type == 1 &&
