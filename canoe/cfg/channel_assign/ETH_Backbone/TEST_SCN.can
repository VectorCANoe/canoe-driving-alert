  }
  else if (gCurrentScenarioId == 229)
  {
    result = (gObsDriveState == 0 &&
              gObsVehicleSpeed == 0 &&
              (int)@Core::failSafeMode == 0 &&
              gObsTmuLinkState == 2 &&
              gObsTmuServiceMode == 1 &&
              gObsRemoteClimateReq == 1 &&
              gObsSignalBars == 4 &&
              gObsCabinSetTemp == 24 &&
              gObsBlowerLevel == 5 &&
              gObsAcCompressorOn == 1 &&
              gObsVentMode == 2 &&
              gObsRearSetTemp == 24 &&
              gObsRearBlowerLevel == 5 &&
              gObsRearVentMode == 2 &&
              gObsRearSyncMode == 1 &&
              gObsDKeyState == 2 &&
              gObsVehicleAccessState == 2 &&
              gObsSecurityGrade == 2 &&
              gObsKeyPresence == 1) ? 1 : 0;
  }
  else if (gCurrentScenarioId == 236)
  {
    result = (level == 4 &&
              type == 3 &&
              gObsDriveMode == 2 &&
              gObsSportMode == 1 &&
              (int)@Core::failSafeMode == 0) ? 1 : 0;
  }
  else if (gCurrentScenarioId == 237)
  {
    result = (gObsDriveState == 3 &&
              gObsVehicleSpeed == 140 &&
              gObsDriveMode == 2 &&
              gObsSportMode == 1 &&
              (int)@Core::failSafeMode == 0) ? 1 : 0;
  }
  else if (gCurrentScenarioId == 239)
  {
    result = (level == 3 &&
              type == 6 &&
              (int)@CoreState::turnLampState == 2 &&
              (int)@Core::failSafeMode == 0) ? 1 : 0;
  }
  else if (gCurrentScenarioId == 244)
  {
    result = (gObsBaseZoneContext == 2 &&
              level == 0 &&
              type == 0 &&
              (int)@Core::failSafeMode == 0) ? 1 : 0;
  }
  else
  {
    result = ((int)@Test::scenarioResult == 1) ? 1 : 0;
  }

  if (gCurrentScenarioId != 0)
  {
    @Test::scenarioEvaluatedId = clampRange(gCurrentScenarioId, 0, 255);
  }
  @Test::scenarioResult = result;
}

on timer tScenarioPhase2
{
  if (gCurrentScenarioId == 9)
  {
    /* Req_030: Phase 2 - inject lower ETA competitor (different sourceId) */
    gLockEmergencyType = 1;
    gLockEta = 10;
    gLockSourceId = 99;
    gLockEmergencyDirection = 2;
    pushLockedScenarioInputs();
    write("[TEST_SCN] Req_030 phase2: inject eta=10 sourceId=99");
  }
  else if (gCurrentScenarioId == 10)
  {
    /* Req_031: Phase 2 - inject same ETA, lower SourceID competitor */
    gLockEmergencyType = 1;
    gLockEta = 10;
    gLockSourceId = 5;
    gLockEmergencyDirection = 2;
    pushLockedScenarioInputs();
    write("[TEST_SCN] Req_031 phase2: inject eta=10 sourceId=5");
  }
  else if (gCurrentScenarioId == 11)
  {
    /* Req_034: Phase 2 - snapshot arbitration baseline then inject emergency */
    gArbitrationSnapshotBaseline = (int)@Test::baseTraceSnapshotId;
    gLockAlertState = 1;
    gLockEmergencyType = 1;
    gLockEta = 15;
    gLockSourceId = 10;
    gLockEmergencyDirection = 1;
    pushLockedScenarioInputs();
    write("[TEST_SCN] Req_034 phase2: inject police, baseline snapshotId=%d",
          gArbitrationSnapshotBaseline);
  }
  else if (gCurrentScenarioId == 12)
  {
    /* Req_006 + Req_026: Phase 2 - clear school zone warning (speed drops below limit) */
    gLockVehicleSpeed = 20;
    pushLockedScenarioInputs();
    setTimer(tScenarioPhase3, 100);
    write("[TEST_SCN] Req_006 phase2: speed=20 clear warning");
  }
  else if (gCurrentScenarioId == 13)
  {
    /* Req_015: Phase 2 - snapshot baseline + switch to highway zone (steerInput=1: no warn) */
    gArbitrationSnapshotBaseline = (int)@Test::baseTraceSnapshotId;
    gLockRoadZone = 2;
    gLockVehicleSpeed = 80;
    gLockSpeedLimit = 100;
    gLockSteeringInput = 1;
    pushLockedScenarioInputs();
    setTimer(tScenarioPhase3, 200);
    write("[TEST_SCN] Req_015 phase2: roadZone=2 baseline snapshotId=%d",
          gArbitrationSnapshotBaseline);
  }
  else if (gCurrentScenarioId == 17)
  {
    /* Req_123: simulate driver intervention (steering input) */
    gLockSteeringInput = 1;
    pushLockedScenarioInputs();
    write("[TEST_SCN] Req_123 phase2: steering intervention");
  }
  else if (gCurrentScenarioId == 18)
  {
    /* Req_127 + Req_128 + Req_129: fail-safe transition after decel assist became active */
    gLockForceFailSafe = 1;
    pushLockedScenarioInputs();
    write("[TEST_SCN] Req_127/128/129 phase2: fail-safe asserted");
  }
  else if (gCurrentScenarioId == 25)
  {
    /* Req_136: force temporary object loss and verify hold-time behavior */
    gLockObjectTrackValid = 0;
    pushLockedScenarioInputs();
    write("[TEST_SCN] Req_136 phase2: object track lost");
  }
  else if (gCurrentScenarioId == 35)
  {
    /* ST_021: 긴급 해제 → 스쿨존 과속 경고 복귀 대기 (1000ms 타임아웃 자동 해제) */
    gLockAlertState = 0;
    gLockEmergencyType = 0;
    pushLockedScenarioInputs();
    write("[TEST_SCN] ST_021 phase2: emergency cleared, expect zone warning restore");
  }
  else if (gCurrentScenarioId == 200)
  {
    /* ST_045: Phase 2 — 경찰 긴급 주입 */
    gLockAlertState = 1;
    gLockEmergencyType = 1;
    gLockEta = 10;
    gLockSourceId = 70;
    gLockEmergencyDirection = 1;
    pushLockedScenarioInputs();
    setTimer(tScenarioPhase3, 1200);
    write("[TEST_SCN] ST_045 phase2: inject police emergency eta=10");
  }
  else if (gCurrentScenarioId == 201)
  {
    /* ST_046: Phase 2 — fail-safe 진입 */
    gLockForceFailSafe = 1;
    pushLockedScenarioInputs();
    setTimer(tScenarioPhase3, 400);
    write("[TEST_SCN] ST_046 phase2: force fail-safe");
  }
  else if (gCurrentScenarioId == 202)
  {
    /* ST_043: Phase 2 — emergency refresh 억제 -> degraded context 유도 */
    gLockSuppressEmergencyFrame = 1;
    pushLockedScenarioInputs();
    setTimer(tScenarioPhase3, 400);
    write("[TEST_SCN] ST_043 phase2: suppress emergency refresh, expect degraded context");
  }
  else if (gCurrentScenarioId == 203)
  {
    gLockSuppressEmergencyFrame = 1;
    pushLockedScenarioInputs();
    setTimer(tScenarioPhase3, 400);
    write("[TEST_SCN] UT_063 phase2: suppress emergency refresh, expect degraded SGW context");
  }
  else if (gCurrentScenarioId == 204)
  {
    gLockSuppressEmergencyFrame = 1;
    pushLockedScenarioInputs();
    setTimer(tScenarioPhase3, 400);
    write("[TEST_SCN] UT_064 phase2: suppress emergency refresh, expect degraded DCM context");
  }
  else if (gCurrentScenarioId == 205)
  {
    gLockSuppressEmergencyFrame = 1;
    pushLockedScenarioInputs();
    setTimer(tScenarioPhase3, 400);
    write("[TEST_SCN] IT_040 phase2: suppress emergency refresh, expect integrated degraded context");
  }
  else if (gCurrentScenarioId == 212)
  {
    /* IT_006/ST_015: inject higher-priority ambulance competitor */
    gLockAlertState = 1;
    gLockEmergencyType = 2;
    gLockEta = 8;
    gLockSourceId = 22;
    gLockEmergencyDirection = 2;
    gLockPoliceDispatch = 0;
    gLockAmbulanceDispatch = 0;
    pushLockedScenarioInputs();
    write("[TEST_SCN] IT_006/ST_015 phase2: inject ambulance eta=8 sourceId=22");
  }
  else if (gCurrentScenarioId == 223)
  {
    gArbitrationSnapshotBaseline = (int)@Test::baseTraceSnapshotId;
    gLockAlertState = 1;
    gLockEmergencyType = 2;
    gLockEta = 15;
    gLockSourceId = 10;
    gLockEmergencyDirection = 1;
    pushLockedScenarioInputs();
    write("[TEST_SCN] ST_012 phase2: inject ambulance, baseline snapshotId=%d",
          gArbitrationSnapshotBaseline);
  }
  else if (gCurrentScenarioId == 224)
  {
    gLockEmergencyType = 2;
    gLockEta = 10;
    gLockSourceId = 5;
    gLockEmergencyDirection = 2;
    pushLockedScenarioInputs();
    write("[TEST_SCN] ST_017 phase2: inject ambulance eta=10 sourceId=5");
  }
}

on timer tScenarioPhase3
{
  if (gCurrentScenarioId == 12)
  {
    /* Req_006 + Req_026: Phase 3 - re-trigger school zone warning */
    gLockVehicleSpeed = 45;
    pushLockedScenarioInputs();
    write("[TEST_SCN] Req_006 phase3: speed=45 re-trigger warning");
  }
  else if (gCurrentScenarioId == 13)
  {
    /* Req_015: Phase 3 - return to school zone (must re-settle without flip-flop) */
    gLockRoadZone = 1;
    gLockVehicleSpeed = 45;
    gLockSpeedLimit = 30;
    gLockSteeringInput = 1;
    pushLockedScenarioInputs();
    write("[TEST_SCN] Req_015 phase3: roadZone=1 back to school zone");
  }
  else if (gCurrentScenarioId == 200)
  {
    /* ST_045: Phase 3 — 긴급 해제 + 차량 정지 (전원OFF 직전 상태) */
    gLockAlertState = 0;
    gLockEmergencyType = 0;
    gLockVehicleSpeed = 0;
    gLockDriveState = 0;
    pushLockedScenarioInputs();
    write("[TEST_SCN] ST_045 phase3: emergency clear + vehicle stop (driveState=P)");
  }
  else if (gCurrentScenarioId == 201)
  {
    /* ST_046: Phase 3 — fail-safe 해제 후 정상 복귀 */
    gLockForceFailSafe = 0;
    pushLockedScenarioInputs();
    write("[TEST_SCN] ST_046 phase3: fail-safe cleared, expect recovery");
  }
  else if (gCurrentScenarioId == 202)
  {
    /* ST_043: Phase 3 — explicit blocked context */
    gLockForceFailSafe = 1;
    gLockSuppressEmergencyFrame = 1;
    pushLockedScenarioInputs();
    write("[TEST_SCN] ST_043 phase3: force fail-safe, expect blocked context");
  }
  else if (gCurrentScenarioId == 203)
  {
    gLockForceFailSafe = 1;
    gLockSuppressEmergencyFrame = 1;
    pushLockedScenarioInputs();
    write("[TEST_SCN] UT_063 phase3: force fail-safe, expect blocked SGW context");
  }
  else if (gCurrentScenarioId == 204)
  {
    gLockForceFailSafe = 1;
    gLockSuppressEmergencyFrame = 1;
    pushLockedScenarioInputs();
    write("[TEST_SCN] UT_064 phase3: force fail-safe, expect blocked DCM context");
  }
  else if (gCurrentScenarioId == 205)
  {
    gLockForceFailSafe = 1;
    gLockSuppressEmergencyFrame = 1;
    pushLockedScenarioInputs();
    write("[TEST_SCN] IT_040 phase3: force fail-safe, expect integrated blocked context");
  }
}

on start
{
  gEthSocket = ethOpenPreferredNodeSocket(getTestScnLocalIp(), getTestScnTxPort());
  gEthTargetIp = ethGetDefaultIpAddress();
  gCurrentScenarioId = 0;
  gArbitrationSnapshotBaseline = 0;
  gScenarioInputLock = 0;
  gLockDriveState = 3;
  gLockVehicleSpeed = 20;
  gLockSteeringInput = 1;
  gLockRoadZone = 0;
  gLockNavDirection = 0;
  gLockZoneDistance = 50;
  gLockSpeedLimit = 30;
  gLockAlertState = 0;
  gLockEmergencyType = 0;
  gLockEmergencyDirection = 1;
  gLockEta = 10;
  gLockSourceId = 1;
  gLockAccelPedalOverride = -1;
  gLockBrakePedalOverride = -1;
  gLockForceFailSafe = 0;
  gLockObjectTrackValid = 0;
  gLockObjectRange = 0;
  gLockObjectRelSpeed = 0;
  gLockObjectConfidence = 0;
  gLockIntersectionConflictFlag = 0;
  gLockMergeCutInFlag = 0;
  gLockObjectAlertHoldMs = 300;
  gScenarioCmdInternalClear = 0;
  gScenarioMirrorInternalWrite = 0;
  gPrevAccelPedal = 0;
  gAccelGroupHoldTick = 0;
  gPrevSteeringInput = 1;
  gSteerGroupHoldTick = 0;
  gLockAccelGroupFlag = 0;
  gLockSteerGroupFlag = 0;
  @Test::scenarioCommand = 0;
  @Test::scenarioCommandAck = 0;
  @Test::testScenario = 0;
  @Test::scenarioResult = 0;
  clearScenarioLifecycleState();
  publishScenarioPanelLamps();
  gEmergencyIngressHeartbeat = 0;
  @Core::accelGroupFlag = 0;
  @Core::steerGroupFlag = 0;
  gObsVehicleSpeed = -1;
  gObsDriveState = -1;
  gObsSteeringState = -1;
  gObsBrakePedal = -1;
  gObsDriveMode = -1;
  gObsEcoMode = -1;
  gObsSportMode = -1;
  gObsBaseZoneContext = -1;
  setTimer(tInput100, 100);
  write("[TEST_SCN] start");
}

on timer tInput100
{
  message frmSteeringCanMsg mStr;
  message frmNavContextCanMsg mNav;
  message frmIgnitionEngineMsg mIgn;
  message frmGearStateMsg mGear;
  message frmPedalInputCanMsg mPedal;
  message frmDoorFlStateMsg mDoorFl;
  message frmDoorFrStateMsg mDoorFr;
  message frmTailgateStateMsg mTailgate;
  message frmDoorControlMsg mDoorCtrl;
  message frmDigitalKeyStateMsg mDkey;
  message frmImmobilizerStateMsg mImmo;
  message frmPowerTailgateCtrlStateMsg mTailgateCtrl;
  message frmSeatStateMsg mSeatState;
  message frmSuspensionStateMsg mSuspension;
  message frmConnectivityStateMsg mConn;
  message frmIviHealthDetailMsg mIviHealth;
  message frmCabinAirStateMsg mCabinAir;
  message frmSteeringAngleMsg mSteerAngle;
  message frmLampControlMsg mLampControl;
  message frmTurnLampInputMsg mTurnLampInput;
  message frmWheelSpeedMsg mWheelSpd;
  message frmFuelBatteryStateMsg mBattery;
  message frmEngineSpeedTempMsg mEngineTemp;
  message frmVehicleModeMsg mVehicleMode;
  message frmPowerLimitMsg mPowerLimit;
  message frmEnergyFlowStateMsg mEnergyFlow;
  message frmFcamInputMsg mFcamInput;
  message frmFradarInputMsg mFradarInput;
  message frmLidarInputMsg mLidarInput;
  message frmSrrFlInputMsg mSrrFlInput;
  message frmSrrFrInputMsg mSrrFrInput;
  message frmSrrRlInputMsg mSrrRlInput;
  message frmSrrRrInputMsg mSrrRrInput;
  message frmParkUltrasonicStateMsg mParkUltrasonic;
  message frmAvmStateMsg mAvm;
  message frmSpasStateMsg mSpas;
  message frmRspaStateMsg mRspa;
  char emergencyFrame[8];
  char objectFrame[12];
  int speed;
  int speedHintCmd;
  int driveState;
  int steeringInput;
  int manualSteeringAngleCmd;
  int roadZone;
  int navDirection;
  int zoneDistance;
  int speedLimit;
  int ignitionState;
  int engineState;
  int gearState;
  int accelPedal;
  int brakePedal;
  int objectTrackValid;
  int objectRange;
  int objectRelSpeed;
  int objectConfidence;
  int intersectionConflictFlag;
  int mergeCutInFlag;
  int objectAlertHoldMs;
  int objectRiskClass;
  int harnessRuntimeActive;
  int alertState;
  int emergencyType;
  int emergencyDirection;
  int eta;
  int sourceId;

  speedHintCmd = 0;

  if (gScenarioInputLock == 1)
  {
    speed = clampRange(gLockVehicleSpeed, 0, 255);
    driveState = clampRange(gLockDriveState, 0, 3);
    steeringInput = clampRange(gLockSteeringInput, 0, 1);
    roadZone = clampRange(gLockRoadZone, 0, 3);
    navDirection = clampRange(gLockNavDirection, 0, 3);
    zoneDistance = clampRange(gLockZoneDistance, 0, 255);
    speedLimit = clampRange(gLockSpeedLimit, 0, 255);
    alertState = clampRange(gLockAlertState, 0, 1);
    emergencyType = clampRange(gLockEmergencyType, 0, 2);
    emergencyDirection = clampRange(gLockEmergencyDirection, 0, 3);
    eta = clampRange(gLockEta, 0, 255);
    sourceId = clampRange(gLockSourceId, 0, 255);
    pushLockedScenarioInputs();
  }
  else
  {
    speed = clampRange((int)@Chassis::vehicleSpeed, 0, 255);
    driveState = (ethIsRecentTick(gGearRxMs, 300) == 1) ?
                 clampRange(gCanGearState, 0, 3) : 0;
    steeringInput = clampRange((int)@Chassis::steeringInput, 0, 1);
    roadZone = clampRange((int)@Infotainment::roadZone, 0, 3);
    navDirection = clampRange((int)@Infotainment::navDirection, 0, 3);
    zoneDistance = clampRange((int)@Infotainment::zoneDistance, 0, 255);
    speedLimit = clampRange((int)@Infotainment::speedLimit, 0, 255);
    alertState = 0;
    emergencyType = 0;
    emergencyDirection = 0;
    eta = 0;
    sourceId = 0;
  }
  ignitionState = calcBaselineIgnitionState(speed, driveState);
  engineState = (ignitionState == 1) ? 2 : 0;
  gearState = calcBaselineGearState(driveState);
  accelPedal = clampRange(speed / 2, 0, 100);
  brakePedal = 0;
  if (gLockAccelPedalOverride >= 0)
  {
    accelPedal = clampRange(gLockAccelPedalOverride, 0, 100);
  }
  if (gLockBrakePedalOverride >= 0)
  {
    brakePedal = clampRange(gLockBrakePedalOverride, 0, 100);
  }
  if (gScenarioInputLock == 0)
  {
    gearState = (ethIsRecentTick(gGearRxMs, 300) == 1) ?
                clampRange(gCanGearState, 0, 3) : 0;
    driveState = gearState;
    speedHintCmd = 0;
    manualSteeringAngleCmd = clampRange((int)@Chassis::steeringAngle, 0, 138);
    steeringInput = calcManualSteeringState(manualSteeringAngleCmd);
    /* In manual mode TEST_SCN is only a donor compatibility publisher.
       Owner ECUs consume panel commands and publish the resulting state.
       TEST_SCN must echo that owner state, not re-create a second command
       source from the raw panel buttons. */
    accelPedal = clampRange((int)@Chassis::throttlePosition, 0, 100);
    brakePedal = clampRange((int)@Chassis::brakePressure, 0, 100);
    ignitionState = ((((int)@Chassis::ignitionCmd) > 0) ||
                     driveState > 0 ||
                     speed > 0 ||
                     accelPedal > 0 ||
                     brakePedal > 0) ? 1 : 0;
    engineState = (ignitionState == 1) ? 2 : 0;
  }
  if (gScenarioInputLock == 1)
  {
    @Chassis::steeringInput = clampRange(steeringInput, 0, 1);
  }
  publishManualPanelCompat(speed, accelPedal, brakePedal);
  if (gScenarioInputLock == 1)
  {
    objectTrackValid = clampRange(gLockObjectTrackValid, 0, 1);
    objectRange = clampRange(gLockObjectRange, 0, 500);
    objectRelSpeed = clampRange(gLockObjectRelSpeed, -200, 200);
    objectConfidence = clampRange(gLockObjectConfidence, 0, 100);
    intersectionConflictFlag = clampRange(gLockIntersectionConflictFlag, 0, 1);
    mergeCutInFlag = clampRange(gLockMergeCutInFlag, 0, 1);
    objectAlertHoldMs = clampRange(gLockObjectAlertHoldMs, 0, 5000);
  }
  else
  {
    objectTrackValid = clampRange((int)@Core::objectTrackValid, 0, 1);
    objectRange = clampRange((int)@Core::objectRange, 0, 500);
    objectRelSpeed = clampRange((int)@Core::objectRelSpeed, -200, 200);
    objectConfidence = clampRange((int)@Core::objectConfidence, 0, 100);
    intersectionConflictFlag = clampRange((int)@Core::intersectionConflictFlag, 0, 1);
    mergeCutInFlag = clampRange((int)@Core::mergeCutInFlag, 0, 1);
    objectAlertHoldMs = clampRange((int)@Core::objectAlertHoldMs, 0, 5000);
  }
  objectRiskClass = clampRange((int)@Core::objectRiskClass, 0, 7);
  harnessRuntimeActive = ((gScenarioInputLock == 1) || (getEvidenceTierCode() > 0)) ? 1 : 0;

  /* A-group 자동 감지: 페달 변화율 기반 급가속/급제동 판정
     100ms 주기당 accelPedal 20% 이상 변화 = 급격한 페달 조작
     (전형적 파워트레인 특성 기준 약 3.5 m/s² 등가)
     시나리오 잠금 시에는 gLockAccelGroupFlag 직접 사용 (pushLockedScenarioInputs에서 설정). */
  if (gScenarioInputLock == 0)
  {
    int accelDelta;
    accelDelta = accelPedal - gPrevAccelPedal;
    if (accelDelta < 0) { accelDelta = -accelDelta; }

    if (accelDelta >= 20)
    {
      gAccelGroupHoldTick = 10;
    }
    if (gAccelGroupHoldTick > 0)
    {
      @Core::accelGroupFlag = 1;
      gAccelGroupHoldTick = gAccelGroupHoldTick - 1;
    }
    else
    {
      @Core::accelGroupFlag = 0;
    }
  }
  gPrevAccelPedal = accelPedal;

  /* B-group 자동 감지: 고속 주행 중 조향 입력 상태 전환 감지
     60 km/h 이상에서 steeringInput이 변화하면 급차선변경/차선이탈 이벤트로 판정.
     시나리오 잠금 시에는 gLockSteerGroupFlag 직접 사용. */
  if (gScenarioInputLock == 0)
  {
    if (steeringInput != gPrevSteeringInput && speed >= 60)
    {
      gSteerGroupHoldTick = 10;
    }
    if (gSteerGroupHoldTick > 0)
    {
      @Core::steerGroupFlag = 1;
      gSteerGroupHoldTick = gSteerGroupHoldTick - 1;
    }
    else
    {
      @Core::steerGroupFlag = 0;
    }
  }
  gPrevSteeringInput = steeringInput;

  if (harnessRuntimeActive == 1 || gScenarioInputLock == 0)
  {
    mGear.GearInput = gearState;
    mGear.GearState = gearState;
    output(mGear);
  }

  if (harnessRuntimeActive == 1)
  {
    mStr.SteeringInput = steeringInput;
    output(mStr);

    mNav.gRoadZone = roadZone;
    mNav.gNavDirection = navDirection;
    mNav.gZoneDistance = zoneDistance;
    mNav.gSpeedLimit = speedLimit;
    output(mNav);

    /* Comm_101 baseline powertrain path */
    mIgn.IgnitionState = ignitionState;
    mIgn.EngineState = engineState;
    output(mIgn);

    /* Comm_102 baseline chassis input path */
    mPedal.AccelPedal = accelPedal;
    mPedal.BrakePedal = brakePedal;
    output(mPedal);

    if (gScenarioInputLock == 0 && speedHintCmd > 0)
    {
      mWheelSpd.WheelSpdFL = speedHintCmd;
      mWheelSpd.WheelSpdFR = speedHintCmd;
      mWheelSpd.WheelSpdRL = speedHintCmd;
      mWheelSpd.WheelSpdRR = speedHintCmd;
      output(mWheelSpd);
    }

    mDoorCtrl.DoorControlCmd = clampRange((int)@Body::doorOpenCmd, 0, 1);
    output(mDoorCtrl);

    mTurnLampInput.TurnLampState = clampRange((int)@Body::manualTurnCmd, 0, 3);
    output(mTurnLampInput);

    mFcamInput.ObjectTrackValid = objectTrackValid;
    mFcamInput.Confidence = objectConfidence;
    output(mFcamInput);

    mFradarInput.ObjectTrackValid = objectTrackValid;
    mFradarInput.DistanceBucket = clampRange(objectRange, 0, 255);
    mFradarInput.RelSpeedBucket = clampRange(objectRelSpeed + 128, 0, 255);
    mFradarInput.Confidence = objectConfidence;
    output(mFradarInput);

    mLidarInput.TargetDetected = objectTrackValid;
    mLidarInput.Confidence = objectConfidence;
    mLidarInput.RangeBucket = clampRange(objectRange, 0, 255);
    mLidarInput.EventCode = clampRange((int)@Core::objectEventCode, 0, 255);
    output(mLidarInput);

    mSrrFlInput.MergeConflict = mergeCutInFlag;
    mSrrFlInput.RiskClass = objectRiskClass;
    output(mSrrFlInput);

    mSrrFrInput.MergeConflict = mergeCutInFlag;
    mSrrFrInput.RiskClass = objectRiskClass;
    output(mSrrFrInput);

    mSrrRlInput.MergeConflict = mergeCutInFlag;
    mSrrRlInput.RiskClass = objectRiskClass;
    output(mSrrRlInput);

    mSrrRrInput.MergeConflict = mergeCutInFlag;
    mSrrRrInput.RiskClass = objectRiskClass;
    output(mSrrRrInput);

    if (gScenarioInputLock == 1 && gCurrentScenarioId == 225)
    {
      /* Chassis comfort path is owned by ESC/ASM/CDC. Scenario 225 only
         supplies upstream driving context so those owners emit the state. */
    }
    else if (gScenarioInputLock == 1 && gCurrentScenarioId == 226)
    {
      mDkey.VehicleAccessState = 1;
      mDkey.KeyPresence = 1;
      output(mDkey);

      mImmo.ImmobilizerState = 1;
      mImmo.KeyAuthState = 1;
      output(mImmo);

      mDoorCtrl.DoorControlCmd = 1;
      output(mDoorCtrl);
    }
    else if (gScenarioInputLock == 1 && gCurrentScenarioId == 227)
    {
      mDkey.VehicleAccessState = 1;
      mDkey.KeyPresence = 1;
      output(mDkey);

      mTailgateCtrl.TailgateAssistMode = 2;
      mTailgateCtrl.OpenRequestState = 1;
      mTailgateCtrl.TailgateActuatorCmd = 0;
      output(mTailgateCtrl);
    }
    else if (gScenarioInputLock == 1 && gCurrentScenarioId == 228)
    {
      @Test::driverBeltOff = 1;
      @Test::passengerBeltOff = 1;

      mSeatState.PassengerSeatPos = 60;
      output(mSeatState);
    }
    else if (gScenarioInputLock == 1 && gCurrentScenarioId == 229)
    {
      mConn.ConnectivityType = 1;
      mConn.ConnectivityState = 1;
      mConn.SignalBars = 4;
      output(mConn);

      mIviHealth.IviCpuLoad = 40;
      mIviHealth.IviMemLoad = 38;
      output(mIviHealth);

      mCabinAir.CabinTemp = 30;
      output(mCabinAir);
    }
    else if (gScenarioInputLock == 1 && gCurrentScenarioId == 230)
    {
      mTurnLampInput.TurnLampState = 2;
      output(mTurnLampInput);
    }
    else if (gScenarioInputLock == 1 && gCurrentScenarioId == 239)
    {
      mTurnLampInput.TurnLampState = 2;
      output(mTurnLampInput);
    }
    else if (gScenarioInputLock == 1 && gCurrentScenarioId == 231)
    {
      mBattery.BatterySoc = 60;
      mBattery.ChargingState = 1;
      output(mBattery);
    }
    else if (gScenarioInputLock == 1 && gCurrentScenarioId == 232)
    {
      mEngineTemp.EngineRpm = 2400;
      mEngineTemp.OilTemp = 90;
      output(mEngineTemp);
    }
    else if (gScenarioInputLock == 1 && gCurrentScenarioId == 233)
    {
      mFcamInput.ObjectTrackValid = 1;
      mFcamInput.Confidence = 80;
      output(mFcamInput);
    }
    else if (gScenarioInputLock == 1 && gCurrentScenarioId == 234)
    {
      mParkUltrasonic.ParkAssistActive = 1;
      mParkUltrasonic.MinDistanceCm = 28;
      output(mParkUltrasonic);

      mAvm.AvmActive = 1;
      mAvm.ViewMode = 3;
      output(mAvm);

      mSpas.SpasActive = 1;
      mSpas.SpasStage = 2;
      mSpas.SteeringAssistReq = 1;
      output(mSpas);
    }
  }

  /* Product-side generated frames stay on ECU owners:
     VCU emits vehicle state, EMS emits engine detail, TCU emits transmission detail. */

  if (gScenarioInputLock == 1)
  {
    if (gLockSuppressEmergencyFrame == 0)
    {
      ethInitFrame(emergencyFrame, ethMsgEmergencyAlert(), 4);
      ethSetU8(emergencyFrame, 0, emergencyType | (emergencyDirection << 2));
      ethSetU8(emergencyFrame, 1, eta);
      ethSetU8(emergencyFrame, 2, sourceId);
      ethSetU8(emergencyFrame, 3, alertState);
      ethSendFrame(gEthSocket, gEthTargetIp, ethMsgEmergencyAlert(), emergencyFrame, 4);
    }

    ethInitFrame(objectFrame, ethMsgObjectRiskInput(), 8);
    ethSetU8(objectFrame, 0, objectTrackValid |
                           (intersectionConflictFlag << 1) |
                           (mergeCutInFlag << 2));
    ethSetU16Le(objectFrame, 1, objectRange);
    ethSetS16Le(objectFrame, 3, objectRelSpeed);
    ethSetU8(objectFrame, 5, objectConfidence);
    ethSetU16Le(objectFrame, 6, objectAlertHoldMs);
    ethSendFrame(gEthSocket, gEthTargetIp, ethMsgObjectRiskInput(), objectFrame, 8);
    EmitBackboneValidationOverrideTest(gLockForceFailSafe);

    if (gCurrentScenarioId != 0 &&
        (int)@Test::scenarioSettledId != clampRange(gCurrentScenarioId, 0, 255))
    {
      @Test::scenarioSettledId = clampRange(gCurrentScenarioId, 0, 255);
    }
  }

  trackSt038DiagnosticContext();
  trackDcmDiagnosticContext();
  trackWave2NominalContexts();

  setTimer(tInput100, 100);
}

on sysvar Test::scenarioResult
{
  publishScenarioResultFrame();
  publishScenarioPanelLamps();
}

on sysvar Test::scenarioActiveId
{
  publishScenarioPanelLamps();
}

on message frmVehicleStateCanMsg
{
  gObsVehicleSpeed = clampRange((int)this.gVehicleSpeed, 0, 255);
  gObsDriveState = clampRange((int)this.gDriveState, 0, 3);
}

on message frmGearStateMsg
{
  gCanGearState = clampRange((int)this.GearState, 0, 3);
  gGearRxMs = getSimulationTimeMs();
}

on message frmSteeringStateCanMsg
{
  gObsSteeringState = clampRange((int)this.SteeringState, 0, 1);
}

on message frmBrakeStatusMsg
{
  gObsBrakePedal = clampRange((int)this.BrakePressure / 2, 0, 100);
  if ((int)this.BrakeMode > 0 && gObsBrakePedal == 0)
  {
    gObsBrakePedal = 1;
  }
}

on message frmVehicleModeMsg
{
  gObsDriveMode = clampRange((int)this.DriveMode, 0, 7);
  gObsEcoMode = clampRange((int)this.EcoMode, 0, 1);
  gObsSportMode = clampRange((int)this.SportMode, 0, 1);
}

on message frmNavModuleStateMsg
{
  gObsBaseZoneContext = calcObservedBaseZoneContext((int)this.NavRouteClass,
                                                    (int)this.NavGuideType);
}

on message frmTmuServiceStateMsg
{
  gObsTmuLinkState = clampRange((int)this.TmuLinkState, 0, 3);
  gObsTmuServiceMode = clampRange((int)this.TmuServiceMode, 0, 3);
  gObsRemoteClimateReq = clampRange((int)this.RemoteClimateReq, 0, 1);
  gObsSignalBars = clampRange((int)this.SignalBars, 0, 15);
}

on message frmHvacStateMsg
{
  gObsCabinSetTemp = clampRange((int)this.CabinSetTemp, 0, 100);
  gObsBlowerLevel = clampRange((int)this.BlowerLevel, 0, 15);
  gObsAcCompressorOn = clampRange((int)this.AcCompressorOn, 0, 1);
}

on message frmHvacActuatorMsg
{
  gObsVentMode = clampRange((int)this.VentMode, 0, 7);
}

on message frmRearClimateStateMsg
{
  gObsRearSetTemp = clampRange((int)this.RearSetTemp, 0, 100);
  gObsRearBlowerLevel = clampRange((int)this.RearBlowerLevel, 0, 15);
  gObsRearVentMode = clampRange((int)this.RearVentMode, 0, 7);
  gObsRearSyncMode = clampRange((int)this.RearSyncMode, 0, 1);
}

on message frmDigitalKeyStateMsg
{
  gObsDKeyState = clampRange((int)this.DKeyState, 0, 7);
  gObsVehicleAccessState = clampRange((int)this.VehicleAccessState, 0, 7);
  gObsSecurityGrade = clampRange((int)this.SecurityGrade, 0, 15);
  gObsKeyPresence = clampRange((int)this.KeyPresence, 0, 1);
}

on message frmAutoDoorCtrlStateMsg
{
  gObsAutoDoorState = clampRange((int)this.AutoDoorState, 0, 7);
  gObsAutoUnlockState = clampRange((int)this.AutoUnlockState, 0, 3);
  gObsDoorApproachScore = clampRange((int)this.DoorApproachScore, 0, 100);
}

on message frmPowerTailgateCtrlStateMsg
{
  gObsTailgateAssistMode = clampRange((int)this.TailgateAssistMode, 0, 7);
  gObsTailgateOpenRequestState = clampRange((int)this.OpenRequestState, 0, 3);
  gObsTailgateActuatorCmd = clampRange((int)this.TailgateActuatorCmd, 0, 100);
}

on sysvar Test::scenarioCommand
{
  int scenarioId;
  scenarioId = (int)@Test::scenarioCommand;

  if (gScenarioCmdInternalClear == 1)
  {
    gScenarioCmdInternalClear = 0;
    return;
  }

  applyScenarioPanelRequest(scenarioId, 0);
  gScenarioCmdInternalClear = 1;
  @Test::scenarioCommand = 0;
}

on sysvar Test::testScenario
{
  int scenarioId;
  int mirrorScenarioId;

  if (gScenarioMirrorInternalWrite == 1)
  {
    gScenarioMirrorInternalWrite = 0;
    return;
  }

  scenarioId = clampRange((int)@Test::testScenario, 0, 255);
  mirrorScenarioId = clampRange(gCurrentScenarioId, 0, 255);

  if (scenarioId == mirrorScenarioId)
  {
    return;
  }

  if (scenarioId == 0 ||
      (scenarioId >= 1 && scenarioId <= 35) ||
      (scenarioId >= 200 && scenarioId <= 255))
  {
    /* Donor panel contract still writes `testScenario` directly.
       Accept it as a compatibility request on the validation harness. */
    applyScenarioPanelRequest(scenarioId, 1);
    return;
  }

  setScenarioMirror(mirrorScenarioId);
  write("[TEST_SCN] ignore direct testScenario write: req=%d keep=%d",
        scenarioId, mirrorScenarioId);
}

on timer tScenarioEval
{
  int coreLevel;
  int coreType;
  int timeoutClear;
  int proximityRiskLevel;
  int decelAssistReq;
  int failSafeMode;
  int driverReleaseReason;
  int objectTrackValid;
  int objectRiskClass;
  int objectTtcMin;
  int objectEventCode;
  int renderAlertType;
  int renderTextCode;
  int clusterCode;

  evaluateScenarioResult();
  coreLevel = getObservedSelectedAlertLevel();
  coreType = getObservedSelectedAlertType();
  timeoutClear = (int)@Core::timeoutClear;
  proximityRiskLevel = (int)@Core::proximityRiskLevel;
  decelAssistReq = (int)@Core::decelAssistReq;
  failSafeMode = (int)@Core::failSafeMode;
  driverReleaseReason = clampRange((int)@CoreState::driverReleaseReason, 0, 3);
  objectTrackValid = (int)@Core::objectTrackValid;
  objectRiskClass = (int)@Core::objectRiskClass;
  objectTtcMin = (int)@Core::objectTtcMin;
  objectEventCode = (int)@Core::objectEventCode;
  renderAlertType = (int)@UiRender::activeAlertType;
  renderTextCode = (int)@UiRender::renderTextCode;
  clusterCode = (int)@Cluster::warningTextCode;

  writeEvidenceOutLine(gCurrentScenarioId,
                       getSimulationTimeMs(),
                       (int)@Test::scenarioResult,
                       coreLevel, coreType, clusterCode, timeoutClear, proximityRiskLevel,
                       decelAssistReq, failSafeMode, driverReleaseReason, objectTrackValid,
                       objectRiskClass, objectTtcMin, objectEventCode, renderAlertType,
                       renderTextCode);

}

on stopMeasurement
{
  stopScenarioExecution();
  cancelTimer(tInput100);
  ethCloseSocket(gEthSocket);
  gEthSocket = ethInvalidSocket();
}
