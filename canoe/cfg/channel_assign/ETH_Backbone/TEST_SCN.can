void scheduleScenarioEvaluation(int scenarioId)
{
  int evalDelayMs;

  evalDelayMs = 700;
  if (scenarioId == 3)
  {
    evalDelayMs = 11000;
  }
  else if (scenarioId == 6)
  {
    evalDelayMs = 1500; /* Req_024: ensure 200ms timeoutClear pulse has fully expired before eval */
  }
  else if (scenarioId == 7 || scenarioId == 8)
  {
    evalDelayMs = 700;
  }
  else if (scenarioId == 9 || scenarioId == 10)
  {
    evalDelayMs = 700;
  }
  else if (scenarioId == 11)
  {
    evalDelayMs = 800;
  }
  else if (scenarioId == 12)
  {
    evalDelayMs = 900;
  }
  else if (scenarioId == 13)
  {
    evalDelayMs = 1000;
  }
  else if (scenarioId == 14)
  {
    evalDelayMs = 700;
  }
  else if (scenarioId == 15 || scenarioId == 16 || scenarioId == 19)
  {
    evalDelayMs = 800;
  }
  else if (scenarioId == 17)
  {
    evalDelayMs = 900;
  }
  else if (scenarioId == 18)
  {
    evalDelayMs = 900;
  }
  else if (scenarioId >= 20 && scenarioId <= 24)
  {
    evalDelayMs = 900;
  }
  else if (scenarioId == 25)
  {
    evalDelayMs = 1100;
  }
  else if (scenarioId >= 26 && scenarioId <= 28)
  {
    /* A/B group 판단은 10ms tAdasCycle 후 즉시 확정되므로 700ms면 충분 */
    evalDelayMs = 700;
  }
  else if (scenarioId >= 29 && scenarioId <= 34)
  {
    /* ST_013/ST_014 방향 테스트: V2X.can 처리 + IVI.can renderDirection 확정까지 700ms */
    evalDelayMs = 700;
  }
  else if (scenarioId == 35)
  {
    /* ST_021: Phase2(600ms) 긴급 해제 + 타임아웃(1000ms) 대기 후 판정 */
    evalDelayMs = 1800;
  }
  else if (scenarioId == 200)
  {
    /* ST_045: Phase3(2200ms) 정지 후 안정화까지 충분한 여유 */
    evalDelayMs = 3500;
  }
  else if (scenarioId == 201)
  {
    /* ST_046: Phase3(800ms) fail-safe 해제 + 안정화 */
    evalDelayMs = 1500;
  }
  else if (scenarioId == 202)
  {
    /* ST_043: degraded phase 관측 후 blocked context까지 포함 */
    evalDelayMs = 1800;
  }
  else if (scenarioId == 203 || scenarioId == 204 || scenarioId == 205)
  {
    evalDelayMs = 1800;
  }
  else if (scenarioId == 206 || scenarioId == 207 || scenarioId == 208 || scenarioId == 209 ||
           scenarioId == 210 || scenarioId == 211)
  {
    evalDelayMs = 900;
  }
  else if (scenarioId == 212)
  {
    evalDelayMs = 700;
  }
  else if (scenarioId == 223)
  {
    evalDelayMs = 800;
  }
  else if (scenarioId == 224)
  {
    evalDelayMs = 700;
  }
  else if (scenarioId == 213)
  {
    evalDelayMs = 800;
  }
  else if (scenarioId == 238)
  {
    evalDelayMs = 800;
  }
  else if (scenarioId == 214 || scenarioId == 215)
  {
    evalDelayMs = 900;
  }
  else if (scenarioId == 216 || scenarioId == 217 || scenarioId == 218 || scenarioId == 219)
  {
    evalDelayMs = 900;
  }
  else if (scenarioId == 220 || scenarioId == 222)
  {
    evalDelayMs = 900;
  }
  else if (scenarioId == 225 || scenarioId == 226 || scenarioId == 227 || scenarioId == 228)
  {
    evalDelayMs = 900;
  }
  else if (scenarioId == 229)
  {
    evalDelayMs = 1300;
  }
  else if (scenarioId == 236 || scenarioId == 237 || scenarioId == 239)
  {
    evalDelayMs = 900;
  }
  else if (scenarioId == 244)
  {
    evalDelayMs = 900;
  }
  setTimer(tScenarioEval, evalDelayMs);
}

void evaluateScenarioResult()
{
  int result;
  int level;
  int type;
  int emergencyType;
  int emergencyDirection;
  int emergencyEtaSec;
  int emergencySourceId;
  int code;
  int timeoutClear;
  int ambientPattern;
  int ambientColor;
  int duplicatePopupGuard;
  int snapshotDelta;
  int proximityRiskLevel;
  int decelAssistReq;
  int failSafeMode;
  int driverReleaseReason;
  int objectTrackValid;
  int objectRiskClass;
  int objectTtcMin;
  int objectEventCode;
  int intersectionConflictFlag;
  int mergeCutInFlag;
  int uiRenderAlertType;
  int uiRenderTextCode;

  result = 0;
  level = getObservedSelectedAlertLevel();
  type = getObservedSelectedAlertType();
  emergencyType = getObservedEmergencyType();
  emergencyDirection = getObservedEmergencyDirection();
  emergencyEtaSec = getObservedEmergencyEtaSec();
  emergencySourceId = getObservedEmergencySourceId();
  code = (int)@Cluster::warningTextCode;
  timeoutClear = ((int)@Core::timeoutClear == 1) ? 1 : 0;
  ambientPattern = (int)@Body::ambientPattern;
  ambientColor = (int)@Body::ambientColor;
  duplicatePopupGuard = (int)@CoreState::duplicatePopupGuard;
  proximityRiskLevel = (int)@Core::proximityRiskLevel;
  decelAssistReq = (int)@Core::decelAssistReq;
  failSafeMode = (int)@Core::failSafeMode;
  driverReleaseReason = clampRange((int)@Test::obsDecelReleaseReason, 0, 3);
  objectTrackValid = (int)@Core::objectTrackValid;
  objectRiskClass = (int)@Core::objectRiskClass;
  objectTtcMin = (int)@Core::objectTtcMin;
  objectEventCode = (int)@Core::objectEventCode;
  intersectionConflictFlag = (int)@Core::intersectionConflictFlag;
  mergeCutInFlag = (int)@Core::mergeCutInFlag;
  uiRenderAlertType = (int)@UiRender::activeAlertType;
  uiRenderTextCode = (int)@UiRender::renderTextCode;

  if (gCurrentScenarioId == 1)
  {
    result = (level == 0 && code == 0) ? 1 : 0;
  }
  else if (gCurrentScenarioId == 2)
  {
    /* Req_010 + Req_037: school zone overspeed, fixed red fast-flash pattern */
    result = (level == 3 && type == 3 && ambientColor == 3 && ambientPattern == 5) ? 1 : 0;
  }
  else if (gCurrentScenarioId == 3)
  {
    /* Req_011 + Req_037 (Legacy Req_038): highway no-steer, fixed orange pulse pattern */
    result = (level == 2 && type == 4 && ambientColor == 4 && ambientPattern == 4) ? 1 : 0;
  }
  else if (gCurrentScenarioId == 4)
  {
    /* Req_017 + Req_035 (Legacy Req_036): police emergency render contract */
    result = (level == 6 && type == 1 &&
              code == getExpectedRuntimeEmergencyWarningCode() &&
              duplicatePopupGuard > 0 &&
              ambientColor == 6 && ambientPattern == 6 &&
              failSafeMode == 0) ? 1 : 0;
  }
  else if (gCurrentScenarioId == 5)
  {
    /* Req_017 + Req_035 (Legacy Req_018/036): ambulance emergency render contract */
    result = (level == 7 && type == 2 &&
              code == getExpectedRuntimeEmergencyWarningCode() &&
              duplicatePopupGuard > 0 &&
              ambientColor == 7 && ambientPattern == 7 &&
              failSafeMode == 0) ? 1 : 0;
  }
  else if (gCurrentScenarioId == 6)
  {
    result = (timeoutClear == 1 && level == 0 && code == 0) ? 1 : 0;
  }
  else if (gCurrentScenarioId == 7)
  {
    /* Req_013 + Req_037 (Legacy Req_039): guide left, cyan flow-left pattern */
    result = (level == 2 && type == 5 && ambientColor == 5 && ambientPattern == 2 && code == 31) ? 1 : 0;
  }
  else if (gCurrentScenarioId == 8)
  {
    /* Req_014 + Req_037 (Legacy Req_039): guide right, cyan flow-right pattern */
    result = (level == 2 && type == 6 && ambientColor == 5 && ambientPattern == 3 && code == 32) ? 1 : 0;
  }
  else if (gCurrentScenarioId == 9)
  {
    /* Req_030: lower ETA competitor (sourceId=99, eta=10) should be active */
    result = (emergencyEtaSec == 10 && emergencySourceId == 99 && level == 6) ? 1 : 0;
  }
  else if (gCurrentScenarioId == 10)
  {
    /* Req_031: lower sourceId (5) wins despite same ETA as prior active (sourceId=20) */
    result = (emergencySourceId == 5 && emergencyEtaSec == 10 && level == 6) ? 1 : 0;
  }
  else if (gCurrentScenarioId == 11)
  {
    /* Req_034: emergency took over AND arbitration delta <= 3 (no repeated flips) */
    snapshotDelta = ((int)@Test::baseTraceSnapshotId - gArbitrationSnapshotBaseline) & 0xFFFF;
    result = (level == 6 && type == 1 && snapshotDelta <= 3) ? 1 : 0;
  }
  else if (gCurrentScenarioId == 12)
  {
    /* Req_006 + Req_026: re-triggered school zone warning still within guard window */
    result = (level == 3 && type == 3 && duplicatePopupGuard > 0) ? 1 : 0;
  }
  else if (gCurrentScenarioId == 13)
  {
    /* Req_015: after zone flip (school->highway->school), settle correctly, <=3 arb changes */
    snapshotDelta = ((int)@Test::baseTraceSnapshotId - gArbitrationSnapshotBaseline) & 0xFFFF;
    result = (level == 3 && type == 3 && snapshotDelta <= 3) ? 1 : 0;
  }
  else if (gCurrentScenarioId == 14)
  {
    /* Req_110 + Req_111 + Req_112: all domain boundaries healthy, routing normal */
    result = ((int)@CoreState::domainBoundaryStatus == 1 &&
              (int)@CoreState::routingPolicy == 1 &&
              level == 0) ? 1 : 0;
  }
  else if (gCurrentScenarioId == 15)
  {
    /* Req_120: risk level must be periodically computed from emergency/speed/ETA */
    result = (proximityRiskLevel >= 60 && proximityRiskLevel <= 100) ? 1 : 0;
  }
  else if (gCurrentScenarioId == 16)
  {
    /* Req_121: threshold-crossing should request decel assist */
    result = (proximityRiskLevel >= 70 && decelAssistReq == 1 && failSafeMode == 0 &&
              level == 7 && type == 2) ? 1 : 0;
  }
  else if (gCurrentScenarioId == 17)
  {
    /* Req_123: steering intervention releases decel assist */
    result = (gObsSteeringState == 1 && decelAssistReq == 0 &&
              failSafeMode == 0 && driverReleaseReason == 1) ? 1 : 0;
  }
  else if (gCurrentScenarioId == 18)
  {
    /* Req_127 + Req_128 + Req_129 (Legacy Req_124): fail-safe blocks decel assist but keeps minimum warning path */
    result = (failSafeMode >= 1 && decelAssistReq == 0 &&
              level >= 6 && code >= 100 && driverReleaseReason == 3) ? 1 : 0;
  }
  else if (gCurrentScenarioId == 19)
  {
    /* Req_125 + Req_126 (Legacy Req_122): decel assist active with emergency-priority sync to renderer */
    result = (decelAssistReq == 1 && level == 7 && type == 2 &&
              uiRenderAlertType == 2 && uiRenderTextCode >= 200 &&
              ambientColor == 7 && code >= 200) ? 1 : 0;
  }
  else if (gCurrentScenarioId == 20)
  {
    /* Req_132: TTC-based forward object conflict warning */
    result = (objectTrackValid == 1 && objectRiskClass >= 3 && objectTtcMin <= 3500 &&
              proximityRiskLevel >= 60) ? 1 : 0;
  }
  else if (gCurrentScenarioId == 21)
  {
    /* Req_134: intersection conflict should map to object-context alert */
    result = (intersectionConflictFlag == 1 && objectRiskClass >= 3 &&
              level >= 4 && type == 5) ? 1 : 0;
  }
  else if (gCurrentScenarioId == 22)
  {
    /* Req_135: merge/cut-in conflict should map to object-context alert */
    result = (mergeCutInFlag == 1 && objectRiskClass >= 3 &&
              level >= 4 && type == 6) ? 1 : 0;
  }
  else if (gCurrentScenarioId == 23)
  {
    /* Req_137: object high-risk must trigger decel assist without emergency input */
    result = (emergencyType == 0 && objectRiskClass >= 4 &&
              proximityRiskLevel >= 75 && decelAssistReq == 1 && failSafeMode == 0) ? 1 : 0;
  }
  else if (gCurrentScenarioId == 24)
  {
    /* Req_138: low confidence must force degrade and cancel decel assist */
    result = (objectTrackValid == 1 && (int)@Core::objectConfidence < 35 &&
              failSafeMode >= 1 && decelAssistReq == 0) ? 1 : 0;
  }
  else if (gCurrentScenarioId == 25)
  {
    /* Req_136: hold-time should keep risk class/event around short track loss window */
    result = (objectTrackValid == 1 && objectRiskClass >= 3 &&
              objectEventCode >= 1381 && objectEventCode <= 1383) ? 1 : 0;
  }
  else if (gCurrentScenarioId == 26)
  {
    /* A-group 단독: 일반도로 급가속
       warningState=1 → alertLevel=1, alertType=1 (경미 경고) */
    result = ((int)@Core::warningState == 1 && level == 1 && type == 1) ? 1 : 0;
  }
  else if (gCurrentScenarioId == 27)
  {
    /* B-group 단독: 일반도로 차선이탈
       warningState=1 → alertLevel=1, alertType=1 (경미 경고) */
    result = ((int)@Core::warningState == 1 && level == 1 && type == 1) ? 1 : 0;
  }
  else if (gCurrentScenarioId == 28)
  {
    /* A+B 복합: 일반도로 급가속+차선이탈 동시
       warningState=2 → alertLevel=2, alertType=4 (오렌지 펄스) */
    result = ((int)@Core::warningState == 2 && level == 2 && type == 4) ? 1 : 0;
  }
  else if (gCurrentScenarioId == 29)
  {
    result = (level == 6 && type == 1 &&
              code == getExpectedRuntimeEmergencyWarningCode() &&
              (int)@UiRender::renderDirection == 0) ? 1 : 0;
  }
  else if (gCurrentScenarioId == 30)
  {
    result = (level == 6 && type == 1 &&
              code == getExpectedRuntimeEmergencyWarningCode() &&
              (int)@UiRender::renderDirection == 2) ? 1 : 0;
  }
  else if (gCurrentScenarioId == 31)
  {
    result = (level == 6 && type == 1 &&
              code == getExpectedRuntimeEmergencyWarningCode() &&
              (int)@UiRender::renderDirection == 3) ? 1 : 0;
  }
  else if (gCurrentScenarioId == 32)
  {
    result = (level == 7 && type == 2 &&
              code == getExpectedRuntimeEmergencyWarningCode() &&
              (int)@UiRender::renderDirection == 0) ? 1 : 0;
  }
  else if (gCurrentScenarioId == 33)
  {
    result = (level == 7 && type == 2 &&
              code == getExpectedRuntimeEmergencyWarningCode() &&
              (int)@UiRender::renderDirection == 1) ? 1 : 0;
  }
  else if (gCurrentScenarioId == 34)
  {
    result = (level == 7 && type == 2 &&
              code == getExpectedRuntimeEmergencyWarningCode() &&
              (int)@UiRender::renderDirection == 3) ? 1 : 0;
  }
  else if (gCurrentScenarioId == 35)
  {
    /* ST_021: 긴급 해제 후 스쿨존 경고 복귀 확인
       emergencyContext가 0이고 스쿨존 경고 레벨(3)이 복원되어야 함 */
    result = (level == 3 && type == 3 && emergencyType == 0) ? 1 : 0;
  }
  else if (gCurrentScenarioId == 200)
  {
    /* ST_045: 연속 시나리오 — 최종 정지 단계에서 경고 없음 확인 */
    result = (level == 0 && code == 0) ? 1 : 0;
  }
  else if (gCurrentScenarioId == 201)
  {
    /* ST_046: fail-safe 복귀 후 안정 상태 확인 */
    result = (failSafeMode == 0) ? 1 : 0;
  }
  else if (gCurrentScenarioId == 202)
  {
    result = (gDiagCtxNominalSeen == 1 &&
              gDiagCtxDegradedSeen == 1 &&
              gDiagCtxBlockedSeen == 1 &&
              (int)@Diag::ServiceState == 2 &&
              (int)@Diag::SecurityState == 3 &&
              (int)@Diag::RouteOwner == 1 &&
              (int)@Diag::ResponseKind == 4 &&
              (int)@Diag::ReasonCode == 2 &&
              failSafeMode >= 2) ? 1 : 0;
  }
  else if (gCurrentScenarioId == 203)
  {
    result = (gDiagCtxNominalSeen == 1 &&
              gDiagCtxDegradedSeen == 1 &&
              gDiagCtxBlockedSeen == 1 &&
              (int)@Diag::SecurityState == 3 &&
              (int)@Diag::RouteOwner == 1) ? 1 : 0;
  }
  else if (gCurrentScenarioId == 204)
  {
    result = (gDcmCtxPositiveSeen == 1 &&
              gDcmCtxNegativeSeen == 1 &&
              gDcmCtxBlockedSeen == 1 &&
              (int)@Diag::LastRequestSid == 0x22 &&
              (int)@Diag::ResponseKind == 4 &&
              (int)@Diag::ReasonCode == 2 &&
              (int)@Diag::LastResponseCode == 0x7F &&
              (int)@Diag::ServiceState == 2 &&
              (int)@Diag::LastResponseOk == 0) ? 1 : 0;
  }
  else if (gCurrentScenarioId == 205)
  {
    result = (gDiagCtxNominalSeen == 1 &&
              gDiagCtxDegradedSeen == 1 &&
              gDiagCtxBlockedSeen == 1 &&
              (int)@Diag::ServiceState == 2 &&
              (int)@Diag::SecurityState == 3 &&
              (int)@Diag::RouteOwner == 1 &&
              (int)@Diag::ResponseKind == 4 &&
              (int)@Diag::ReasonCode == 2) ? 1 : 0;
  }
  else if (gCurrentScenarioId == 206)
  {
    result = (gCgwBoundaryNominalSeen == 1 &&
              (int)@CoreState::domainBoundaryStatus == 1 &&
              (int)@CoreState::routingPolicy == 1 &&
              level == 0 &&
              (int)@Core::failSafeMode == 0) ? 1 : 0;
  }
  else if (gCurrentScenarioId == 207)
  {
    result = (gAdasWarningNominalSeen == 1 &&
              level == 3 &&
              type == 3 &&
              (int)@CoreState::warningPathStatus == 0 &&
              (int)@Core::failSafeMode == 0) ? 1 : 0;
  }
  else if (gCurrentScenarioId == 208)
  {
    result = (gBcmAmbientNominalSeen == 1 &&
              level == 3 &&
              type == 3 &&
              (int)@Body::ambientColor == 3 &&
              (int)@Body::ambientPattern == 5 &&
              (int)@Core::failSafeMode == 0) ? 1 : 0;
  }
  else if (gCurrentScenarioId == 209)
  {
    result = (gIviTextNominalSeen == 1 &&
              level == 6 &&
              type == 1 &&
              (int)@Cluster::warningTextCode == getExpectedRuntimeEmergencyWarningCode() &&
              (int)@Core::failSafeMode == 0) ? 1 : 0;
  }
  else if (gCurrentScenarioId == 210)
  {
    result = (gV2xContextNominalSeen == 1 &&
              emergencyEtaSec == 9 &&
              emergencySourceId == 92 &&
              level == 6 &&
              type == 1 &&
              (int)@Core::failSafeMode == 0) ? 1 : 0;
  }
  else if (gCurrentScenarioId == 211)
  {
    result = (gCluDisplayNominalSeen == 1 &&
              level == 6 &&
              type == 1 &&
              (int)@Cluster::warningTextCode == getExpectedRuntimeEmergencyWarningCode() &&
              (int)@UiRender::renderDirection == emergencyDirection &&
              (int)@Core::failSafeMode == 0) ? 1 : 0;
  }
  else if (gCurrentScenarioId == 212)
  {
    result = (emergencyType == 2 &&
              level == 7 &&
              type == 2 &&
              (int)@Cluster::warningTextCode == getExpectedRuntimeEmergencyWarningCode() &&
              (int)@Core::failSafeMode == 0) ? 1 : 0;
  }
  else if (gCurrentScenarioId == 223)
  {
    snapshotDelta = ((int)@Test::baseTraceSnapshotId - gArbitrationSnapshotBaseline) & 0xFFFF;
    result = (level == 7 && type == 2 && snapshotDelta <= 3) ? 1 : 0;
  }
  else if (gCurrentScenarioId == 224)
  {
    result = (emergencySourceId == 5 &&
              emergencyEtaSec == 10 &&
              emergencyType == 2 &&
              level == 7) ? 1 : 0;
  }
  else if (gCurrentScenarioId == 213)
  {
    result = (emergencyType == 2 &&
              (int)@Core::intersectionConflictFlag == 1 &&
