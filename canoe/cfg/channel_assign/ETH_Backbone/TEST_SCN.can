  gDiagCtxDegradedSeen = 0;
  gDiagCtxBlockedSeen = 0;
  gDcmCtxPositiveSeen = 0;
  gDcmCtxNegativeSeen = 0;
  gDcmCtxBlockedSeen = 0;
  gCgwBoundaryNominalSeen = 0;
  gAdasWarningNominalSeen = 0;
  gBcmAmbientNominalSeen = 0;
  gIviTextNominalSeen = 0;
  gV2xContextNominalSeen = 0;
  gCluDisplayNominalSeen = 0;
  gObsTmuLinkState = -1;
  gObsTmuServiceMode = -1;
  gObsRemoteClimateReq = -1;
  gObsSignalBars = -1;
  gObsCabinSetTemp = -1;
  gObsBlowerLevel = -1;
  gObsAcCompressorOn = -1;
  gObsVentMode = -1;
  gObsRearSetTemp = -1;
  gObsRearBlowerLevel = -1;
  gObsRearVentMode = -1;
  gObsRearSyncMode = -1;
  gObsDKeyState = -1;
  gObsVehicleAccessState = -1;
  gObsSecurityGrade = -1;
  gObsKeyPresence = -1;
  gObsAutoDoorState = -1;
  gObsAutoUnlockState = -1;
  gObsDoorApproachScore = -1;
  gObsTailgateAssistMode = -1;
  gObsTailgateOpenRequestState = -1;
  gObsTailgateActuatorCmd = -1;
  /* TEST_SCN remains as scenario lifecycle/evidence harness only.
     Runtime hard-coded injection is disabled so manual/operator seams are
     owned by ECU runtime paths instead of the test harness. */
  return;
  if (scenarioId == 1)
  {
    /* Normal idle */
  }
  else if (scenarioId == 2)
  {
    /* School zone overspeed */
    gLockRoadZone = 1;
    gLockVehicleSpeed = 45;
    gLockSpeedLimit = 30;
  }
  else if (scenarioId == 3)
  {
    /* Highway no steering */
    gLockRoadZone = 2;
    gLockSteeringInput = 0;
    gLockVehicleSpeed = 80;
    gLockSpeedLimit = 100;
  }
  else if (scenarioId == 4)
  {
    /* Police emergency */
    gLockAlertState = 1;
    gLockEmergencyType = 1;
    gLockEta = 12;
    gLockEmergencyDirection = 1;
    gLockSourceId = 11;
  }
  else if (scenarioId == 5)
  {
    /* Ambulance emergency */
    gLockAlertState = 1;
    gLockEmergencyType = 2;
    gLockEta = 8;
    gLockEmergencyDirection = 2;
    gLockSourceId = 22;
  }
  else if (scenarioId == 6)
  {
    /* Timeout test preparation: emergency active then stop update externally */
    gLockAlertState = 1;
    gLockEmergencyType = 2;
    gLockEta = 5;
    gLockSourceId = 33;
  }
  else if (scenarioId == 7)
  {
    /* Guide zone left */
    gLockRoadZone = 3;
    gLockNavDirection = 1;
    gLockVehicleSpeed = 35;
  }
  else if (scenarioId == 8)
  {
    /* Guide zone right */
    gLockRoadZone = 3;
    gLockNavDirection = 2;
    gLockVehicleSpeed = 35;
  }
  else if (scenarioId == 9)
  {
    /* Req_030: ETA priority - Phase 1: Police ETA=20 sourceId=5 */
    gLockAlertState = 1;
    gLockEmergencyType = 1;
    gLockEta = 20;
    gLockSourceId = 5;
    gLockEmergencyDirection = 1;
    setTimer(tScenarioPhase2, 300);
  }
  else if (scenarioId == 10)
  {
    /* Req_031: SourceID tiebreaker - Phase 1: Police ETA=10 sourceId=20 */
    gLockAlertState = 1;
    gLockEmergencyType = 1;
    gLockEta = 10;
    gLockSourceId = 20;
    gLockEmergencyDirection = 1;
    setTimer(tScenarioPhase2, 300);
