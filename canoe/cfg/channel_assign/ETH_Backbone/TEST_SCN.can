              gObsTailgateAssistMode == 2 &&
              gObsTailgateOpenRequestState == 1 &&
              gObsTailgateActuatorCmd == 0) ? 1 : 0;
  }
  else if (gCurrentScenarioId == 228)
  {
    result = (gObsDriveState == 0 &&
              gObsVehicleSpeed == 0 &&
