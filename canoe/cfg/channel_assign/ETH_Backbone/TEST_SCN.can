int calcBaselineGearState(int driveState)
{
  if (driveState <= 0)
  {
    return 0; /* P */
  }
  if (driveState == 1)
  {
    return 1; /* R */
  }
  if (driveState == 2)
  {
    return 2; /* N */
  }
  return 3;   /* D */
}

int calcBaselineIgnitionState(int speed, int driveState)
{
  if (speed > 0 || driveState > 0)
  {
    return 1;
  }
  return 0;
}

int calcManualSteeringState(int steeringAngleCmd)
{
  steeringAngleCmd = clampRange(steeringAngleCmd, 0, 138);
  if (steeringAngleCmd <= 54 || steeringAngleCmd >= 84)
  {
    return 1;
  }
  return 0;
}

int calcObservedBaseZoneContext(int routeClass, int guideType)
{
  if (routeClass == 1)
  {
    return 1;
  }
  if (routeClass == 2)
  {
    return 2;
  }
  if (routeClass == 3)
  {
    return (guideType == 2) ? 4 : 3;
  }
  return 0;
}

int getTestScnTxPort()
{
  return ethBackbonePort() + 7;
}

dword getTestScnLocalIp()
{
  return IpGetAddressAsNumber("192.168.1.8");
}

int getEvidenceTierCode()
{
  return clampRange((int)@Test::nativeExecTierCode, 0, 4);
}

int calcScenarioEmergencyDistanceM(int etaSec, int speedKph)
{
  long distanceM;

  if (etaSec <= 0 || speedKph <= 0)
  {
    return 0;
  }

  distanceM = ((long)etaSec * (long)speedKph * 10) / 36;
  if (distanceM < 0)
  {
    distanceM = 0;
  }
  if (distanceM > 10000)
  {
    distanceM = 10000;
  }
  return (int)distanceM;
}

int calcScenarioEmergencyDistanceBand(int distanceM)
{
  distanceM = clampRange(distanceM, 0, 10000);

  if (distanceM <= 0)
  {
    return 0;
  }
  if (distanceM <= 80)
  {
    return 1;
  }
  if (distanceM <= 180)
  {
    return 2;
  }
  return 3;
}

int calcScenarioEmergencyWarningCode(int emergencyType, int emergencyDirection, int etaSec, int speedKph)
{
  int distanceBand;
  int baseCode;

  emergencyType = clampRange(emergencyType, 0, 2);
  emergencyDirection = clampRange(emergencyDirection, 0, 3);
  distanceBand = calcScenarioEmergencyDistanceBand(calcScenarioEmergencyDistanceM(etaSec, speedKph));

  if (emergencyType == 2)
  {
    baseCode = 200;
  }
  else if (emergencyType == 1)
  {
    baseCode = 100;
  }
  else
  {
    return 0;
  }

  if (distanceBand > 0)
  {
    return baseCode + (distanceBand * 10) + emergencyDirection;
  }
  return baseCode + emergencyDirection;
}

