              gObsVehicleSpeed == 0 &&
              gObsSteeringState == 0 &&
              gObsBrakePedal >= 30 &&
              (int)@Core::failSafeMode == 0) ? 1 : 0;
  }
  else if (gCurrentScenarioId == 220)
  {
    result = (level == 3 &&
              type == 3 &&
