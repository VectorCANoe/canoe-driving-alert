int getObservedSelectedAlertLevel()
{
  int alertLevel;

  alertLevel = clampRange((int)@CoreState::selectedAlertEffectiveLevel, 0, 7);
  if (alertLevel == 0)
  {
    alertLevel = clampRange((int)@CoreState::selectedAlertDecisionLevel, 0, 7);
  }
  if (alertLevel == 0)
  {
    alertLevel = clampRange((int)@Core::selectedAlertLevel, 0, 7);
  }
  return alertLevel;
}

int getObservedSelectedAlertType()
{
  int alertType;

  alertType = clampRange((int)@CoreState::selectedAlertEffectiveType, 0, 15);
  if (alertType == 0)
  {
    alertType = clampRange((int)@CoreState::selectedAlertDecisionType, 0, 15);
  }
  if (alertType == 0)
  {
    alertType = clampRange((int)@Core::selectedAlertType, 0, 15);
  }
  return alertType;
}

