              (int)@CoreState::audioFocusOwner == 1 &&
              (int)@CoreState::audioDuckingLvl == 4 &&
              (int)@CoreState::volumeLevel == 80 &&
              (int)@Core::failSafeMode == 0) ? 1 : 0;
  }
  else if (gCurrentScenarioId == 216)
  {
    result = (gObsDriveState == 0 &&
              gObsVehicleSpeed == 0 &&
              level == 0 &&
              (int)@Core::failSafeMode == 0) ? 1 : 0;
  }
  else if (gCurrentScenarioId == 217)
  {
    result = (gObsDriveState == 3 &&
              gObsVehicleSpeed == 55 &&
              level == 0 &&
              (int)@Core::failSafeMode == 0) ? 1 : 0;
