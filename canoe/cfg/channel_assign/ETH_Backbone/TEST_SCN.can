{
  return calcScenarioEmergencyWarningCode(getObservedEmergencyType(),
                                          getObservedEmergencyDirection(),
                                          getObservedEmergencyEtaSec(),
                                          getObservedScenarioVehicleSpeed());
}

int evidenceAutoWriteEnabled()
{
  return (((int)@Test::evidenceAutoWrite == 1) &&
          getEvidenceTierCode() > 0) ? 1 : 0;
}

dword openEvidenceRawFile()
{
  int tierCode;

  if (!evidenceAutoWriteEnabled())
  {
    return 0;
  }

  tierCode = getEvidenceTierCode();
  if (tierCode == 1)
  {
    return openFileWrite("..\\logging\\evidence\\incoming\\UT\\raw_write_window.txt", 2);
  }
  if (tierCode == 2)
  {
    return openFileWrite("..\\logging\\evidence\\incoming\\IT\\raw_write_window.txt", 2);
  }
  if (tierCode == 3)
  {
    return openFileWrite("..\\logging\\evidence\\incoming\\ST\\raw_write_window.txt", 2);
  }
  if (tierCode == 4)
  {
    return openFileWrite("..\\logging\\evidence\\incoming\\FULL\\raw_write_window.txt", 2);
  }

  return 0;
}

void appendEvidenceRawLine(char line[])
{
  dword fileHandle;

  fileHandle = openEvidenceRawFile();
  if (fileHandle > 0)
  {
    filePutString(line, strlen(line), fileHandle);
    fileClose(fileHandle);
  }
}

void writeEvidenceInLine(int scenarioId, dword inputTsMs)
{
  char line[128];

  write("[EVIDENCE_IN] scenario=%d inputTsMs=%lu",
        scenarioId, inputTsMs);

  snprintf(line, elcount(line),
           "[EVIDENCE_IN] scenario=%d inputTsMs=%lu\n",
           scenarioId, inputTsMs);
  appendEvidenceRawLine(line);
}

void writeEvidenceOutLine(int scenarioId,
                          dword outputTsMs,
                          int result,
                          int level,
                          int type,
                          int code,
                          int timeoutClear,
                          int proximityRiskLevel,
                          int decelAssistReq,
                          int failSafeMode,
                          int driverReleaseReason,
                          int objectTrackValid,
                          int objectRiskClass,
                          int objectTtcMin,
                          int objectEventCode,
                          int renderAlertType,
                          int renderTextCode)
{
  char line[384];

  write("[EVIDENCE_OUT] scenario=%d outputTsMs=%lu result=%d level=%d type=%d code=%d timeout=%d risk=%d decel=%d failSafe=%d release=%d objValid=%d objClass=%d objTtc=%d objEvent=%d renderType=%d renderCode=%d",
        scenarioId, outputTsMs, result, level, type, code, timeoutClear, proximityRiskLevel,
        decelAssistReq, failSafeMode, driverReleaseReason, objectTrackValid, objectRiskClass,
        objectTtcMin, objectEventCode, renderAlertType, renderTextCode);

  snprintf(line, elcount(line),
           "[EVIDENCE_OUT] scenario=%d outputTsMs=%lu result=%d level=%d type=%d code=%d timeout=%d risk=%d decel=%d failSafe=%d release=%d objValid=%d objClass=%d objTtc=%d objEvent=%d renderType=%d renderCode=%d\n",
           scenarioId, outputTsMs, result, level, type, code, timeoutClear, proximityRiskLevel,
           decelAssistReq, failSafeMode, driverReleaseReason, objectTrackValid, objectRiskClass,
           objectTtcMin, objectEventCode, renderAlertType, renderTextCode);
  appendEvidenceRawLine(line);
}

void pushLockedScenarioInputs()
{
  int compatDispatchActive;

  if (gScenarioInputLock != 1)
  {
    return;
  }

  @Chassis::steeringInput = clampRange(gLockSteeringInput, 0, 1);
  @Infotainment::roadZone = clampRange(gLockRoadZone, 0, 3);
  @Infotainment::navDirection = clampRange(gLockNavDirection, 0, 3);
  @Infotainment::zoneDistance = clampRange(gLockZoneDistance, 0, 255);
  @Infotainment::speedLimit = clampRange(gLockSpeedLimit, 0, 255);
  compatDispatchActive = 0;
  if (clampRange(gLockPoliceDispatch, 0, 1) == 1 ||
      clampRange(gLockAmbulanceDispatch, 0, 1) == 1)
  {
    compatDispatchActive = 1;
  }

  if (compatDispatchActive == 1)
  {
    @Test::compatPoliceDispatch = clampRange(gLockPoliceDispatch, 0, 1);
    @Test::compatAmbulanceDispatch = clampRange(gLockAmbulanceDispatch, 0, 1);
    @Test::compatEmergencyDirection = clampRange(gLockEmergencyDirection, 0, 3);
    @Test::compatEmergencyEta = clampRange(gLockEta, 0, 255);
    @Test::compatEmergencySourceId = clampRange(gLockSourceId, 0, 255);
  }
  /* A/B 그룹 플래그: CGW 정규화 경로를 거치지 않고 Core에 직접 주입 */
  @Core::accelGroupFlag = clampRange(gLockAccelGroupFlag, 0, 1);
  @Core::steerGroupFlag = clampRange(gLockSteerGroupFlag, 0, 1);

  if (gLockSuppressEmergencyFrame == 0)
  {
    EmitBackboneEmergencyTest(clampRange(gLockEmergencyType, 0, 2),
                              clampRange(gLockEta, 0, 255),
                              clampRange(gLockSourceId, 0, 255),
                              clampRange(gLockEmergencyDirection, 0, 3),
                              clampRange(gLockAlertState, 0, 1));
  }
  EmitBackboneObjectRiskTest(clampRange(gLockObjectTrackValid, 0, 1),
                             clampRange(gLockObjectRange, 0, 500),
                             clampRange(gLockObjectRelSpeed, -200, 200),
                             clampRange(gLockObjectConfidence, 0, 100),
                             clampRange(gLockIntersectionConflictFlag, 0, 1),
                             clampRange(gLockMergeCutInFlag, 0, 1),
                             clampRange(gLockObjectAlertHoldMs, 0, 5000));
  EmitBackboneValidationOverrideTest(clampRange(gLockForceFailSafe, 0, 1));
}

long EmitBackboneEmergencyTest(int emergencyType,
                               int etaSec,
                               int sourceId,
                               int emergencyDirection,
                               int alertState)
{
  char emergencyFrame[8];

  if (gEthSocket == ethInvalidSocket())
  {
    return -1;
  }

  ethInitFrame(emergencyFrame, ethMsgEmergencyAlert(), 4);
  ethSetU8(emergencyFrame, 0,
           clampRange(emergencyType, 0, 2) |
           (clampRange(emergencyDirection, 0, 3) << 2));
  ethSetU8(emergencyFrame, 1, clampRange(etaSec, 0, 255));
  ethSetU8(emergencyFrame, 2, clampRange(sourceId, 0, 255));
  ethSetU8(emergencyFrame, 3, (alertState == 1) ? 1 : 0);
  return ethSendFrame(gEthSocket, gEthTargetIp, ethMsgEmergencyAlert(), emergencyFrame, 4);
}

long EmitBackboneObjectRiskTest(int trackValid,
                                int rangeM,
                                int relSpeedKph,
                                int confidence,
                                int intersectionConflict,
                                int mergeCutIn,
                                int holdMs)
{
  char objectFrame[12];

  if (gEthSocket == ethInvalidSocket())
  {
    return -1;
  }

  ethInitFrame(objectFrame, ethMsgObjectRiskInput(), 8);
  ethSetU8(objectFrame, 0,
           (trackValid == 1 ? 1 : 0) |
           ((intersectionConflict == 1 ? 1 : 0) << 1) |
           ((mergeCutIn == 1 ? 1 : 0) << 2));
  ethSetU16Le(objectFrame, 1, clampRange(rangeM, 0, 500));
  ethSetS16Le(objectFrame, 3, clampRange(relSpeedKph, -200, 200));
  ethSetU8(objectFrame, 5, clampRange(confidence, 0, 100));
  ethSetU16Le(objectFrame, 6, clampRange(holdMs, 0, 5000));
  return ethSendFrame(gEthSocket, gEthTargetIp, ethMsgObjectRiskInput(), objectFrame, 8);
}

long EmitBackboneValidationOverrideTest(int forceFailSafe)
{
  char overrideFrame[4];

  if (gEthSocket == ethInvalidSocket())
  {
    return -1;
  }

  ethInitFrame(overrideFrame, ethMsgValidationOverride(), 1);
  ethSetU8(overrideFrame, 0, clampRange(forceFailSafe, 0, 1));
  return ethSendFrame(gEthSocket, gEthTargetIp, ethMsgValidationOverride(), overrideFrame, 1);
}

void cancelScenarioTransientTimers()
{
  cancelTimer(tScenarioEval);
  cancelTimer(tScenarioPhase2);
  cancelTimer(tScenarioPhase3);
}

int calcCompatEtaFromPanelPos(int pos)
{
  pos = clampRange(pos, 0, 7);
  if (pos <= 0)
  {
    return 255;
  }
  return clampRange((8 - pos) * 4, 1, 60);
}

void clearManualDispatchCompat()
{
  @Test::compatPoliceDispatch = 0;
  @Test::compatAmbulanceDispatch = 0;
  @Test::compatEmergencyDirection = 0;
  @Test::compatEmergencyEta = 255;
  @Test::compatEmergencySourceId = 255;
}

void publishManualPanelCompat(int speed, int accelPedal, int brakePedal)
{
  int policePos;
  int ambulancePos;
  int manualAlertOverride;
  int manualEmergencyAlertCmd;
  int donorAlertState;
  int emergencyType;
  int emergencyDirection;
  int emergencyEta;
  int emergencySourceId;
  int policeDispatch;
  int ambulanceDispatch;

  if (gScenarioInputLock == 0)
  {
    policePos = clampRange((int)@V2X::policePos, 0, 7);
    ambulancePos = clampRange((int)@V2X::ambulancePos, 0, 7);
    manualAlertOverride = clampRange((int)@Test::manualAlertOverride, 0, 255);
    manualEmergencyAlertCmd = clampRange((int)@Test::manualEmergencyAlertCmd, 0, 1);
    donorAlertState = clampRange((int)@V2X::alertState, 0, 1);
    policeDispatch = 0;
    ambulanceDispatch = 0;
    emergencyType = clampRange((int)@Test::manualEmergencyTypeCmd, 0, 2);
    emergencyDirection = clampRange((int)@Test::manualEmergencyDirectionCmd, 0, 3);
    emergencyEta = clampRange((int)@Test::manualEmergencyEtaCmd, 0, 255);
    emergencySourceId = 255;

    if (manualEmergencyAlertCmd == 1 || donorAlertState == 1 || manualAlertOverride > 0)
    {
      if (emergencyType == 0)
      {
        emergencyType = clampRange((int)@V2X::emergencyType, 0, 2);
      }
      if (emergencyType == 0)
      {
        emergencyType = 2;
      }
      if (emergencyDirection == 0 && manualEmergencyAlertCmd == 0)
      {
        emergencyDirection = clampRange((int)@V2X::emergencyDirection, 0, 3);
      }
      if (emergencyEta == 0 || emergencyEta == 255)
      {
        emergencyEta = clampRange((int)@V2X::eta, 0, 255);
      }
      if (emergencyEta == 0 || emergencyEta == 255)
      {
        emergencyEta = 20;
      }
      emergencySourceId = clampRange((int)@V2X::sourceId, 0, 255);
      if (emergencySourceId == 0 || emergencySourceId == 255)
      {
        emergencySourceId = (emergencyType == 1) ? 1 : 2;
      }
      policeDispatch = (emergencyType == 1) ? 1 : 0;
      ambulanceDispatch = (emergencyType == 2) ? 1 : 0;
    }
    else if (ambulancePos > 0 || policePos > 0)
    {
      emergencyDirection = 0;
      if (ambulancePos >= policePos)
      {
        ambulanceDispatch = 1;
        emergencyEta = calcCompatEtaFromPanelPos(ambulancePos);
        emergencySourceId = 2;
      }
      else
      {
        policeDispatch = 1;
        emergencyEta = calcCompatEtaFromPanelPos(policePos);
        emergencySourceId = 1;
      }
    }

    if (policeDispatch == 1 || ambulanceDispatch == 1)
    {
      @Test::compatPoliceDispatch = policeDispatch;
      @Test::compatAmbulanceDispatch = ambulanceDispatch;
      @Test::compatEmergencyDirection = emergencyDirection;
      @Test::compatEmergencyEta = emergencyEta;
      @Test::compatEmergencySourceId = emergencySourceId;
    }
    else
    {
      clearManualDispatchCompat();
    }

  }
}

void stopScenarioExecution()
{
  gScenarioInputLock = 0;
  gCurrentScenarioId = 0;
  gArbitrationSnapshotBaseline = 0;
  cancelScenarioTransientTimers();
  EmitBackboneValidationOverrideTest(0);
  if (gLockSuppressEmergencyFrame == 0)
  {
    EmitBackboneEmergencyTest(clampRange(gLockEmergencyType, 0, 2),
                              0,
                              clampRange(gLockSourceId, 0, 255),
                              clampRange(gLockEmergencyDirection, 0, 3),
                              0);
  }
  EmitBackboneObjectRiskTest(0, 0, 0, 0, 0, 0, 300);
  @Test::scenarioCommandAck = 0;
  clearScenarioLifecycleState();
  @Test::scenarioResult = 0;
  publishScenarioPanelLamps();
  gLockAccelGroupFlag = 0;
  gLockSteerGroupFlag = 0;
  gLockPoliceDispatch = 0;
  gLockAmbulanceDispatch = 0;
  gLockForceFailSafe = 0;
  gLockSuppressEmergencyFrame = 0;
  gEmergencyIngressHeartbeat = 0;
  gDiagCtxNominalSeen = 0;
  gDiagCtxDegradedSeen = 0;
  gDiagCtxBlockedSeen = 0;
  gDcmCtxPositiveSeen = 0;
  gDcmCtxNegativeSeen = 0;
  gDcmCtxBlockedSeen = 0;
  gCgwBoundaryNominalSeen = 0;
  gAdasWarningNominalSeen = 0;
  gBcmAmbientNominalSeen = 0;
  gIviTextNominalSeen = 0;
  gV2xContextNominalSeen = 0;
  gCluDisplayNominalSeen = 0;
  gObsTmuLinkState = -1;
  gObsTmuServiceMode = -1;
  gObsRemoteClimateReq = -1;
  gObsSignalBars = -1;
  gObsCabinSetTemp = -1;
  gObsBlowerLevel = -1;
  gObsAcCompressorOn = -1;
  gObsVentMode = -1;
  gObsRearSetTemp = -1;
  gObsRearBlowerLevel = -1;
  gObsRearVentMode = -1;
  gObsRearSyncMode = -1;
  gObsDKeyState = -1;
  gObsVehicleAccessState = -1;
  gObsSecurityGrade = -1;
  gObsKeyPresence = -1;
  gObsAutoDoorState = -1;
  gObsAutoUnlockState = -1;
  gObsDoorApproachScore = -1;
  gObsTailgateAssistMode = -1;
  gObsTailgateOpenRequestState = -1;
  gObsTailgateActuatorCmd = -1;
  gObsVehicleSpeed = -1;
  gObsDriveState = -1;
  gObsSteeringState = -1;
  gObsBrakePedal = -1;
  gObsDriveMode = -1;
  gObsEcoMode = -1;
  gObsSportMode = -1;
  gObsBaseZoneContext = -1;
  @Core::accelGroupFlag = 0;
  @Core::steerGroupFlag = 0;
}

void trackSt038DiagnosticContext()
{
  int serviceState;
  int securityState;
  int routeOwner;
  int reasonCode;
  int failSafeMode;

  if (gCurrentScenarioId != 202)
  {
    return;
  }

  serviceState = clampRange((int)@Diag::ServiceState, 0, 255);
  securityState = clampRange((int)@Diag::SecurityState, 0, 255);
  routeOwner = clampRange((int)@Diag::RouteOwner, 0, 255);
  reasonCode = clampRange((int)@Diag::ReasonCode, 0, 255);
  failSafeMode = clampRange((int)@Core::failSafeMode, 0, 7);

  if (serviceState == 1 && securityState == 1 && routeOwner == 3 &&
      reasonCode == 0 && failSafeMode == 0)
  {
    gDiagCtxNominalSeen = 1;
  }
  else if (serviceState == 3 && securityState == 2 && routeOwner == 1 &&
           reasonCode == 3 && failSafeMode == 1)
  {
    gDiagCtxDegradedSeen = 1;
  }
  else if (serviceState == 2 && securityState == 3 && routeOwner == 1 &&
           reasonCode == 2 && failSafeMode >= 2)
  {
    gDiagCtxBlockedSeen = 1;
  }
}

void trackDcmDiagnosticContext()
{
  int serviceState;
  int responseKind;
  int reasonCode;
  int lastSid;

  if (gCurrentScenarioId != 204)
  {
    return;
  }

  serviceState = clampRange((int)@Diag::ServiceState, 0, 255);
  responseKind = clampRange((int)@Diag::ResponseKind, 0, 255);
  reasonCode = clampRange((int)@Diag::ReasonCode, 0, 255);
  lastSid = clampRange((int)@Diag::LastRequestSid, 0, 255);

  if (serviceState == 1 && responseKind == 1 && reasonCode == 0 && lastSid == 0x22)
  {
    gDcmCtxPositiveSeen = 1;
  }
  else if (serviceState == 3 && responseKind == 2 && reasonCode == 3 && lastSid == 0x22)
  {
    gDcmCtxNegativeSeen = 1;
  }
  else if (serviceState == 2 && responseKind == 4 && reasonCode == 2 && lastSid == 0x22)
  {
    gDcmCtxBlockedSeen = 1;
  }
}

void trackWave2NominalContexts()
{
  if (gCurrentScenarioId == 206)
  {
    if ((int)@CoreState::domainBoundaryStatus == 1 &&
        (int)@CoreState::routingPolicy == 1 &&
        getObservedSelectedAlertLevel() == 0 &&
        (int)@Core::failSafeMode == 0)
    {
      gCgwBoundaryNominalSeen = 1;
    }
  }
  else if (gCurrentScenarioId == 207)
  {
    if (getObservedSelectedAlertLevel() == 3 &&
        getObservedSelectedAlertType() == 3 &&
        (int)@CoreState::warningPathStatus == 0 &&
        (int)@Core::failSafeMode == 0)
    {
      gAdasWarningNominalSeen = 1;
    }
  }
  else if (gCurrentScenarioId == 208)
  {
    if (getObservedSelectedAlertLevel() == 3 &&
        getObservedSelectedAlertType() == 3 &&
        (int)@Body::ambientColor == 3 &&
        (int)@Body::ambientPattern == 5 &&
        (int)@Core::failSafeMode == 0)
    {
      gBcmAmbientNominalSeen = 1;
    }
  }
  else if (gCurrentScenarioId == 209)
  {
    if (getObservedSelectedAlertLevel() == 6 &&
        getObservedSelectedAlertType() == 1 &&
        (int)@Cluster::warningTextCode == getExpectedRuntimeEmergencyWarningCode() &&
        (int)@Core::failSafeMode == 0)
    {
      gIviTextNominalSeen = 1;
    }
  }
  else if (gCurrentScenarioId == 210)
  {
    if (getObservedEmergencyEtaSec() == 9 &&
        getObservedEmergencySourceId() == 92 &&
        getObservedSelectedAlertLevel() == 6 &&
        getObservedSelectedAlertType() == 1 &&
        (int)@Core::failSafeMode == 0)
    {
      gV2xContextNominalSeen = 1;
    }
  }
  else if (gCurrentScenarioId == 211)
  {
    if (getObservedSelectedAlertLevel() == 6 &&
        getObservedSelectedAlertType() == 1 &&
        (int)@Cluster::warningTextCode == getExpectedRuntimeEmergencyWarningCode() &&
        (int)@UiRender::renderDirection == getObservedEmergencyDirection() &&
        (int)@Core::failSafeMode == 0)
    {
      gCluDisplayNominalSeen = 1;
    }
  }
}

void setScenarioMirror(int scenarioId)
{
  gScenarioMirrorInternalWrite = 1;
  @Test::testScenario = clampRange(scenarioId, 0, 255);
}

void clearScenarioLifecycleState()
{
  @Test::scenarioActiveId = 0;
  @Test::scenarioSettledId = 0;
  @Test::scenarioEvaluatedId = 0;
}

void publishScenarioPanelLamps()
{
  int activeScenarioId;
  int evaluatedScenarioId;
  int lastAck;
  int result;
  int stopLamp;
  int warnLamp;
  int runLamp;

  activeScenarioId = clampRange((int)@Test::scenarioActiveId, 0, 255);
  evaluatedScenarioId = clampRange((int)@Test::scenarioEvaluatedId, 0, 255);
  lastAck = clampRange((int)@Test::scenarioCommandAck, 0, 255);
  result = (((int)@Test::scenarioResult) == 1) ? 1 : 0;

  stopLamp = 1;
  warnLamp = 0;
  runLamp = 0;

  if (activeScenarioId != 0)
  {
    stopLamp = 0;
    runLamp = 1;
  }
  else if (lastAck != 0 && evaluatedScenarioId != 0 && result == 0)
  {
    stopLamp = 0;
    warnLamp = 1;
  }

  @Test::scenarioLampStop = stopLamp;
  @Test::scenarioLampWarn = warnLamp;
  @Test::scenarioLampRun = runLamp;
}

void publishScenarioResultFrame()
{
  write("[TEST_SCN] scenario result=%d",
        (((int)@Test::scenarioResult) == 1) ? 1 : 0);
}

void beginScenarioExecution(int scenarioId)
{
  cancelScenarioTransientTimers();
  clearScenarioLifecycleState();
  @Test::scenarioResult = 0;
  applyScenarioPreset(scenarioId);
  gCurrentScenarioId = scenarioId;
  setScenarioMirror(scenarioId);
  @Test::scenarioActiveId = clampRange(scenarioId, 0, 255);
  publishScenarioPanelLamps();
  scheduleScenarioEvaluation(scenarioId);
}

int applyScenarioPanelRequest(int scenarioId, int fromCompatMirror)
{
  int acceptedScenarioId;

  acceptedScenarioId = 0;

  if (scenarioId == 0)
  {
    stopScenarioExecution();
    setScenarioMirror(0);
    if (fromCompatMirror == 1)
    {
      write("[TEST_SCN] direct testScenario stop");
    }
    else
    {
      write("[TEST_SCN] command stop");
    }
  }
  else if (scenarioId >= 1 && scenarioId <= 35)
  {
    beginScenarioExecution(scenarioId);
    acceptedScenarioId = clampRange(scenarioId, 0, 255);
    if (fromCompatMirror == 1)
    {
      write("[TEST_SCN] direct testScenario apply=%d", scenarioId);
    }
    else
    {
      write("[TEST_SCN] command apply scenario=%d", scenarioId);
    }
  }
  else if (scenarioId >= 200 && scenarioId <= 255)
  {
    beginScenarioExecution(scenarioId);
    acceptedScenarioId = clampRange(scenarioId, 0, 255);
    if (fromCompatMirror == 1)
    {
      write("[TEST_SCN] direct testScenario execute=%d", scenarioId);
    }
    else
    {
      write("[TEST_SCN] command execute scenario=%d", scenarioId);
    }
  }
  else
  {
    if (fromCompatMirror == 1)
    {
      write("[TEST_SCN] ignore invalid testScenario=%d", scenarioId);
    }
    else
    {
      write("[TEST_SCN] command ignore invalid scenario=%d", scenarioId);
    }
  }

  @Test::scenarioCommandAck = acceptedScenarioId;
  return acceptedScenarioId;
}

void applyScenarioPreset(int scenarioId)
{
  gScenarioInputLock = 0;
  gLockDriveState = 0;
