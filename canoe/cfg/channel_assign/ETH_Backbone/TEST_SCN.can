  }
  else if (gCurrentScenarioId == 222)
  {
    result = ((int)@CoreState::emergencyDistanceM == 180 &&
              level == 6 &&
              type == 1 &&
              (int)@Cluster::warningTextCode == getExpectedRuntimeEmergencyWarningCode() &&
              (int)@Core::failSafeMode == 0) ? 1 : 0;
  }
  else if (gCurrentScenarioId == 225)
  {
    result = (gObsDriveState == 3 &&
              gObsVehicleSpeed == 70 &&
              (int)@Core::failSafeMode == 0) ? 1 : 0;
  }
  else if (gCurrentScenarioId == 226)
  {
    result = (gObsDriveState == 0 &&
              gObsVehicleSpeed == 0 &&
              (int)@Core::failSafeMode == 0 &&
              gObsAutoDoorState == 1 &&
              gObsAutoUnlockState == 1 &&
              gObsDoorApproachScore >= 80) ? 1 : 0;
  }
  else if (gCurrentScenarioId == 227)
  {
    result = (gObsDriveState == 0 &&
              gObsVehicleSpeed == 0 &&
