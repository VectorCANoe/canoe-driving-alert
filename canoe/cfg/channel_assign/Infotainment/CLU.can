on message frmClusterBaseStateMsg
{
  gBaseClusterSpeed  = clampRange((int)this.ClusterSpeed,  0, 255);
  gBaseClusterGear   = clampRange((int)this.ClusterGear,   0, 15);
  gBaseClusterStatus = clampRange((int)this.ClusterStatus, 0, 15);
}

on message frmClusterThemeMsg
{
  gThemeMode = clampRange((int)this.ThemeMode, 0, 7);
  @CoreState::themeMode = gThemeMode;
}

on message frmHmiPopupStateMsg
{
  gPopupType     = clampRange((int)this.PopupType,     0, 15);
  gPopupPriority = clampRange((int)this.PopupPriority, 0, 7);
  gPopupActive   = clampRange((int)this.PopupActive,   0, 1);
  @CoreState::popupType     = gPopupType;
  @CoreState::popupPriority = gPopupPriority;
  @CoreState::popupActive   = gPopupActive;
}

on message frmMediaStateMsg
{
  gVolumeLevel = clampRange((int)this.VolumeLevel, 0, 100);
  @CoreState::volumeLevel = gVolumeLevel;
}

on message frmAudioFocusMsg
{
  gAudioFocusOwner = clampRange((int)this.AudioFocusOwner, 0, 7);
  gAudioDuckingLvl = clampRange((int)this.AudioDuckingLvl, 0, 7);
  @CoreState::audioFocusOwner = gAudioFocusOwner;
  @CoreState::audioDuckingLvl = gAudioDuckingLvl;
}

on message frmSpeechTtsStateMsg
{
  gTtsState = clampRange((int)this.TtsState, 0, 7);
  @CoreState::ttsState = gTtsState;
}

on message frmClusterSyncStateMsg
{
  gClusterSyncState = clampRange((int)this.ClusterSyncState, 0, 15);
  gClusterSyncSeq   = clampRange((int)this.ClusterSyncAge,   0, 255);
  @CoreState::clusterSyncState = gClusterSyncState;
  @CoreState::clusterSyncSeq   = gClusterSyncSeq;
  if (gClusterSyncState != gLastBaseSyncState ||
      (int)this.ClusterSyncError != gLastBaseSyncError)
  {
    write("[CLU] base sync state=%d err=%d age=%d spd=%d gear=%d status=%d",
          gClusterSyncState, (int)this.ClusterSyncError, gClusterSyncSeq,
          gBaseClusterSpeed, gBaseClusterGear, gBaseClusterStatus);
    gLastBaseSyncState = gClusterSyncState;
    gLastBaseSyncError = (int)this.ClusterSyncError;
  }
}

on message frmClusterNotifMsg
{
  gNotifType = clampRange((int)this.ClusterNotifType, 0, 255);
  gNotifArg  = clampRange((int)this.ClusterNotifArg,  0, 255);
  @CoreState::clusterNotifType = gNotifType;
  @CoreState::clusterNotifPrio = gNotifArg;
}

// �麻 ��� �޽��� (�α� ���� - warningTextCode�� applyClusterImage()�� ����)
on message frmClusterWarningMsg
{
  int rawCode;
  rawCode = clampRange((int)this.WarningTextCode, 0, 255);
  write("[CLU] backbone warning raw=%d (ignored: image mapper active)", rawCode);
}

on sysvar Test::historyQueryOffset
{
  respondHistoryQuery();
  write("[CLU] history query offset=%d code=%d",
        (int)@Test::historyQueryOffset, (int)@Test::historyQueryCode);
}

on timer tDuplicateGuard
{
  int guardRemainMs;
  dword nowMs;
  dword elapsedMs;

  if (gLastDisplayedCode == 0)
  {
    @CoreState::duplicatePopupGuard = 0;
    return;
  }

  nowMs     = getSimulationTimeMs();
  elapsedMs = nowMs - gLastDisplayMs;
  if (elapsedMs >= 1000)
  {
    guardRemainMs = 0;
  }
  else
  {
    guardRemainMs = 1000 - (int)elapsedMs;
  }

  @CoreState::duplicatePopupGuard = guardRemainMs;
  if (guardRemainMs > 0)
  {
    setTimer(tDuplicateGuard, 100);
  }
}

on sysvar V2X::AnimationTrigger {
  if (@V2X::AnimationTrigger == 1) {
    @V2X::MyCarFrame = 0; @V2X::AmbFrame = 0; @Display::animFrame = 0;
    vMyCarFinished = 0;
    
    // 시나리오 시작 설정
    @Chassis::vehicleSpeed = 50;   // 50에서 시작
    @Chassis::driveState = 3;      // D기어
    @Chassis::brakePressure = 50.0; // 즉시 감속 시작
    
    setTimer(tSceneTimer, 250); 
  }
}

on timer tSceneTimer {
  int isFinished = 1;

  // 1. 구급차 이동
  if (@V2X::AmbFrame < kAmbEnd) {
    @V2X::AmbFrame++; isFinished = 0;
    if (@V2X::AmbFrame == 7) @Display::animFrame = 2;
    if (@V2X::AmbFrame == 25) @Display::animFrame = 0;
  }

  // 2. 마이카 제어
  if (vMyCarFinished == 0) {
    isFinished = 0;
    if (@V2X::MyCarFrame < kMyCarEnd) {
      if (@V2X::AmbFrame < 15) { 
        @Chassis::brakePressure = 50.0; @V2X::MyCarFrame++;
      }
      else if (@V2X::AmbFrame < 25) { 
        @Chassis::throttlePedalBtn = 0; @Chassis::brakePressure = 50.0;
      }
      else { // 구간 C: 재출발 및 가속
        @Chassis::brakePressure = 0.0;
        if (@Chassis::vehicleSpeed >= 60) @Chassis::throttlePedalBtn = 0;
        else @Chassis::throttlePedalBtn = 1;
        @V2X::MyCarFrame++;
      }
    } 
    else { // ★ 도착 시점: 여기서 악셀을 떼줘야 합니다!
      vMyCarFinished = 1; 
      @Chassis::vehicleSpeed = 0; 
      @Chassis::brakePressure = 0.0;
      @Chassis::throttlePedalBtn = 0; // 이 줄이 범인이었습니다! 0으로 추가.
      write("[CLU] 도착 완료: 악셀 버튼 해제");
    }
  }

  // 3. 타이머 반복 및 시나리오 종료 (3배 느린 450ms 적용)
  if (isFinished == 0) setTimer(tSceneTimer, 450); 
  else {
    @V2X::AnimationTrigger = 0;
    @Chassis::throttlePedalBtn = 0; // 안전을 위해 종료 시 한 번 더 꺼줌
    @Chassis::brakePressure = 0.0;
  }
}