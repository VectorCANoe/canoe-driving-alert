// ============================================================
// ��� ǥ�� Ÿ�̸� (1�� �� ����)
// ============================================================

on timer tGearHold
{
  int animFrame;

  gGearHoldActive = 0;
  applyClusterImage();

  // ��� ǥ�� ������(19~22)�̸� �⺻ ȭ������ ����
  animFrame = (int)@Display::animFrame;
  if (animFrame >= 19 && animFrame <= 22)
    @Display::animFrame = 0;

  write("[CLU] gear hold cleared");
}


// ============================================================
// ��� ���� ���� (driveState ���� -> 1�� ����)
// ============================================================

on sysvar Chassis::driveState
{
  int newState;
  int code;
  int curFrame;

  newState = (int)@Chassis::driveState;
  if (newState == gPrevDriveState)
  {
    return;
  }

  code = 0;
  if      (newState == 3) code = 20;  // D
  else if (newState == 2) code = 21;  // N
  else if (newState == 1) code = 22;  // R
  else if (newState == 0) code = 23;  // P

  if (code > 0)
  {
    gGearHoldCode   = code;
    gGearHoldActive = 1;
    cancelTimer(tGearHold);
    setTimer(tGearHold, 1000);
    write("[CLU] gear change -> code=%d (1s hold)", code);

    // animFrame ��� ǥ�� (���/�õ��ִ� ����� �ÿ���): 19=D 20=N 21=R 22=P
    curFrame = (int)@Display::animFrame;
    if (curFrame < 23)  // �õ� �ִϸ��̼�(23~50) �ƴ� ��
    {
      if (curFrame != 1 && curFrame != 2 && curFrame != 7 && curFrame != 8)
      {
        if      (newState == 3) @Display::animFrame = 19;  // D
        else if (newState == 2) @Display::animFrame = 20;  // N
        else if (newState == 1) @Display::animFrame = 21;  // R
        else if (newState == 0) @Display::animFrame = 22;  // P
      }
    }
  }

  gPrevDriveState = newState;
  applyClusterImage();
}


// ============================================================
// CAN �޽��� �ڵ鷯 (��ȣ ĳ�� + ��� ��)
// ============================================================

// �����浹 (frmRearRadarMasterStateMsg ID=475=0x1EB)
// RearObjectDetected: bit0, RearRiskLevel: byte1
on message 0x1EB
{
  gRearObjectDetected = (int)(this.byte(0)) & 0x01;
  gRearRiskLevel      = (int)(this.byte(1));
  applyClusterImage();
}

// ������ ��� (frmBcwStateMsg ID=458=0x1CA)
// BcwWarnLeft: bit0, BcwWarnRight: bit1
on message 0x1CA
{
  gBcwWarnLeft  = (int)(this.byte(0)) & 0x01;
  gBcwWarnRight = ((int)(this.byte(0)) >> 1) & 0x01;
  applyClusterImage();
}

// ���� ���� ��� - Body::doorOpenCmd sysvar ��� (DBC ��Ȯ�� ��ȸ)
on sysvar Body::doorOpenCmd
{
  gDoorOpenWarn = (int)@Body::doorOpenCmd;
  applyClusterImage();
}

// �ڵ� ������ (frmHighwayPilotStateMsg ID=477=0x1ED)
// DriverMonitorReq: bit3
on message 0x1ED
{
  gDriverMonitorReq = ((int)(this.byte(0)) >> 3) & 0x01;
  applyClusterImage();
}


