// ============================================================
// �ڵ� ���� �����̴� -> Display::steeringFrame ��ȯ ����
//
// �����̴� ����: 0 ~ 138  (center = 69)
// ��Ʈ���̹���: 71������ (0~70), 360�� �ð���� ȸ��
//   frame 0  = 12�� ����
//   frame 35 = 6�� (180�� ȸ��)
//   frame 70 �� 360�� (12�� ����)
//
// [��ȯ ����]  (��Ʈ���̹��� 71��, StateCnt=70, frame 0~69 ���)
//   frame�� = �ݽð����(��ȸ��), frame�� = �ð����(��ȸ��)
//   ��ȸ�� (angle 69->138): frame = 69-(angle-69)*34/69 -> 69~35 (�ð���� ����)
//   ��ȸ�� (angle 69->0):   frame = (69-angle)*35/69   -> 0~35 (�ݽð���� ����)
//
//  angle:   0   69  138
//  frame:  35   0/69  35
//  (frame 0 = ����, frame 69 �� ����, frame 35 = �ִ�ȸ��)
//
// steeringInput: 0 = ������(�߾ӡ�4����=��20��) �̳�, 1 = ���� ��
// ============================================================
on sysvar Chassis::steeringAngle
{
  int angle;
  int frame;
  int deviation;

  angle = (int)@Chassis::steeringAngle;

  if (angle >= 69)
  {
    // ��ȸ��: frame 69->35 (�ð����)
    frame = 69 - (angle - 69) * 34 / 69;
  }
  else
  {
    // ��ȸ��: frame 0->35 (�ݽð����)
    frame = (69 - angle) * 35 / 69;
  }
  if (frame < 0)  frame = 0;
  if (frame > 69) frame = 69;

  @Display::steeringFrame = frame;

  // ������ ����: �߾�(angle=69) ��4����(��20��) �̳�
  deviation = 69 - angle;
  if (deviation < 0) deviation = angle - 69;  // abs

  if (deviation <= 4)
  {
    @Chassis::steeringInput = 0;  // �ڵ� ������ (�߾�)
  }
  else
  {
    @Chassis::steeringInput = 1;  // �ڵ� ���� ��
    if (angle < 69)
      write("[CLU] steering LEFT  angle=%d frame=%d", angle, frame);
    else
      write("[CLU] steering RIGHT angle=%d frame=%d", angle, frame);
  }

  applyClusterImage();
}


