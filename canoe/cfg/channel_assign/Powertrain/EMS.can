  int gLastRoadZone;          // ?ҙм „ ?„лЎң кө¬м—ӯ (кі мҶқ?„лЎң м§„мһ… к°қм???
  int gFuelLevel;
  int gBatterySoc;
  int gCoolantTemp;           // ?„мһ¬ ?үк°қ???Ёлқ„: 20В°C(?үк°„) ??90В°C(?•мғқ) ?ңм„ң??ліҖ??  int gFuelDisplay;           // ?°лЈҢ кІҢмқҙм§Җ ?ңмӢңк°? ?ңлқҷ ??0?’gFuelLevel ?ңм„ң???қмҠ№
  int gAnimFrame;             // ?„мһ¬ ?ңмӢң мӨ‘мқё ? лӢҲл©”мқҙ???„л Ҳ??лІҲнҳё
  int gAnimEndFrame;          // л§Ҳм?л§??„л Ҳ??лІҲнҳё (мҙ?41??
  int gAnimRunning;           // ? лӢҲл©”мқҙ???¬мғқ мӨ??¬л? (0=?•м?, 1=?¬мғқ)
  int gAnimInterval;          // ?„л Ҳ??к°„кІ© ms = 4000 / 30?„л Ҳ??= 133ms
  int gInitDone;              // мҙҲкё°???„лЈҢ ?Ңлһҳк·?(0=мҙҲкё°??мӨ? 1=?„лЈҢ)
