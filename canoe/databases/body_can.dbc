BU_: BCM ADAS CGW DATC SMK BODY_SECURITY_MODULE WIPER_MODULE AFLS DOOR_FL DOOR_FR SEAT_DRV SEAT_PASS VAL_SCENARIO_CTRL Vector__XXX

BO_ 608 frmAmbientControlMsg: 1 BCM
 SG_ AmbientMode    : 0|3@1+ (1,0) [0|7] "" BCM
 SG_ AmbientColor   : 3|3@1+ (1,0) [0|7] "" BCM
 SG_ AmbientPattern : 6|2@1+ (1,0) [0|3] "" BCM

BO_ 609 frmHazardControlMsg: 1 BCM
 SG_ HazardSwitch     : 0|1@1+ (1,0) [0|1] "" BCM
 SG_ HazardState      : 1|1@1+ (1,0) [0|1] "" BCM
 SG_ Reserved0        : 2|6@1+ (1,0) [0|0] "" Vector__XXX

BO_ 610 frmWindowControlMsg: 1 BCM
 SG_ WindowCommand    : 0|2@1+ (1,0) [0|3] "" BCM
 SG_ WindowState      : 2|2@1+ (1,0) [0|3] "" BCM
 SG_ Reserved0        : 4|4@1+ (1,0) [0|0] "" Vector__XXX

BO_ 612 frmDoorStateMsg: 2 BCM
 SG_ DoorStateMask    : 0|8@1+ (1,0) [0|255] "" BCM,BCM
 SG_ DoorLockState    : 8|2@1+ (1,0) [0|3] "" BCM,BCM
 SG_ ChildLockState   : 10|1@1+ (1,0) [0|1] "" BCM,BCM
 SG_ DoorOpenWarn     : 11|1@1+ (1,0) [0|1] "" BCM,BCM
 SG_ Reserved0        : 12|4@1+ (1,0) [0|0] "" Vector__XXX

BO_ 613 frmLampControlMsg: 1 BCM
 SG_ HeadLampState    : 0|2@1+ (1,0) [0|3] "" BCM
 SG_ TailLampState    : 2|2@1+ (1,0) [0|3] "" BCM
 SG_ TurnLampState    : 4|2@1+ (1,0) [0|3] "" BCM
 SG_ HazardLampReq    : 6|1@1+ (1,0) [0|1] "" BCM
 SG_ Reserved0        : 7|1@1+ (1,0) [0|0] "" Vector__XXX

BO_ 614 frmWiperStateMsg: 1 WIPER_MODULE
 SG_ FrontWiperState  : 0|2@1+ (1,0) [0|3] "" WIPER_MODULE
 SG_ RearWiperState   : 2|2@1+ (1,0) [0|3] "" WIPER_MODULE
 SG_ WiperInterval    : 4|4@1+ (1,0) [0|15] "" WIPER_MODULE

BO_ 615 frmSeatBeltStateMsg: 1 BCM
 SG_ DriverSeatBelt   : 0|1@1+ (1,0) [0|1] "" BCM,BCM
 SG_ PassengerSeatBelt : 1|1@1+ (1,0) [0|1] "" BCM,BCM
