VAL_ 680 IgnitionState
  0 "Off"
  1 "On" ;

VAL_ 680 EngineState
  0 "Off"
  1 "Starting"
  2 "Running"
  3 "Fault" ;

VAL_ 681 GearInput
  0 "P"
  1 "R"
  2 "N"
  3 "D"
  4 "S"
  5 "M"
  6 "Reserved6"
  7 "Reserved7" ;

VAL_ 681 GearState
  0 "P"
  1 "R"
  2 "N"
  3 "D"
  4 "S"
  5 "M"
  6 "Reserved6"
  7 "Reserved7" ;

VAL_ 299 ChargingState
  0 "Idle"
  1 "Charging"
  2 "Discharging"
  3 "Fault" ;

VAL_ 266 DriveMode
  0 "Normal"
  1 "Eco"
  2 "Sport"
  3 "Snow"
  4 "Comfort"
  5 "Custom"
  6 "Reserved6"
  7 "Reserved7" ;

VAL_ 266 EcoMode
  0 "Off"
  1 "On" ;

VAL_ 266 SportMode
  0 "Off"
  1 "On" ;

VAL_ 266 SnowMode
  0 "Off"
  1 "On" ;

VAL_ 268 CruiseState
  0 "Off"
  1 "Standby"
  2 "Active"
  3 "Fault" ;

