CM_ BO_ 449 "Comm_201: ADAS chassis status output. ADAS-owned frame.";
CM_ SG_ 449 AdasChassisState "Computed ADAS warning level (0=none).";
CM_ SG_ 449 AdasHealthLevel  "ADAS node health (0=fault 1=ok).";

CM_ BO_ 451 "Comm_120: Emergency proximity risk frame. Produced by ADAS through its internal backbone transport seam.";
CM_ SG_ 451 RiskLevel "0..100 emergency proximity risk score.";
CM_ SG_ 451 EtaSeconds "Emergency ETA seconds used by risk model.";
CM_ SG_ 451 VehicleSpeed "Vehicle speed input used by risk model.";
CM_ SG_ 451 EmergencyDirection "0=front 1=left 2=right 3=rear.";
CM_ SG_ 451 EmergencyType "0=none 1=police 2=ambulance.";
CM_ BO_ 452 "Comm_121: Deceleration assist request frame. Produced by ADAS from ADAS Core decision state through its internal transport seam.";
CM_ SG_ 452 DecelAssistReq "0=off 1=active.";
CM_ SG_ 452 FailSafeMode "0=normal 1=degraded 2=blocked.";
CM_ SG_ 452 DriverReleaseReason "0=none 1=steering 2=brake 3=failsafe.";
CM_ BO_ 518 "Comm_006/007/008/122: Selected alert distribution frame. Produced by ADAS for BCM/IVI sync through its internal transport seam.";
CM_ SG_ 518 selectedAlertLevel "Final selected alert level (0..7).";
CM_ SG_ 518 selectedAlertType "Final selected alert type (0..7).";
CM_ SG_ 518 timeoutClear "Timeout clear pulse for deterministic reset path.";
CM_ BO_ 453 "Comm_130: Object risk input frame (SIL harness path). Produced by TEST_SCN and consumed by ADAS.";
CM_ SG_ 453 ObjectTrackValid "Object track validity.";
CM_ SG_ 453 ObjectRangeM "Representative object range in meters.";
CM_ SG_ 453 ObjectRelSpeedKph "Relative speed of representative object (negative=closing).";
CM_ SG_ 453 ObjectConfidence "Object confidence score in percent.";
CM_ SG_ 453 IntersectionConflict "1=intersection lateral conflict context.";
CM_ SG_ 453 MergeCutIn "1=merge/cut-in conflict context.";
CM_ SG_ 453 ObjectAlertHoldMs "Conservative hold time for temporary track loss.";
CM_ BO_ 454 "Comm_131: Object risk state frame. Produced by ADAS for object TTC/risk arbitration through its internal transport seam.";
CM_ SG_ 454 ObjectRiskClass "0=none .. 5=critical object risk class.";
CM_ SG_ 454 ObjectTtcMinMs "Representative object minimum TTC in ms.";
CM_ SG_ 454 ObjectRiskLevel "Normalized object risk level (0..100).";
CM_ BO_ 455 "Comm_132: Object scenario alert frame. Produced by ADAS for object-context alert sharing through its internal transport seam.";
CM_ SG_ 455 ObjectAlertLevel "Object-context selected alert level.";
CM_ SG_ 455 ObjectAlertType "Object-context selected alert type.";
CM_ BO_ 456 "Comm_202: LDWS/LKAS state frame derived from current ADAS core state for lane warning and keep-assist visibility.";
CM_ SG_ 456 LaneDepartureWarn "Lane departure warning state (0=off 1=warn).";
CM_ SG_ 456 LaneKeepAssistActive "Lane keep assist active state.";
CM_ SG_ 456 LaneGuideState "0=none 1=warn 2=assist.";
CM_ BO_ 457 "Comm_203: FCA state frame derived from current ADAS forward-risk and decel decision state.";
CM_ SG_ 457 FcwState "0=off 1=advisory 2=warning 3=critical.";
CM_ SG_ 457 AebRequest "Automatic emergency braking request state.";
CM_ SG_ 457 TtcBucket "Object TTC bucket in 100 ms units.";
CM_ BO_ 458 "Comm_204: BCW state frame derived from merge/cut-in conflict and turn intent.";
CM_ SG_ 458 BcwWarnLeft "Left-side blind-spot/collision warning state.";
CM_ SG_ 458 BcwWarnRight "Right-side blind-spot/collision warning state.";
CM_ BO_ 459 "Comm_205: LCA state frame derived from lane-change readiness and conflict state.";
CM_ SG_ 459 LcaReady "Lane change assist ready state.";
CM_ SG_ 459 LcaWarn "Lane change conflict warning state.";
CM_ BO_ 460 "Comm_206: SPAS state frame derived from low-speed steering and parking assist context.";
CM_ SG_ 460 SpasActive "Smart parking assist active state.";
CM_ SG_ 460 SteeringAssistReq "Steering assist request for parking maneuver.";
CM_ BO_ 461 "Comm_207: RSPA state frame derived from remote parking readiness and low-speed hold request.";
CM_ SG_ 461 RspaReady "Remote smart parking assist ready state.";
CM_ SG_ 461 BrakeHoldReq "Brake hold request during remote parking maneuver.";
CM_ BO_ 462 "Comm_208: AVM state frame derived from low-speed surround-view activation context.";
CM_ SG_ 462 AvmActive "Around-view monitor active state.";
CM_ SG_ 462 ViewMode "0=off 1=front 2=rear 3=surround.";
CM_ BO_ 463 "Comm_209: FCAM state frame derived from ADAS object and lane-model confidence.";
CM_ SG_ 463 CameraHealth "0=fault 1=degraded 2=ok.";
CM_ SG_ 463 ObjectDetected "Front camera object detected state.";
CM_ SG_ 463 LaneModelValid "Lane model validity state.";
CM_ BO_ 464 "Comm_210: Front radar state frame derived from current ADAS object tracking context.";
CM_ SG_ 464 RadarHealth "0=fault 1=degraded 2=ok.";
CM_ SG_ 464 ObjectDetected "Front radar target detected state.";
CM_ BO_ 465 "Comm_211: Left rear side radar frame derived from side conflict and turn intent.";
CM_ SG_ 465 SideObjectDetected "Left side object detected state.";
CM_ BO_ 466 "Comm_212: Right rear side radar frame derived from side conflict and turn intent.";
CM_ SG_ 466 SideObjectDetected "Right side object detected state.";
CM_ BO_ 467 "Comm_213: Parking ultrasonic state frame derived from low-speed parking proximity context.";
CM_ SG_ 467 ParkAssistActive "Parking ultrasonic active state.";
CM_ SG_ 467 MinDistanceCm "Minimum proximity bucket in centimeters.";
CM_ BO_ 468 "Comm_214: Driver monitoring state frame derived from current alert context and driver restraint state.";
CM_ SG_ 468 DriverMonitorActive "Driver monitoring active state.";
CM_ SG_ 468 AttentionLevel "0=unknown 1=normal 2=watch 3=critical.";
