 SG_ IviDiagData0     : 8|8@1+ (1,0) [0|255] "" VAL_SCENARIO_CTRL
 SG_ IviDiagData1     : 16|8@1+ (1,0) [0|255] "" VAL_SCENARIO_CTRL

BO_ 657 frmMediaMetaMsg: 2 IVI_GW
 SG_ MediaTrackType   : 0|4@1+ (1,0) [0|15] "" CLU_HMI_CTRL
 SG_ MediaRepeatMode  : 4|2@1+ (1,0) [0|3] "" CLU_HMI_CTRL
 SG_ MediaShuffleMode : 6|2@1+ (1,0) [0|3] "" CLU_HMI_CTRL
 SG_ MediaRemainTime  : 8|8@1+ (1,0) [0|255] "s" CLU_HMI_CTRL

BO_ 658 frmSpeechTtsStateMsg: 2 IVI_GW
 SG_ TtsState         : 0|3@1+ (1,0) [0|7] "" CLU_HMI_CTRL
 SG_ TtsPriority      : 3|3@1+ (1,0) [0|7] "" CLU_HMI_CTRL
 SG_ Reserved0        : 6|2@1+ (1,0) [0|0] "" Vector__XXX
 SG_ TtsQueueDepth    : 8|8@1+ (1,0) [0|255] "" CLU_HMI_CTRL

BO_ 659 frmConnectivityStateMsg: 2 INFOTAINMENT_GW
 SG_ ConnectivityType : 0|3@1+ (1,0) [0|7] "" NAV_CTX_MGR
 SG_ ConnectivityState: 3|3@1+ (1,0) [0|7] "" NAV_CTX_MGR
 SG_ SignalBars       : 8|4@1+ (1,0) [0|15] "" NAV_CTX_MGR
 SG_ Reserved0        : 12|4@1+ (1,0) [0|0] "" Vector__XXX

BO_ 660 frmIviHealthDetailMsg: 2 INFOTAINMENT_GW
 SG_ IviCpuLoad       : 0|8@1+ (1,0) [0|100] "%" VAL_SCENARIO_CTRL
 SG_ IviMemLoad       : 8|8@1+ (1,0) [0|100] "%" VAL_SCENARIO_CTRL

BO_ 661 frmClusterSyncStateMsg: 2 IVI_GW
 SG_ ClusterSyncState : 0|4@1+ (1,0) [0|15] "" CLU_BASE_CTRL
 SG_ ClusterSyncError : 4|4@1+ (1,0) [0|15] "" CLU_BASE_CTRL
 SG_ ClusterSyncAge   : 8|8@1+ (1,0) [0|255] "ms" CLU_BASE_CTRL

