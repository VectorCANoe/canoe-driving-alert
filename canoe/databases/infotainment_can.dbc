BO_ 610 frmMapRenderStateMsg: 2 INFOTAINMENT_GW
 SG_ MapRenderState   : 0|3@1+ (1,0) [0|7] "" NAV_CONTEXT_MGR
 SG_ ZoomLevel        : 3|5@1+ (1,0) [0|31] "" NAV_CONTEXT_MGR
 SG_ TileLoadPercent  : 8|8@1+ (1,0) [0|100] "%" NAV_CONTEXT_MGR

BO_ 611 frmRouteAlertMsg: 2 INFOTAINMENT_GW
 SG_ RouteAlertType   : 0|4@1+ (1,0) [0|15] "" NAV_CONTEXT_MGR
 SG_ RouteAlertPrio   : 4|3@1+ (1,0) [0|7] "" NAV_CONTEXT_MGR
 SG_ RouteAlertActive : 7|1@1+ (1,0) [0|1] "" NAV_CONTEXT_MGR
 SG_ RouteAlertEta    : 8|8@1+ (1,0) [0|255] "s" NAV_CONTEXT_MGR

BO_ 612 frmTrafficEventMsg: 3 INFOTAINMENT_GW
 SG_ TrafficEventType : 0|8@1+ (1,0) [0|255] "" NAV_CONTEXT_MGR
 SG_ TrafficSeverity  : 8|8@1+ (1,0) [0|255] "" NAV_CONTEXT_MGR
 SG_ TrafficDistance  : 16|8@1+ (1,0) [0|255] "m" NAV_CONTEXT_MGR

BO_ 613 frmPhoneProjectionMsg: 1 IVI_GW
 SG_ ProjectionType   : 0|2@1+ (1,0) [0|3] "" CLU_HMI_CTRL
 SG_ ProjectionState  : 2|2@1+ (1,0) [0|3] "" CLU_HMI_CTRL
 SG_ Reserved0        : 4|4@1+ (1,0) [0|0] "" Vector__XXX

BO_ 614 frmClusterNotifMsg: 2 IVI_GW
 SG_ ClusterNotifType : 0|8@1+ (1,0) [0|255] "" CLU_HMI_CTRL
 SG_ ClusterNotifArg  : 8|8@1+ (1,0) [0|255] "" CLU_HMI_CTRL

BO_ 615 frmIviDiagReqMsg: 3 SIL_TEST_CTRL
 SG_ IviDiagServiceId : 0|8@1+ (1,0) [0|255] "" INFOTAINMENT_GW
 SG_ IviDiagDidHigh   : 8|8@1+ (1,0) [0|255] "" INFOTAINMENT_GW
 SG_ IviDiagDidLow    : 16|8@1+ (1,0) [0|255] "" INFOTAINMENT_GW

BO_ 616 frmIviDiagResMsg: 3 INFOTAINMENT_GW
 SG_ IviDiagRespCode  : 0|8@1+ (1,0) [0|255] "" SIL_TEST_CTRL
 SG_ IviDiagData0     : 8|8@1+ (1,0) [0|255] "" SIL_TEST_CTRL
 SG_ IviDiagData1     : 16|8@1+ (1,0) [0|255] "" SIL_TEST_CTRL

BO_ 617 frmMediaMetaMsg: 2 IVI_GW
 SG_ MediaTrackType   : 0|4@1+ (1,0) [0|15] "" CLU_HMI_CTRL
 SG_ MediaRepeatMode  : 4|2@1+ (1,0) [0|3] "" CLU_HMI_CTRL
 SG_ MediaShuffleMode : 6|2@1+ (1,0) [0|3] "" CLU_HMI_CTRL
 SG_ MediaRemainTime  : 8|8@1+ (1,0) [0|255] "s" CLU_HMI_CTRL

BO_ 618 frmSpeechTtsStateMsg: 2 IVI_GW
 SG_ TtsState         : 0|3@1+ (1,0) [0|7] "" CLU_HMI_CTRL
 SG_ TtsPriority      : 3|3@1+ (1,0) [0|7] "" CLU_HMI_CTRL
 SG_ Reserved0        : 6|2@1+ (1,0) [0|0] "" Vector__XXX
 SG_ TtsQueueDepth    : 8|8@1+ (1,0) [0|255] "" CLU_HMI_CTRL

BO_ 619 frmConnectivityStateMsg: 2 INFOTAINMENT_GW
 SG_ ConnectivityType : 0|3@1+ (1,0) [0|7] "" NAV_CONTEXT_MGR
 SG_ ConnectivityState: 3|3@1+ (1,0) [0|7] "" NAV_CONTEXT_MGR
 SG_ SignalBars       : 8|4@1+ (1,0) [0|15] "" NAV_CONTEXT_MGR
 SG_ Reserved0        : 12|4@1+ (1,0) [0|0] "" Vector__XXX

BO_ 620 frmIviHealthDetailMsg: 2 INFOTAINMENT_GW
 SG_ IviCpuLoad       : 0|8@1+ (1,0) [0|100] "%" SIL_TEST_CTRL
 SG_ IviMemLoad       : 8|8@1+ (1,0) [0|100] "%" SIL_TEST_CTRL

BO_ 621 frmClusterSyncStateMsg: 2 IVI_GW
 SG_ ClusterSyncState : 0|4@1+ (1,0) [0|15] "" CLUSTER_BASE_CTRL
 SG_ ClusterSyncError : 4|4@1+ (1,0) [0|15] "" CLUSTER_BASE_CTRL
 SG_ ClusterSyncAge   : 8|8@1+ (1,0) [0|255] "ms" CLUSTER_BASE_CTRL

