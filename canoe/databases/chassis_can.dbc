BS_:

BU_: VAL_SCENARIO_CTRL VCU ESC MDPS ADAS CGW Vector__XXX VAL_BASELINE_CTRL

BO_ 672 frmVehicleStateCanMsg: 2 VAL_SCENARIO_CTRL
 SG_ gVehicleSpeed : 0|8@1+ (1,0) [0|255] "km/h" ESC,ADAS
 SG_ gDriveState   : 8|2@1+ (1,0) [0|3]   ""     ESC,ADAS
 SG_ Reserved0     : 10|6@1+ (1,0) [0|0]  ""     Vector__XXX

BO_ 673 frmSteeringCanMsg: 1 VAL_SCENARIO_CTRL
 SG_ SteeringInput : 0|1@1+ (1,0) [0|1] "" ESC,MDPS
 SG_ Reserved0     : 1|7@1+ (1,0) [0|0] "" Vector__XXX

BO_ 674 frmPedalInputCanMsg: 2 VAL_SCENARIO_CTRL
 SG_ AccelPedal       : 0|8@1+ (1,0) [0|100] "%" VCU
 SG_ BrakePedal       : 8|8@1+ (1,0) [0|100] "%" ESC

BO_ 256 frmSteeringStateCanMsg: 1 MDPS
 SG_ SteeringState    : 0|2@1+ (1,0) [0|3] "" MDPS
 SG_ Reserved0        : 2|6@1+ (1,0) [0|0] "" Vector__XXX

BO_ 257 frmWheelSpeedMsg: 4 ESC
 SG_ WheelSpdFL       : 0|8@1+ (1,0) [0|255] "km/h" VCU,ESC,MDPS
 SG_ WheelSpdFR       : 8|8@1+ (1,0) [0|255] "km/h" VCU,ESC,MDPS
 SG_ WheelSpdRL       : 16|8@1+ (1,0) [0|255] "km/h" VCU,ESC,MDPS
 SG_ WheelSpdRR       : 24|8@1+ (1,0) [0|255] "km/h" VCU,ESC,MDPS

BO_ 258 frmYawAccelMsg: 4 ESC
 SG_ YawRate          : 0|16@1+ (1,0) [0|65535] "deg/s" ESC,MDPS
 SG_ LatAccel         : 16|16@1+ (1,0) [0|65535] "0.01m/s2" ESC,MDPS

BO_ 288 frmBrakeStatusMsg: 2 ESC
 SG_ BrakePressure    : 0|8@1+ (1,0) [0|255] "%" ESC
 SG_ BrakeMode        : 8|2@1+ (1,0) [0|3] "" ESC
 SG_ AbsActive        : 10|1@1+ (1,0) [0|1] "" ESC
 SG_ EspActive        : 11|1@1+ (1,0) [0|1] "" ESC
 SG_ Reserved0        : 12|4@1+ (1,0) [0|0] "" Vector__XXX

BO_ 289 frmAccelStatusMsg: 2 VCU
 SG_ AccelRequest     : 0|8@1+ (1,0) [0|100] "%" ESC
 SG_ TorqueRequest    : 8|8@1+ (1,0) [0|255] "Nm" ESC

BO_ 290 frmSteeringTorqueMsg: 2 MDPS
 SG_ SteeringTorque   : 0|12@1+ (1,0) [0|4095] "0.1Nm" ESC
 SG_ SteeringAssistLv : 12|4@1+ (1,0) [0|15] "" ESC

BO_ 259 frmChassisHealthMsg: 2 ESC
 SG_ ChassisAliveCnt  : 0|8@1+ (1,0) [0|255] "" VAL_SCENARIO_CTRL,CGW
 SG_ ChassisDiagState : 8|4@1+ (1,0) [0|15] "" VAL_SCENARIO_CTRL,CGW
 SG_ ChassisFailCode  : 12|4@1+ (1,0) [0|15] "" VAL_SCENARIO_CTRL,CGW

BO_ 291 frmEpsStateMsg: 2 MDPS
 SG_ EpsAssistState   : 0|3@1+ (1,0) [0|7] "" ESC,ADAS
 SG_ EpsFaultState    : 3|1@1+ (1,0) [0|1] "" ESC,ADAS
 SG_ Reserved0        : 4|4@1+ (1,0) [0|0] "" Vector__XXX
 SG_ EpsTemp          : 8|8@1+ (1,0) [0|255] "degC" ESC,ADAS

BO_ 292 frmAbsStateMsg: 2 ABS
 SG_ AbsCtrlState     : 0|2@1+ (1,0) [0|3] "" ESC,ADAS
 SG_ AbsSlipLevel     : 2|6@1+ (1,0) [0|63] "" ESC,ADAS
 SG_ AbsPressureCmd   : 8|8@1+ (1,0) [0|255] "" ESC,ADAS

BO_ 293 frmEscStateMsg: 2 ESC
 SG_ EscCtrlState     : 0|2@1+ (1,0) [0|3] "" ESC,ADAS
 SG_ EscIntervention  : 2|6@1+ (1,0) [0|63] "" ESC,ADAS
 SG_ EscYawTarget     : 8|8@1+ (1,0) [0|255] "" ESC,ADAS

BO_ 294 frmTcsStateMsg: 2 VCU
 SG_ TcsCtrlState     : 0|2@1+ (1,0) [0|3] "" ESC,ADAS
 SG_ TcsTorqueCut     : 2|6@1+ (1,0) [0|63] "" ESC,ADAS
 SG_ TcsSlipRatio     : 8|8@1+ (1,0) [0|255] "" ESC,ADAS

BO_ 295 frmBrakeTempMsg: 2 ESC
 SG_ BrakeTempFL      : 0|8@1+ (1,0) [0|255] "degC" ESC,ADAS
 SG_ BrakeTempFR      : 8|8@1+ (1,0) [0|255] "degC" ESC,ADAS

BO_ 296 frmSteeringAngleMsg: 2 SAS
 SG_ SteeringAngleRaw : 0|16@1+ (1,0) [0|65535] "0.1deg" ESC,ADAS

BO_ 260 frmWheelPulseMsg: 2 VCU
 SG_ WheelPulseFront  : 0|8@1+ (1,0) [0|255] "" ADAS
 SG_ WheelPulseRear   : 8|8@1+ (1,0) [0|255] "" ADAS

BO_ 261 frmSuspensionStateMsg: 2 ESC
 SG_ SuspensionMode   : 0|3@1+ (1,0) [0|7] "" ADAS
 SG_ SuspensionLevel  : 3|5@1+ (1,0) [0|31] "" ADAS
 SG_ DampingLevel     : 8|8@1+ (1,0) [0|255] "" ADAS

BO_ 262 frmTirePressureMsg: 4 TPMS
 SG_ TirePressFL      : 0|8@1+ (1,0) [0|255] "kPa" ADAS
 SG_ TirePressFR      : 8|8@1+ (1,0) [0|255] "kPa" ADAS
 SG_ TirePressRL      : 16|8@1+ (1,0) [0|255] "kPa" ADAS
 SG_ TirePressRR      : 24|8@1+ (1,0) [0|255] "kPa" ADAS

BO_ 298 frmEpbStateMsg: 2 EPB
 SG_ EpbState         : 0|2@1+ (1,0) [0|3] "" CLU,VAL_SCENARIO_CTRL
 SG_ EpbWarnLevel     : 2|2@1+ (1,0) [0|3] "" CLU,VAL_SCENARIO_CTRL
 SG_ Reserved0        : 4|4@1+ (1,0) [0|0] "" Vector__XXX
 SG_ EpbHoldForce     : 8|8@1+ (1,0) [0|255] "%" CLU,VAL_SCENARIO_CTRL

BO_ 676 frmChassisDiagReqMsg: 3 VAL_SCENARIO_CTRL
 SG_ ChsDiagServiceId : 0|8@1+ (1,0) [0|255] "" ESC
 SG_ ChsDiagDidHigh   : 8|8@1+ (1,0) [0|255] "" ESC
 SG_ ChsDiagDidLow    : 16|8@1+ (1,0) [0|255] "" ESC

BO_ 263 frmChassisDiagResMsg: 3 ESC
 SG_ ChsDiagRespCode  : 0|8@1+ (1,0) [0|255] "" VAL_SCENARIO_CTRL
 SG_ ChsDiagData0     : 8|8@1+ (1,0) [0|255] "" VAL_SCENARIO_CTRL
 SG_ ChsDiagData1     : 16|8@1+ (1,0) [0|255] "" VAL_SCENARIO_CTRL

BO_ 297 frmBrakeWearMsg: 1 ESC
 SG_ BrakePadWearLvl  : 0|8@1+ (1,0) [0|255] "%" ESC

BO_ 264 frmRoadFrictionMsg: 1 ESC
 SG_ RoadFrictionCoef : 0|8@1+ (1,0) [0|255] "0.01" ADAS

BO_ 677 frmTestResultMsg: 1 VAL_SCENARIO_CTRL
 SG_ ScenarioResult : 0|1@1+ (1,0) [0|1] "" VAL_BASELINE_CTRL
 SG_ Reserved0      : 1|7@1+ (1,0) [0|0] "" Vector__XXX

BO_ 678 frmBaseTestResultMsg: 8 VAL_BASELINE_CTRL
 SG_ BaseScenarioId    : 0|8@1+ (1,0) [0|255] "" VAL_SCENARIO_CTRL
 SG_ BaseScenarioResult: 8|1@1+ (1,0) [0|1]   "" VAL_SCENARIO_CTRL
 SG_ FlowCoverageMask  : 9|15@1+ (1,0) [0|32767] "" VAL_SCENARIO_CTRL
 SG_ TraceSnapshotId   : 24|16@1+ (1,0) [0|65535] "" VAL_SCENARIO_CTRL
 SG_ TestHealth        : 40|8@1+ (1,0) [0|255] "" VAL_SCENARIO_CTRL
 SG_ Reserved1         : 48|16@1+ (1,0) [0|0] "" Vector__XXX

