VAL_ 256 gDriveState
  0 "P"
  1 "R"
  2 "N"
  3 "D" ;

VAL_ 257 SteeringInput
  0 "NoInput"
  1 "Input" ;


VAL_ 259 SteeringState
  0 "Stable"
  1 "LeftTurn"
  2 "RightTurn"
  3 "Fault" ;

VAL_ 262 BrakeMode
  0 "Normal"
  1 "Assist"
  2 "Emergency"
  3 "Fault" ;

VAL_ 262 AbsActive
  0 "Inactive"
  1 "Active" ;

VAL_ 262 EspActive
  0 "Inactive"
  1 "Active" ;

