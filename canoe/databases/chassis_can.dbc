VAL_ 672 gDriveState
  0 "P"
  1 "R"
  2 "N"
  3 "D" ;

VAL_ 673 SteeringInput
  0 "NoInput"
  1 "Input" ;


VAL_ 256 SteeringState
  0 "Stable"
  1 "LeftTurn"
  2 "RightTurn"
  3 "Fault" ;

VAL_ 288 BrakeMode
  0 "Normal"
  1 "Assist"
  2 "Emergency"
  3 "Fault" ;

VAL_ 288 AbsActive
  0 "Inactive"
  1 "Active" ;

VAL_ 288 EspActive
  0 "Inactive"
  1 "Active" ;

VAL_ 677 ScenarioResult
  0 "Fail"
  1 "Pass" ;

