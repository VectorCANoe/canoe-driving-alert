long observerStateIsReset()
{
  return ((((long)@Test::obsFailSafeMode == -1) || ((long)@Test::obsFailSafeMode == 0)) &&
          (((long)@Test::obsEmergencyContext == -1) || ((long)@Test::obsEmergencyContext == 0)) &&
          (((long)@Test::obsDecelDecisionReq == -1) || ((long)@Test::obsDecelDecisionReq == 0)) &&
          (((long)@Test::obsDecelAssistReq == -1) || ((long)@Test::obsDecelAssistReq == 0)) &&
          (((long)@Test::obsDecelRisk == -1) || ((long)@Test::obsDecelRisk == 0)) &&
          (((long)@Test::obsDecelGateReason == -1) || ((long)@Test::obsDecelGateReason == 0)) &&
          (((long)@Test::obsSelectedAlertLevel == -1) || ((long)@Test::obsSelectedAlertLevel == 0)) &&
          (((long)@Test::obsSelectedAlertType == -1) || ((long)@Test::obsSelectedAlertType == 0)) &&
          (((long)@Test::obsObjectRiskClass == -1) || ((long)@Test::obsObjectRiskClass == 0)) &&
          (((long)@Test::obsObjectRiskLevel == -1) || ((long)@Test::obsObjectRiskLevel == 0)) &&
          (((long)@Test::obsObjectTrackValid == -1) || ((long)@Test::obsObjectTrackValid == 0)) &&
          (((long)@Test::obsObjectConfidence == -1) || ((long)@Test::obsObjectConfidence == 0)) &&
          (((long)@Test::obsIntersectionConflictFlag == -1) || ((long)@Test::obsIntersectionConflictFlag == 0)) &&
          (((long)@Test::obsMergeCutInFlag == -1) || ((long)@Test::obsMergeCutInFlag == 0)));
}

void forceValidationHarnessObserverReset()
{
  @Test::baseScenarioId = 0;
  @Test::baseScenarioResult = 0;
  @Test::baseFlowCoverageMask = 0;
  @Test::baseTraceSnapshotId = 0;
  @Test::baseTestHealth = 0;

  @Test::obsFailSafeMode = -1;
  @Test::obsEmergencyContext = -1;
  @Test::obsDecelDecisionReq = -1;
  @Test::obsDecelAssistReq = -1;
  @Test::obsDecelRisk = -1;
  @Test::obsDecelGateReason = -1;
  @Test::obsDecelReleaseReason = -1;
  @Test::obsSelectedAlertLevel = -1;
  @Test::obsSelectedAlertType = -1;
  @Test::obsObjectRiskClass = -1;
  @Test::obsObjectRiskLevel = -1;
  @Test::obsObjectTrackValid = -1;
  @Test::obsObjectConfidence = -1;
  @Test::obsIntersectionConflictFlag = -1;
  @Test::obsMergeCutInFlag = -1;
}

long waitForObserverReset(dword timeoutMs)
{
  dword waitedMs;

  waitedMs = 0;
  while (!observerStateIsReset() && waitedMs < timeoutMs)
  {
    TestWaitForTimeout(50);
    waitedMs += 50;
  }

  if (!observerStateIsReset())
  {
    testStepFail("observer-reset", "Shared observer reset timeout waited=%d failSafe=%d decision=%d decel=%d gate=%d level=%d type=%d (idle accepts sentinel -1 or neutral 0)",
                 waitedMs,
                 (long)@Test::obsFailSafeMode,
                 (long)@Test::obsDecelDecisionReq,
                 (long)@Test::obsDecelAssistReq,
                 (long)@Test::obsDecelGateReason,
                 (long)@Test::obsSelectedAlertLevel,
                 (long)@Test::obsSelectedAlertType);
    return 0;
  }

  return 1;
}

