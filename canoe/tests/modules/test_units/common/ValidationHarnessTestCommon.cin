long getCanonicalSelectedAlertLevel()
{
  long effectiveAlertLevel;
  long effectiveAlertType;
  long decisionAlertLevel;
  long decisionAlertType;
  long selectedAlertGateReason;

  effectiveAlertLevel = (long)@CoreState::selectedAlertEffectiveLevel;
  effectiveAlertType = (long)@CoreState::selectedAlertEffectiveType;
  decisionAlertLevel = (long)@CoreState::selectedAlertDecisionLevel;
  decisionAlertType = (long)@CoreState::selectedAlertDecisionType;
  selectedAlertGateReason = (long)@CoreState::selectedAlertGateReason;

  if (effectiveAlertLevel > 0 || effectiveAlertType > 0 || selectedAlertGateReason > 0)
  {
    return effectiveAlertLevel;
  }

  if (decisionAlertLevel > 0 || decisionAlertType > 0)
  {
    return decisionAlertLevel;
  }

  return (long)@Core::selectedAlertLevel;
}

long getCanonicalSelectedAlertType()
{
  long effectiveAlertLevel;
  long effectiveAlertType;
  long decisionAlertLevel;
  long decisionAlertType;
  long selectedAlertGateReason;

  effectiveAlertLevel = (long)@CoreState::selectedAlertEffectiveLevel;
  effectiveAlertType = (long)@CoreState::selectedAlertEffectiveType;
  decisionAlertLevel = (long)@CoreState::selectedAlertDecisionLevel;
  decisionAlertType = (long)@CoreState::selectedAlertDecisionType;
  selectedAlertGateReason = (long)@CoreState::selectedAlertGateReason;

  if (effectiveAlertLevel > 0 || effectiveAlertType > 0 || selectedAlertGateReason > 0)
  {
    return effectiveAlertType;
  }

  if (decisionAlertLevel > 0 || decisionAlertType > 0)
  {
    return decisionAlertType;
  }

  return (long)@Core::selectedAlertType;
}

