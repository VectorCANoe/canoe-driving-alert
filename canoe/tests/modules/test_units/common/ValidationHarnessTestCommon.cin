long getValidationHarnessOwnerToken()
{
  static long sOwnerToken;

  if (sOwnerToken == 0)
  {
    sOwnerToken = (long)timeNow();
    if (sOwnerToken <= 0)
    {
      sOwnerToken = 1;
    }

    while (sOwnerToken == (long)@Test::harnessLockOwner)
    {
      sOwnerToken += 97;
      if (sOwnerToken <= 0)
      {
        sOwnerToken = 1;
      }
    }
  }

  return sOwnerToken;
}

long acquireValidationHarnessLock(dword timeoutMs)
{
  dword waitedMs;
  long ownerToken;

  ownerToken = getValidationHarnessOwnerToken();
  if ((long)@Test::harnessLockOwner == ownerToken)
  {
    return 1;
  }

  waitedMs = 0;
  while ((long)@Test::harnessLockOwner != 0 &&
         (long)@Test::harnessLockOwner != ownerToken &&
         waitedMs < timeoutMs)
  {
    TestWaitForTimeout(50);
    waitedMs += 50;
  }

  if ((long)@Test::harnessLockOwner != 0 &&
      (long)@Test::harnessLockOwner != ownerToken)
  {
    testStepFail("harness-lock", "Lock timeout owner=%d waited=%d",
                 (long)@Test::harnessLockOwner, waitedMs);
    return 0;
  }

  @Test::harnessLockOwner = ownerToken;
  TestWaitForTimeout(50);

  if ((long)@Test::harnessLockOwner != ownerToken)
  {
    testStepFail("harness-lock", "Lock takeover failed expected=%d actual=%d",
                 ownerToken, (long)@Test::harnessLockOwner);
    return 0;
  }

  return 1;
}

void releaseValidationHarnessLock()
{
  long ownerToken;

  ownerToken = getValidationHarnessOwnerToken();
  if ((long)@Test::harnessLockOwner == ownerToken)
  {
    @Test::harnessLockOwner = 0;
    TestWaitForTimeout(50);
  }
}

void cleanupValidationHarnessAfterFailure()
{
  dword waitedMs;

  @Test::scenarioCommand = 0;
  waitedMs = 0;
  while ((int)@Test::scenarioCommandAck != 0 && waitedMs < 1000)
  {
    TestWaitForTimeout(50);
    waitedMs += 50;
  }

  releaseValidationHarnessLock();
}

long resetValidationHarnessIfNeeded()
{
  long releaseAfterReset;
  dword waitedMs;

  releaseAfterReset = 0;
  if ((long)@Test::harnessLockOwner == getValidationHarnessOwnerToken())
  {
    releaseAfterReset = 1;
  }
  else if (!acquireValidationHarnessLock(10000))
  {
    return 0;
  }

  if ((int)@Test::scenarioCommandAck == 0 &&
      (int)@Test::scenarioResult == 0)
  {
    TestWaitForTimeout(100);
    if (releaseAfterReset)
    {
      releaseValidationHarnessLock();
    }
    return 1;
  }

  @Test::scenarioCommand = 0;
  waitedMs = 0;
  while (((int)@Test::scenarioCommandAck != 0 ||
          (int)@Test::scenarioResult != 0) &&
         waitedMs < 1000)
  {
    TestWaitForTimeout(50);
    waitedMs += 50;
  }

  if ((int)@Test::scenarioCommandAck != 0 ||
      (int)@Test::scenarioResult != 0)
  {
    testStepFail("scenario-reset", "Harness reset timeout waited=%d ack=%d result=%d",
                 waitedMs, (int)@Test::scenarioCommandAck, (int)@Test::scenarioResult);
    releaseValidationHarnessLock();
    return 0;
  }

  TestWaitForTimeout(150);
  if (releaseAfterReset)
  {
    releaseValidationHarnessLock();
  }
  testStepPass("scenario-reset", "Validation harness reset completed");
  return 1;
}

long waitForScenarioAck(int scenarioId, dword timeoutMs)
{
  dword waitedMs;

  waitedMs = 0;
  while ((int)@Test::scenarioCommandAck != scenarioId && waitedMs < timeoutMs)
  {
    TestWaitForTimeout(50);
    waitedMs += 50;
  }

  if ((int)@Test::scenarioCommandAck != scenarioId)
  {
    testStepFail("scenario-ack", "Scenario ack timeout expected=%d actual=%d waited=%d",
                 scenarioId, (int)@Test::scenarioCommandAck, waitedMs);
    return 0;
  }

  testStepPass("scenario-ack", "Scenario %d accepted", scenarioId);
  return 1;
}

long launchScenarioAndWait(int scenarioId, dword ackTimeoutMs, dword settleMs)
{
  if (!acquireValidationHarnessLock(10000))
  {
    return 0;
  }

  @Test::scenarioCommand = scenarioId;
  if (!waitForScenarioAck(scenarioId, ackTimeoutMs))
  {
    cleanupValidationHarnessAfterFailure();
    return 0;
  }

  TestWaitForTimeout(settleMs);
  return 1;
}

long waitForBaseResult(int scenarioId, dword timeoutMs)
{
  dword waitedMs;

  waitedMs = 0;
  while ((int)@Test::baseScenarioId != scenarioId && waitedMs < timeoutMs)
  {
    TestWaitForTimeout(50);
    waitedMs += 50;
  }

  if ((int)@Test::baseScenarioId != scenarioId)
  {
    testStepFail("base-result-wait", "Base result timeout expected=%d actual=%d waited=%d",
                 scenarioId, (int)@Test::baseScenarioId, waitedMs);
    cleanupValidationHarnessAfterFailure();
    return 0;
  }

  testStepPass("base-result-wait", "Base result ready for scenario %d", scenarioId);
  return 1;
}

void assertIntEq(char stepId[], long expected, long actual, char label[])
{
  if (expected == actual)
  {
    testStepPass(stepId, "%s expected=%d actual=%d", label, expected, actual);
  }
  else
  {
    testStepFail(stepId, "%s expected=%d actual=%d", label, expected, actual);
  }
}

void assertIntMin(char stepId[], long minValue, long actual, char label[])
{
  if (actual >= minValue)
  {
    testStepPass(stepId, "%s minimum=%d actual=%d", label, minValue, actual);
  }
  else
  {
    testStepFail(stepId, "%s minimum=%d actual=%d", label, minValue, actual);
  }
}

void assertLongGe(char stepId[], long actual, long minValue, char label[])
{
  if (actual >= minValue)
  {
    testStepPass(stepId, "%s minimum=%d actual=%d", label, minValue, actual);
  }
  else
  {
    testStepFail(stepId, "%s minimum=%d actual=%d", label, minValue, actual);
  }
}
