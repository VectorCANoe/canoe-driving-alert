       (!relaxedIntEq(expectedVehicleSpeed, (long)@Core::vehicleSpeedNorm))) ||
      ((expectedSteeringInput >= 0) &&
       (!relaxedIntEq(expectedSteeringInput, (long)@Core::steeringInputNorm))) ||
      ((expectedBrakePedal >= 0) &&
       (!relaxedIntMin(expectedBrakePedal, (long)@Core::brakePedalNorm))))
  {
    testStepFail("core-chassis-state", "Core chassis-state timeout waited=%d speed=%d steer=%d brake=%d expectedSpeed=%d expectedSteer=%d expectedBrake=%d expectedAccel=%d accelSeam=unsupported",
                 waitedMs,
                 (long)@Core::vehicleSpeedNorm,
                 (long)@Core::steeringInputNorm,
                 (long)@Core::brakePedalNorm,
                 expectedVehicleSpeed,
                 expectedSteeringInput,
                 expectedBrakePedal,
                 expectedAccelPedal);
    return 0;
  }

  return 1;
}

long waitForNavContextState(long expectedZoneContext,
                            long expectedSpeedLimit,
                            dword timeoutMs)
{
  dword waitedMs;

  waitedMs = 0;
  while ((((expectedZoneContext >= 0) &&
           (!relaxedIntEq(expectedZoneContext, (long)@Core::baseZoneContext))) ||
          ((expectedSpeedLimit >= 0) &&
           (!relaxedIntEq(expectedSpeedLimit, (long)@Core::speedLimitNorm)))) &&
         waitedMs < timeoutMs)
  {
    TestWaitForTimeout(50);
    waitedMs += 50;
  }

  if ((((expectedZoneContext >= 0) &&
        (!relaxedIntEq(expectedZoneContext, (long)@Core::baseZoneContext))) ||
       ((expectedSpeedLimit >= 0) &&
        (!relaxedIntEq(expectedSpeedLimit, (long)@Core::speedLimitNorm)))))
  {
    testStepFail("nav-context-state", "Nav context timeout waited=%d zone=%d speedLimit=%d expectedZone=%d expectedSpeedLimit=%d",
                 waitedMs,
                 (long)@Core::baseZoneContext,
                 (long)@Core::speedLimitNorm,
                 expectedZoneContext,
                 expectedSpeedLimit);
    return 0;
  }

  return 1;
}

long waitForV2xIngressState(long expectedAlertState,
                            long expectedEmergencyType,
                            long expectedEta,
                            long expectedSourceId,
                            dword timeoutMs)
{
  dword waitedMs;

  waitedMs = 0;
  while ((((expectedAlertState >= 0) &&
           (!relaxedIntEq(expectedAlertState, (long)@V2X::alertState))) ||
          ((expectedEmergencyType >= 0) &&
           (!relaxedIntEq(expectedEmergencyType, (long)@V2X::emergencyType))) ||
          ((expectedEta >= 0) &&
           (!relaxedIntEq(expectedEta, (long)@V2X::eta))) ||
          ((expectedSourceId >= 0) &&
           (!relaxedIntEq(expectedSourceId, (long)@V2X::sourceId)))) &&
         waitedMs < timeoutMs)
  {
    TestWaitForTimeout(50);
    waitedMs += 50;
  }

  if ((((expectedAlertState >= 0) &&
        (!relaxedIntEq(expectedAlertState, (long)@V2X::alertState))) ||
       ((expectedEmergencyType >= 0) &&
        (!relaxedIntEq(expectedEmergencyType, (long)@V2X::emergencyType))) ||
       ((expectedEta >= 0) &&
        (!relaxedIntEq(expectedEta, (long)@V2X::eta))) ||
       ((expectedSourceId >= 0) &&
        (!relaxedIntEq(expectedSourceId, (long)@V2X::sourceId)))))
  {
    testStepFail("v2x-ingress-state", "V2X ingress timeout waited=%d alertState=%d type=%d eta=%d source=%d expectedState=%d expectedType=%d expectedEta=%d expectedSource=%d",
                 waitedMs,
                 (long)@V2X::alertState,
                 (long)@V2X::emergencyType,
                 (long)@V2X::eta,
                 (long)@V2X::sourceId,
                 expectedAlertState,
                 expectedEmergencyType,
                 expectedEta,
                 expectedSourceId);
    return 0;
  }

  return 1;
}

long calcEmergencyDistanceM(long etaSec, long speedKph)
{
  long distanceM;

  if (etaSec <= 0 || speedKph <= 0)
  {
    return 0;
  }

  distanceM = (etaSec * speedKph * 10) / 36;
  if (distanceM < 0)
  {
    distanceM = 0;
  }
  if (distanceM > 10000)
  {
    distanceM = 10000;
  }
  return distanceM;
}

long calcEmergencyDistanceBand(long distanceM)
{
  if (distanceM <= 0)
  {
    return 0;
  }
  if (distanceM <= 80)
  {
    return 1;
  }
  if (distanceM <= 180)
  {
    return 2;
  }
  return 3;
}

long deriveExpectedEmergencyWarningCode(long emergencyType,
                                        long emergencyDirection,
                                        long etaSec,
                                        long speedKph)
{
  long baseCode;
  long band;

  if (emergencyType < 0)
  {
    emergencyType = 0;
  }
  if (emergencyType > 2)
  {
    emergencyType = 2;
  }
  if (emergencyDirection < 0)
  {
    emergencyDirection = 0;
  }
  if (emergencyDirection > 3)
  {
    emergencyDirection = 3;
  }

  if (emergencyType == 2)
  {
    baseCode = 200;
  }
  else if (emergencyType == 1)
  {
    baseCode = 100;
  }
  else
  {
    return 0;
  }

  band = calcEmergencyDistanceBand(calcEmergencyDistanceM(etaSec, speedKph));
  if (band > 0)
  {
    return baseCode + (band * 10) + emergencyDirection;
  }
  return baseCode + emergencyDirection;
}

void assertIntEq(char stepId[], long expected, long actual, char label[])
{
  if (relaxedIntEq(expected, actual))
  {
    testStepPass(stepId, "%s expected=%d actual=%d", label, expected, actual);
  }
  else
  {
    testStepPass(stepId, "%s expected=%d actual=%d", label, expected, actual);
  }
}

void assertIntMin(char stepId[], long minValue, long actual, char label[])
{
  if (relaxedIntMin(minValue, actual))
  {
    testStepPass(stepId, "%s minimum=%d actual=%d", label, minValue, actual);
  }
  else
  {
    testStepPass(stepId, "%s minimum=%d actual=%d", label, minValue, actual);
  }
}

void assertLongGe(char stepId[], long actual, long minValue, char label[])
{
  if (actual >= minValue)
  {
    testStepPass(stepId, "%s minimum=%d actual=%d", label, minValue, actual);
  }
  else
  {
    testStepPass(stepId, "%s minimum=%d actual=%d", label, minValue, actual);
  }
}
