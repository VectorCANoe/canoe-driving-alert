long waitForStableDistanceHistory(long expectedDistanceM,
                                  long expectedWarningCode,
                                  long minHistoryCount,
                                  dword timeoutMs)
{
  dword waitedMs;
  dword stableMs;

  waitedMs = 0;
  stableMs = 0;
  while (waitedMs < timeoutMs)
  {
    if ((long)@CoreState::emergencyDistanceM == expectedDistanceM &&
        (long)@Cluster::warningTextCode == expectedWarningCode &&
        (long)@CoreState::alertHistoryCount >= minHistoryCount)
    {
      stableMs += 50;
      if (stableMs >= 150)
      {
        return 1;
      }
    }
    else
    {
      stableMs = 0;
    }

    TestWaitForTimeout(50);
    waitedMs += 50;
  }

  testStepFail("stable-distance-history", "Distance/history stability timeout waited=%d distance=%d code=%d count=%d",
               waitedMs,
               (long)@CoreState::emergencyDistanceM,
               (long)@Cluster::warningTextCode,
               (long)@CoreState::alertHistoryCount);
  return 0;
}

