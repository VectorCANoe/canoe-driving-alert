long observerStateIsReset()
{
  return ((long)@Test::obsFailSafeMode == -1 &&
          (long)@Test::obsEmergencyContext == -1 &&
          (long)@Test::obsDecelDecisionReq == -1 &&
          (long)@Test::obsDecelAssistReq == -1 &&
          (long)@Test::obsDecelRisk == -1 &&
          (long)@Test::obsDecelGateReason == -1 &&
          (long)@Test::obsSelectedAlertLevel == -1 &&
          (long)@Test::obsSelectedAlertType == -1 &&
          (long)@Test::obsObjectRiskClass == -1 &&
          (long)@Test::obsObjectRiskLevel == -1 &&
          (long)@Test::obsObjectTrackValid == -1 &&
          (long)@Test::obsObjectConfidence == -1 &&
          (long)@Test::obsIntersectionConflictFlag == -1 &&
          (long)@Test::obsMergeCutInFlag == -1);
}

long waitForObserverReset(dword timeoutMs)
{
  dword waitedMs;

  waitedMs = 0;
  while (!observerStateIsReset() && waitedMs < timeoutMs)
  {
    TestWaitForTimeout(50);
    waitedMs += 50;
  }

  if (!observerStateIsReset())
  {
    testStepFail("observer-reset", "Shared observer reset timeout waited=%d failSafe=%d decision=%d decel=%d gate=%d level=%d type=%d",
                 waitedMs,
                 (long)@Test::obsFailSafeMode,
                 (long)@Test::obsDecelDecisionReq,
                 (long)@Test::obsDecelAssistReq,
                 (long)@Test::obsDecelGateReason,
                 (long)@Test::obsSelectedAlertLevel,
                 (long)@Test::obsSelectedAlertType);
    return 0;
  }

  return 1;
}

long waitForObservedEmergencyContext(dword timeoutMs)
{
  dword waitedMs;

  waitedMs = 0;
  while ((long)@Test::obsEmergencyContext < 0 && waitedMs < timeoutMs)
