long waitForObservedDecelState(long expectedDecision,
                               long expectedEffective,
                               long expectedGateReason,
                               dword timeoutMs)
{
  dword waitedMs;

  waitedMs = 0;
  while ((((expectedDecision >= 0) &&
           ((long)@Test::obsDecelDecisionReq != expectedDecision)) ||
          (((expectedEffective >= 0) &&
            ((long)@Test::obsDecelAssistReq != expectedEffective))) ||
          (((expectedGateReason >= 0) &&
            ((long)@Test::obsDecelGateReason != expectedGateReason)))) &&
         waitedMs < timeoutMs)
  {
    TestWaitForTimeout(50);
    waitedMs += 50;
  }

  if (((expectedDecision >= 0) &&
       ((long)@Test::obsDecelDecisionReq != expectedDecision)) ||
      ((expectedEffective >= 0) &&
       ((long)@Test::obsDecelAssistReq != expectedEffective)) ||
      ((expectedGateReason >= 0) &&
       ((long)@Test::obsDecelGateReason != expectedGateReason)))
  {
    testStepFail("observer-decel-state", "Decel state timeout waited=%d decision=%d effective=%d gate=%d expectedDecision=%d expectedEffective=%d expectedGate=%d",
                 waitedMs,
                 (long)@Test::obsDecelDecisionReq,
                 (long)@Test::obsDecelAssistReq,
                 (long)@Test::obsDecelGateReason,
                 expectedDecision,
                 expectedEffective,
                 expectedGateReason);
    return 0;
  }

  return 1;
}

long waitForStableWarningRender(long expectedCode,
                                long expectedDirection,
                                dword timeoutMs)
{
  dword waitedMs;
  dword stableMs;

  waitedMs = 0;
  stableMs = 0;
  while (waitedMs < timeoutMs)
  {
    if ((long)@Cluster::warningTextCode == expectedCode &&
        (expectedDirection < 0 ||
         (long)@UiRender::renderDirection == expectedDirection))
    {
      stableMs += 50;
      if (stableMs >= 150)
      {
        return 1;
      }
    }
    else
    {
      stableMs = 0;
    }

    TestWaitForTimeout(50);
    waitedMs += 50;
  }

  testStepFail("stable-warning-render", "Warning render stability timeout waited=%d code=%d direction=%d expectedCode=%d expectedDirection=%d",
               waitedMs,
               (long)@Cluster::warningTextCode,
               (long)@UiRender::renderDirection,
               expectedCode,
               expectedDirection);
  return 0;
}

