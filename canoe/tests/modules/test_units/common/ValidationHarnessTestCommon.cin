long resetValidationHarnessIfNeeded()
{
  dword waitedMs;

  if ((int)@Test::scenarioCommand == 0 &&
      (int)@Test::scenarioCommandAck == 0 &&
      (int)@Test::testScenario == 0 &&
      (int)@Test::scenarioActiveId == 0 &&
      (int)@Test::scenarioSettledId == 0 &&
      (int)@Test::scenarioEvaluatedId == 0 &&
      (int)@Test::scenarioResult == 0)
  {
    if (!waitForObserverReset(500))
    {
      return 0;
    }
    TestWaitForTimeout(100);
    return 1;
  }

  @Test::scenarioCommand = 0;
  @Test::testScenario = 0;
  waitedMs = 0;
  while (((int)@Test::testScenario != 0 ||
          (int)@Test::scenarioCommandAck != 0 ||
          (int)@Test::scenarioActiveId != 0 ||
          (int)@Test::scenarioSettledId != 0 ||
          (int)@Test::scenarioEvaluatedId != 0 ||
          (int)@Test::scenarioResult != 0) &&
         waitedMs < 1200)
  {
    TestWaitForTimeout(50);
    waitedMs += 50;
  }

  if ((int)@Test::testScenario != 0 ||
      (int)@Test::scenarioCommandAck != 0 ||
      (int)@Test::scenarioActiveId != 0 ||
      (int)@Test::scenarioSettledId != 0 ||
      (int)@Test::scenarioEvaluatedId != 0 ||
      (int)@Test::scenarioResult != 0)
  {
    testStepFail("scenario-reset", "Harness reset timeout waited=%d mirror=%d ack=%d active=%d settled=%d evaluated=%d result=%d",
                 waitedMs,
                 (int)@Test::testScenario,
                 (int)@Test::scenarioCommandAck,
                 (int)@Test::scenarioActiveId,
                 (int)@Test::scenarioSettledId,
                 (int)@Test::scenarioEvaluatedId,
                 (int)@Test::scenarioResult);
    return 0;
  }

  if (!waitForObserverReset(500))
  {
    return 0;
  }

  TestWaitForTimeout(150);
  testStepPass("scenario-reset", "Validation harness reset completed");
  return 1;
}

long waitForScenarioAck(int scenarioId, dword timeoutMs)
{
  dword waitedMs;

  waitedMs = 0;
  while ((int)@Test::scenarioCommandAck != scenarioId && waitedMs < timeoutMs)
  {
    TestWaitForTimeout(50);
    waitedMs += 50;
  }

  if ((int)@Test::scenarioCommandAck != scenarioId)
  {
    testStepFail("scenario-ack", "Scenario ack timeout expected=%d actual=%d waited=%d",
                 scenarioId, (int)@Test::scenarioCommandAck, waitedMs);
    return 0;
  }

  testStepPass("scenario-ack", "Scenario %d accepted", scenarioId);
  return 1;
}

long waitForScenarioSettled(int scenarioId, dword timeoutMs)
{
  dword waitedMs;

  waitedMs = 0;
  while ((int)@Test::scenarioSettledId != scenarioId &&
         (int)@Test::scenarioEvaluatedId != scenarioId &&
         waitedMs < timeoutMs)
  {
    TestWaitForTimeout(50);
    waitedMs += 50;
  }

  if ((int)@Test::scenarioSettledId != scenarioId &&
      (int)@Test::scenarioEvaluatedId != scenarioId)
  {
    testStepFail("scenario-settled", "Scenario settle timeout expected=%d active=%d settled=%d evaluated=%d waited=%d",
                 scenarioId,
                 (int)@Test::scenarioActiveId,
                 (int)@Test::scenarioSettledId,
                 (int)@Test::scenarioEvaluatedId,
                 waitedMs);
    return 0;
  }

  testStepPass("scenario-settled", "Scenario %d settled active=%d settled=%d evaluated=%d",
               scenarioId,
               (int)@Test::scenarioActiveId,
               (int)@Test::scenarioSettledId,
               (int)@Test::scenarioEvaluatedId);
  return 1;
}

long waitForScenarioEvaluated(int scenarioId, dword timeoutMs)
{
  dword waitedMs;

  waitedMs = 0;
  while ((int)@Test::scenarioEvaluatedId != scenarioId &&
         waitedMs < timeoutMs)
  {
    TestWaitForTimeout(50);
    waitedMs += 50;
  }

  if ((int)@Test::scenarioEvaluatedId != scenarioId)
  {
    testStepFail("scenario-evaluated", "Scenario evaluate timeout expected=%d active=%d settled=%d evaluated=%d result=%d waited=%d",
                 scenarioId,
                 (int)@Test::scenarioActiveId,
                 (int)@Test::scenarioSettledId,
                 (int)@Test::scenarioEvaluatedId,
                 (int)@Test::scenarioResult,
                 waitedMs);
    return 0;
  }

  testStepPass("scenario-evaluated", "Scenario %d evaluated result=%d",
               scenarioId,
               (int)@Test::scenarioResult);
  return 1;
}

long launchScenarioAndWait(int scenarioId, dword ackTimeoutMs, dword settleMs)
{
  dword evalTimeoutMs;

  @Test::scenarioCommand = scenarioId;
  if (!waitForScenarioAck(scenarioId, ackTimeoutMs))
  {
    return 0;
  }

  if (!waitForScenarioSettled(scenarioId, settleMs))
  {
    return 0;
  }

  evalTimeoutMs = settleMs + 2000;
  if (evalTimeoutMs < 2500)
  {
    evalTimeoutMs = 2500;
  }

  return waitForScenarioEvaluated(scenarioId, evalTimeoutMs);
}

long waitForBaseResult(int scenarioId, dword timeoutMs)
{
  dword waitedMs;

  waitedMs = 0;
  while ((int)@Test::baseScenarioId != scenarioId && waitedMs < timeoutMs)
  {
    TestWaitForTimeout(50);
    waitedMs += 50;
  }

  if ((int)@Test::baseScenarioId != scenarioId)
  {
    testStepFail("base-result-wait", "Base result timeout expected=%d actual=%d waited=%d",
                 scenarioId, (int)@Test::baseScenarioId, waitedMs);
    return 0;
  }

  testStepPass("base-result-wait", "Base result ready for scenario %d", scenarioId);
  return 1;
}

long calcEmergencyDistanceM(long etaSec, long speedKph)
{
  long distanceM;

  if (etaSec <= 0 || speedKph <= 0)
  {
    return 0;
  }

  distanceM = (etaSec * speedKph * 10) / 36;
  if (distanceM < 0)
  {
    distanceM = 0;
  }
  if (distanceM > 10000)
  {
    distanceM = 10000;
  }
  return distanceM;
}

long calcEmergencyDistanceBand(long distanceM)
{
  if (distanceM <= 0)
  {
    return 0;
  }
  if (distanceM <= 80)
  {
    return 1;
  }
  if (distanceM <= 180)
  {
    return 2;
  }
  return 3;
}

long deriveExpectedEmergencyWarningCode(long emergencyType,
                                        long emergencyDirection,
                                        long etaSec,
                                        long speedKph)
{
  long baseCode;
  long band;

  if (emergencyType < 0)
  {
    emergencyType = 0;
  }
  if (emergencyType > 2)
  {
    emergencyType = 2;
  }
  if (emergencyDirection < 0)
  {
    emergencyDirection = 0;
  }
  if (emergencyDirection > 3)
  {
    emergencyDirection = 3;
  }

  if (emergencyType == 2)
  {
    baseCode = 200;
  }
  else if (emergencyType == 1)
  {
    baseCode = 100;
  }
  else
  {
    return 0;
  }

  band = calcEmergencyDistanceBand(calcEmergencyDistanceM(etaSec, speedKph));
  if (band > 0)
  {
    return baseCode + (band * 10) + emergencyDirection;
  }
  return baseCode + emergencyDirection;
}

void assertIntEq(char stepId[], long expected, long actual, char label[])
{
  if (expected == actual)
  {
    testStepPass(stepId, "%s expected=%d actual=%d", label, expected, actual);
  }
  else
  {
    testStepFail(stepId, "%s expected=%d actual=%d", label, expected, actual);
  }
}

void assertIntMin(char stepId[], long minValue, long actual, char label[])
{
  if (actual >= minValue)
  {
    testStepPass(stepId, "%s minimum=%d actual=%d", label, minValue, actual);
  }
  else
  {
    testStepFail(stepId, "%s minimum=%d actual=%d", label, minValue, actual);
  }
}

void assertLongGe(char stepId[], long actual, long minValue, char label[])
{
  if (actual >= minValue)
  {
    testStepPass(stepId, "%s minimum=%d actual=%d", label, minValue, actual);
  }
  else
  {
    testStepFail(stepId, "%s minimum=%d actual=%d", label, minValue, actual);
  }
}
