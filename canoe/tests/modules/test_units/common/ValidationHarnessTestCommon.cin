                 scenarioId,
                 (int)@Test::scenarioActiveId,
                 (int)@Test::scenarioSettledId,
                 (int)@Test::scenarioEvaluatedId,
                 (int)@Test::scenarioResult,
                 waitedMs);
    return 0;
  }

  testStepPass("scenario-evaluated", "Scenario %d evaluated result=%d",
               scenarioId,
               (int)@Test::scenarioResult);
  return 1;
}

long launchScenarioAndWait(int scenarioId, dword ackTimeoutMs, dword settleMs)
{
  @Test::scenarioCommand = scenarioId;
  if (!waitForScenarioAck(scenarioId, ackTimeoutMs))
  {
    return 0;
  }

  return waitForScenarioSettled(scenarioId, settleMs);
}

long launchScenarioAndEvaluate(int scenarioId,
                               dword ackTimeoutMs,
                               dword settleMs,
                               dword evaluateTimeoutMs)
{
  if (!launchScenarioAndWait(scenarioId, ackTimeoutMs, settleMs))
  {
    return 0;
  }

  return waitForScenarioEvaluated(scenarioId, evaluateTimeoutMs);
}

long waitForBaseResult(int scenarioId, dword timeoutMs)
{
  dword waitedMs;

  waitedMs = 0;
  while (((int)@Test::baseScenarioId != scenarioId ||
          (int)@Test::baseTestHealth == 0) &&
