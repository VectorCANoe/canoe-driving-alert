long resetValidationHarnessIfNeeded()
{
  dword waitedMs;

  if ((int)@Test::scenarioCommandAck == 0 &&
      (int)@Test::scenarioResult == 0)
  {
    TestWaitForTimeout(100);
    return 1;
  }

  @Test::scenarioCommand = 0;
  waitedMs = 0;
  while ((int)@Test::scenarioCommandAck != 0 && waitedMs < 1000)
  {
    TestWaitForTimeout(50);
    waitedMs += 50;
  }

  if ((int)@Test::scenarioCommandAck != 0)
  {
    testStepFail("scenario-reset", "Harness reset timeout waited=%d ack=%d",
                 waitedMs, (int)@Test::scenarioCommandAck);
    return 0;
  }

  TestWaitForTimeout(150);
  testStepPass("scenario-reset", "Validation harness reset completed");
  return 1;
}

long waitForScenarioAck(int scenarioId, dword timeoutMs)
{
  dword waitedMs;

  waitedMs = 0;
  while ((int)@Test::scenarioCommandAck != scenarioId && waitedMs < timeoutMs)
  {
    TestWaitForTimeout(50);
    waitedMs += 50;
  }

  if ((int)@Test::scenarioCommandAck != scenarioId)
  {
    testStepFail("scenario-ack", "Scenario ack timeout expected=%d actual=%d waited=%d",
                 scenarioId, (int)@Test::scenarioCommandAck, waitedMs);
    return 0;
  }

  testStepPass("scenario-ack", "Scenario %d accepted", scenarioId);
  return 1;
}

long launchScenarioAndWait(int scenarioId, dword ackTimeoutMs, dword settleMs)
{
  @Test::scenarioCommand = scenarioId;
  if (!waitForScenarioAck(scenarioId, ackTimeoutMs))
  {
    return 0;
  }

  TestWaitForTimeout(settleMs);
  return 1;
}

long waitForBaseResult(int scenarioId, dword timeoutMs)
{
  dword waitedMs;

  waitedMs = 0;
  while ((int)@Test::baseScenarioId != scenarioId && waitedMs < timeoutMs)
  {
    TestWaitForTimeout(50);
    waitedMs += 50;
  }

  if ((int)@Test::baseScenarioId != scenarioId)
  {
    testStepFail("base-result-wait", "Base result timeout expected=%d actual=%d waited=%d",
                 scenarioId, (int)@Test::baseScenarioId, waitedMs);
    return 0;
  }

  testStepPass("base-result-wait", "Base result ready for scenario %d", scenarioId);
  return 1;
}

void assertIntEq(char stepId[], long expected, long actual, char label[])
{
  if (expected == actual)
  {
    testStepPass(stepId, "%s expected=%d actual=%d", label, expected, actual);
  }
  else
  {
    testStepFail(stepId, "%s expected=%d actual=%d", label, expected, actual);
  }
}

void assertIntMin(char stepId[], long minValue, long actual, char label[])
{
  if (actual >= minValue)
  {
    testStepPass(stepId, "%s minimum=%d actual=%d", label, minValue, actual);
  }
  else
  {
    testStepFail(stepId, "%s minimum=%d actual=%d", label, minValue, actual);
  }
}
