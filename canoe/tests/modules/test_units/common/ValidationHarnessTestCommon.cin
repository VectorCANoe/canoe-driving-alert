long getCanonicalSelectedAlertLevel()
{
  long effectiveAlertLevel;
  long effectiveAlertType;
  long decisionAlertLevel;
  long decisionAlertType;
  long selectedAlertGateReason;

  effectiveAlertLevel = (long)@CoreState::selectedAlertEffectiveLevel;
  effectiveAlertType = (long)@CoreState::selectedAlertEffectiveType;
  decisionAlertLevel = (long)@CoreState::selectedAlertDecisionLevel;
  decisionAlertType = (long)@CoreState::selectedAlertDecisionType;
  selectedAlertGateReason = (long)@CoreState::selectedAlertGateReason;

  if (effectiveAlertLevel > 0 || effectiveAlertType > 0 || selectedAlertGateReason > 0)
  {
    return effectiveAlertLevel;
  }

  if (decisionAlertLevel > 0 || decisionAlertType > 0)
  {
    return decisionAlertLevel;
  }

  return (long)@Core::selectedAlertLevel;
}

long getCanonicalSelectedAlertType()
{
  long effectiveAlertLevel;
  long effectiveAlertType;
  long decisionAlertLevel;
  long decisionAlertType;
  long selectedAlertGateReason;

  effectiveAlertLevel = (long)@CoreState::selectedAlertEffectiveLevel;
  effectiveAlertType = (long)@CoreState::selectedAlertEffectiveType;
  decisionAlertLevel = (long)@CoreState::selectedAlertDecisionLevel;
  decisionAlertType = (long)@CoreState::selectedAlertDecisionType;
  selectedAlertGateReason = (long)@CoreState::selectedAlertGateReason;

  if (effectiveAlertLevel > 0 || effectiveAlertType > 0 || selectedAlertGateReason > 0)
  {
    return effectiveAlertType;
  }

  if (decisionAlertLevel > 0 || decisionAlertType > 0)
  {
    return decisionAlertType;
  }

  return (long)@Core::selectedAlertType;
}

long waitForAmbientState(long expectedAlertLevel,
                         long expectedAlertType,
                         long expectedAmbientColor,
                         long expectedAmbientPattern,
                         dword timeoutMs)
{
  dword waitedMs;
  dword stableMs;

  waitedMs = 0;
  stableMs = 0;
  while (waitedMs < timeoutMs)
  {
    if ((expectedAlertLevel < 0 ||
         relaxedIntMin(expectedAlertLevel, getCanonicalSelectedAlertLevel())) &&
        (expectedAlertType < 0 ||
         relaxedIntEq(expectedAlertType, getCanonicalSelectedAlertType())) &&
        (expectedAmbientColor < 0 ||
         relaxedIntEq(expectedAmbientColor, (long)@Body::ambientColor)) &&
        (expectedAmbientPattern < 0 ||
         relaxedIntEq(expectedAmbientPattern, (long)@Body::ambientPattern)))
    {
      stableMs += 50;
      if (stableMs >= 150)
      {
        return 1;
      }
    }
    else
    {
      stableMs = 0;
    }

    TestWaitForTimeout(50);
    waitedMs += 50;
  }

  testStepFail("ambient-state", "Ambient state timeout waited=%d level=%d type=%d color=%d pattern=%d expectedLevel=%d expectedType=%d expectedColor=%d expectedPattern=%d",
               waitedMs,
               getCanonicalSelectedAlertLevel(),
