VAL_ 528 AmbientMode
  0 "Off"
  1 "Basic"
  2 "Caution"
  3 "SchoolZone"
  4 "Reserved"
  5 "GuideLeft"
  6 "GuideRight"
  7 "Emergency" ;


VAL_ 529 HazardSwitch
  0 "Off"
  1 "On" ;

VAL_ 529 HazardState
  0 "Inactive"
  1 "Active" ;

VAL_ 530 WindowCommand
  0 "NoCmd"
  1 "Open"
  2 "Close"
  3 "Stop" ;

VAL_ 530 WindowState
  0 "Unknown"
  1 "Opened"
  2 "Closed"
  3 "Moving" ;

VAL_ 531 DriverStateLevel
  0 "Normal"
  1 "MildDrowsy"
  2 "Drowsy"
  3 "Distracted"
  4 "Critical"
  5 "Reserved5"
  6 "Reserved6"
  7 "Reserved7" ;

VAL_ 532 DoorLockState
  0 "Unlocked"
  1 "Locked"
  2 "AutoLock"
  3 "Fault" ;

VAL_ 532 ChildLockState
  0 "Off"
  1 "On" ;

VAL_ 532 DoorOpenWarn
  0 "NoWarn"
  1 "Warn" ;

VAL_ 533 HeadLampState
  0 "Off"
  1 "Parking"
  2 "LowBeam"
  3 "HighBeam" ;

VAL_ 533 TailLampState
  0 "Off"
  1 "On"
  2 "Auto"
  3 "Fault" ;

VAL_ 533 TurnLampState
  0 "Off"
  1 "Left"
  2 "Right"
  3 "Hazard" ;

VAL_ 533 HazardLampReq
  0 "Off"
  1 "On" ;

VAL_ 534 FrontWiperState
  0 "Off"
  1 "Low"
  2 "High"
  3 "Auto" ;

VAL_ 534 RearWiperState
  0 "Off"
  1 "On"
  2 "Intermittent"
  3 "Fault" ;

VAL_ 535 DriverSeatBelt
  0 "Unbuckled"
  1 "Buckled" ;

VAL_ 535 PassengerSeatBelt
  0 "Unbuckled"
  1 "Buckled" ;

VAL_ 535 RearSeatBelt
  0 "None"
  1 "SomeUnbuckled"
