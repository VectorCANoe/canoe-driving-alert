@startuml 01_vehicle_system_overview
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

title Level 1: Vehicle System Architecture - 47 ECU Overview\nBased on Hyundai/Kia OpenDBC with Tier1 Best Practices

LAYOUT_WITH_LEGEND()

' Powertrain Domain (7 ECUs)
System_Boundary(powertrain, "Powertrain Domain") {
    Container(EMS, "EMS", "ECU", "Engine Management System")
    Container(TCU, "TCU", "ECU", "Transmission Control Unit")
    Container(OPI, "OPI", "ECU", "Oil Pump Inverter")
    Container(LPI, "LPI", "ECU", "LPG Injection")
    Container(FPCM, "FPCM", "ECU", "Fuel Pump Control Module")
    Container(REA, "REA", "ECU", "Rear Engine Actuator")
    Container(AAF, "AAF", "ECU", "Active Air Flap")
}

' Chassis Domain (6 ECUs)
System_Boundary(chassis, "Chassis Domain") {
    Container(ESP, "ESP", "ECU", "Electronic Stability Program")
    Container(ABS, "ABS", "ECU", "Anti-lock Braking System")
    Container(MDPS, "MDPS", "ECU", "Motor Driven Power Steering")
    Container(SAS, "SAS", "ECU", "Steering Angle Sensor")
    Container(EPB, "EPB", "ECU", "Electronic Parking Brake")
    Container(ECS, "ECS", "ECU", "Electronic Control Suspension")
}

' ADAS Domain (7 ECUs)
System_Boundary(adas, "ADAS Domain") {
    Container(F_CAMERA, "F_CAMERA", "ECU", "Front Camera\n(LDWS/LKAS)")
    Container(BSD_RADAR, "BSD_RADAR", "ECU", "Blind Spot Detection\n(LCA)")
    Container(SCC, "SCC", "ECU", "Smart Cruise Control")
    Container(SPAS, "SPAS", "ECU", "Smart Parking Assist")
    Container(AVM, "AVM", "ECU", "Around View Monitor")
    Container(PGS, "PGS", "ECU", "Parking Guidance System")
    Container(SNV, "SNV", "ECU", "Surround Night Vision")
}

' Body Domain (8 ECUs)
System_Boundary(body, "Body Domain") {
    Container(BCM, "BCM", "ECU", "Body Control Module")
    Container(DATC, "DATC", "ECU", "Dual Auto Temperature Control")
    Container(FATC, "FATC", "ECU", "Full Auto Temperature Control")
    Container(AFLS, "AFLS", "ECU", "Adaptive Front Lighting")
    Container(AHLS, "AHLS", "ECU", "Adaptive High-beam Light")
    Container(PSB, "PSB", "ECU", "Pre-Safe Belt")
    Container(TPMS, "TPMS", "ECU", "Tire Pressure Monitoring")
    Container(SMK, "SMK", "ECU", "Smart Key")
}

' Infotainment Domain (5 ECUs)
System_Boundary(infotainment, "Infotainment Domain") {
    Container(IVI, "IVI", "ECU", "In-Vehicle Infotainment\n(IBOX)")
    Container(CLU, "CLU", "ECU", "Cluster Unit")
    Container(HUD, "HUD", "ECU", "Head-Up Display")
    Container(TMU, "TMU", "ECU", "Telematics Unit")
    Container(CUBIS, "CUBIS", "ECU", "Connected User Box")
}

' Safety Domain (2 ECUs)
System_Boundary(safety, "Safety Domain") {
    Container(ACU, "ACU", "ECU", "Airbag Control Unit")
    Container(ODS, "ODS", "ECU", "Occupant Detection System")
}

' Gateway (1 ECU)
Container(CGW, "CGW", "Gateway ECU", "Central Gateway\nRouting & Filtering")

' Additional ECUs (11 ECUs)
System_Boundary(others, "Other ECUs") {
    Container(LVR, "LVR", "ECU", "Lever")
    Container(EVP, "EVP", "ECU", "Electric Vacuum Pump")
    Container(DI_BOX, "DI_BOX", "ECU", "Direct Injection Box")
    Container(_4WD, "4WD", "ECU", "4-Wheel Drive Control")
    Container(MTS, "MTS", "ECU", "Manual Transmission System")
    Container(AEMC, "AEMC", "ECU", "Active Engine Mount Control")
    Container(IAP, "IAP", "ECU", "Intake Air Pressure")
    Container(AAF_Tester, "AAF_Tester", "Test ECU", "AAF Test Equipment")
    Container(Dummy, "Dummy", "Virtual ECU", "Simulation Node")
}

' CAN Network Connections
Rel(EMS, CGW, "CAN-HS #1", "500 kbps\nPowertrain")
Rel(TCU, CGW, "CAN-HS #1", "500 kbps")
Rel(ESP, CGW, "CAN-HS #1", "500 kbps\nChassis")
Rel(ABS, CGW, "CAN-HS #1", "500 kbps")
Rel(MDPS, CGW, "CAN-HS #1", "500 kbps")

Rel(F_CAMERA, CGW, "CAN-HS #2", "500 kbps\nADAS")
Rel(BSD_RADAR, CGW, "CAN-HS #2", "500 kbps")
Rel(SCC, CGW, "CAN-HS #2", "500 kbps")

Rel(IVI, CGW, "CAN-HS #2", "500 kbps\nInfotainment")
Rel(CLU, CGW, "CAN-HS #2", "500 kbps")
Rel(HUD, CGW, "CAN-HS #2", "500 kbps")

Rel(BCM, CGW, "CAN-LS", "125 kbps\nBody")
Rel(DATC, CGW, "CAN-LS", "125 kbps")
Rel(TPMS, CGW, "CAN-LS", "125 kbps")

Rel(ACU, CGW, "CAN-HS #1", "500 kbps\nSafety")
Rel(ODS, CGW, "CAN-HS #1", "500 kbps")

SHOW_LEGEND()

note right of CGW
  **Gateway Functions**
  • Route messages between networks
  • Filter unauthorized messages
  • Diagnostic gateway (UDS)
  • Network management
end note

note bottom of powertrain
  **Domain Characteristics**
  • High-speed communication (10-100ms)
  • Safety-critical (ASIL-D)
  • Real-time requirements
end note

note bottom of adas
  **Domain Characteristics**
  • Sensor fusion
  • High bandwidth (images, radar)
  • ASIL-B/C requirements
end note

@enduml
