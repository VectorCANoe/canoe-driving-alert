@startuml
!theme silver
skinparam componentStyle uml2

package "IVI User Interface Subsystem" #E6F3FF {

    ' Presentation Layer
    package "IVI HMI Application Layer" #LightBlue {
        component "Theme_Selection_UI" as THEME_UI #LightBlue {
            portin "User_Input_In" as THEME_INPUT
            portout "Theme_Command_Out" as THEME_CMD

            note right of THEME_UI
                **REQ_IVI_042 (QM)**
                Mode Selection → Theme Apply
                • Sport/Eco/Comfort Modes
                • Response: <100ms
                • Color/Brightness/Effect Package
            end note
        }

        component "Profile_Manager_UI" as PROFILE_UI #LightGreen {
            portin "Profile_Select_In" as PROFILE_INPUT
            portout "Profile_Load_Cmd" as PROFILE_LOAD
            portout "Profile_Save_Cmd" as PROFILE_SAVE

            note right of PROFILE_UI
                **REQ_IVI_043 (QM)**
                Driver Profile Personalization
                • Max 3 Profiles
                • Load: <200ms, Save: <150ms
                • Color/Brightness/Alert Preferences
            end note
        }

        component "Scene_Controller_UI" as SCENE_UI #Orange {
            portin "Scene_Select_In" as SCENE_INPUT
            portout "Scene_Activation_Cmd" as SCENE_CMD

            note right of SCENE_UI
                **REQ_IVI_044 (QM)**
                Driving Context Scenes
                • Night Highway/Urban/Parking
                • Scene Switch: <120ms
                • Lighting + Warning + Alert Patterns
            end note
        }

        component "Scenario_Editor_UI" as EDITOR_UI #LightYellow {
            portin "Edit_Input_In" as EDIT_INPUT
            portout "Scenario_Save_Cmd" as SCENARIO_SAVE

            note right of EDITOR_UI
                **REQ_IVI_045 (QM)**
                Custom Scenario Editor
                • Speed/Time/Parking Conditions
                • Save: <200ms, UI Response: <150ms
                • OTA Deployable Parameters
            end note
        }

        component "Simulation_Viewer_UI" as SIM_UI #Pink {
            portin "Simulation_Start_In" as SIM_INPUT
            portout "CANoe_Trigger_Out" as SIM_TRIGGER
            portin "Simulation_Result_In" as SIM_RESULT

            note right of SIM_UI
                **REQ_IVI_046 (QM)**
                Event Simulation & Replay
                • CANoe Integration
                • Start: <300ms
                • Visual Lighting/Warning Preview
            end note
        }

        component "Feedback_Logger_UI" as FEEDBACK_UI #LightCoral {
            portin "User_Feedback_In" as FEEDBACK_INPUT
            portout "Log_Tag_Cmd" as LOG_TAG

            note right of FEEDBACK_UI
                **REQ_IVI_049 (QM)**
                User Feedback Logging
                • "Too Bright/Late/Annoying" Reports
                • Response: <100ms, Tag: <50ms
                • vECU State + CAN Log Tagging
            end note
        }

        component "Diagnostic_Viewer_UI" as DIAG_UI #LightGray {
            portin "Service_Mode_In" as DIAG_INPUT
            portout "Self_Test_Cmd" as DIAG_CMD
            portin "Test_Result_In" as DIAG_RESULT

            note right of DIAG_UI
                **REQ_IVI_046 (ASIL-B)**
                Service Mode Self-Diagnosis
                • Checklist Button Interface
                • Test: <2s, Result: <500ms
                • Pass/Fail Graphic Display
            end note
        }

        component "OTA_History_Viewer_UI" as OTA_UI #Lavender {
            portin "Version_Request_In" as OTA_INPUT
            portout "Version_Info_Out" as OTA_INFO
            portout "Replay_Cmd_Out" as OTA_REPLAY

            note right of OTA_UI
                **REQ_IVI_050 (QM)**
                OTA Change History Viewer
                • Current/Previous Version
                • Load: <200ms, Replay: <300ms
                • Feature Change Tracking
            end note
        }
    }

    ' Application Logic Layer
    package "IVI Application Logic" #LightGreen {
        component "Theme_Manager" as THEME_MGR {
            portin "Theme_Cmd_In" as TM_IN
            portout "vECU_Theme_Out\\n[CAN 0x210]" as TM_OUT
        }

        component "Profile_Storage_Manager" as PROFILE_MGR {
            portin "Profile_Cmd_In" as PM_IN
            portout "vECU_Profile_Out\\n[CAN 0x211]" as PM_OUT
            database "Profile_DB\\n(Local Storage)" as PROFILE_DB

            PROFILE_MGR --> PROFILE_DB
        }

        component "Scenario_Manager" as SCENARIO_MGR {
            portin "Scenario_Cmd_In" as SM_IN
            portout "vECU_Scenario_Out\\n[CAN 0x212]" as SM_OUT
        }

        component "CANoe_Interface_Adapter" as CANOE_ADAPTER {
            portin "Simulation_Cmd_In" as CA_IN
            portout "CANoe_API_Out" as CA_OUT
            portin "CANoe_Result_In" as CA_RESULT
        }

        component "Feedback_Logger" as FEEDBACK_LOG {
            portin "Feedback_In" as FL_IN
            portout "CAN_Log_Tag_Out" as FL_TAG
            database "Feedback_DB\\n(Local Storage)" as FEEDBACK_DB

            FEEDBACK_LOG --> FEEDBACK_DB
        }

        ' Connections
        THEME_CMD --> TM_IN
        PROFILE_LOAD --> PM_IN
        PROFILE_SAVE --> PM_IN
        SCENE_CMD --> SM_IN
        SCENARIO_SAVE --> SM_IN
        SIM_TRIGGER --> CA_IN
        LOG_TAG --> FL_IN
        CA_RESULT --> SIM_RESULT
    }

    ' Communication Layer
    package "IVI Communication Layer" #LightGray {
        component "CAN_Tx_Manager" as CAN_TX
        component "CAN_Rx_Manager" as CAN_RX

        TM_OUT --> CAN_TX
        PM_OUT --> CAN_TX
        SM_OUT --> CAN_TX
        FL_TAG --> CAN_TX

        CAN_RX --> DIAG_RESULT
        CAN_RX --> OTA_INFO
    }

    ' Virtual Hardware
    package "Virtual Hardware (CANoe)" #LightYellow {
        component "CAN Bus (IVI Commands)" as CAN_IVI
        component "CANoe Simulation Engine" as CANOE_SIM

        CAN_TX --> CAN_IVI
        CAN_IVI --> CAN_RX
        CA_OUT --> CANOE_SIM
        CANOE_SIM --> CA_RESULT

        note bottom of CAN_IVI
            **IVI Command CAN Signals**:
            • 0x210: Theme_Package [struct, 100ms]
            • 0x211: Profile_Data [struct, 200ms]
            • 0x212: Scenario_Params [struct, 200ms]
            • 0x213: Feedback_Tag [struct, event-based]

            **Data Flow**:
            IVI → vECU: User Commands
            vECU → IVI: Status/Results
        end note
    }

    ' External Interface
    cloud "vECU (Body Domain Controller)" as VECU {
        interface "Theme_Receiver" as VECU_THEME
        interface "Profile_Receiver" as VECU_PROFILE
        interface "Scenario_Receiver" as VECU_SCENARIO
    }

    CAN_IVI --> VECU : CAN Commands
    VECU --> CAN_IVI : Status Feedback
}

caption IVI User Interface Architecture - User Experience Layer
@enduml
