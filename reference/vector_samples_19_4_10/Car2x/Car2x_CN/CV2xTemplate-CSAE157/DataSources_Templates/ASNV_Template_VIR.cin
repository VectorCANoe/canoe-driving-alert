int SetVIRReq_SignalPriorityParams(LONG packetHandle, struct VIRReq_SignalPriority value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "intersectionId");
  SetVIRNodeReferenceIDParams(packetHandle, value.intersectionId, newPath);
  result = CheckLastError("VIR", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "requiredMov");
  SetVIRMovementExParams(packetHandle, value.requiredMov, newPath);
  result = CheckLastError("VIR", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "estimatedArrivalTime");
  if(value.estimatedArrivalTime.isValidFlag==1)
  {
    if (value.estimatedArrivalTime.value < 1)
    {
        C2xSetTokenInt(packetHandle, "VIR", newPath, 1);
    }
    else if (value.estimatedArrivalTime.value > 65535)
    {
        C2xSetTokenInt(packetHandle, "VIR", newPath, 65535);
    }
    else
    {
        C2xSetTokenInt(packetHandle, "VIR", newPath, value.estimatedArrivalTime.value);
    }
    result = CheckLastError("VIR", gkFuncRefGet, result);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "VIR", newPath) )
    {
      C2xRemoveToken(packetHandle, "VIR", newPath);
    }
  }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "distance2Intersection");
  if(value.distance2Intersection.isValidFlag==1)
  {
    C2xSetTokenInt(packetHandle, "VIR", newPath, value.distance2Intersection.value);
    result = CheckLastError("VIR", gkFuncRefGet, result);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "VIR", newPath) )
    {
      C2xRemoveToken(packetHandle, "VIR", newPath);
    }
  }

  return result;
}

