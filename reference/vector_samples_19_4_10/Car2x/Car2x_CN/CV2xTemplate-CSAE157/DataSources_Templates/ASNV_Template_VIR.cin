  result = CheckLastError("VIR", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "reqPriority");
  value.reqPriority.isValidFlag = C2xIsTokenAvailable(packetHandle, "VIR", newPath);
  if(value.reqPriority.isValidFlag==1)
  {
    value.reqPriority.isValidFlag = 1;
    value.reqPriority.stringLength = C2xGetTokenData(packetHandle, "VIR", newPath, elcount(value.reqPriority.string), value.reqPriority.string);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "targetVeh");
  value.targetVeh.isValidFlag = C2xIsTokenAvailable(packetHandle, "VIR", newPath);
  if(value.targetVeh.isValidFlag==1)
  {
    value.targetVeh.isValidFlag = 1;
    value.targetVeh.stringLength = C2xGetTokenData(packetHandle, "VIR", newPath, elcount(value.targetVeh.string), value.targetVeh.string);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "targetRSU");
  value.targetRSU.isValidFlag = C2xIsTokenAvailable(packetHandle, "VIR", newPath);
  if(value.targetRSU.isValidFlag==1)
  {
    value.targetRSU.isValidFlag = 1;
    value.targetRSU.stringLength = C2xGetTokenData(packetHandle, "VIR", newPath, elcount(value.targetRSU.string), value.targetRSU.string);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "info");
  value.info.isValidFlag = C2xIsTokenAvailable(packetHandle, "VIR", newPath);
  if(value.info.isValidFlag==1)
  {
    GetVIRReqInfoParams(packetHandle, value.info, newPath);
    result = CheckLastError("VIR", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "lifeTime");
  value.lifeTime.isValidFlag = C2xIsTokenAvailable(packetHandle, "VIR", newPath);
  if(value.lifeTime.isValidFlag==1)
  {
    value.lifeTime.value = C2xGetTokenInt(packetHandle, "VIR", newPath);
    result = CheckLastError("VIR", gkFuncRefGet, result);
  }
  return result;
}

int SetVIRDriveRequestParams(LONG packetHandle, struct VIRDriveRequest value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "reqID");
  C2xSetTokenInt(packetHandle, "VIR", newPath, value.reqID);
  result = CheckLastError("VIR", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "status");
  C2xSetTokenInt(packetHandle, "VIR", newPath, value.status);
  result = CheckLastError("VIR", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "reqPriority");
  if(value.reqPriority.isValidFlag==1)
  {
    C2xSetTokenData(packetHandle, "VIR", newPath, value.reqPriority.stringLength, value.reqPriority.string);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "VIR", newPath) )
    {
      C2xRemoveToken(packetHandle, "VIR", newPath);
    }
  }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "targetVeh");
  if(value.targetVeh.isValidFlag==1)
  {
    C2xSetTokenData(packetHandle, "VIR", newPath, value.targetVeh.stringLength, value.targetVeh.string);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "VIR", newPath) )
    {
      C2xRemoveToken(packetHandle, "VIR", newPath);
    }
  }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "targetRSU");
  if(value.targetRSU.isValidFlag==1)
  {
    C2xSetTokenData(packetHandle, "VIR", newPath, value.targetRSU.stringLength, value.targetRSU.string);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "VIR", newPath) )
    {
      C2xRemoveToken(packetHandle, "VIR", newPath);
    }
  }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "info");
  if(value.info.isValidFlag==1)
  {
    SetVIRReqInfoParams(packetHandle, value.info, newPath);
    result = CheckLastError("VIR", gkFuncRefGet, result);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "VIR", newPath) )
    {
      C2xRemoveToken(packetHandle, "VIR", newPath);
    }
  }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "lifeTime");
  if(value.lifeTime.isValidFlag==1)
  {
    if (value.lifeTime.value < 1)
    {
        C2xSetTokenInt(packetHandle, "VIR", newPath, 1);
    }
    else if (value.lifeTime.value > 65535)
    {
        C2xSetTokenInt(packetHandle, "VIR", newPath, 65535);
    }
    else
    {
        C2xSetTokenInt(packetHandle, "VIR", newPath, value.lifeTime.value);
    }
    result = CheckLastError("VIR", gkFuncRefGet, result);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "VIR", newPath) )
    {
      C2xRemoveToken(packetHandle, "VIR", newPath);
    }
  }

  return result;
}

int GetVIRIARData_reqsParams(LONG packetHandle, struct VIRIARData_reqs value, char oldPath[])
{
  char newPath[300]; 
  int i;
  int result;

  result = 0;

  value.length = C2xGetTokenInt(packetHandle, "VIR", oldPath);
  if((result = CheckLastError("VIR", gkFuncRefGet, result))==0)
  {
    for(i=0; i<value.length; i++)
    {
      snprintf(newPath, elcount(newPath), "%s[%d]", oldPath, i);
      GetVIRDriveRequestParams(packetHandle, value.arrayValue[i], newPath);
      result = CheckLastError("VIR", gkFuncRefGet, result);
    }
  }
  return result;
}

int SetVIRIARData_reqsParams(LONG packetHandle, struct VIRIARData_reqs value, char oldPath[])
{
  char newPath[300]; 
  int i;
  int result;

  result = 0;

  C2xRemoveToken(packetHandle, "VIR", oldPath);
  for(i=0; i<value.length; i++)
  {
    snprintf(newPath, elcount(newPath), "%s[%d]", oldPath, i);
    SetVIRDriveRequestParams(packetHandle, value.arrayValue[i], newPath);
    result = CheckLastError("VIR", gkFuncRefGet, result);
  }
  return result;
}

int GetVIRIARDataParams(LONG packetHandle, struct VIRIARData value, char oldPath[])
{
  char newPath[300]; 
  int j; 
  int k;
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "currentPos");
  value.currentPos.isValidFlag = C2xIsTokenAvailable(packetHandle, "VIR", newPath);
  if(value.currentPos.isValidFlag==1)
  {
    GetVIRPathPlanningPointParams(packetHandle, value.currentPos, newPath);
    result = CheckLastError("VIR", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "path_Planning");
  value.path_Planning.isValidFlag = C2xIsTokenAvailable(packetHandle, "VIR", newPath);
  if(value.path_Planning.isValidFlag==1)
  {
    GetVIRPathPlanningParams(packetHandle, value.path_Planning, newPath);
    result = CheckLastError("VIR", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "currentBehavior");
  value.currentBehavior.isValidFlag = C2xIsTokenAvailable(packetHandle, "VIR", newPath);
  if(value.currentBehavior.isValidFlag==1)
  {
    value.currentBehavior.isValidFlag = 1;
    value.currentBehavior.stringLength = C2xGetTokenLengthBit(packetHandle, "VIR", newPath);
    if ((result = CheckLastError("VIR", gkFuncRefGet, result))==0)
    {
      if(value.currentBehavior.stringLength > 0)
      {
        for(j=0; j<value.currentBehavior.stringLength; j++)
        {
          if(C2xGetTokenBitOfBitString(packetHandle, "VIR", newPath, j) == 0)
          {
            value.currentBehavior.string[j] = '0';
          }
          else if(C2xGetTokenBitOfBitString(packetHandle, "VIR", newPath, j) == 1)
          {
            value.currentBehavior.string[j] = '1';
          }

          if(value.currentBehavior.stringLength == 1)
          {
            value.currentBehavior.string[1] = '0';
          }
          result = CheckLastError("VIR", gkFuncRefGet, result);
        }
      }
      else
      {
        for(k = value.currentBehavior.stringLength+1; k > -1; k--)
        {
          if(value.currentBehavior.string[k] == '1')
          {
            value.currentBehavior.string[k] = '0';
          }
        }
      }
    }

  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "reqs");
  value.reqs.isValidFlag = C2xIsTokenAvailable(packetHandle, "VIR", newPath);
  if(value.reqs.isValidFlag==1)
  {
    GetVIRIARData_reqsParams(packetHandle, value.reqs, newPath);
    result = CheckLastError("VIR", gkFuncRefGet, result);
  }
  return result;
}

int SetVIRIARDataParams(LONG packetHandle, struct VIRIARData value, char oldPath[])
{
  char newPath[300]; 
  int j;
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "currentPos");
  if(value.currentPos.isValidFlag==1)
  {
    SetVIRPathPlanningPointParams(packetHandle, value.currentPos, newPath);
    result = CheckLastError("VIR", gkFuncRefGet, result);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "VIR", newPath) )
    {
      C2xRemoveToken(packetHandle, "VIR", newPath);
    }
  }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "path_Planning");
  if(value.path_Planning.isValidFlag==1)
  {
    SetVIRPathPlanningParams(packetHandle, value.path_Planning, newPath);
    result = CheckLastError("VIR", gkFuncRefGet, result);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "VIR", newPath) )
    {
      C2xRemoveToken(packetHandle, "VIR", newPath);
    }
  }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "currentBehavior");
  if(value.currentBehavior.isValidFlag==1)
  {
      for(j=0; j<value.currentBehavior.stringLength; j++)
      {
        if(value.currentBehavior.string[j] == '0')
        {
          C2xSetTokenBitOfBitString(packetHandle, "VIR", newPath, j, 0);
        }
        else
        {
          C2xSetTokenBitOfBitString(packetHandle, "VIR", newPath, j, 1);
        }
        result = CheckLastError("VIR", gkFuncRefGet, result);
      }
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "VIR", newPath) )
    {
      C2xRemoveToken(packetHandle, "VIR", newPath);
    }
  }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "reqs");
  if(value.reqs.isValidFlag==1)
  {
    SetVIRIARData_reqsParams(packetHandle, value.reqs, newPath);
    result = CheckLastError("VIR", gkFuncRefGet, result);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "VIR", newPath) )
    {
      C2xRemoveToken(packetHandle, "VIR", newPath);
    }
  }

  return result;
}

int GetVIRVehIntentionAndRequestParams(LONG packetHandle, struct VIRVehIntentionAndRequest value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "msgCnt");
  value.msgCnt = C2xGetTokenInt(packetHandle, "VIR", newPath);
  result = CheckLastError("VIR", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "id");
  value.id.stringLength = C2xGetTokenData(packetHandle, "VIR", newPath, elcount(value.id.string), value.id.string);
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "secMark");
  value.secMark = C2xGetTokenInt(packetHandle, "VIR", newPath);
  result = CheckLastError("VIR", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "refPos");
  GetVIRPosition3DParams(packetHandle, value.refPos, newPath);
  result = CheckLastError("VIR", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "intAndReq");
  GetVIRIARDataParams(packetHandle, value.intAndReq, newPath);
  result = CheckLastError("VIR", gkFuncRefGet, result);

  return result;
}

int SetVIRVehIntentionAndRequestParams(LONG packetHandle, struct VIRVehIntentionAndRequest value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "msgCnt");
  C2xSetTokenInt(packetHandle, "VIR", newPath, value.msgCnt);
  result = CheckLastError("VIR", gkFuncRefGet, result);

  if(value.id.stringLength == 0)
  {
    value.id.stringLength = 8;
    memcpy(value.id.string, "00000000", value.id.stringLength);
  }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "id");
  C2xSetTokenData(packetHandle, "VIR", newPath, value.id.stringLength, value.id.string);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "secMark");
  C2xSetTokenInt(packetHandle, "VIR", newPath, value.secMark);
  result = CheckLastError("VIR", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "refPos");
  SetVIRPosition3DParams(packetHandle, value.refPos, newPath);
  result = CheckLastError("VIR", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "intAndReq");
  SetVIRIARDataParams(packetHandle, value.intAndReq, newPath);
  result = CheckLastError("VIR", gkFuncRefGet, result);

  return result;
}

int GetVIRMessageTypesParams(LONG packetHandle, WORD tableKey, struct VIRMessageTypes value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  switch(tableKey)
  {
    case 13:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "virData");
      GetVIRVehIntentionAndRequestParams(packetHandle, value.virData, newPath);
      result = CheckLastError("VIR", gkFuncRefGet, result);
    }
    break;
  }
  return result;
}

