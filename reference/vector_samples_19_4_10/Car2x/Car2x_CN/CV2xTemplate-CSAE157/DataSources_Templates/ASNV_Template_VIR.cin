int GetVIRReq_ParkingAreaParams(LONG packetHandle, struct VIRReq_ParkingArea value, char oldPath[])
{
  char newPath[300]; 
  int j; 
  int k;
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "vehicleClass");
  GetVIRVehicleClassificationParams(packetHandle, value.vehicleClass, newPath);
  result = CheckLastError("VIR", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "req");
  value.req.isValidFlag = 1;
  value.req.stringLength = C2xGetTokenLengthBit(packetHandle, "VIR", newPath);
  if ((result = CheckLastError("VIR", gkFuncRefGet, result))==0)
  {
    if(value.req.stringLength > 0)
    {
      for(j=0; j<value.req.stringLength; j++)
      {
        if(C2xGetTokenBitOfBitString(packetHandle, "VIR", newPath, j) == 0)
        {
          value.req.string[j] = '0';
        }
        else if(C2xGetTokenBitOfBitString(packetHandle, "VIR", newPath, j) == 1)
        {
          value.req.string[j] = '1';
        }

        if(value.req.stringLength == 1)
        {
          value.req.string[1] = '0';
        }
        result = CheckLastError("VIR", gkFuncRefGet, result);
      }
    }
    else
    {
      for(k = value.req.stringLength+1; k > -1; k--)
      {
        if(value.req.string[k] == '1')
        {
          value.req.string[k] = '0';
        }
      }
    }
  }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "parkingType");
  value.parkingType.isValidFlag = C2xIsTokenAvailable(packetHandle, "VIR", newPath);
  if(value.parkingType.isValidFlag==1)
  {
    value.parkingType.isValidFlag = 1;
    value.parkingType.stringLength = C2xGetTokenLengthBit(packetHandle, "VIR", newPath);
    if ((result = CheckLastError("VIR", gkFuncRefGet, result))==0)
    {
      if(value.parkingType.stringLength > 0)
      {
        for(j=0; j<value.parkingType.stringLength; j++)
        {
          if(C2xGetTokenBitOfBitString(packetHandle, "VIR", newPath, j) == 0)
          {
            value.parkingType.string[j] = '0';
          }
          else if(C2xGetTokenBitOfBitString(packetHandle, "VIR", newPath, j) == 1)
          {
            value.parkingType.string[j] = '1';
          }

          if(value.parkingType.stringLength == 1)
          {
            value.parkingType.string[1] = '0';
          }
          result = CheckLastError("VIR", gkFuncRefGet, result);
        }
      }
      else
      {
        for(k = value.parkingType.stringLength+1; k > -1; k--)
        {
          if(value.parkingType.string[k] == '1')
          {
            value.parkingType.string[k] = '0';
          }
        }
      }
    }

  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "expectedParkingSlotID");
  value.expectedParkingSlotID.isValidFlag = C2xIsTokenAvailable(packetHandle, "VIR", newPath);
  if(value.expectedParkingSlotID.isValidFlag==1)
  {
    value.expectedParkingSlotID.value = C2xGetTokenInt(packetHandle, "VIR", newPath);
    result = CheckLastError("VIR", gkFuncRefGet, result);
  }
  return result;
}

