int GetVIRDriveRequestParams(LONG packetHandle, struct VIRDriveRequest value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "reqID");
