    break;
    case 5:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "position_LL6");
      GetVIRPosition_LL_48BParams(packetHandle, value.position_LL6, newPath);
      result = CheckLastError("VIR", gkFuncRefGet, result);
