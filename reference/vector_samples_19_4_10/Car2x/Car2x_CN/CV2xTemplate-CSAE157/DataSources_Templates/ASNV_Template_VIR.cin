int GetVIRReqInfoParams(LONG packetHandle, struct VIRReqInfo value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  value.choice = C2xGetTokenInt(packetHandle, "VIR", oldPath);

  switch(value.choice)
  {
    case 0:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "laneChange");
      GetVIRReq_LaneChangeParams(packetHandle, value.laneChange, newPath);
      result = CheckLastError("VIR", gkFuncRefGet, result);
    }
    break;
    case 1:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "clearTheWay");
      GetVIRReq_ClearTheWayParams(packetHandle, value.clearTheWay, newPath);
      result = CheckLastError("VIR", gkFuncRefGet, result);
    }
    break;
    case 2:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "signalPriority");
      GetVIRReq_SignalPriorityParams(packetHandle, value.signalPriority, newPath);
      result = CheckLastError("VIR", gkFuncRefGet, result);
    }
    break;
    case 3:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "sensorSharing");
      GetVIRReq_SensorSharingParams(packetHandle, value.sensorSharing, newPath);
      result = CheckLastError("VIR", gkFuncRefGet, result);
    }
    break;
    case 4:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "parking");
      GetVIRReq_ParkingAreaParams(packetHandle, value.parking, newPath);
      result = CheckLastError("VIR", gkFuncRefGet, result);
    }
    break;
  }
  return result;
}

