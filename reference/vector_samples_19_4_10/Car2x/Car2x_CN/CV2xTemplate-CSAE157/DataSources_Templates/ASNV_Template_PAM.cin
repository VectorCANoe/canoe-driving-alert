//
//  //This example demonstrates how to set a packet's payload:
//  LONG packetHandle;
//  struct PAM payload;
//  //you need to set the values of the variable "payload" yourself
//  packetHandle = API_InitPAMPacket();
//  if (packetHandle!=0) {
//    if (API_SetPAMParams(packetHandle, payload)==0) {
//      if (C2xCompletePacket(packetHandle)==0) {
//        C2xOutputPacket(packetHandle);
//      }
//    }
//  }
//                                                                             */
includes
{
}
variables
{
    struct PAMDescriptiveName {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        CHAR string[64];
        INT  stringLength;
    };
    
    struct PAMParkingLotInfo {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        struct OPT_WORD_ASN id;  // INTEGER, OPTIONAL, 0..65535;
        struct PAMDescriptiveName name;  // IA5STRING, OPTIONAL;
        struct OPT_WORD_ASN number;  // INTEGER, OPTIONAL, 0..65535;
        struct OPT_WORD_ASN buildingLayerNum;  // INTEGER, OPTIONAL, 0..256;
        struct OPT_ENUM_ASN avpType;  // ENUMERATED, OPTIONAL, p0(0), p1(1), p2(2), p3(3), p4(4), p5(5);
    };
    
    struct PAMPosition3D {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        LONG lat;  // INTEGER, -900000000..900000001;
        LONG lon;  // INTEGER, -1799999999..1800000001;
        struct OPT_LONG_ASN elevation;  // INTEGER, OPTIONAL, -4096..61439;
    };
    
    struct PAMPAMNodeAttributes {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        CHAR string[9];
        INT  stringLength;
    };
    
    struct PAMPosition_LL_24B {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        INT lon;  // INTEGER, -2048..2047;
        INT lat;  // INTEGER, -2048..2047;
    };
    
    struct PAMPosition_LL_28B {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        INT lon;  // INTEGER, -8192..8191;
        INT lat;  // INTEGER, -8192..8191;
    };
    
    struct PAMPosition_LL_32B {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        INT lon;  // INTEGER, -32768..32767;
        INT lat;  // INTEGER, -32768..32767;
    };
    
    struct PAMPosition_LL_36B {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        LONG lon;  // INTEGER, -131072..131071;
        LONG lat;  // INTEGER, -131072..131071;
    };
    
    struct PAMPosition_LL_44B {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        LONG lon;  // INTEGER, -2097152..2097151;
        LONG lat;  // INTEGER, -2097152..2097151;
    };
    
    struct PAMPosition_LL_48B {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        LONG lon;  // INTEGER, -8388608..8388607;
        LONG lat;  // INTEGER, -8388608..8388607;
    };
    
    struct PAMPosition_LLmD_64b {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        LONG lon;  // INTEGER, -1799999999..1800000001;
        LONG lat;  // INTEGER, -900000000..900000001;
    };
    
    struct PAMPositionOffsetLL {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        INT choice;
        struct PAMPosition_LL_24B position_LL1;  // SEQUENCE;
        struct PAMPosition_LL_28B position_LL2;  // SEQUENCE;
        struct PAMPosition_LL_32B position_LL3;  // SEQUENCE;
        struct PAMPosition_LL_36B position_LL4;  // SEQUENCE;
        struct PAMPosition_LL_44B position_LL5;  // SEQUENCE;
        struct PAMPosition_LL_48B position_LL6;  // SEQUENCE;
        struct PAMPosition_LLmD_64b position_LatLon;  // SEQUENCE;
    };
    
    struct PAMVerticalOffset {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        INT choice;
        INT offset1;  // INTEGER, -64..63;
        INT offset2;  // INTEGER, -128..127;
        INT offset3;  // INTEGER, -256..255;
        INT offset4;  // INTEGER, -512..511;
        INT offset5;  // INTEGER, -1024..1023;
        INT offset6;  // INTEGER, -2048..2047;
        LONG elevation;  // INTEGER, -4096..61439;
    };
    
    struct PAMPositionOffsetLLV {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        struct PAMPositionOffsetLL offsetLL;  // CHOICE;
        struct PAMVerticalOffset offsetV;  // CHOICE, OPTIONAL;
    };
    
    struct PAMRoadPoint {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        struct PAMPositionOffsetLLV posOffset;  // SEQUENCE;
    };
    
    struct PAMPointList {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        INT length;
        struct PAMRoadPoint arrayValue[31];  // SEQUENCE;
    };
    
    struct PAMPAMMovementList {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        INT length;
        WORD arrayValue[32];  // INTEGER, 0..65535;
    };
    
    struct PAMParkingSlotPosition {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        struct PAMPositionOffsetLLV topLeft;  // SEQUENCE;
        struct PAMPositionOffsetLLV topRight;  // SEQUENCE;
        struct PAMPositionOffsetLLV bottomLeft;  // SEQUENCE;
    };
    
    struct PAMParkingType {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        CHAR string[11];
        INT  stringLength;
    };
    
    struct PAMParkingSlot {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        WORD slotID;  // INTEGER, 0..65535;
        struct PAMParkingSlotPosition position;  // SEQUENCE, OPTIONAL;
        struct PAMDescriptiveName sign;  // IA5STRING, OPTIONAL;
        struct PAMParkingType parkingType;  // BITSTRING;
        INT status;  // ENUMERATED, unknown(0), available(1), occupied(2), reserved(3);
        INT parkingSpaceTheta;  // ENUMERATED, unknown(0), vertical(1), side(2), oblique(3);
        INT parkingLock;  // ENUMERATED, unknown(0), nolock(1), locked(2), unlocked(3);
    };
    
    struct PAMParkingSlots {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        INT length;
        struct PAMParkingSlot arrayValue[256];  // SEQUENCE;
    };
    
    struct PAMPAMDrive {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        WORD upstreamPAMNodeId;  // INTEGER, 0..65535;
        struct OPT_BYTE_ASN driveID;  // INTEGER, OPTIONAL, 0..255;
        struct OPT_BOOL_ASN twowaySepration;  // BOOLEAN, OPTIONAL;
        struct OPT_WORD_ASN speedLimit;  // INTEGER, OPTIONAL, 0..8191;
        struct OPT_BYTE_ASN heightRestriction;  // INTEGER, OPTIONAL, 0..100;
        struct OPT_WORD_ASN driveWidth;  // INTEGER, OPTIONAL, 0..32767;
        struct OPT_BYTE_ASN laneNum;  // INTEGER, OPTIONAL, 0..100;
        struct PAMPointList points;  // SEQUENCEOF, OPTIONAL;
        struct PAMPAMMovementList movements;  // SEQUENCEOF, OPTIONAL;
        struct PAMParkingSlots parkingSlots;  // SEQUENCEOF, OPTIONAL;
    };
    
    struct PAMPAMDriveList {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        INT length;
        struct PAMPAMDrive arrayValue[63];  // SEQUENCE;
    };
    
    struct PAMPAMNode {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        WORD id;  // INTEGER, 0..65535;
        struct PAMPosition3D refPos;  // SEQUENCE;
        struct OPT_INT_ASN floor;  // INTEGER, OPTIONAL, -128..128;
        struct PAMPAMNodeAttributes attributes;  // BITSTRING, OPTIONAL;
        struct PAMPAMDriveList inDrives;  // SEQUENCEOF, OPTIONAL;
    };
    
    struct PAMPAMNodeList {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        INT length;
        struct PAMPAMNode arrayValue[63];  // SEQUENCE;
    };
    
    struct PAMParkingGuide_vehId {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        CHAR string[9];
        INT  stringLength;
    };
    
    struct PAMParkingGuide_drivePath {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        INT length;
        WORD arrayValue[32];  // INTEGER, 0..65535;
    };
    
    struct PAMParkingGuide {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        struct PAMParkingGuide_vehId vehId;  // OCTETSTRING;
        struct PAMParkingGuide_drivePath drivePath;  // SEQUENCEOF;
        struct OPT_WORD_ASN targetParkingSlot;  // INTEGER, OPTIONAL, 0..65535;
    };
    
    struct PAMPAMData_parkingAreaGuidance {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        INT length;
        struct PAMParkingGuide arrayValue[16];  // SEQUENCE;
    };
    
    struct PAMPAM_PAMData {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        BYTE msgCnt;  // INTEGER, 0..127;
        struct OPT_DWORD_ASN timeStamp;  // INTEGER, OPTIONAL, 0..527040;
        struct PAMParkingLotInfo parkingLotInfo;  // SEQUENCE;
        struct PAMPAMNodeList pamNodes;  // SEQUENCEOF;
        struct PAMPAMData_parkingAreaGuidance parkingAreaGuidance;  // SEQUENCEOF, OPTIONAL;
    };
    
    struct PAMMessageTypes {
        struct PAMPAM_PAMData pamData;  // SEQUENCE;
    };
    
    struct PAMMessageFrameExt {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        WORD messageId;  // INTEGER, 0..32767;
        struct PAMMessageTypes value;  // TABLE;
    };
    
    struct PAM {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        INT choice;
        struct PAMMessageFrameExt msgFrameExt;  // SEQUENCE;
    };
    
}

/*
// init function to create a simple packet handle
*/ 
LONG API_InitPAMPacket()
{
  return C2xInitPacket("PAM"); 
}

/*
// init function to create a simple packet handle and
// initialize the struct with valid data
*/ 
LONG API_InitPAMPacket(struct PAM msgStruct)
{
  long pktHandle;

  pktHandle = API_InitPAMPacket();

  if (pktHandle != 0)
  {
    // create valid message and application data
    if (C2xCompletePacket(pktHandle) == 0) 
    {
      API_GetPAMParams(pktHandle, msgStruct);
    }
  }
  return pktHandle;
}

/*
// init function to create a packet with security layer and
// initialize the struct with valid data
*/ 
LONG API_InitPAMPacket(struct PAM msgStruct, char packetTypeDesignator[], char certificateName[])
{
  long pktHandle, certHdl;

  // initialize the packet
  pktHandle = C2xInitPacket("PAM", packetTypeDesignator);

  if (pktHandle != 0)
  {
    certHdl = C2xSecCertificateGetHandle(certificateName);  // get the certificate handle for the cert with name "certificateName"
    if (certHdl != 0) 
    {
      C2xSecPacketSetSignerHandle(pktHandle, certHdl); // set the certHdl to the packet
    }

    // create valid message and application data
    if (C2xCompletePacket(pktHandle) == 0) 
    {
      // copy application data to the application structure
      API_GetPAMParams(pktHandle, msgStruct);
    }
  }
  return pktHandle;
}
    

int GetPAMParkingLotInfoParams(LONG packetHandle, struct PAMParkingLotInfo value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "id");
  value.id.isValidFlag = C2xIsTokenAvailable(packetHandle, "PAM", newPath);
  if(value.id.isValidFlag==1)
  {
    value.id.value = C2xGetTokenInt(packetHandle, "PAM", newPath);
    result = CheckLastError("PAM", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "name");
  value.name.isValidFlag = C2xIsTokenAvailable(packetHandle, "PAM", newPath);
  if(value.name.isValidFlag==1)
  {
    value.name.stringLength = C2xGetTokenData(packetHandle, "PAM", newPath, elcount(value.name.string), value.name.string);
    result = CheckLastError("PAM", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "number");
  value.number.isValidFlag = C2xIsTokenAvailable(packetHandle, "PAM", newPath);
  if(value.number.isValidFlag==1)
  {
    value.number.value = C2xGetTokenInt(packetHandle, "PAM", newPath);
    result = CheckLastError("PAM", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "buildingLayerNum");
  value.buildingLayerNum.isValidFlag = C2xIsTokenAvailable(packetHandle, "PAM", newPath);
  if(value.buildingLayerNum.isValidFlag==1)
  {
    value.buildingLayerNum.value = C2xGetTokenInt(packetHandle, "PAM", newPath);
    result = CheckLastError("PAM", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "avpType");
  value.avpType.isValidFlag = C2xIsTokenAvailable(packetHandle, "PAM", newPath);
  if(value.avpType.isValidFlag==1)
  {
    value.avpType.value = C2xGetTokenInt(packetHandle, "PAM", newPath);
    result = CheckLastError("PAM", gkFuncRefGet, result);
  }
  return result;
}

int SetPAMParkingLotInfoParams(LONG packetHandle, struct PAMParkingLotInfo value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "id");
  if(value.id.isValidFlag==1)
  {
    C2xSetTokenInt(packetHandle, "PAM", newPath, value.id.value);
    result = CheckLastError("PAM", gkFuncRefGet, result);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "PAM", newPath) )
    {
      C2xRemoveToken(packetHandle, "PAM", newPath);
    }
  }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "name");
  if(value.name.isValidFlag==1)
  {
    C2xSetTokenData(packetHandle, "PAM", newPath, value.name.stringLength, value.name.string);
    result = CheckLastError("PAM", gkFuncRefGet, result);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "PAM", newPath) )
    {
      C2xRemoveToken(packetHandle, "PAM", newPath);
    }
  }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "number");
  if(value.number.isValidFlag==1)
  {
    C2xSetTokenInt(packetHandle, "PAM", newPath, value.number.value);
    result = CheckLastError("PAM", gkFuncRefGet, result);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "PAM", newPath) )
    {
      C2xRemoveToken(packetHandle, "PAM", newPath);
    }
  }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "buildingLayerNum");
  if(value.buildingLayerNum.isValidFlag==1)
  {
    C2xSetTokenInt(packetHandle, "PAM", newPath, value.buildingLayerNum.value);
    result = CheckLastError("PAM", gkFuncRefGet, result);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "PAM", newPath) )
    {
      C2xRemoveToken(packetHandle, "PAM", newPath);
    }
  }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "avpType");
  if(value.avpType.isValidFlag==1)
  {
    C2xSetTokenInt(packetHandle, "PAM", newPath, value.avpType.value);
    result = CheckLastError("PAM", gkFuncRefGet, result);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "PAM", newPath) )
    {
      C2xRemoveToken(packetHandle, "PAM", newPath);
    }
  }

  return result;
}

