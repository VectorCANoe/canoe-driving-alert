int GetPAMParkingSlotParams(LONG packetHandle, struct PAMParkingSlot value, char oldPath[])
{
  char newPath[300]; 
  int j; 
  int k;
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "slotID");
  value.slotID = C2xGetTokenInt(packetHandle, "PAM", newPath);
  result = CheckLastError("PAM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "position");
  value.position.isValidFlag = C2xIsTokenAvailable(packetHandle, "PAM", newPath);
  if(value.position.isValidFlag==1)
  {
    GetPAMParkingSlotPositionParams(packetHandle, value.position, newPath);
    result = CheckLastError("PAM", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "sign");
  value.sign.isValidFlag = C2xIsTokenAvailable(packetHandle, "PAM", newPath);
  if(value.sign.isValidFlag==1)
  {
    value.sign.stringLength = C2xGetTokenData(packetHandle, "PAM", newPath, elcount(value.sign.string), value.sign.string);
    result = CheckLastError("PAM", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "parkingType");
  value.parkingType.isValidFlag = 1;
  value.parkingType.stringLength = C2xGetTokenLengthBit(packetHandle, "PAM", newPath);
  if ((result = CheckLastError("PAM", gkFuncRefGet, result))==0)
  {
    if(value.parkingType.stringLength > 0)
    {
      for(j=0; j<value.parkingType.stringLength; j++)
      {
        if(C2xGetTokenBitOfBitString(packetHandle, "PAM", newPath, j) == 0)
        {
          value.parkingType.string[j] = '0';
        }
        else if(C2xGetTokenBitOfBitString(packetHandle, "PAM", newPath, j) == 1)
        {
          value.parkingType.string[j] = '1';
        }

        if(value.parkingType.stringLength == 1)
        {
          value.parkingType.string[1] = '0';
        }
        result = CheckLastError("PAM", gkFuncRefGet, result);
      }
    }
    else
    {
      for(k = value.parkingType.stringLength+1; k > -1; k--)
      {
        if(value.parkingType.string[k] == '1')
        {
          value.parkingType.string[k] = '0';
        }
      }
    }
  }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "status");
  value.status = C2xGetTokenInt(packetHandle, "PAM", newPath);
  result = CheckLastError("PAM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "parkingSpaceTheta");
  value.parkingSpaceTheta = C2xGetTokenInt(packetHandle, "PAM", newPath);
  result = CheckLastError("PAM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "parkingLock");
  value.parkingLock = C2xGetTokenInt(packetHandle, "PAM", newPath);
  result = CheckLastError("PAM", gkFuncRefGet, result);

  return result;
}

int SetPAMParkingSlotParams(LONG packetHandle, struct PAMParkingSlot value, char oldPath[])
{
  char newPath[300]; 
  int j;
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "slotID");
  C2xSetTokenInt(packetHandle, "PAM", newPath, value.slotID);
  result = CheckLastError("PAM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "position");
  if(value.position.isValidFlag==1)
  {
    SetPAMParkingSlotPositionParams(packetHandle, value.position, newPath);
    result = CheckLastError("PAM", gkFuncRefGet, result);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "PAM", newPath) )
    {
      C2xRemoveToken(packetHandle, "PAM", newPath);
    }
  }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "sign");
  if(value.sign.isValidFlag==1)
  {
    C2xSetTokenData(packetHandle, "PAM", newPath, value.sign.stringLength, value.sign.string);
    result = CheckLastError("PAM", gkFuncRefGet, result);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "PAM", newPath) )
    {
      C2xRemoveToken(packetHandle, "PAM", newPath);
    }
  }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "parkingType");
    for(j=0; j<value.parkingType.stringLength; j++)
    {
      if(value.parkingType.string[j] == '0')
      {
        C2xSetTokenBitOfBitString(packetHandle, "PAM", newPath, j, 0);
      }
      else
      {
        C2xSetTokenBitOfBitString(packetHandle, "PAM", newPath, j, 1);
      }
      result = CheckLastError("PAM", gkFuncRefGet, result);
    }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "status");
  C2xSetTokenInt(packetHandle, "PAM", newPath, value.status);
  result = CheckLastError("PAM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "parkingSpaceTheta");
  C2xSetTokenInt(packetHandle, "PAM", newPath, value.parkingSpaceTheta);
  result = CheckLastError("PAM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "parkingLock");
  C2xSetTokenInt(packetHandle, "PAM", newPath, value.parkingLock);
  result = CheckLastError("PAM", gkFuncRefGet, result);

  return result;
}

