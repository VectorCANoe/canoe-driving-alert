  SetPAMPAMNodeListParams(packetHandle, value.pamNodes, newPath);
  result = CheckLastError("PAM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "parkingAreaGuidance");
  if(value.parkingAreaGuidance.isValidFlag==1)
  {
    SetPAMPAMData_parkingAreaGuidanceParams(packetHandle, value.parkingAreaGuidance, newPath);
    result = CheckLastError("PAM", gkFuncRefGet, result);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "PAM", newPath) )
    {
      C2xRemoveToken(packetHandle, "PAM", newPath);
    }
  }

  return result;
}

int GetPAMMessageTypesParams(LONG packetHandle, WORD tableKey, struct PAMMessageTypes value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  switch(tableKey)
  {
    case 14:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "pamData");
      GetPAMPAM_PAMDataParams(packetHandle, value.pamData, newPath);
      result = CheckLastError("PAM", gkFuncRefGet, result);
    }
    break;
  }
  return result;
}

int SetPAMMessageTypesParams(LONG packetHandle, WORD tableKey, struct PAMMessageTypes value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  switch(tableKey)
  {
    case 14:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "pamData");
      SetPAMPAM_PAMDataParams(packetHandle, value.pamData, newPath);
      result = CheckLastError("PAM", gkFuncRefGet, result);
    }
    break;
  }
  return result;
}

int GetPAMMessageFrameExtParams(LONG packetHandle, struct PAMMessageFrameExt value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "messageId");
  value.messageId = C2xGetTokenInt(packetHandle, "PAM", newPath);
  result = CheckLastError("PAM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "value");
  GetPAMMessageTypesParams(packetHandle, value.messageId, value.value, newPath);
  result = CheckLastError("PAM", gkFuncRefGet, result);

  return result;
}

int SetPAMMessageFrameExtParams(LONG packetHandle, struct PAMMessageFrameExt value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;


  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "value");
  SetPAMMessageTypesParams(packetHandle, value.messageId, value.value, newPath);
  result = CheckLastError("PAM", gkFuncRefGet, result);

  return result;
}

int API_GetPAMParams(LONG packetHandle, struct PAM value)
{
  int result;
  result = 0;

  value.msgFrameExt.isValidFlag = 1;
  GetPAMMessageFrameExtParams(packetHandle, value.msgFrameExt, "msgFrameExt");
  result = CheckLastError("PAM", gkFuncRefGet, result);

  return result;
}

int API_SetPAMParams(LONG packetHandle, struct PAM value)
{
  int result;
  result = 0;

  SetPAMMessageFrameExtParams(packetHandle, value.msgFrameExt, "msgFrameExt");
  result = CheckLastError("PAM", gkFuncRefGet, result);

  return result;
}

