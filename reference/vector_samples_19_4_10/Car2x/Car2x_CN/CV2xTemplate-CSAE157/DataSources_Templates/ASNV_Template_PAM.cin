  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "lat");
  C2xSetTokenInt(packetHandle, "PAM", newPath, value.lat);
  result = CheckLastError("PAM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "lon");
  C2xSetTokenInt(packetHandle, "PAM", newPath, value.lon);
  result = CheckLastError("PAM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "elevation");
  if(value.elevation.isValidFlag==1)
  {
    C2xSetTokenInt(packetHandle, "PAM", newPath, value.elevation.value);
    result = CheckLastError("PAM", gkFuncRefGet, result);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "PAM", newPath) )
    {
      C2xRemoveToken(packetHandle, "PAM", newPath);
    }
  }

  return result;
}

