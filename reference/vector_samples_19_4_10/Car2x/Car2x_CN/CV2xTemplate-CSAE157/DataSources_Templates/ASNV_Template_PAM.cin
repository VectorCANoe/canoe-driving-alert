int GetPAMPAMNodeParams(LONG packetHandle, struct PAMPAMNode value, char oldPath[])
{
  char newPath[300]; 
  int j; 
  int k;
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "id");
  value.id = C2xGetTokenInt(packetHandle, "PAM", newPath);
  result = CheckLastError("PAM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "refPos");
  GetPAMPosition3DParams(packetHandle, value.refPos, newPath);
  result = CheckLastError("PAM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "floor");
  value.floor.isValidFlag = C2xIsTokenAvailable(packetHandle, "PAM", newPath);
  if(value.floor.isValidFlag==1)
  {
    value.floor.value = C2xGetTokenInt(packetHandle, "PAM", newPath);
    result = CheckLastError("PAM", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "attributes");
  value.attributes.isValidFlag = C2xIsTokenAvailable(packetHandle, "PAM", newPath);
  if(value.attributes.isValidFlag==1)
  {
    value.attributes.isValidFlag = 1;
    value.attributes.stringLength = C2xGetTokenLengthBit(packetHandle, "PAM", newPath);
    if ((result = CheckLastError("PAM", gkFuncRefGet, result))==0)
    {
      if(value.attributes.stringLength > 0)
      {
        for(j=0; j<value.attributes.stringLength; j++)
        {
          if(C2xGetTokenBitOfBitString(packetHandle, "PAM", newPath, j) == 0)
          {
            value.attributes.string[j] = '0';
          }
          else if(C2xGetTokenBitOfBitString(packetHandle, "PAM", newPath, j) == 1)
          {
            value.attributes.string[j] = '1';
          }

          if(value.attributes.stringLength == 1)
          {
            value.attributes.string[1] = '0';
          }
          result = CheckLastError("PAM", gkFuncRefGet, result);
        }
      }
      else
      {
        for(k = value.attributes.stringLength+1; k > -1; k--)
        {
          if(value.attributes.string[k] == '1')
          {
            value.attributes.string[k] = '0';
          }
        }
      }
    }

  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "inDrives");
  value.inDrives.isValidFlag = C2xIsTokenAvailable(packetHandle, "PAM", newPath);
  if(value.inDrives.isValidFlag==1)
  {
    GetPAMPAMDriveListParams(packetHandle, value.inDrives, newPath);
    result = CheckLastError("PAM", gkFuncRefGet, result);
  }
  return result;
}

int SetPAMPAMNodeParams(LONG packetHandle, struct PAMPAMNode value, char oldPath[])
{
  char newPath[300]; 
  int j;
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "id");
  C2xSetTokenInt(packetHandle, "PAM", newPath, value.id);
  result = CheckLastError("PAM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "refPos");
  SetPAMPosition3DParams(packetHandle, value.refPos, newPath);
  result = CheckLastError("PAM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "floor");
  if(value.floor.isValidFlag==1)
  {
    C2xSetTokenInt(packetHandle, "PAM", newPath, value.floor.value);
    result = CheckLastError("PAM", gkFuncRefGet, result);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "PAM", newPath) )
    {
      C2xRemoveToken(packetHandle, "PAM", newPath);
    }
  }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "attributes");
  if(value.attributes.isValidFlag==1)
  {
      for(j=0; j<value.attributes.stringLength; j++)
      {
        if(value.attributes.string[j] == '0')
        {
          C2xSetTokenBitOfBitString(packetHandle, "PAM", newPath, j, 0);
        }
        else
        {
          C2xSetTokenBitOfBitString(packetHandle, "PAM", newPath, j, 1);
        }
        result = CheckLastError("PAM", gkFuncRefGet, result);
      }
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "PAM", newPath) )
    {
      C2xRemoveToken(packetHandle, "PAM", newPath);
    }
  }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "inDrives");
  if(value.inDrives.isValidFlag==1)
  {
    SetPAMPAMDriveListParams(packetHandle, value.inDrives, newPath);
    result = CheckLastError("PAM", gkFuncRefGet, result);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "PAM", newPath) )
    {
      C2xRemoveToken(packetHandle, "PAM", newPath);
    }
  }

  return result;
}

