int GetRoadSideInformationAuxiliarySignParams(LONG packetHandle, struct RoadSideInformationAuxiliarySign value, char oldPath[])
{
  char newPath[300]; 
  int j; 
  int k;
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "signWithVehicleType");
  value.signWithVehicleType.isValidFlag = C2xIsTokenAvailable(packetHandle, "RoadSideInformation", newPath);
  if(value.signWithVehicleType.isValidFlag==1)
  {
    value.signWithVehicleType.isValidFlag = 1;
    value.signWithVehicleType.stringLength = C2xGetTokenLengthBit(packetHandle, "RoadSideInformation", newPath);
    if ((result = CheckLastError("RoadSideInformation", gkFuncRefGet, result))==0)
    {
      if(value.signWithVehicleType.stringLength > 0)
      {
        for(j=0; j<value.signWithVehicleType.stringLength; j++)
        {
          if(C2xGetTokenBitOfBitString(packetHandle, "RoadSideInformation", newPath, j) == 0)
          {
            value.signWithVehicleType.string[j] = '0';
          }
          else if(C2xGetTokenBitOfBitString(packetHandle, "RoadSideInformation", newPath, j) == 1)
          {
            value.signWithVehicleType.string[j] = '1';
          }

          if(value.signWithVehicleType.stringLength == 1)
          {
            value.signWithVehicleType.string[1] = '0';
          }
          result = CheckLastError("RoadSideInformation", gkFuncRefGet, result);
        }
      }
      else
      {
        for(k = value.signWithVehicleType.stringLength+1; k > -1; k--)
        {
          if(value.signWithVehicleType.string[k] == '1')
          {
            value.signWithVehicleType.string[k] = '0';
          }
        }
      }
    }

  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "signDirection");
  value.signDirection.isValidFlag = C2xIsTokenAvailable(packetHandle, "RoadSideInformation", newPath);
  if(value.signDirection.isValidFlag==1)
  {
    value.signDirection.value = C2xGetTokenInt(packetHandle, "RoadSideInformation", newPath);
    result = CheckLastError("RoadSideInformation", gkFuncRefGet, result);
  }
  return result;
}

int SetRoadSideInformationAuxiliarySignParams(LONG packetHandle, struct RoadSideInformationAuxiliarySign value, char oldPath[])
{
  char newPath[300]; 
  int j;
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "signWithVehicleType");
  if(value.signWithVehicleType.isValidFlag==1)
  {
      for(j=0; j<value.signWithVehicleType.stringLength; j++)
      {
        if(value.signWithVehicleType.string[j] == '0')
        {
          C2xSetTokenBitOfBitString(packetHandle, "RoadSideInformation", newPath, j, 0);
        }
        else
        {
          C2xSetTokenBitOfBitString(packetHandle, "RoadSideInformation", newPath, j, 1);
        }
        result = CheckLastError("RoadSideInformation", gkFuncRefGet, result);
      }
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "RoadSideInformation", newPath) )
    {
      C2xRemoveToken(packetHandle, "RoadSideInformation", newPath);
    }
  }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "signDirection");
  if(value.signDirection.isValidFlag==1)
  {
    C2xSetTokenInt(packetHandle, "RoadSideInformation", newPath, value.signDirection.value);
    result = CheckLastError("RoadSideInformation", gkFuncRefGet, result);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "RoadSideInformation", newPath) )
    {
      C2xRemoveToken(packetHandle, "RoadSideInformation", newPath);
    }
  }

  return result;
}

