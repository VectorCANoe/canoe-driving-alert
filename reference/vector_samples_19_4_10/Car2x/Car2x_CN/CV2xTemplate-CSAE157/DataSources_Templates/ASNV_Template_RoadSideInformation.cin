int GetRoadSideInformationPositionOffsetLLParams(LONG packetHandle, struct RoadSideInformationPositionOffsetLL value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  value.choice = C2xGetTokenInt(packetHandle, "RoadSideInformation", oldPath);

  switch(value.choice)
  {
    case 0:
    {
