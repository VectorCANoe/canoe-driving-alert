int API_GetPSMParams(LONG packetHandle, struct PSM value)
{
  int result;
  result = 0;

  value.msgFrameExt.isValidFlag = 1;
  GetPSMMessageFrameExtParams(packetHandle, value.msgFrameExt, "msgFrameExt");
  result = CheckLastError("PSM", gkFuncRefGet, result);

  return result;
}

int API_SetPSMParams(LONG packetHandle, struct PSM value)
{
