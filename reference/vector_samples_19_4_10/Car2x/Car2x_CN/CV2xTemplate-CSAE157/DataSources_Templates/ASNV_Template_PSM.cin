int SetPSMPersonalSafetyMessageParams(LONG packetHandle, struct PSMPersonalSafetyMessage value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "msgCnt");
  C2xSetTokenInt(packetHandle, "PSM", newPath, value.msgCnt);
  result = CheckLastError("PSM", gkFuncRefGet, result);

