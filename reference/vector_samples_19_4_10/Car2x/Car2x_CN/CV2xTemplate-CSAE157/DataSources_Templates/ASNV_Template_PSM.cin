  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "semiMinor");
  C2xSetTokenInt(packetHandle, "PSM", newPath, value.semiMinor);
  result = CheckLastError("PSM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "orientation");
  C2xSetTokenInt(packetHandle, "PSM", newPath, value.orientation);
  result = CheckLastError("PSM", gkFuncRefGet, result);

  return result;
