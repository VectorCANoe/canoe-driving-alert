  result = CheckLastError("PSM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "accelSet");
  if(value.accelSet.isValidFlag==1)
  {
    SetPSMAccelerationSet4WayParams(packetHandle, value.accelSet, newPath);
    result = CheckLastError("PSM", gkFuncRefGet, result);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "PSM", newPath) )
    {
      C2xRemoveToken(packetHandle, "PSM", newPath);
    }
  }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "pathHistory");
  if(value.pathHistory.isValidFlag==1)
  {
    SetPSMPathHistoryParams(packetHandle, value.pathHistory, newPath);
    result = CheckLastError("PSM", gkFuncRefGet, result);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "PSM", newPath) )
    {
      C2xRemoveToken(packetHandle, "PSM", newPath);
    }
  }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "path_Planning");
  if(value.path_Planning.isValidFlag==1)
  {
    SetPSMPathPlanningParams(packetHandle, value.path_Planning, newPath);
    result = CheckLastError("PSM", gkFuncRefGet, result);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "PSM", newPath) )
    {
      C2xRemoveToken(packetHandle, "PSM", newPath);
    }
  }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "overallRadius");
  C2xSetTokenInt(packetHandle, "PSM", newPath, value.overallRadius);
  result = CheckLastError("PSM", gkFuncRefGet, result);

