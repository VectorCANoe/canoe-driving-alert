int GetPSMMessageTypesParams(LONG packetHandle, WORD tableKey, struct PSMMessageTypes value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  switch(tableKey)
  {
    case 15:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "psmData");
      GetPSMPersonalSafetyMessageParams(packetHandle, value.psmData, newPath);
      result = CheckLastError("PSM", gkFuncRefGet, result);
    }
    break;
  }
  return result;
}

