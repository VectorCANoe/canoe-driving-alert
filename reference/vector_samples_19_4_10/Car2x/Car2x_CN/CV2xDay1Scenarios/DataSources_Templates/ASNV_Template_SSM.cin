int GetSSMPositionOffsetLLParams(LONG packetHandle, struct SSMPositionOffsetLL value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  value.choice = C2xGetTokenInt(packetHandle, "SSM", oldPath);

  switch(value.choice)
  {
    case 0:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "position_LL1");
      GetSSMPosition_LL_24BParams(packetHandle, value.position_LL1, newPath);
      result = CheckLastError("SSM", gkFuncRefGet, result);
    }
    break;
    case 1:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "position_LL2");
      GetSSMPosition_LL_28BParams(packetHandle, value.position_LL2, newPath);
      result = CheckLastError("SSM", gkFuncRefGet, result);
    }
    break;
    case 2:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "position_LL3");
      GetSSMPosition_LL_32BParams(packetHandle, value.position_LL3, newPath);
      result = CheckLastError("SSM", gkFuncRefGet, result);
    }
    break;
    case 3:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "position_LL4");
      GetSSMPosition_LL_36BParams(packetHandle, value.position_LL4, newPath);
      result = CheckLastError("SSM", gkFuncRefGet, result);
    }
    break;
    case 4:
    {
