int GetSSMDescriptionParams(LONG packetHandle, struct SSMDescription value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  value.choice = C2xGetTokenInt(packetHandle, "SSM", oldPath);

  switch(value.choice)
  {
    case 0:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "textString");
      value.textString.stringLength = C2xGetTokenData(packetHandle, "SSM", newPath, elcount(value.textString.string), value.textString.string);
      result = CheckLastError("SSM", gkFuncRefGet, result);
    }
    break;
    case 1:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "textGB2312");
      value.textGB2312.stringLength = C2xGetTokenData(packetHandle, "SSM", newPath, elcount(value.textGB2312.string), value.textGB2312.string);
      result = CheckLastError("SSM", gkFuncRefGet, result);
    }
    break;
  }
  return result;
}

