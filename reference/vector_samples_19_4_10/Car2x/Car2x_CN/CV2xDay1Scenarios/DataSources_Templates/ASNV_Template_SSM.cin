    }
  }

  return result;
}

int GetSSMPathHistoryPointListParams(LONG packetHandle, struct SSMPathHistoryPointList value, char oldPath[])
{
  char newPath[300]; 
  int i;
  int result;

  result = 0;

  value.length = C2xGetTokenInt(packetHandle, "SSM", oldPath);
  if((result = CheckLastError("SSM", gkFuncRefGet, result))==0)
  {
    for(i=0; i<value.length; i++)
    {
      snprintf(newPath, elcount(newPath), "%s[%d]", oldPath, i);
      GetSSMPathHistoryPointParams(packetHandle, value.arrayValue[i], newPath);
      result = CheckLastError("SSM", gkFuncRefGet, result);
    }
  }
  return result;
}

int SetSSMPathHistoryPointListParams(LONG packetHandle, struct SSMPathHistoryPointList value, char oldPath[])
{
  char newPath[300]; 
  int i;
  int result;

  result = 0;

  C2xRemoveToken(packetHandle, "SSM", oldPath);
  for(i=0; i<value.length; i++)
  {
    snprintf(newPath, elcount(newPath), "%s[%d]", oldPath, i);
    SetSSMPathHistoryPointParams(packetHandle, value.arrayValue[i], newPath);
    result = CheckLastError("SSM", gkFuncRefGet, result);
  }
  return result;
}

int GetSSMPathHistoryParams(LONG packetHandle, struct SSMPathHistory value, char oldPath[])
{
  char newPath[300]; 
  int j; 
  int k;
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "initialPosition");
  value.initialPosition.isValidFlag = C2xIsTokenAvailable(packetHandle, "SSM", newPath);
  if(value.initialPosition.isValidFlag==1)
  {
    GetSSMFullPositionVectorParams(packetHandle, value.initialPosition, newPath);
    result = CheckLastError("SSM", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "currGNSSstatus");
  value.currGNSSstatus.isValidFlag = C2xIsTokenAvailable(packetHandle, "SSM", newPath);
  if(value.currGNSSstatus.isValidFlag==1)
  {
    value.currGNSSstatus.isValidFlag = 1;
    value.currGNSSstatus.stringLength = C2xGetTokenLengthBit(packetHandle, "SSM", newPath);
    if ((result = CheckLastError("SSM", gkFuncRefGet, result))==0)
    {
      if(value.currGNSSstatus.stringLength > 0)
      {
        for(j=0; j<value.currGNSSstatus.stringLength; j++)
        {
          if(C2xGetTokenBitOfBitString(packetHandle, "SSM", newPath, j) == 0)
          {
            value.currGNSSstatus.string[j] = '0';
          }
          else if(C2xGetTokenBitOfBitString(packetHandle, "SSM", newPath, j) == 1)
          {
            value.currGNSSstatus.string[j] = '1';
          }

          if(value.currGNSSstatus.stringLength == 1)
          {
            value.currGNSSstatus.string[1] = '0';
          }
          result = CheckLastError("SSM", gkFuncRefGet, result);
        }
      }
      else
      {
        for(k = value.currGNSSstatus.stringLength+1; k > -1; k--)
        {
          if(value.currGNSSstatus.string[k] == '1')
          {
            value.currGNSSstatus.string[k] = '0';
          }
        }
      }
    }

  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "crumbData");
  GetSSMPathHistoryPointListParams(packetHandle, value.crumbData, newPath);
  result = CheckLastError("SSM", gkFuncRefGet, result);

  return result;
}

int SetSSMPathHistoryParams(LONG packetHandle, struct SSMPathHistory value, char oldPath[])
{
  char newPath[300]; 
  int j;
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "initialPosition");
  if(value.initialPosition.isValidFlag==1)
  {
    SetSSMFullPositionVectorParams(packetHandle, value.initialPosition, newPath);
    result = CheckLastError("SSM", gkFuncRefGet, result);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "SSM", newPath) )
    {
      C2xRemoveToken(packetHandle, "SSM", newPath);
    }
  }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "currGNSSstatus");
  if(value.currGNSSstatus.isValidFlag==1)
  {
      for(j=0; j<value.currGNSSstatus.stringLength; j++)
      {
        if(value.currGNSSstatus.string[j] == '0')
        {
          C2xSetTokenBitOfBitString(packetHandle, "SSM", newPath, j, 0);
        }
        else
        {
          C2xSetTokenBitOfBitString(packetHandle, "SSM", newPath, j, 1);
        }
        result = CheckLastError("SSM", gkFuncRefGet, result);
      }
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "SSM", newPath) )
    {
      C2xRemoveToken(packetHandle, "SSM", newPath);
    }
  }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "crumbData");
  SetSSMPathHistoryPointListParams(packetHandle, value.crumbData, newPath);
  result = CheckLastError("SSM", gkFuncRefGet, result);

  return result;
}

