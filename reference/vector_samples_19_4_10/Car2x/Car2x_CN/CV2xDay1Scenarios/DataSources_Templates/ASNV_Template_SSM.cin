int GetSSMPlanningParams(LONG packetHandle, struct SSMPlanning value, char oldPath[])
{
  char newPath[300]; 
  int j; 
  int k;
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "duration");
  value.duration.isValidFlag = C2xIsTokenAvailable(packetHandle, "SSM", newPath);
  if(value.duration.isValidFlag==1)
  {
    value.duration.value = C2xGetTokenInt(packetHandle, "SSM", newPath);
    result = CheckLastError("SSM", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "planConfidence");
  value.planConfidence.isValidFlag = C2xIsTokenAvailable(packetHandle, "SSM", newPath);
  if(value.planConfidence.isValidFlag==1)
  {
    value.planConfidence.value = C2xGetTokenInt(packetHandle, "SSM", newPath);
    result = CheckLastError("SSM", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "drivingBehavior");
  value.drivingBehavior.isValidFlag = C2xIsTokenAvailable(packetHandle, "SSM", newPath);
  if(value.drivingBehavior.isValidFlag==1)
  {
    value.drivingBehavior.isValidFlag = 1;
    value.drivingBehavior.stringLength = C2xGetTokenLengthBit(packetHandle, "SSM", newPath);
    if ((result = CheckLastError("SSM", gkFuncRefGet, result))==0)
    {
      if(value.drivingBehavior.stringLength > 0)
      {
        for(j=0; j<value.drivingBehavior.stringLength; j++)
        {
          if(C2xGetTokenBitOfBitString(packetHandle, "SSM", newPath, j) == 0)
          {
            value.drivingBehavior.string[j] = '0';
          }
          else if(C2xGetTokenBitOfBitString(packetHandle, "SSM", newPath, j) == 1)
          {
            value.drivingBehavior.string[j] = '1';
          }

          if(value.drivingBehavior.stringLength == 1)
          {
            value.drivingBehavior.string[1] = '0';
          }
          result = CheckLastError("SSM", gkFuncRefGet, result);
        }
      }
      else
      {
        for(k = value.drivingBehavior.stringLength+1; k > -1; k--)
        {
          if(value.drivingBehavior.string[k] == '1')
          {
            value.drivingBehavior.string[k] = '0';
          }
        }
      }
    }

  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "pathPlanning");
  value.pathPlanning.isValidFlag = C2xIsTokenAvailable(packetHandle, "SSM", newPath);
  if(value.pathPlanning.isValidFlag==1)
  {
    GetSSMPathPlanningParams(packetHandle, value.pathPlanning, newPath);
    result = CheckLastError("SSM", gkFuncRefGet, result);
  }
  return result;
}

