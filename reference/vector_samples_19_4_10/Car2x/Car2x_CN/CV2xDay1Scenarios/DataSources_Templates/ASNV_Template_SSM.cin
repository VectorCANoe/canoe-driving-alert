int GetSSMPolygonParams(LONG packetHandle, struct SSMPolygon value, char oldPath[])
{
  char newPath[300]; 
  int i;
  int result;

  result = 0;

  value.length = C2xGetTokenInt(packetHandle, "SSM", oldPath);
  if((result = CheckLastError("SSM", gkFuncRefGet, result))==0)
  {
    for(i=0; i<value.length; i++)
    {
      snprintf(newPath, elcount(newPath), "%s[%d]", oldPath, i);
      GetSSMPositionOffsetLLVParams(packetHandle, value.arrayValue[i], newPath);
      result = CheckLastError("SSM", gkFuncRefGet, result);
    }
  }
  return result;
}

