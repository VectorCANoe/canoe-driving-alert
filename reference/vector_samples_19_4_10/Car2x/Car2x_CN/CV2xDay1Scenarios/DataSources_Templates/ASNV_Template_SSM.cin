int GetSSMDetectedPTCData_type_relatedExtParams(LONG packetHandle, struct SSMDetectedPTCData_type_relatedExt value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  value.choice = C2xGetTokenInt(packetHandle, "SSM", oldPath);

  switch(value.choice)
  {
    case 0:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "motorExt");
      GetSSMMotorDataExtensionParams(packetHandle, value.motorExt, newPath);
      result = CheckLastError("SSM", gkFuncRefGet, result);
    }
    break;
    case 1:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "non_motorExt");
      GetSSMNon_motorDataExtensionParams(packetHandle, value.non_motorExt, newPath);
      result = CheckLastError("SSM", gkFuncRefGet, result);
    }
    break;
  }
  return result;
}

