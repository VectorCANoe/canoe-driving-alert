      C2xRemoveToken(packetHandle, "SSM", newPath);
    }
  }

  return result;
}

int GetSSMMessageTypesParams(LONG packetHandle, WORD tableKey, struct SSMMessageTypes value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  switch(tableKey)
  {
    case 12:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "ssmData");
      GetSSMSensorSharing_SensorSharingMsgParams(packetHandle, value.ssmData, newPath);
      result = CheckLastError("SSM", gkFuncRefGet, result);
    }
    break;
  }
  return result;
}

