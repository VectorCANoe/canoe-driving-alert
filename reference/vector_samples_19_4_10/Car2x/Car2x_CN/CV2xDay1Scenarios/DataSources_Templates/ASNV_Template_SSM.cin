int GetSSMPersonalExtensionsParams(LONG packetHandle, struct SSMPersonalExtensions value, char oldPath[])
{
  char newPath[300]; 
  int j; 
  int k;
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "useState");
  value.useState.isValidFlag = C2xIsTokenAvailable(packetHandle, "SSM", newPath);
  if(value.useState.isValidFlag==1)
  {
    value.useState.isValidFlag = 1;
    value.useState.stringLength = C2xGetTokenLengthBit(packetHandle, "SSM", newPath);
    if ((result = CheckLastError("SSM", gkFuncRefGet, result))==0)
    {
      if(value.useState.stringLength > 0)
      {
        for(j=0; j<value.useState.stringLength; j++)
        {
          if(C2xGetTokenBitOfBitString(packetHandle, "SSM", newPath, j) == 0)
          {
            value.useState.string[j] = '0';
          }
          else if(C2xGetTokenBitOfBitString(packetHandle, "SSM", newPath, j) == 1)
          {
            value.useState.string[j] = '1';
          }

          if(value.useState.stringLength == 1)
          {
            value.useState.string[1] = '0';
          }
          result = CheckLastError("SSM", gkFuncRefGet, result);
        }
      }
      else
      {
        for(k = value.useState.stringLength+1; k > -1; k--)
        {
          if(value.useState.string[k] == '1')
          {
            value.useState.string[k] = '0';
          }
        }
      }
    }

  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "assistType");
  value.assistType.isValidFlag = C2xIsTokenAvailable(packetHandle, "SSM", newPath);
  if(value.assistType.isValidFlag==1)
  {
    value.assistType.isValidFlag = 1;
    value.assistType.stringLength = C2xGetTokenLengthBit(packetHandle, "SSM", newPath);
    if ((result = CheckLastError("SSM", gkFuncRefGet, result))==0)
    {
      if(value.assistType.stringLength > 0)
      {
        for(j=0; j<value.assistType.stringLength; j++)
        {
          if(C2xGetTokenBitOfBitString(packetHandle, "SSM", newPath, j) == 0)
          {
            value.assistType.string[j] = '0';
          }
          else if(C2xGetTokenBitOfBitString(packetHandle, "SSM", newPath, j) == 1)
          {
            value.assistType.string[j] = '1';
          }

          if(value.assistType.stringLength == 1)
          {
            value.assistType.string[1] = '0';
          }
          result = CheckLastError("SSM", gkFuncRefGet, result);
        }
      }
      else
      {
        for(k = value.assistType.stringLength+1; k > -1; k--)
        {
          if(value.assistType.string[k] == '1')
          {
            value.assistType.string[k] = '0';
          }
        }
      }
    }

  }
  return result;
}

int SetSSMPersonalExtensionsParams(LONG packetHandle, struct SSMPersonalExtensions value, char oldPath[])
{
  char newPath[300]; 
  int j;
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "useState");
  if(value.useState.isValidFlag==1)
  {
      for(j=0; j<value.useState.stringLength; j++)
      {
        if(value.useState.string[j] == '0')
        {
          C2xSetTokenBitOfBitString(packetHandle, "SSM", newPath, j, 0);
        }
        else
        {
          C2xSetTokenBitOfBitString(packetHandle, "SSM", newPath, j, 1);
        }
        result = CheckLastError("SSM", gkFuncRefGet, result);
      }
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "SSM", newPath) )
    {
      C2xRemoveToken(packetHandle, "SSM", newPath);
    }
  }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "assistType");
  if(value.assistType.isValidFlag==1)
  {
      for(j=0; j<value.assistType.stringLength; j++)
      {
        if(value.assistType.string[j] == '0')
        {
          C2xSetTokenBitOfBitString(packetHandle, "SSM", newPath, j, 0);
        }
        else
        {
          C2xSetTokenBitOfBitString(packetHandle, "SSM", newPath, j, 1);
        }
        result = CheckLastError("SSM", gkFuncRefGet, result);
      }
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "SSM", newPath) )
    {
      C2xRemoveToken(packetHandle, "SSM", newPath);
    }
  }

  return result;
}

