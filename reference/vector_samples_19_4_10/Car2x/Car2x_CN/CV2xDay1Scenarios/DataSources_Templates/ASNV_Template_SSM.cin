  else
  {
    if( C2xIsTokenAvailable(packetHandle, "SSM", newPath) )
    {
      C2xRemoveToken(packetHandle, "SSM", newPath);
    }
  }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "obstacles");
  if(value.obstacles.isValidFlag==1)
  {
    SetSSMDetectedObstacleListParams(packetHandle, value.obstacles, newPath);
    result = CheckLastError("SSM", gkFuncRefGet, result);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "SSM", newPath) )
    {
      C2xRemoveToken(packetHandle, "SSM", newPath);
    }
  }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "rtes");
  if(value.rtes.isValidFlag==1)
  {
    SetSSMRTEListParams(packetHandle, value.rtes, newPath);
