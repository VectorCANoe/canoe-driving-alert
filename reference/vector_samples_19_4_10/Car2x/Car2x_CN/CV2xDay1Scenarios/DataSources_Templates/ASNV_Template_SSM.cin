int GetSSMRTEDataParams(LONG packetHandle, struct SSMRTEData value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "rteId");
  value.rteId = C2xGetTokenInt(packetHandle, "SSM", newPath);
  result = CheckLastError("SSM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "eventType");
  value.eventType = C2xGetTokenInt(packetHandle, "SSM", newPath);
  result = CheckLastError("SSM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "eventSource");
  value.eventSource = C2xGetTokenInt(packetHandle, "SSM", newPath);
  result = CheckLastError("SSM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "eventPos");
  value.eventPos.isValidFlag = C2xIsTokenAvailable(packetHandle, "SSM", newPath);
  if(value.eventPos.isValidFlag==1)
  {
    GetSSMPositionOffsetLLVParams(packetHandle, value.eventPos, newPath);
    result = CheckLastError("SSM", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "eventRadius");
  value.eventRadius.isValidFlag = C2xIsTokenAvailable(packetHandle, "SSM", newPath);
  if(value.eventRadius.isValidFlag==1)
  {
    value.eventRadius.value = C2xGetTokenInt(packetHandle, "SSM", newPath);
    result = CheckLastError("SSM", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "description");
  value.description.isValidFlag = C2xIsTokenAvailable(packetHandle, "SSM", newPath);
  if(value.description.isValidFlag==1)
  {
    GetSSMDescriptionParams(packetHandle, value.description, newPath);
    result = CheckLastError("SSM", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "timeDetails");
  value.timeDetails.isValidFlag = C2xIsTokenAvailable(packetHandle, "SSM", newPath);
  if(value.timeDetails.isValidFlag==1)
  {
    GetSSMRSITimeDetailsParams(packetHandle, value.timeDetails, newPath);
    result = CheckLastError("SSM", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "priority");
  value.priority.isValidFlag = C2xIsTokenAvailable(packetHandle, "SSM", newPath);
  if(value.priority.isValidFlag==1)
  {
    value.priority.isValidFlag = 1;
    value.priority.stringLength = C2xGetTokenData(packetHandle, "SSM", newPath, elcount(value.priority.string), value.priority.string);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "referencePaths");
  value.referencePaths.isValidFlag = C2xIsTokenAvailable(packetHandle, "SSM", newPath);
  if(value.referencePaths.isValidFlag==1)
  {
    GetSSMReferencePathListParams(packetHandle, value.referencePaths, newPath);
    result = CheckLastError("SSM", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "referenceLinks");
  value.referenceLinks.isValidFlag = C2xIsTokenAvailable(packetHandle, "SSM", newPath);
  if(value.referenceLinks.isValidFlag==1)
  {
    GetSSMReferenceLinkListParams(packetHandle, value.referenceLinks, newPath);
    result = CheckLastError("SSM", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "eventConfidence");
  value.eventConfidence.isValidFlag = C2xIsTokenAvailable(packetHandle, "SSM", newPath);
  if(value.eventConfidence.isValidFlag==1)
  {
    value.eventConfidence.value = C2xGetTokenInt(packetHandle, "SSM", newPath);
    result = CheckLastError("SSM", gkFuncRefGet, result);
  }
  return result;
}

