int GetSSMParticipantDataParams(LONG packetHandle, struct SSMParticipantData value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "ptcType");
  value.ptcType = C2xGetTokenInt(packetHandle, "SSM", newPath);
  result = CheckLastError("SSM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "ptcId");
  value.ptcId = C2xGetTokenInt(packetHandle, "SSM", newPath);
  result = CheckLastError("SSM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "source");
  value.source = C2xGetTokenInt(packetHandle, "SSM", newPath);
  result = CheckLastError("SSM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "id");
  value.id.isValidFlag = C2xIsTokenAvailable(packetHandle, "SSM", newPath);
  if(value.id.isValidFlag==1)
  {
    value.id.isValidFlag = 1;
    value.id.stringLength = C2xGetTokenData(packetHandle, "SSM", newPath, elcount(value.id.string), value.id.string);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "secMark");
  value.secMark = C2xGetTokenInt(packetHandle, "SSM", newPath);
  result = CheckLastError("SSM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "pos");
  GetSSMPositionOffsetLLVParams(packetHandle, value.pos, newPath);
  result = CheckLastError("SSM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "posConfidence");
  GetSSMPositionConfidenceSetParams(packetHandle, value.posConfidence, newPath);
  result = CheckLastError("SSM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "transmission");
  value.transmission.isValidFlag = C2xIsTokenAvailable(packetHandle, "SSM", newPath);
  if(value.transmission.isValidFlag==1)
  {
    value.transmission.value = C2xGetTokenInt(packetHandle, "SSM", newPath);
    result = CheckLastError("SSM", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "speed");
  value.speed = C2xGetTokenInt(packetHandle, "SSM", newPath);
