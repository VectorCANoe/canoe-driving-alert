        INT basicType;  // ENUMERATED, unavailable(0), aPEDESTRIAN(1), aPEDALCYCLIST(2), aROADWORKER(3), anANIMAL(4);
        struct SSMPropelledInformation propulsion;  // CHOICE, OPTIONAL;
        struct OPT_ENUM_ASN clusterSize;  // ENUMERATED, OPTIONAL, unavailable(0), small(1), medium(2), large(3);
        struct OPT_ENUM_ASN attachment;  // ENUMERATED, OPTIONAL, unavailable(0), stroller(1), bicycleTrailer(2), cart(3), wheelchair(4), otherWalkAssistAttachments(5), pet(6);
        struct SSMPersonalExtensions personalExt;  // SEQUENCE, OPTIONAL;
        struct SSMRoadWorkerExtensions roadWorkerExt;  // SEQUENCE, OPTIONAL;
        struct SSMPersonalRequest personalReq;  // SEQUENCE, OPTIONAL;
    };
    
    struct SSMNon_motorDataExtension {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        BYTE overallRadius;  // INTEGER, 0..200;
        struct SSMNon_motorData non_motorData;  // SEQUENCE;
    };
    
    struct SSMDetectedPTCData_type_relatedExt {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        INT choice;
        struct SSMMotorDataExtension motorExt;  // SEQUENCE;
        struct SSMNon_motorDataExtension non_motorExt;  // SEQUENCE;
    };
    
    struct SSMDetectedPTCData {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        struct SSMParticipantData ptc;  // SEQUENCE;
        struct SSMObjectSizeConfidence objSizeConfidence;  // SEQUENCE, OPTIONAL;
        struct OPT_ENUM_ASN detectedPTCType;  // ENUMERATED, OPTIONAL, unknown(0), unknown_movable(1), unknown_unmovable(2), car(3), van(4), truck(5), bus(6), cyclist(7), motorcyclist(8), tricyclist(9), pedestrian(10);
        struct OPT_BYTE_ASN typeConfidence;  // INTEGER, OPTIONAL, 0..200;
        struct SSMAccSet4WayConfidence acc4WayConfidence;  // SEQUENCE, OPTIONAL;
        struct OPT_WORD_ASN statusDuration;  // INTEGER, OPTIONAL, 1..65535;
        struct SSMPathHistory pathHistory;  // SEQUENCE, OPTIONAL;
        struct SSMPlanningList planningList;  // SEQUENCEOF, OPTIONAL;
        struct OPT_WORD_ASN tracking;  // INTEGER, OPTIONAL, 1..65535;
        struct SSMPolygon polygon;  // SEQUENCEOF, OPTIONAL;
        struct SSMDetectedPTCData_type_relatedExt type_relatedExt;  // CHOICE, OPTIONAL;
    };
    
    struct SSMDetectedPTCList {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        INT length;
        struct SSMDetectedPTCData arrayValue[512];  // SEQUENCE;
    };
    
    struct SSMObjectSize {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        WORD width;  // INTEGER, 0..1023;
        WORD length;  // INTEGER, 0..1023;
        struct OPT_WORD_ASN height;  // INTEGER, OPTIONAL, 0..1023;
    };
    
    struct SSMDetectedObstacleData {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        INT obsType;  // ENUMERATED, unknown(0), rockfall(1), landslide(2), animal_intrusion(3), liquid_spill(4), goods_scattered(5), trafficcone(6), safety_triangle(7), traffic_roadblock(8), inspection_shaft_without_cover(9), unknown_fragments(10), unknown_hard_object(11), unknown_soft_object(12);
        struct OPT_BYTE_ASN objTypeConfidence;  // INTEGER, OPTIONAL, 0..200;
        WORD obsId;  // INTEGER, 0..65535;
        INT source;  // ENUMERATED, unknown(0), selfinfo(1), v2x(2), video(3), microwaveRadar(4), loop(5), lidar(6), integrated(7);
        WORD secMark;  // INTEGER, 0..65535;
        struct SSMPositionOffsetLLV pos;  // SEQUENCE;
        struct SSMPositionConfidenceSet posConfidence;  // SEQUENCE;
        WORD speed;  // INTEGER, 0..8191;
        struct OPT_ENUM_ASN speedCfd;  // ENUMERATED, OPTIONAL, unavailable(0), prec100ms(1), prec10ms(2), prec5ms(3), prec1ms(4), prec0_1ms(5), prec0_05ms(6), prec0_01ms(7);
        WORD heading;  // INTEGER, 0..28800;
        struct OPT_ENUM_ASN headingCfd;  // ENUMERATED, OPTIONAL, unavailable(0), prec10deg(1), prec05deg(2), prec01deg(3), prec0_1deg(4), prec0_05deg(5), prec0_01deg(6), prec0_0125deg(7);
        struct OPT_WORD_ASN verSpeed;  // INTEGER, OPTIONAL, 0..8191;
        struct OPT_ENUM_ASN verSpeedConfidence;  // ENUMERATED, OPTIONAL, unavailable(0), prec100ms(1), prec10ms(2), prec5ms(3), prec1ms(4), prec0_1ms(5), prec0_05ms(6), prec0_01ms(7);
        struct SSMAccelerationSet4Way accelSet;  // SEQUENCE, OPTIONAL;
        struct SSMObjectSize size;  // SEQUENCE;
        struct SSMObjectSizeConfidence objSizeConfidence;  // SEQUENCE, OPTIONAL;
        struct OPT_WORD_ASN tracking;  // INTEGER, OPTIONAL, 1..65535;
        struct SSMPolygon polygon;  // SEQUENCEOF, OPTIONAL;
    };
    
    struct SSMDetectedObstacleList {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        INT length;
        struct SSMDetectedObstacleData arrayValue[64];  // SEQUENCE;
    };
    
    struct SSMDescription_textString {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        CHAR string[513];
        INT  stringLength;
    };
    
    struct SSMDescription_textGB2312 {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        CHAR string[513];
        INT  stringLength;
    };
    
    struct SSMDescription {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        INT choice;
        struct SSMDescription_textString textString;  // IA5STRING;
        struct SSMDescription_textGB2312 textGB2312;  // OCTETSTRING;
    };
    
    struct SSMRSITimeDetails {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        struct OPT_DWORD_ASN startTime;  // INTEGER, OPTIONAL, 0..527040;
        struct OPT_DWORD_ASN endTime;  // INTEGER, OPTIONAL, 0..527040;
        struct OPT_ENUM_ASN endTimeConfidence;  // ENUMERATED, OPTIONAL, unavailable(0), time_100_000(1), time_050_000(2), time_020_000(3), time_010_000(4), time_002_000(5), time_001_000(6), time_000_500(7), time_000_200(8), time_000_100(9), time_000_050(10), time_000_020(11), time_000_010(12), time_000_005(13), time_000_002(14), time_000_001(15), time_000_000_5(16), time_000_000_2(17), time_000_000_1(18), time_000_000_05(19), time_000_000_02(20), time_000_000_01(21), time_000_000_005(22), time_000_000_002(23), time_000_000_001(24), time_000_000_000_5(25), time_000_000_000_2(26), time_000_000_000_1(27), time_000_000_000_05(28), time_000_000_000_02(29), time_000_000_000_01(30), time_000_000_000_005(31), time_000_000_000_002(32), time_000_000_000_001(33), time_000_000_000_000_5(34), time_000_000_000_000_2(35), time_000_000_000_000_1(36), time_000_000_000_000_05(37), time_000_000_000_000_02(38), time_000_000_000_000_01(39);
    };
    
    struct SSMRSIPriority {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        CHAR string[2];
        INT  stringLength;
    };
    
    struct SSMPathPointList {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        INT length;
        struct SSMPositionOffsetLLV arrayValue[32];  // SEQUENCE;
    };
    
    struct SSMReferencePath {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        struct SSMPathPointList activePath;  // SEQUENCEOF;
        WORD pathRadius;  // INTEGER, 0..65535;
    };
    
    struct SSMReferencePathList {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        INT length;
        struct SSMReferencePath arrayValue[8];  // SEQUENCE;
    };
    
    struct SSMReferenceLinkList {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        INT length;
        struct SSMReferenceLink arrayValue[16];  // SEQUENCE;
    };
    
    struct SSMRTEData {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        BYTE rteId;  // INTEGER, 0..255;
        WORD eventType;  // INTEGER, 0..65535;
        INT eventSource;  // ENUMERATED, unknown(0), police(1), government(2), meteorological(3), internet(4), detection(5);
        struct SSMPositionOffsetLLV eventPos;  // SEQUENCE, OPTIONAL;
        struct OPT_WORD_ASN eventRadius;  // INTEGER, OPTIONAL, 0..65535;
        struct SSMDescription description;  // CHOICE, OPTIONAL;
        struct SSMRSITimeDetails timeDetails;  // SEQUENCE, OPTIONAL;
        struct SSMRSIPriority priority;  // OCTETSTRING, OPTIONAL;
        struct SSMReferencePathList referencePaths;  // SEQUENCEOF, OPTIONAL;
        struct SSMReferenceLinkList referenceLinks;  // SEQUENCEOF, OPTIONAL;
        struct OPT_BYTE_ASN eventConfidence;  // INTEGER, OPTIONAL, 0..200;
    };
    
    struct SSMRTEList {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        INT length;
        struct SSMRTEData arrayValue[8];  // SEQUENCE;
    };
    
    struct SSMSensorSharing_SensorSharingMsg {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        BYTE msgCnt;  // INTEGER, 0..127;
        struct SSMSensorSharingMsg_id id;  // OCTETSTRING;
        INT equipmentType;  // ENUMERATED, unknown(0), rsu(1), obu(2), vru(3);
        WORD secMark;  // INTEGER, 0..65535;
        struct SSMPosition3D sensorPos;  // SEQUENCE;
        struct SSMDetectedRegion detectedRegion;  // SEQUENCEOF, OPTIONAL;
        struct SSMDetectedPTCList participants;  // SEQUENCEOF, OPTIONAL;
        struct SSMDetectedObstacleList obstacles;  // SEQUENCEOF, OPTIONAL;
        struct SSMRTEList rtes;  // SEQUENCEOF, OPTIONAL;
    };
    
    struct SSMMessageTypes {
        struct SSMSensorSharing_SensorSharingMsg ssmData;  // SEQUENCE;
    };
    
    struct SSMMessageFrameExt {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        WORD messageId;  // INTEGER, 0..32767;
        struct SSMMessageTypes value;  // TABLE;
    };
    
    struct SSM {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        INT choice;
        struct SSMMessageFrameExt msgFrameExt;  // SEQUENCE;
    };
    
}

/*
// init function to create a simple packet handle
*/ 
LONG API_InitSSMPacket()
{
  return C2xInitPacket("SSM"); 
}

/*
// init function to create a simple packet handle and
// initialize the struct with valid data
*/ 
LONG API_InitSSMPacket(struct SSM msgStruct)
{
  long pktHandle;

  pktHandle = API_InitSSMPacket();

  if (pktHandle != 0)
  {
    // create valid message and application data
    if (C2xCompletePacket(pktHandle) == 0) 
    {
      API_GetSSMParams(pktHandle, msgStruct);
    }
  }
  return pktHandle;
}

/*
// init function to create a packet with security layer and
// initialize the struct with valid data
*/ 
LONG API_InitSSMPacket(struct SSM msgStruct, char packetTypeDesignator[], char certificateName[])
{
  long pktHandle, certHdl;

  // initialize the packet
  pktHandle = C2xInitPacket("SSM", packetTypeDesignator);

  if (pktHandle != 0)
  {
    certHdl = C2xSecCertificateGetHandle(certificateName);  // get the certificate handle for the cert with name "certificateName"
    if (certHdl != 0) 
    {
      C2xSecPacketSetSignerHandle(pktHandle, certHdl); // set the certHdl to the packet
    }

    // create valid message and application data
    if (C2xCompletePacket(pktHandle) == 0) 
    {
      // copy application data to the application structure
      API_GetSSMParams(pktHandle, msgStruct);
    }
  }
  return pktHandle;
}
    

int GetSSMPosition3DParams(LONG packetHandle, struct SSMPosition3D value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "lat");
  value.lat = C2xGetTokenInt(packetHandle, "SSM", newPath);
  result = CheckLastError("SSM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "lon");
  value.lon = C2xGetTokenInt(packetHandle, "SSM", newPath);
  result = CheckLastError("SSM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "elevation");
  value.elevation.isValidFlag = C2xIsTokenAvailable(packetHandle, "SSM", newPath);
  if(value.elevation.isValidFlag==1)
  {
    value.elevation.value = C2xGetTokenInt(packetHandle, "SSM", newPath);
    result = CheckLastError("SSM", gkFuncRefGet, result);
  }
  return result;
}

int SetSSMPosition3DParams(LONG packetHandle, struct SSMPosition3D value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "lat");
  C2xSetTokenInt(packetHandle, "SSM", newPath, value.lat);
  result = CheckLastError("SSM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "lon");
  C2xSetTokenInt(packetHandle, "SSM", newPath, value.lon);
  result = CheckLastError("SSM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "elevation");
  if(value.elevation.isValidFlag==1)
  {
    C2xSetTokenInt(packetHandle, "SSM", newPath, value.elevation.value);
    result = CheckLastError("SSM", gkFuncRefGet, result);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "SSM", newPath) )
    {
      C2xRemoveToken(packetHandle, "SSM", newPath);
    }
  }

  return result;
}

