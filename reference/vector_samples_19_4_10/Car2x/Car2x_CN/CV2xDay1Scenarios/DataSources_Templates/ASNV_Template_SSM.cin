  {
    if( C2xIsTokenAvailable(packetHandle, "SSM", newPath) )
    {
      C2xRemoveToken(packetHandle, "SSM", newPath);
    }
  }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "acc4WayConfidence");
  if(value.acc4WayConfidence.isValidFlag==1)
  {
    SetSSMAccSet4WayConfidenceParams(packetHandle, value.acc4WayConfidence, newPath);
    result = CheckLastError("SSM", gkFuncRefGet, result);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "SSM", newPath) )
    {
      C2xRemoveToken(packetHandle, "SSM", newPath);
    }
  }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "estimatedTime");
  if(value.estimatedTime.isValidFlag==1)
  {
    if (value.estimatedTime.value < 1)
    {
        C2xSetTokenInt(packetHandle, "SSM", newPath, 1);
    }
    else if (value.estimatedTime.value > 65535)
    {
        C2xSetTokenInt(packetHandle, "SSM", newPath, 65535);
    }
    else
    {
        C2xSetTokenInt(packetHandle, "SSM", newPath, value.estimatedTime.value);
    }
    result = CheckLastError("SSM", gkFuncRefGet, result);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "SSM", newPath) )
    {
      C2xRemoveToken(packetHandle, "SSM", newPath);
    }
  }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "timeConfidence");
  if(value.timeConfidence.isValidFlag==1)
  {
    C2xSetTokenInt(packetHandle, "SSM", newPath, value.timeConfidence.value);
    result = CheckLastError("SSM", gkFuncRefGet, result);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "SSM", newPath) )
    {
      C2xRemoveToken(packetHandle, "SSM", newPath);
    }
  }

  return result;
}

