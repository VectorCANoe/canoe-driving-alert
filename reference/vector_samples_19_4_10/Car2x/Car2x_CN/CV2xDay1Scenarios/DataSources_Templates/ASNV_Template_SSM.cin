int GetSSMPropelledInformationParams(LONG packetHandle, struct SSMPropelledInformation value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  value.choice = C2xGetTokenInt(packetHandle, "SSM", oldPath);

  switch(value.choice)
  {
    case 0:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "human");
      value.human = C2xGetTokenInt(packetHandle, "SSM", newPath);
      result = CheckLastError("SSM", gkFuncRefGet, result);
    }
    break;
    case 1:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "animal");
      value.animal = C2xGetTokenInt(packetHandle, "SSM", newPath);
      result = CheckLastError("SSM", gkFuncRefGet, result);
    }
    break;
    case 2:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "motor");
      value.motor = C2xGetTokenInt(packetHandle, "SSM", newPath);
      result = CheckLastError("SSM", gkFuncRefGet, result);
    }
    break;
  }
  return result;
}

