int GetRSCPositionOffsetLLParams(LONG packetHandle, struct RSCPositionOffsetLL value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  value.choice = C2xGetTokenInt(packetHandle, "RSC", oldPath);

  switch(value.choice)
  {
    case 0:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "position_LL1");
      GetRSCPosition_LL_24BParams(packetHandle, value.position_LL1, newPath);
      result = CheckLastError("RSC", gkFuncRefGet, result);
    }
    break;
    case 1:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "position_LL2");
      GetRSCPosition_LL_28BParams(packetHandle, value.position_LL2, newPath);
      result = CheckLastError("RSC", gkFuncRefGet, result);
    }
    break;
    case 2:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "position_LL3");
      GetRSCPosition_LL_32BParams(packetHandle, value.position_LL3, newPath);
      result = CheckLastError("RSC", gkFuncRefGet, result);
    }
    break;
    case 3:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "position_LL4");
      GetRSCPosition_LL_36BParams(packetHandle, value.position_LL4, newPath);
      result = CheckLastError("RSC", gkFuncRefGet, result);
    }
    break;
    case 4:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "position_LL5");
      GetRSCPosition_LL_44BParams(packetHandle, value.position_LL5, newPath);
      result = CheckLastError("RSC", gkFuncRefGet, result);
    }
    break;
    case 5:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "position_LL6");
      GetRSCPosition_LL_48BParams(packetHandle, value.position_LL6, newPath);
      result = CheckLastError("RSC", gkFuncRefGet, result);
    }
    break;
    case 6:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "position_LatLon");
      GetRSCPosition_LLmD_64bParams(packetHandle, value.position_LatLon, newPath);
      result = CheckLastError("RSC", gkFuncRefGet, result);
    }
    break;
  }
  return result;
}

