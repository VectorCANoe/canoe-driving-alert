int GetRSCLaneCoordinationParams(LONG packetHandle, struct RSCLaneCoordination value, char oldPath[])
{
  char newPath[300]; 
  int j; 
  int k;
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "targetLane");
  GetRSCReferenceLinkParams(packetHandle, value.targetLane, newPath);
  result = CheckLastError("RSC", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "relatedPath");
  value.relatedPath.isValidFlag = C2xIsTokenAvailable(packetHandle, "RSC", newPath);
  if(value.relatedPath.isValidFlag==1)
  {
    GetRSCReferencePathParams(packetHandle, value.relatedPath, newPath);
    result = CheckLastError("RSC", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "tBegin");
  value.tBegin.isValidFlag = C2xIsTokenAvailable(packetHandle, "RSC", newPath);
  if(value.tBegin.isValidFlag==1)
  {
    GetRSCDDateTimeParams(packetHandle, value.tBegin, newPath);
    result = CheckLastError("RSC", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "tEnd");
  value.tEnd.isValidFlag = C2xIsTokenAvailable(packetHandle, "RSC", newPath);
  if(value.tEnd.isValidFlag==1)
  {
    GetRSCDDateTimeParams(packetHandle, value.tEnd, newPath);
    result = CheckLastError("RSC", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "recommendedSpeed");
  value.recommendedSpeed.isValidFlag = C2xIsTokenAvailable(packetHandle, "RSC", newPath);
  if(value.recommendedSpeed.isValidFlag==1)
  {
    value.recommendedSpeed.value = C2xGetTokenInt(packetHandle, "RSC", newPath);
    result = CheckLastError("RSC", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "recommendedBehavior");
  value.recommendedBehavior.isValidFlag = C2xIsTokenAvailable(packetHandle, "RSC", newPath);
  if(value.recommendedBehavior.isValidFlag==1)
  {
    value.recommendedBehavior.isValidFlag = 1;
    value.recommendedBehavior.stringLength = C2xGetTokenLengthBit(packetHandle, "RSC", newPath);
    if ((result = CheckLastError("RSC", gkFuncRefGet, result))==0)
    {
      if(value.recommendedBehavior.stringLength > 0)
      {
        for(j=0; j<value.recommendedBehavior.stringLength; j++)
        {
          if(C2xGetTokenBitOfBitString(packetHandle, "RSC", newPath, j) == 0)
          {
            value.recommendedBehavior.string[j] = '0';
          }
          else if(C2xGetTokenBitOfBitString(packetHandle, "RSC", newPath, j) == 1)
          {
            value.recommendedBehavior.string[j] = '1';
          }

          if(value.recommendedBehavior.stringLength == 1)
          {
            value.recommendedBehavior.string[1] = '0';
          }
          result = CheckLastError("RSC", gkFuncRefGet, result);
        }
      }
      else
      {
        for(k = value.recommendedBehavior.stringLength+1; k > -1; k--)
        {
          if(value.recommendedBehavior.string[k] == '1')
          {
            value.recommendedBehavior.string[k] = '0';
          }
        }
      }
    }

  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "info");
  value.info.isValidFlag = C2xIsTokenAvailable(packetHandle, "RSC", newPath);
  if(value.info.isValidFlag==1)
  {
    value.info.isValidFlag = 1;
    value.info.stringLength = C2xGetTokenLengthBit(packetHandle, "RSC", newPath);
    if ((result = CheckLastError("RSC", gkFuncRefGet, result))==0)
    {
      if(value.info.stringLength > 0)
      {
        for(j=0; j<value.info.stringLength; j++)
        {
          if(C2xGetTokenBitOfBitString(packetHandle, "RSC", newPath, j) == 0)
          {
            value.info.string[j] = '0';
          }
          else if(C2xGetTokenBitOfBitString(packetHandle, "RSC", newPath, j) == 1)
          {
            value.info.string[j] = '1';
          }

          if(value.info.stringLength == 1)
          {
            value.info.string[1] = '0';
          }
          result = CheckLastError("RSC", gkFuncRefGet, result);
        }
      }
      else
      {
        for(k = value.info.stringLength+1; k > -1; k--)
        {
          if(value.info.string[k] == '1')
          {
            value.info.string[k] = '0';
          }
        }
      }
    }

  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "description");
  value.description.isValidFlag = C2xIsTokenAvailable(packetHandle, "RSC", newPath);
  if(value.description.isValidFlag==1)
  {
    GetRSCDescriptionParams(packetHandle, value.description, newPath);
    result = CheckLastError("RSC", gkFuncRefGet, result);
  }
  return result;
}

