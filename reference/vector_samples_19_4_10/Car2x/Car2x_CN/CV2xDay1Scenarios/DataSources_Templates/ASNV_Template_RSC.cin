  {
    SetRSCRoadsideCoordination_coordinatesParams(packetHandle, value.coordinates, newPath);
    result = CheckLastError("RSC", gkFuncRefGet, result);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "RSC", newPath) )
    {
      C2xRemoveToken(packetHandle, "RSC", newPath);
    }
  }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "laneCoordinates");
  if(value.laneCoordinates.isValidFlag==1)
  {
    SetRSCRoadsideCoordination_laneCoordinatesParams(packetHandle, value.laneCoordinates, newPath);
    result = CheckLastError("RSC", gkFuncRefGet, result);
