  value.region.isValidFlag = C2xIsTokenAvailable(packetHandle, "RSC", newPath);
  if(value.region.isValidFlag==1)
  {
    value.region.value = C2xGetTokenInt(packetHandle, "RSC", newPath);
    result = CheckLastError("RSC", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "id");
  value.id = C2xGetTokenInt(packetHandle, "RSC", newPath);
