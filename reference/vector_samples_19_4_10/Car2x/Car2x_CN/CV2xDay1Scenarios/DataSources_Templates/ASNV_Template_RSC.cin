int GetRSCVehicleCoordinationParams(LONG packetHandle, struct RSCVehicleCoordination value, char oldPath[])
{
  char newPath[300]; 
  int j; 
  int k;
  char buffer[300];
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "vehId");
  value.vehId.stringLength = C2xGetTokenData(packetHandle, "RSC", newPath, elcount(value.vehId.string), value.vehId.string);
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "driveSuggestion");
  value.driveSuggestion.isValidFlag = C2xIsTokenAvailable(packetHandle, "RSC", newPath);
  if(value.driveSuggestion.isValidFlag==1)
  {
    GetRSCDriveSuggestionParams(packetHandle, value.driveSuggestion, newPath);
    result = CheckLastError("RSC", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "pathGuidance");
  value.pathGuidance.isValidFlag = C2xIsTokenAvailable(packetHandle, "RSC", newPath);
  if(value.pathGuidance.isValidFlag==1)
  {
    GetRSCPathPlanningParams(packetHandle, value.pathGuidance, newPath);
    result = CheckLastError("RSC", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "info");
  value.info.isValidFlag = C2xIsTokenAvailable(packetHandle, "RSC", newPath);
  if(value.info.isValidFlag==1)
  {
    value.info.isValidFlag = 1;
    value.info.stringLength = C2xGetTokenLengthBit(packetHandle, "RSC", newPath);
    if ((result = CheckLastError("RSC", gkFuncRefGet, result))==0)
    {
      if(value.info.stringLength > 0)
      {
        for(j=0; j<value.info.stringLength; j++)
        {
          if(C2xGetTokenBitOfBitString(packetHandle, "RSC", newPath, j) == 0)
          {
            value.info.string[j] = '0';
          }
          else if(C2xGetTokenBitOfBitString(packetHandle, "RSC", newPath, j) == 1)
          {
            value.info.string[j] = '1';
          }

          if(value.info.stringLength == 1)
          {
            value.info.string[1] = '0';
          }
          result = CheckLastError("RSC", gkFuncRefGet, result);
        }
      }
      else
      {
        for(k = value.info.stringLength+1; k > -1; k--)
        {
          if(value.info.string[k] == '1')
          {
            value.info.string[k] = '0';
          }
        }
      }
    }

  }
  return result;
}

int SetRSCVehicleCoordinationParams(LONG packetHandle, struct RSCVehicleCoordination value, char oldPath[])
{
  char newPath[300]; 
  int j;
  char buffer[300];
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "vehId");
  C2xSetTokenData(packetHandle, "RSC", newPath, value.vehId.stringLength, value.vehId.string);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "driveSuggestion");
  if(value.driveSuggestion.isValidFlag==1)
  {
    SetRSCDriveSuggestionParams(packetHandle, value.driveSuggestion, newPath);
    result = CheckLastError("RSC", gkFuncRefGet, result);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "RSC", newPath) )
    {
      C2xRemoveToken(packetHandle, "RSC", newPath);
    }
  }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "pathGuidance");
  if(value.pathGuidance.isValidFlag==1)
  {
    SetRSCPathPlanningParams(packetHandle, value.pathGuidance, newPath);
    result = CheckLastError("RSC", gkFuncRefGet, result);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "RSC", newPath) )
    {
      C2xRemoveToken(packetHandle, "RSC", newPath);
    }
  }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "info");
  if(value.info.isValidFlag==1)
  {
      for(j=0; j<value.info.stringLength; j++)
      {
        if(value.info.string[j] == '0')
        {
          C2xSetTokenBitOfBitString(packetHandle, "RSC", newPath, j, 0);
        }
        else
        {
          C2xSetTokenBitOfBitString(packetHandle, "RSC", newPath, j, 1);
        }
        result = CheckLastError("RSC", gkFuncRefGet, result);
      }
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "RSC", newPath) )
    {
      C2xRemoveToken(packetHandle, "RSC", newPath);
    }
  }

  return result;
}

