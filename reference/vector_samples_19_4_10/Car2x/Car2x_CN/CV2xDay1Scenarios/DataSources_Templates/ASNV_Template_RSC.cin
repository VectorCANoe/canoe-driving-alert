int GetRSCDescriptionParams(LONG packetHandle, struct RSCDescription value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  value.choice = C2xGetTokenInt(packetHandle, "RSC", oldPath);

  switch(value.choice)
  {
    case 0:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "textString");
      value.textString.stringLength = C2xGetTokenData(packetHandle, "RSC", newPath, elcount(value.textString.string), value.textString.string);
      result = CheckLastError("RSC", gkFuncRefGet, result);
    }
    break;
    case 1:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "textGB2312");
      value.textGB2312.stringLength = C2xGetTokenData(packetHandle, "RSC", newPath, elcount(value.textGB2312.string), value.textGB2312.string);
      result = CheckLastError("RSC", gkFuncRefGet, result);
    }
    break;
  }
  return result;
}

