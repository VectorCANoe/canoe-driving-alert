  SetRSCPositionOffsetLLParams(packetHandle, value.offsetLL, newPath);
  result = CheckLastError("RSC", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "offsetV");
  if(value.offsetV.isValidFlag==1)
  {
    SetRSCVerticalOffsetParams(packetHandle, value.offsetV, newPath);
    result = CheckLastError("RSC", gkFuncRefGet, result);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "RSC", newPath) )
    {
      C2xRemoveToken(packetHandle, "RSC", newPath);
    }
  }

  return result;
}

int GetRSCPathPointListParams(LONG packetHandle, struct RSCPathPointList value, char oldPath[])
{
  char newPath[300]; 
  int i;
  int result;

  result = 0;

  value.length = C2xGetTokenInt(packetHandle, "RSC", oldPath);
  if((result = CheckLastError("RSC", gkFuncRefGet, result))==0)
  {
    for(i=0; i<value.length; i++)
    {
      snprintf(newPath, elcount(newPath), "%s[%d]", oldPath, i);
      GetRSCPositionOffsetLLVParams(packetHandle, value.arrayValue[i], newPath);
      result = CheckLastError("RSC", gkFuncRefGet, result);
    }
  }
  return result;
}

int SetRSCPathPointListParams(LONG packetHandle, struct RSCPathPointList value, char oldPath[])
{
  char newPath[300]; 
  int i;
  int result;

  result = 0;

  C2xRemoveToken(packetHandle, "RSC", oldPath);
  for(i=0; i<value.length; i++)
  {
    snprintf(newPath, elcount(newPath), "%s[%d]", oldPath, i);
    SetRSCPositionOffsetLLVParams(packetHandle, value.arrayValue[i], newPath);
    result = CheckLastError("RSC", gkFuncRefGet, result);
  }
  return result;
}

