  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "offsetLL");
  GetRSCPositionOffsetLLParams(packetHandle, value.offsetLL, newPath);
  result = CheckLastError("RSC", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "offsetV");
  value.offsetV.isValidFlag = C2xIsTokenAvailable(packetHandle, "RSC", newPath);
  if(value.offsetV.isValidFlag==1)
  {
    GetRSCVerticalOffsetParams(packetHandle, value.offsetV, newPath);
    result = CheckLastError("RSC", gkFuncRefGet, result);
  }
  return result;
}

int SetRSCPositionOffsetLLVParams(LONG packetHandle, struct RSCPositionOffsetLLV value, char oldPath[])
