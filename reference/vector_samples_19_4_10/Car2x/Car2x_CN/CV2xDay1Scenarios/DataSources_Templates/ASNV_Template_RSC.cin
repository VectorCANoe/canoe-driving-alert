int GetRSCDriveSuggestionParams(LONG packetHandle, struct RSCDriveSuggestion value, char oldPath[])
{
  char newPath[300]; 
  int j; 
  int k;
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "suggestion");
  value.suggestion.isValidFlag = 1;
  value.suggestion.stringLength = C2xGetTokenLengthBit(packetHandle, "RSC", newPath);
  if ((result = CheckLastError("RSC", gkFuncRefGet, result))==0)
  {
    if(value.suggestion.stringLength > 0)
    {
      for(j=0; j<value.suggestion.stringLength; j++)
      {
        if(C2xGetTokenBitOfBitString(packetHandle, "RSC", newPath, j) == 0)
        {
          value.suggestion.string[j] = '0';
        }
        else if(C2xGetTokenBitOfBitString(packetHandle, "RSC", newPath, j) == 1)
        {
          value.suggestion.string[j] = '1';
        }

        if(value.suggestion.stringLength == 1)
        {
          value.suggestion.string[1] = '0';
        }
        result = CheckLastError("RSC", gkFuncRefGet, result);
      }
    }
    else
    {
      for(k = value.suggestion.stringLength+1; k > -1; k--)
      {
        if(value.suggestion.string[k] == '1')
        {
          value.suggestion.string[k] = '0';
        }
      }
    }
  }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "lifeTime");
  value.lifeTime.isValidFlag = C2xIsTokenAvailable(packetHandle, "RSC", newPath);
  if(value.lifeTime.isValidFlag==1)
  {
    value.lifeTime.value = C2xGetTokenInt(packetHandle, "RSC", newPath);
    result = CheckLastError("RSC", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "relatedLink");
  value.relatedLink.isValidFlag = C2xIsTokenAvailable(packetHandle, "RSC", newPath);
  if(value.relatedLink.isValidFlag==1)
  {
    GetRSCReferenceLinkParams(packetHandle, value.relatedLink, newPath);
    result = CheckLastError("RSC", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "relatedPath");
  value.relatedPath.isValidFlag = C2xIsTokenAvailable(packetHandle, "RSC", newPath);
  if(value.relatedPath.isValidFlag==1)
  {
    GetRSCReferencePathParams(packetHandle, value.relatedPath, newPath);
    result = CheckLastError("RSC", gkFuncRefGet, result);
  }
  return result;
}

int SetRSCDriveSuggestionParams(LONG packetHandle, struct RSCDriveSuggestion value, char oldPath[])
{
  char newPath[300]; 
  int j;
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "suggestion");
    for(j=0; j<value.suggestion.stringLength; j++)
    {
      if(value.suggestion.string[j] == '0')
      {
        C2xSetTokenBitOfBitString(packetHandle, "RSC", newPath, j, 0);
      }
      else
      {
        C2xSetTokenBitOfBitString(packetHandle, "RSC", newPath, j, 1);
      }
      result = CheckLastError("RSC", gkFuncRefGet, result);
    }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "lifeTime");
  if(value.lifeTime.isValidFlag==1)
  {
    if (value.lifeTime.value < 1)
    {
        C2xSetTokenInt(packetHandle, "RSC", newPath, 1);
    }
    else if (value.lifeTime.value > 65535)
    {
        C2xSetTokenInt(packetHandle, "RSC", newPath, 65535);
    }
    else
    {
        C2xSetTokenInt(packetHandle, "RSC", newPath, value.lifeTime.value);
    }
    result = CheckLastError("RSC", gkFuncRefGet, result);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "RSC", newPath) )
    {
      C2xRemoveToken(packetHandle, "RSC", newPath);
    }
  }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "relatedLink");
  if(value.relatedLink.isValidFlag==1)
  {
    SetRSCReferenceLinkParams(packetHandle, value.relatedLink, newPath);
    result = CheckLastError("RSC", gkFuncRefGet, result);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "RSC", newPath) )
    {
      C2xRemoveToken(packetHandle, "RSC", newPath);
    }
  }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "relatedPath");
  if(value.relatedPath.isValidFlag==1)
  {
    SetRSCReferencePathParams(packetHandle, value.relatedPath, newPath);
    result = CheckLastError("RSC", gkFuncRefGet, result);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "RSC", newPath) )
    {
      C2xRemoveToken(packetHandle, "RSC", newPath);
    }
  }

  return result;
}

