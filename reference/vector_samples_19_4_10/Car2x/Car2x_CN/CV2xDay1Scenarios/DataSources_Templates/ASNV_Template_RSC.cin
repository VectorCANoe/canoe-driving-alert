  {
    for(i=0; i<value.length; i++)
    {
      snprintf(newPath, elcount(newPath), "%s[%d]", oldPath, i);
      GetRSCPathPlanningPointParams(packetHandle, value.arrayValue[i], newPath);
      result = CheckLastError("RSC", gkFuncRefGet, result);
    }
  }
  return result;
}

