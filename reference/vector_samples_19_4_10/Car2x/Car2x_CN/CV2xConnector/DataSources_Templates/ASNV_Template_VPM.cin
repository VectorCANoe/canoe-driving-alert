  value.tollingNodeInfo.isValidFlag = C2xIsTokenAvailable(packetHandle, "VPM", newPath);
  if(value.tollingNodeInfo.isValidFlag==1)
  {
    GetVPMTollingNodeInfoParams(packetHandle, value.tollingNodeInfo, newPath);
    result = CheckLastError("VPM", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "tollInfo");
  value.tollInfo.isValidFlag = C2xIsTokenAvailable(packetHandle, "VPM", newPath);
  if(value.tollInfo.isValidFlag==1)
  {
    GetVPMTollInfoParams(packetHandle, value.tollInfo, newPath);
    result = CheckLastError("VPM", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "serviceInfo");
  value.serviceInfo.isValidFlag = C2xIsTokenAvailable(packetHandle, "VPM", newPath);
  if(value.serviceInfo.isValidFlag==1)
  {
    value.serviceInfo.isValidFlag = 1;
