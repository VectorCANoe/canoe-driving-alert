        struct VPMChannelRq transferChannelRq;  // SEQUENCE;
        struct VPMChannelRs transferChannelRs;  // SEQUENCE;
        struct VPMSetMMIRq setMMIRq;  // SEQUENCE;
    };
    
    struct VPMAction_Request_accessCredentials {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        CHAR string[9];
        INT  stringLength;
    };
    
    struct VPMAction_Request {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        struct VPMDDateTime time;  // SEQUENCE;
        INT mode;  // BOOLEAN;
        struct VPMAction_Request_sourceId sourceId;  // OCTETSTRING;
        struct VPMAction_Request_targetId targetId;  // OCTETSTRING, OPTIONAL;
        INT paymentEntityId;  // ENUMERATED, system(0), freeflow(1), enclosed(2), congestion(3), charging(4), parking(5);
        struct VPMTransInfo actionParameter;  // CHOICE;
        struct VPMAction_Request_accessCredentials accessCredentials;  // OCTETSTRING, OPTIONAL;
    };
    
    struct VPMAction_Response_sourceId {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        CHAR string[9];
        INT  stringLength;
    };
    
    struct VPMAction_Response_targetId {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        CHAR string[9];
        INT  stringLength;
    };
    
    struct VPMAction_Response {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        struct VPMDDateTime time;  // SEQUENCE;
        struct VPMAction_Response_sourceId sourceId;  // OCTETSTRING;
        struct VPMAction_Response_targetId targetId;  // OCTETSTRING, OPTIONAL;
        INT paymentEntityId;  // ENUMERATED, system(0), freeflow(1), enclosed(2), congestion(3), charging(4), parking(5);
        struct VPMTransInfo responseParameter;  // CHOICE, OPTIONAL;
        INT ret;  // ENUMERATED, noError(0), accessDenied(1), argumnetError(2), complexityLimitation(3), processingFailure(4), processing(5);
    };
    
    struct VPMVehiclePaymentMessage_payment {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        INT choice;
        struct VPMRST initialzation_request;  // SEQUENCE;
        struct VPMVSI initialzation_response;  // SEQUENCE;
        struct VPMAction_Request action_request;  // SEQUENCE;
        struct VPMAction_Response action_response;  // SEQUENCE;
    };
    
    struct VPMVPM_VehiclePaymentMessage {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        BYTE msgCnt;  // INTEGER, 0..127;
        struct VPMVehiclePaymentMessage_payment payment;  // CHOICE;
    };
    
    struct VPMMessageTypes {
        struct VPMVPM_VehiclePaymentMessage vpmData;  // SEQUENCE;
    };
    
    struct VPMMessageFrameExt {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        WORD messageId;  // INTEGER, 0..32767;
        struct VPMMessageTypes value;  // TABLE;
    };
    
    struct VPM {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        INT choice;
        struct VPMMessageFrameExt msgFrameExt;  // SEQUENCE;
    };
    
}

/*
// init function to create a simple packet handle
*/ 
LONG API_InitVPMPacket()
{
  return C2xInitPacket("VPM"); 
}

/*
// init function to create a simple packet handle and
// initialize the struct with valid data
*/ 
LONG API_InitVPMPacket(struct VPM msgStruct)
{
  long pktHandle;

  pktHandle = API_InitVPMPacket();

  if (pktHandle != 0)
  {
    // create valid message and application data
    if (C2xCompletePacket(pktHandle) == 0) 
    {
      API_GetVPMParams(pktHandle, msgStruct);
    }
  }
  return pktHandle;
}

/*
// init function to create a packet with security layer and
// initialize the struct with valid data
*/ 
LONG API_InitVPMPacket(struct VPM msgStruct, char packetTypeDesignator[], char certificateName[])
{
  long pktHandle, certHdl;

  // initialize the packet
  pktHandle = C2xInitPacket("VPM", packetTypeDesignator);

  if (pktHandle != 0)
  {
    certHdl = C2xSecCertificateGetHandle(certificateName);  // get the certificate handle for the cert with name "certificateName"
    if (certHdl != 0) 
    {
      C2xSecPacketSetSignerHandle(pktHandle, certHdl); // set the certHdl to the packet
    }

    // create valid message and application data
    if (C2xCompletePacket(pktHandle) == 0) 
    {
      // copy application data to the application structure
      API_GetVPMParams(pktHandle, msgStruct);
    }
  }
  return pktHandle;
}
    

int GetVPMDDateTimeParams(LONG packetHandle, struct VPMDDateTime value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "year");
  value.year.isValidFlag = C2xIsTokenAvailable(packetHandle, "VPM", newPath);
  if(value.year.isValidFlag==1)
  {
    value.year.value = C2xGetTokenInt(packetHandle, "VPM", newPath);
    result = CheckLastError("VPM", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "month");
  value.month.isValidFlag = C2xIsTokenAvailable(packetHandle, "VPM", newPath);
  if(value.month.isValidFlag==1)
  {
    value.month.value = C2xGetTokenInt(packetHandle, "VPM", newPath);
    result = CheckLastError("VPM", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "day");
  value.day.isValidFlag = C2xIsTokenAvailable(packetHandle, "VPM", newPath);
  if(value.day.isValidFlag==1)
  {
    value.day.value = C2xGetTokenInt(packetHandle, "VPM", newPath);
    result = CheckLastError("VPM", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "hour");
  value.hour.isValidFlag = C2xIsTokenAvailable(packetHandle, "VPM", newPath);
  if(value.hour.isValidFlag==1)
  {
    value.hour.value = C2xGetTokenInt(packetHandle, "VPM", newPath);
    result = CheckLastError("VPM", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "minute");
  value.minute.isValidFlag = C2xIsTokenAvailable(packetHandle, "VPM", newPath);
  if(value.minute.isValidFlag==1)
  {
    value.minute.value = C2xGetTokenInt(packetHandle, "VPM", newPath);
    result = CheckLastError("VPM", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "second");
  value.second.isValidFlag = C2xIsTokenAvailable(packetHandle, "VPM", newPath);
  if(value.second.isValidFlag==1)
  {
    value.second.value = C2xGetTokenInt(packetHandle, "VPM", newPath);
    result = CheckLastError("VPM", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "offset");
  value.offset.isValidFlag = C2xIsTokenAvailable(packetHandle, "VPM", newPath);
  if(value.offset.isValidFlag==1)
  {
    value.offset.value = C2xGetTokenInt(packetHandle, "VPM", newPath);
    result = CheckLastError("VPM", gkFuncRefGet, result);
  }
  return result;
}

