int GetVPMAction_RequestParams(LONG packetHandle, struct VPMAction_Request value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "time");
  GetVPMDDateTimeParams(packetHandle, value.time, newPath);
  result = CheckLastError("VPM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "mode");
  value.mode = C2xGetTokenInt64(packetHandle, "VPM", newPath);
  result = CheckLastError("VPM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "sourceId");
  value.sourceId.stringLength = C2xGetTokenData(packetHandle, "VPM", newPath, elcount(value.sourceId.string), value.sourceId.string);
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "targetId");
  value.targetId.isValidFlag = C2xIsTokenAvailable(packetHandle, "VPM", newPath);
  if(value.targetId.isValidFlag==1)
  {
    value.targetId.isValidFlag = 1;
    value.targetId.stringLength = C2xGetTokenData(packetHandle, "VPM", newPath, elcount(value.targetId.string), value.targetId.string);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "paymentEntityId");
  value.paymentEntityId = C2xGetTokenInt(packetHandle, "VPM", newPath);
  result = CheckLastError("VPM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "actionParameter");
  GetVPMTransInfoParams(packetHandle, value.actionParameter, newPath);
  result = CheckLastError("VPM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "accessCredentials");
  value.accessCredentials.isValidFlag = C2xIsTokenAvailable(packetHandle, "VPM", newPath);
  if(value.accessCredentials.isValidFlag==1)
  {
    value.accessCredentials.isValidFlag = 1;
    value.accessCredentials.stringLength = C2xGetTokenData(packetHandle, "VPM", newPath, elcount(value.accessCredentials.string), value.accessCredentials.string);
  }
  return result;
}

int SetVPMAction_RequestParams(LONG packetHandle, struct VPMAction_Request value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "time");
  SetVPMDDateTimeParams(packetHandle, value.time, newPath);
  result = CheckLastError("VPM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "mode");
  C2xSetTokenInt64(packetHandle, "VPM", newPath, value.mode);
  result = CheckLastError("VPM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "sourceId");
  C2xSetTokenData(packetHandle, "VPM", newPath, value.sourceId.stringLength, value.sourceId.string);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "targetId");
  if(value.targetId.isValidFlag==1)
  {
    C2xSetTokenData(packetHandle, "VPM", newPath, value.targetId.stringLength, value.targetId.string);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "VPM", newPath) )
    {
      C2xRemoveToken(packetHandle, "VPM", newPath);
    }
  }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "paymentEntityId");
  C2xSetTokenInt(packetHandle, "VPM", newPath, value.paymentEntityId);
  result = CheckLastError("VPM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "actionParameter");
  SetVPMTransInfoParams(packetHandle, value.actionParameter, newPath);
  result = CheckLastError("VPM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "accessCredentials");
  if(value.accessCredentials.isValidFlag==1)
  {
    C2xSetTokenData(packetHandle, "VPM", newPath, value.accessCredentials.stringLength, value.accessCredentials.string);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "VPM", newPath) )
    {
      C2xRemoveToken(packetHandle, "VPM", newPath);
    }
  }

  return result;
}

