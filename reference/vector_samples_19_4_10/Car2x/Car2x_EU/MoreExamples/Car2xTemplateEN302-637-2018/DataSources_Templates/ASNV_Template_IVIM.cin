int API_GetIVIMParams(LONG packetHandle, struct IVIM value)
{
  int result;
  result = 0;

  value.header.isValidFlag = 1;
  GetIVIMItsPduHeaderParams(packetHandle, value.header, "header");
  result = CheckLastError("IVIM", gkFuncRefGet, result);

  value.ivi.isValidFlag = 1;
  GetIVIMIviStructureParams(packetHandle, value.ivi, "ivi");
  result = CheckLastError("IVIM", gkFuncRefGet, result);

  return result;
}

int API_SetIVIMParams(LONG packetHandle, struct IVIM value)
{
  int result;
  result = 0;

  SetIVIMItsPduHeaderParams(packetHandle, value.header, "header");
  result = CheckLastError("IVIM", gkFuncRefGet, result);

  SetIVIMIviStructureParams(packetHandle, value.ivi, "ivi");
  result = CheckLastError("IVIM", gkFuncRefGet, result);

  return result;
}

