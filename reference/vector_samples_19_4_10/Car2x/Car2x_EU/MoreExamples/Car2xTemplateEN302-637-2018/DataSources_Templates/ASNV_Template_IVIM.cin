        struct OPT_WORD_ASN platoonMinSpeedLimit;  // INTEGER, OPTIONAL, 0..16383, unavailable(16383);
        struct OPT_WORD_ASN platoonSpeedRecommendation;  // INTEGER, OPTIONAL, 0..16383, unavailable(16383);
        struct IVIMRoadSignCodes roadSignCodes;  // SEQUENCEOF, OPTIONAL;
        struct IVIMConstraintTextLines2 extraText;  // SEQUENCEOF, OPTIONAL;
    };
    
    struct IVIMPlatooningRules {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        INT length;
        struct IVIMPlatooningRule arrayValue[5];  // SEQUENCE;
    };
    
    struct IVIMAvcPart {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        struct IVIMZoneIds detectionZoneIds;  // SEQUENCEOF, OPTIONAL;
        struct IVIMZoneIds relevanceZoneIds;  // SEQUENCEOF;
        struct OPT_BYTE_ASN direction;  // INTEGER, OPTIONAL, 0..3, sameDirection(0), oppositeDirection(1), bothDirections(2), valueNotUsed(3);
        struct IVIMLanePositions applicableLanes;  // SEQUENCEOF, OPTIONAL;
        struct IVIMVehicleCharacteristicsList vehicleCharacteristics;  // SEQUENCEOF, OPTIONAL;
        struct IVIMAutomatedVehicleRules automatedVehicleRules;  // SEQUENCEOF, OPTIONAL;
        struct IVIMPlatooningRules platooningRules;  // SEQUENCEOF, OPTIONAL;
    };
    
    struct IVIMAutomatedVehicleContainer {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        INT length;
        struct IVIMAvcPart arrayValue[16];  // SEQUENCE;
    };
    
    struct IVIMRoadSegmentReferenceID {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        struct OPT_WORD_ASN region;  // INTEGER, OPTIONAL, 0..65535;
        WORD id;  // INTEGER, 0..65535;
    };
    
    struct IVIMIntersectionReferenceID {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        struct OPT_WORD_ASN region;  // INTEGER, OPTIONAL, 0..65535;
        WORD id;  // INTEGER, 0..65535;
    };
    
    struct IVIMMapReference {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        INT choice;
        struct IVIMRoadSegmentReferenceID roadsegment;  // SEQUENCE;
        struct IVIMIntersectionReferenceID intersection;  // SEQUENCE;
    };
    
    struct IVIMLaneIds {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        INT length;
        BYTE arrayValue[16];  // INTEGER, 0..255;
    };
    
    struct IVIMMlcPart {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        BYTE zoneId;  // INTEGER, 1..32;
        struct IVIMLaneIds laneIds;  // SEQUENCEOF, OPTIONAL;
    };
    
    struct IVIMMlcParts {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        INT length;
        struct IVIMMlcPart arrayValue[16];  // SEQUENCE;
    };
    
    struct IVIMMapLocationContainer {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        struct IVIMMapReference reference;  // CHOICE;
        struct IVIMMlcParts parts;  // SEQUENCEOF;
    };
    
    struct IVIMRscPart {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        struct IVIMZoneIds detectionZoneIds;  // SEQUENCEOF, OPTIONAL;
        struct IVIMZoneIds relevanceZoneIds;  // SEQUENCEOF;
        struct OPT_BYTE_ASN direction;  // INTEGER, OPTIONAL, 0..3, sameDirection(0), oppositeDirection(1), bothDirections(2), valueNotUsed(3);
        struct IVIMRoadSurfaceStaticCharacteristics roadSurfaceStaticCharacteristics;  // SEQUENCE, OPTIONAL;
        struct IVIMRoadSurfaceDynamicCharacteristics roadSurfaceDynamicCharacteristics;  // SEQUENCE, OPTIONAL;
    };
    
    struct IVIMRoadSurfaceContainer {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        INT length;
        struct IVIMRscPart arrayValue[16];  // SEQUENCE;
    };
    
    struct IVIMIviContainer {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        INT choice;
        struct IVIMGeographicLocationContainer glc;  // SEQUENCE;
        struct IVIMGeneralIviContainer giv;  // SEQUENCEOF;
        struct IVIMRoadConfigurationContainer rcc;  // SEQUENCEOF;
        struct IVIMTextContainer tc;  // SEQUENCEOF;
        struct IVIMLayoutContainer lac;  // SEQUENCE;
        struct IVIMAutomatedVehicleContainer avc;  // SEQUENCEOF;
        struct IVIMMapLocationContainer mlc;  // SEQUENCE;
        struct IVIMRoadSurfaceContainer rsc;  // SEQUENCEOF;
    };
    
    struct IVIMIviContainers {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        INT length;
        struct IVIMIviContainer arrayValue[8];  // CHOICE;
    };
    
    struct IVIMIviStructure {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        struct IVIMIviManagementContainer mandatory;  // SEQUENCE;
        struct IVIMIviContainers optional;  // SEQUENCEOF, OPTIONAL;
    };
    
    struct IVIM {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        struct IVIMItsPduHeader header;  // SEQUENCE;
        struct IVIMIviStructure ivi;  // SEQUENCE;
    };
    
}

/*
// init function to create a simple packet handle
*/ 
LONG API_InitIVIMPacket()
{
  return C2xInitPacket("IVIM"); 
}

/*
// init function to create a simple packet handle and
// initialize the struct with valid data
*/ 
LONG API_InitIVIMPacket(struct IVIM msgStruct)
{
  long pktHandle;

  pktHandle = API_InitIVIMPacket();

  if (pktHandle != 0)
  {
    // create valid message and application data
    if (C2xCompletePacket(pktHandle) == 0) 
    {
      API_GetIVIMParams(pktHandle, msgStruct);
    }
  }
  return pktHandle;
}

/*
// init function to create a packet with security layer and
// initialize the struct with valid data
*/ 
LONG API_InitIVIMPacket(struct IVIM msgStruct, char packetTypeDesignator[], char certificateName[])
{
  long pktHandle, certHdl;

  // initialize the packet
  pktHandle = C2xInitPacket("IVIM", packetTypeDesignator);

  if (pktHandle != 0)
  {
    certHdl = C2xSecCertificateGetHandle(certificateName);  // get the certificate handle for the cert with name "certificateName"
    if (certHdl != 0) 
    {
      C2xSecPacketSetSignerHandle(pktHandle, certHdl); // set the certHdl to the packet
    }

    // create valid message and application data
    if (C2xCompletePacket(pktHandle) == 0) 
    {
      // copy application data to the application structure
      API_GetIVIMParams(pktHandle, msgStruct);
    }
  }
  return pktHandle;
}
    

int GetIVIMItsPduHeaderParams(LONG packetHandle, struct IVIMItsPduHeader value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "protocolVersion");
  value.protocolVersion = C2xGetTokenInt(packetHandle, "IVIM", newPath);
  result = CheckLastError("IVIM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "messageID");
  value.messageID = C2xGetTokenInt(packetHandle, "IVIM", newPath);
  result = CheckLastError("IVIM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "stationID");
  value.stationID = C2xGetTokenInt64(packetHandle, "IVIM", newPath);
  result = CheckLastError("IVIM", gkFuncRefGet, result);

  return result;
}

int SetIVIMItsPduHeaderParams(LONG packetHandle, struct IVIMItsPduHeader value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "protocolVersion");
  C2xSetTokenInt(packetHandle, "IVIM", newPath, value.protocolVersion);
  result = CheckLastError("IVIM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "messageID");
  C2xSetTokenInt(packetHandle, "IVIM", newPath, value.messageID);
  result = CheckLastError("IVIM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "stationID");
  C2xSetTokenInt64(packetHandle, "IVIM", newPath, value.stationID);
  result = CheckLastError("IVIM", gkFuncRefGet, result);

  return result;
}

int GetIVIMProviderParams(LONG packetHandle, struct IVIMProvider value, char oldPath[])
{
  char newPath[300]; 
  int j; 
  int k;
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "countryCode");
  value.countryCode.isValidFlag = 1;
  value.countryCode.stringLength = C2xGetTokenLengthBit(packetHandle, "IVIM", newPath);
  if ((result = CheckLastError("IVIM", gkFuncRefGet, result))==0)
  {
    if(value.countryCode.stringLength > 0)
    {
      for(j=0; j<value.countryCode.stringLength; j++)
      {
        if(C2xGetTokenBitOfBitString(packetHandle, "IVIM", newPath, j) == 0)
        {
          value.countryCode.string[j] = '0';
        }
        else if(C2xGetTokenBitOfBitString(packetHandle, "IVIM", newPath, j) == 1)
        {
          value.countryCode.string[j] = '1';
        }

        if(value.countryCode.stringLength == 1)
        {
          value.countryCode.string[1] = '0';
        }
        result = CheckLastError("IVIM", gkFuncRefGet, result);
      }
    }
    else
    {
      for(k = value.countryCode.stringLength+1; k > -1; k--)
      {
        if(value.countryCode.string[k] == '1')
        {
          value.countryCode.string[k] = '0';
        }
      }
    }
  }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "providerIdentifier");
  value.providerIdentifier = C2xGetTokenInt(packetHandle, "IVIM", newPath);
  result = CheckLastError("IVIM", gkFuncRefGet, result);

  return result;
}

int SetIVIMProviderParams(LONG packetHandle, struct IVIMProvider value, char oldPath[])
{
  char newPath[300]; 
  int j;
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "countryCode");
    for(j=0; j<value.countryCode.stringLength; j++)
    {
      if(value.countryCode.string[j] == '0')
      {
        C2xSetTokenBitOfBitString(packetHandle, "IVIM", newPath, j, 0);
      }
      else
      {
        C2xSetTokenBitOfBitString(packetHandle, "IVIM", newPath, j, 1);
      }
      result = CheckLastError("IVIM", gkFuncRefGet, result);
    }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "providerIdentifier");
  C2xSetTokenInt(packetHandle, "IVIM", newPath, value.providerIdentifier);
  result = CheckLastError("IVIM", gkFuncRefGet, result);

  return result;
}

