int GetIVIMMapReferenceParams(LONG packetHandle, struct IVIMMapReference value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  value.choice = C2xGetTokenInt(packetHandle, "IVIM", oldPath);

  switch(value.choice)
  {
    case 0:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "roadsegment");
      GetIVIMRoadSegmentReferenceIDParams(packetHandle, value.roadsegment, newPath);
      result = CheckLastError("IVIM", gkFuncRefGet, result);
    }
    break;
    case 1:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "intersection");
      GetIVIMIntersectionReferenceIDParams(packetHandle, value.intersection, newPath);
      result = CheckLastError("IVIM", gkFuncRefGet, result);
    }
    break;
  }
  return result;
}

