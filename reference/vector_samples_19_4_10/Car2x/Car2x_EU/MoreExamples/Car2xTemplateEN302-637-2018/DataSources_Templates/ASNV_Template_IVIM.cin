{
  char newPath[300];
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "priority");
  C2xSetTokenInt(packetHandle, "IVIM", newPath, value.priority);
  result = CheckLastError("IVIM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "allowedSaeAutomationLevels");
  SetIVIMSaeAutomationLevelsParams(packetHandle, value.allowedSaeAutomationLevels, newPath);
  result = CheckLastError("IVIM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "maxNoOfVehicles");
  if(value.maxNoOfVehicles.isValidFlag==1)
  {
    if (value.maxNoOfVehicles.value < 2)
    {
        C2xSetTokenInt(packetHandle, "IVIM", newPath, 2);
    }
    else if (value.maxNoOfVehicles.value > 64)
    {
        C2xSetTokenInt(packetHandle, "IVIM", newPath, 64);
    }
    else
    {
        C2xSetTokenInt(packetHandle, "IVIM", newPath, value.maxNoOfVehicles.value);
    }
    result = CheckLastError("IVIM", gkFuncRefGet, result);
  }
  else
