int GetIVIMGeneralIviContainerParams(LONG packetHandle, struct IVIMGeneralIviContainer value, char oldPath[])
{
  char newPath[300]; 
  int i;
  int result;

  result = 0;

  value.length = C2xGetTokenInt(packetHandle, "IVIM", oldPath);
  if((result = CheckLastError("IVIM", gkFuncRefGet, result))==0)
  {
    for(i=0; i<value.length; i++)
    {
      snprintf(newPath, elcount(newPath), "%s[%d]", oldPath, i);
      GetIVIMGicPartParams(packetHandle, value.arrayValue[i], newPath);
      result = CheckLastError("IVIM", gkFuncRefGet, result);
    }
  }
  return result;
}

int SetIVIMGeneralIviContainerParams(LONG packetHandle, struct IVIMGeneralIviContainer value, char oldPath[])
{
  char newPath[300]; 
  int i;
  int result;

  result = 0;

  C2xRemoveToken(packetHandle, "IVIM", oldPath);
  for(i=0; i<value.length; i++)
  {
    snprintf(newPath, elcount(newPath), "%s[%d]", oldPath, i);
    SetIVIMGicPartParams(packetHandle, value.arrayValue[i], newPath);
    result = CheckLastError("IVIM", gkFuncRefGet, result);
  }
  return result;
}

