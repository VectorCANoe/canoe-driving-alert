  value.detectionZoneIds.isValidFlag = C2xIsTokenAvailable(packetHandle, "IVIM", newPath);
  if(value.detectionZoneIds.isValidFlag==1)
  {
    GetIVIMZoneIdsParams(packetHandle, value.detectionZoneIds, newPath);
    result = CheckLastError("IVIM", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "relevanceZoneIds");
  GetIVIMZoneIdsParams(packetHandle, value.relevanceZoneIds, newPath);
  result = CheckLastError("IVIM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "direction");
  value.direction.isValidFlag = C2xIsTokenAvailable(packetHandle, "IVIM", newPath);
  if(value.direction.isValidFlag==1)
  {
    value.direction.value = C2xGetTokenInt(packetHandle, "IVIM", newPath);
    result = CheckLastError("IVIM", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "roadSurfaceStaticCharacteristics");
  value.roadSurfaceStaticCharacteristics.isValidFlag = C2xIsTokenAvailable(packetHandle, "IVIM", newPath);
  if(value.roadSurfaceStaticCharacteristics.isValidFlag==1)
  {
    GetIVIMRoadSurfaceStaticCharacteristicsParams(packetHandle, value.roadSurfaceStaticCharacteristics, newPath);
    result = CheckLastError("IVIM", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "roadSurfaceDynamicCharacteristics");
  value.roadSurfaceDynamicCharacteristics.isValidFlag = C2xIsTokenAvailable(packetHandle, "IVIM", newPath);
  if(value.roadSurfaceDynamicCharacteristics.isValidFlag==1)
  {
    GetIVIMRoadSurfaceDynamicCharacteristicsParams(packetHandle, value.roadSurfaceDynamicCharacteristics, newPath);
    result = CheckLastError("IVIM", gkFuncRefGet, result);
  }
  return result;
}

