  {
    C2xSetTokenInt(packetHandle, "IVIM", newPath, value.minGapBetweenVehicles.value);
    result = CheckLastError("IVIM", gkFuncRefGet, result);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "IVIM", newPath) )
    {
      C2xRemoveToken(packetHandle, "IVIM", newPath);
    }
  }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "platoonMaxSpeedLimit");
  if(value.platoonMaxSpeedLimit.isValidFlag==1)
  {
    C2xSetTokenInt(packetHandle, "IVIM", newPath, value.platoonMaxSpeedLimit.value);
    result = CheckLastError("IVIM", gkFuncRefGet, result);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "IVIM", newPath) )
    {
      C2xRemoveToken(packetHandle, "IVIM", newPath);
    }
  }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "platoonMinSpeedLimit");
  if(value.platoonMinSpeedLimit.isValidFlag==1)
  {
    C2xSetTokenInt(packetHandle, "IVIM", newPath, value.platoonMinSpeedLimit.value);
    result = CheckLastError("IVIM", gkFuncRefGet, result);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "IVIM", newPath) )
    {
      C2xRemoveToken(packetHandle, "IVIM", newPath);
    }
  }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "platoonSpeedRecommendation");
  if(value.platoonSpeedRecommendation.isValidFlag==1)
  {
    C2xSetTokenInt(packetHandle, "IVIM", newPath, value.platoonSpeedRecommendation.value);
    result = CheckLastError("IVIM", gkFuncRefGet, result);
  }
  else
  {
