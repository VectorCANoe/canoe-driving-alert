    }
    else if (value.timeToCollision.value > 10000)
    {
        C2xSetTokenInt(packetHandle, "DENM", newPath, 10000);
    }
    else
    {
        C2xSetTokenInt(packetHandle, "DENM", newPath, value.timeToCollision.value);
    }
    result = CheckLastError("DENM", gkFuncRefGet, result);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "DENM", newPath) )
    {
      C2xRemoveToken(packetHandle, "DENM", newPath);
    }
  }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "impactSection");
  if(value.impactSection.isValidFlag==1)
  {
    C2xSetTokenInt(packetHandle, "DENM", newPath, value.impactSection.value);
    result = CheckLastError("DENM", gkFuncRefGet, result);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "DENM", newPath) )
