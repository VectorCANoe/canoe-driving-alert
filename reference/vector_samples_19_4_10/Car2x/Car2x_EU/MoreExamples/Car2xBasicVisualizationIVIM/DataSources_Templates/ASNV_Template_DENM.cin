      result = CheckLastError("DENM", gkFuncRefGet, result);
    }
    break;
    case 3:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "lanePositionWithLateralDetails");
      GetDENMLanePositionWithLateralDetailsParams(packetHandle, value.lanePositionWithLateralDetails, newPath);
      result = CheckLastError("DENM", gkFuncRefGet, result);
    }
    break;
    case 4:
    {
