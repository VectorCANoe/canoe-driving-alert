int GetDENMLowerTriangularPositiveSemidefiniteMatrixParams(LONG packetHandle, struct DENMLowerTriangularPositiveSemidefiniteMatrix value, char oldPath[])
{
  char newPath[300]; 
  int j; 
  int k;
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "componentsIncludedIntheMatrix");
  value.componentsIncludedIntheMatrix.isValidFlag = 1;
  value.componentsIncludedIntheMatrix.stringLength = C2xGetTokenLengthBit(packetHandle, "DENM", newPath);
  if ((result = CheckLastError("DENM", gkFuncRefGet, result))==0)
  {
    if(value.componentsIncludedIntheMatrix.stringLength > 0)
    {
      for(j=0; j<value.componentsIncludedIntheMatrix.stringLength; j++)
      {
        if(C2xGetTokenBitOfBitString(packetHandle, "DENM", newPath, j) == 0)
        {
          value.componentsIncludedIntheMatrix.string[j] = '0';
        }
        else if(C2xGetTokenBitOfBitString(packetHandle, "DENM", newPath, j) == 1)
        {
          value.componentsIncludedIntheMatrix.string[j] = '1';
        }

        if(value.componentsIncludedIntheMatrix.stringLength == 1)
        {
          value.componentsIncludedIntheMatrix.string[1] = '0';
        }
        result = CheckLastError("DENM", gkFuncRefGet, result);
      }
    }
    else
    {
      for(k = value.componentsIncludedIntheMatrix.stringLength+1; k > -1; k--)
      {
        if(value.componentsIncludedIntheMatrix.string[k] == '1')
        {
          value.componentsIncludedIntheMatrix.string[k] = '0';
        }
      }
    }
  }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "matrix");
  GetDENMLowerTriangularPositiveSemidefiniteMatrixColumnsParams(packetHandle, value.matrix, newPath);
  result = CheckLastError("DENM", gkFuncRefGet, result);

  return result;
}

int SetDENMLowerTriangularPositiveSemidefiniteMatrixParams(LONG packetHandle, struct DENMLowerTriangularPositiveSemidefiniteMatrix value, char oldPath[])
{
  char newPath[300]; 
  int j;
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "componentsIncludedIntheMatrix");
    for(j=0; j<value.componentsIncludedIntheMatrix.stringLength; j++)
    {
      if(value.componentsIncludedIntheMatrix.string[j] == '0')
      {
        C2xSetTokenBitOfBitString(packetHandle, "DENM", newPath, j, 0);
      }
      else
      {
        C2xSetTokenBitOfBitString(packetHandle, "DENM", newPath, j, 1);
      }
      result = CheckLastError("DENM", gkFuncRefGet, result);
    }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "matrix");
  SetDENMLowerTriangularPositiveSemidefiniteMatrixColumnsParams(packetHandle, value.matrix, newPath);
  result = CheckLastError("DENM", gkFuncRefGet, result);

  return result;
}

