      C2xRemoveToken(packetHandle, "DENM", newPath);
    }
  }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "estimatedBrakingDistance");
  if(value.estimatedBrakingDistance.isValidFlag==1)
  {
    C2xSetTokenInt(packetHandle, "DENM", newPath, value.estimatedBrakingDistance.value);
    result = CheckLastError("DENM", gkFuncRefGet, result);
