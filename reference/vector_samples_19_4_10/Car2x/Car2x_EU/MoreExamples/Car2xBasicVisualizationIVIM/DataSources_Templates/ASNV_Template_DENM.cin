  else
  {
    if( C2xIsTokenAvailable(packetHandle, "DENM", newPath) )
    {
      C2xRemoveToken(packetHandle, "DENM", newPath);
    }
  }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "timeToCollision");
  if(value.timeToCollision.isValidFlag==1)
  {
    if (value.timeToCollision.value < 1)
