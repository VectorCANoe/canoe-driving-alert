  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "objectClass");
  SetDENMObjectClassParams(packetHandle, value.objectClass, newPath);
  result = CheckLastError("DENM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "confidence");
  if (value.confidence < 1)
  {
    C2xSetTokenInt(packetHandle, "DENM", newPath, 1);
  }
  else if (value.confidence > 101)
  {
    C2xSetTokenInt(packetHandle, "DENM", newPath, 101);
  }
  else
  {
    C2xSetTokenInt(packetHandle, "DENM", newPath, value.confidence);
  }
  result = CheckLastError("DENM", gkFuncRefGet, result);

  return result;
}

