int GetDENMVruClusterInformationParams(LONG packetHandle, struct DENMVruClusterInformation value, char oldPath[])
{
  char newPath[300]; 
  int j; 
  int k;
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "clusterId");
  value.clusterId.isValidFlag = C2xIsTokenAvailable(packetHandle, "DENM", newPath);
  if(value.clusterId.isValidFlag==1)
  {
    value.clusterId.value = C2xGetTokenInt(packetHandle, "DENM", newPath);
    result = CheckLastError("DENM", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "clusterBoundingBoxShape");
  value.clusterBoundingBoxShape.isValidFlag = C2xIsTokenAvailable(packetHandle, "DENM", newPath);
  if(value.clusterBoundingBoxShape.isValidFlag==1)
  {
    GetDENMShapeParams(packetHandle, value.clusterBoundingBoxShape, newPath);
    result = CheckLastError("DENM", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "clusterCardinalitySize");
  value.clusterCardinalitySize = C2xGetTokenInt(packetHandle, "DENM", newPath);
  result = CheckLastError("DENM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "clusterProfiles");
  value.clusterProfiles.isValidFlag = C2xIsTokenAvailable(packetHandle, "DENM", newPath);
  if(value.clusterProfiles.isValidFlag==1)
  {
    value.clusterProfiles.isValidFlag = 1;
    value.clusterProfiles.stringLength = C2xGetTokenLengthBit(packetHandle, "DENM", newPath);
    if ((result = CheckLastError("DENM", gkFuncRefGet, result))==0)
    {
      if(value.clusterProfiles.stringLength > 0)
      {
        for(j=0; j<value.clusterProfiles.stringLength; j++)
        {
          if(C2xGetTokenBitOfBitString(packetHandle, "DENM", newPath, j) == 0)
          {
            value.clusterProfiles.string[j] = '0';
          }
          else if(C2xGetTokenBitOfBitString(packetHandle, "DENM", newPath, j) == 1)
          {
            value.clusterProfiles.string[j] = '1';
          }

          if(value.clusterProfiles.stringLength == 1)
          {
            value.clusterProfiles.string[1] = '0';
          }
          result = CheckLastError("DENM", gkFuncRefGet, result);
        }
      }
      else
      {
        for(k = value.clusterProfiles.stringLength+1; k > -1; k--)
        {
          if(value.clusterProfiles.string[k] == '1')
          {
            value.clusterProfiles.string[k] = '0';
          }
        }
      }
    }

  }
  return result;
}

int SetDENMVruClusterInformationParams(LONG packetHandle, struct DENMVruClusterInformation value, char oldPath[])
{
  char newPath[300]; 
  int j;
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "clusterId");
  if(value.clusterId.isValidFlag==1)
  {
    C2xSetTokenInt(packetHandle, "DENM", newPath, value.clusterId.value);
    result = CheckLastError("DENM", gkFuncRefGet, result);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "DENM", newPath) )
    {
      C2xRemoveToken(packetHandle, "DENM", newPath);
    }
  }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "clusterBoundingBoxShape");
  if(value.clusterBoundingBoxShape.isValidFlag==1)
  {
    SetDENMShapeParams(packetHandle, value.clusterBoundingBoxShape, newPath);
    result = CheckLastError("DENM", gkFuncRefGet, result);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "DENM", newPath) )
    {
      C2xRemoveToken(packetHandle, "DENM", newPath);
    }
  }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "clusterCardinalitySize");
  C2xSetTokenInt(packetHandle, "DENM", newPath, value.clusterCardinalitySize);
  result = CheckLastError("DENM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "clusterProfiles");
  if(value.clusterProfiles.isValidFlag==1)
  {
      for(j=0; j<value.clusterProfiles.stringLength; j++)
      {
        if(value.clusterProfiles.string[j] == '0')
        {
          C2xSetTokenBitOfBitString(packetHandle, "DENM", newPath, j, 0);
        }
        else
        {
          C2xSetTokenBitOfBitString(packetHandle, "DENM", newPath, j, 1);
        }
        result = CheckLastError("DENM", gkFuncRefGet, result);
      }
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "DENM", newPath) )
    {
      C2xRemoveToken(packetHandle, "DENM", newPath);
    }
  }

  return result;
}

