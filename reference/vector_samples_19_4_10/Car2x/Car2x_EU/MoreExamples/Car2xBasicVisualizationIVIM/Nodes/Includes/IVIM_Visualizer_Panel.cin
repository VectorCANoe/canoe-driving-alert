        @sysvar::IVIM09::areaDistanceA = areaDistanceA;
      }
      break;
    case 9:
      {
        @sysvar::IVIM10::id = ivimId;
        @sysvar::IVIM10::lat = lat;
        @sysvar::IVIM10::lon = lon;
        @sysvar::IVIM10::countGLC = glcCount;
        @sysvar::IVIM10::countGIV = givCount;
        @sysvar::IVIM10::countRCC = rccCount;
        @sysvar::IVIM10::countTC = tcCount;
        @sysvar::IVIM10::countAVC = avcCount;
        @sysvar::IVIM10::areaPosLat = areaPosLat;
        @sysvar::IVIM10::areaPosLon = areaPosLon;
        @sysvar::IVIM10::areaDistanceA = areaDistanceA;
      }
      break;
  }
  
  gPanelCurrentIndex++;
}

void UpdateContainerCounters(int iviNr, int glcCount, int givCount, int rccCount, int tcCount, int avcCount)
{  
  if (@sysvar::IVIM01::id == iviParams[iviNr].id)
  {
    @sysvar::IVIM01::countGLC = glcCount;
    @sysvar::IVIM01::countGIV = givCount;
    @sysvar::IVIM01::countRCC = rccCount;
    @sysvar::IVIM01::countTC = tcCount;
    @sysvar::IVIM01::countAVC = avcCount;
  }
  else if (@sysvar::IVIM02::id == iviParams[iviNr].id)
  {
    @sysvar::IVIM02::countGLC = glcCount;
    @sysvar::IVIM02::countGIV = givCount;
    @sysvar::IVIM02::countRCC = rccCount;
    @sysvar::IVIM02::countTC = tcCount;
    @sysvar::IVIM02::countAVC = avcCount;
  }
  else if (@sysvar::IVIM03::id == iviParams[iviNr].id)
  {
    @sysvar::IVIM03::countGLC = glcCount;
    @sysvar::IVIM03::countGIV = givCount;
    @sysvar::IVIM03::countRCC = rccCount;
    @sysvar::IVIM03::countTC = tcCount;
