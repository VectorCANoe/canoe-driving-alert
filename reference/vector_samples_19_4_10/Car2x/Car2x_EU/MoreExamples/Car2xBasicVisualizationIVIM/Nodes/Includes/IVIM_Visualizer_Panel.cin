        @sysvar::IVIM04::areaDistanceA = areaDistanceA;
      }
      break;
    case 4:
      {
        @sysvar::IVIM05::id = ivimId;
        @sysvar::IVIM05::lat = lat;
        @sysvar::IVIM05::lon = lon;
        @sysvar::IVIM05::countGLC = glcCount;
        @sysvar::IVIM05::countGIV = givCount;
        @sysvar::IVIM05::countRCC = rccCount;
        @sysvar::IVIM05::countTC = tcCount;
        @sysvar::IVIM05::countAVC = avcCount;
        @sysvar::IVIM05::areaPosLat = areaPosLat;
        @sysvar::IVIM05::areaPosLon = areaPosLon;
        @sysvar::IVIM05::areaDistanceA = areaDistanceA;
