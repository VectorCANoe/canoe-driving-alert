        @sysvar::IVIM06::areaPosLat = areaPosLat;
        @sysvar::IVIM06::areaPosLon = areaPosLon;
        @sysvar::IVIM06::areaDistanceA = areaDistanceA;
      }
      break;
    case 6:
      {
        @sysvar::IVIM07::id = ivimId;
        @sysvar::IVIM07::lat = lat;
        @sysvar::IVIM07::lon = lon;
