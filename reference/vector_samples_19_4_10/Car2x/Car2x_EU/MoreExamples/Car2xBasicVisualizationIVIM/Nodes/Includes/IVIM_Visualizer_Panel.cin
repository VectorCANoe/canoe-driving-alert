        @sysvar::IVIM07::areaDistanceA = areaDistanceA;
      }
      break;
    case 7:
      {
        @sysvar::IVIM08::id = ivimId;
        @sysvar::IVIM08::lat = lat;
        @sysvar::IVIM08::lon = lon;
