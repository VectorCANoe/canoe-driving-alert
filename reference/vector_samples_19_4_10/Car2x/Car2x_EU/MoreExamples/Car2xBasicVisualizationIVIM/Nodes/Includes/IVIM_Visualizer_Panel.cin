void FillPanel(int iviNr, int glcNr, int glcCount, int givCount, int rccCount, int tcCount, int avcCount, float areaPosLat, float areaPosLon, float areaDistanceA)
{
  float refPosLat, refPosLon;
  
  refPosLat = iviParams[iviNr].glc[glcNr].refLat / gFactorGeoPos;
  refPosLon = iviParams[iviNr].glc[glcNr].refLon / gFactorGeoPos;
  
  FillNextPanelField(iviParams[iviNr].id, refPosLat, refPosLon, glcCount, givCount, rccCount, tcCount, avcCount, areaPosLat, areaPosLon, areaDistanceA);
}

void FillNextPanelField(int ivimId, float lat, float lon, int glcCount, int givCount, int rccCount, int tcCount, int avcCount, float areaPosLat, float areaPosLon, float areaDistanceA)
{
  if (gPanelCurrentIndex > 9)
  {
    return;
  }
  
  switch (gPanelCurrentIndex)
  {
    case 0:
      {
        @sysvar::IVIM01::id = ivimId;
        @sysvar::IVIM01::lat = lat;
        @sysvar::IVIM01::lon = lon;
        @sysvar::IVIM01::countGLC = glcCount;
        @sysvar::IVIM01::countGIV = givCount;
        @sysvar::IVIM01::countRCC = rccCount;
        @sysvar::IVIM01::countTC = tcCount;
        @sysvar::IVIM01::countAVC = avcCount;
        @sysvar::IVIM01::areaPosLat = areaPosLat;
        @sysvar::IVIM01::areaPosLon = areaPosLon;
        @sysvar::IVIM01::areaDistanceA = areaDistanceA;
      }
      break;
    case 1:
      {
        @sysvar::IVIM02::id = ivimId;
        @sysvar::IVIM02::lat = lat;
        @sysvar::IVIM02::lon = lon;
        @sysvar::IVIM02::countGLC = glcCount;
        @sysvar::IVIM02::countGIV = givCount;
        @sysvar::IVIM02::countRCC = rccCount;
        @sysvar::IVIM02::countTC = tcCount;
        @sysvar::IVIM02::countAVC = avcCount;
        @sysvar::IVIM02::areaPosLat = areaPosLat;
        @sysvar::IVIM02::areaPosLon = areaPosLon;
        @sysvar::IVIM02::areaDistanceA = areaDistanceA;
      }
      break;
    case 2:
      {
        @sysvar::IVIM03::id = ivimId;
        @sysvar::IVIM03::lat = lat;
        @sysvar::IVIM03::lon = lon;
        @sysvar::IVIM03::countGLC = glcCount;
        @sysvar::IVIM03::countGIV = givCount;
        @sysvar::IVIM03::countRCC = rccCount;
        @sysvar::IVIM03::countTC = tcCount;
        @sysvar::IVIM03::countAVC = avcCount;
        @sysvar::IVIM03::areaPosLat = areaPosLat;
        @sysvar::IVIM03::areaPosLon = areaPosLon;
        @sysvar::IVIM03::areaDistanceA = areaDistanceA;
      }
      break;
    case 3:
      {
        @sysvar::IVIM04::id = ivimId;
        @sysvar::IVIM04::lat = lat;
        @sysvar::IVIM04::lon = lon;
        @sysvar::IVIM04::countGLC = glcCount;
