/*@!Encoding:1252*/
//////////////////////////////
////// MoveToIVIM Panel //////
//////////////////////////////

void VisualizeIVIMArea(float areaPosLat, float areaPosLon, float distanceA)
{
  // Area position
  if (gAreaPositionHandle == 0)
  {
    gAreaPositionHandle = CreateMapObject(Cross);
  }
  SetMapObjectPosition(gAreaPositionHandle, areaPosLat, areaPosLon);
  SetMapObjectSize(gAreaPositionHandle, 5);
  SetMapObjectPenWidth(gAreaPositionHandle, 3);
  SetMapObjectLineColor(gAreaPositionHandle, makeRGB(255, 0, 0));
  DrawMapObject(gAreaPositionHandle);
  
  // Area perimeter
  if (gAreaPerimeterHandle == 0)
  {
    gAreaPerimeterHandle = CreateMapObject(Ellipse);
  }
  SetMapObjectPosition(gAreaPerimeterHandle, areaPosLat, areaPosLon);
  SetMapObjectSize(gAreaPerimeterHandle, distanceA * 2, distanceA * 2);
  SetMapObjectLineColor(gAreaPerimeterHandle, makeRGB(255, 0, 0));
  DrawMapObject(gAreaPerimeterHandle);
}

void VisualizeIVIMAreaForId(float areaPosLat, float areaPosLon, float distanceA)
{
  // Area position
  if (gAreaPositionHandleForId == 0)
  {
    gAreaPositionHandleForId = CreateMapObject(Cross);
  }
  SetMapObjectPosition(gAreaPositionHandleForId, areaPosLat, areaPosLon);
  SetMapObjectSize(gAreaPositionHandleForId, 5);
  SetMapObjectPenWidth(gAreaPositionHandleForId, 3);
  SetMapObjectLineColor(gAreaPositionHandleForId, makeRGB(0, 0, 255));
  DrawMapObject(gAreaPositionHandleForId);
  
  // Area perimeter
  if (gAreaPerimeterHandleForId == 0)
  {
    gAreaPerimeterHandleForId = CreateMapObject(Ellipse);
  }
  SetMapObjectPosition(gAreaPerimeterHandleForId, areaPosLat, areaPosLon);
  SetMapObjectSize(gAreaPerimeterHandleForId, distanceA * 2, distanceA * 2);
  SetMapObjectLineColor(gAreaPerimeterHandleForId, makeRGB(0, 0, 255));
  DrawMapObject(gAreaPerimeterHandleForId);
}

void MoveToPosition(float latitude, float longitude)
{
  if (latitude != 0 && longitude != 0)
  {
    SetMapPosition(latitude, longitude);
  }
}

on sysvar_update IVIM01::moveToPressed
{
  MoveToPosition(@sysvar::IVIM01::lat, @sysvar::IVIM01::lon);
  VisualizeIVIMAreaForId((float)@sysvar::IVIM01::areaPosLat / 10000000, (float)@sysvar::IVIM01::areaPosLon / 10000000, (float)@sysvar::IVIM01::areaDistanceA);
}

