void UpdatePanelForId(int id, int iviStatus, char stationName[], long stationType, double timeStamp)
{
  char defaultStr[4] = "N/A";
  char currentName[1024];
  
  if (@sysvar::IVIM01::id == id)
  {
    sysGetVariableString(sysvar::IVIM01::station, currentName, elcount(currentName));
    if (strncmp(defaultStr, currentName, strlen(defaultStr)) != 0 && strncmp(stationName, currentName, strlen(stationName)) != 0)
    {
      @sysvar::IVIM01::multipleSenders = 1;
    }
    sysSetVariableString(sysvar::IVIM01::station, stationName);
    
    @sysvar::IVIM01::stationType = stationType;
    @sysvar::IVIM01::timeStamp = timeStamp / 1000000000;
    @sysvar::IVIM01::statusIndicator = iviStatus;
    switch (iviStatus)
    {
      case 0: // New
      {
        sysSetVariableString(sysvar::IVIM01::statusString, "New");
      }
      break;
      case 1: // Update
      {
        sysSetVariableString(sysvar::IVIM01::statusString, "Update");
      }
      break;
      case 2: // Cancellation
      {
        sysSetVariableString(sysvar::IVIM01::statusString, "Canceled");
      }
      break;
    }
  }
  else if (@sysvar::IVIM02::id == id)
  {
    sysGetVariableString(sysvar::IVIM02::station, currentName, elcount(currentName));
