        @sysvar::IVIM08::areaPosLon = areaPosLon;
        @sysvar::IVIM08::areaDistanceA = areaDistanceA;
      }
      break;
    case 8:
      {
        @sysvar::IVIM09::id = ivimId;
        @sysvar::IVIM09::lat = lat;
        @sysvar::IVIM09::lon = lon;
        @sysvar::IVIM09::countGLC = glcCount;
        @sysvar::IVIM09::countGIV = givCount;
        @sysvar::IVIM09::countRCC = rccCount;
        @sysvar::IVIM09::countTC = tcCount;
        @sysvar::IVIM09::countAVC = avcCount;
        @sysvar::IVIM09::areaPosLat = areaPosLat;
