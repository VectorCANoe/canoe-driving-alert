int SetMIMAvmE2EProtectionParams(LONG packetHandle, struct MIMAvmE2EProtection value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "length");
  C2xSetTokenInt(packetHandle, "MIM", newPath, value.length);
  result = CheckLastError("MIM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "rollingCounter");
  C2xSetTokenInt(packetHandle, "MIM", newPath, value.rollingCounter);
  result = CheckLastError("MIM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "dataID");
  C2xSetTokenInt64(packetHandle, "MIM", newPath, value.dataID);
  result = CheckLastError("MIM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "crc32");
  C2xSetTokenInt64(packetHandle, "MIM", newPath, value.crc32);
  result = CheckLastError("MIM", gkFuncRefGet, result);

