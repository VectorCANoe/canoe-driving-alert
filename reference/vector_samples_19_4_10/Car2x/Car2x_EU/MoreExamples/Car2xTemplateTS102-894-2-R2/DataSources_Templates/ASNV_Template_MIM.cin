includes
{
 
}
variables
{
    struct MIMItsPduHeader {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        BYTE protocolVersion;  // INTEGER, 0..255;
        BYTE messageID;  // INTEGER, 0..255, denm(1), cam(2), poim(3), spatem(4), mapem(5), ivim(6), rfu1(7), rfu2(8), srem(9), ssem(10), evcsn(11), saem(12), rtcmem(13), cpm(14), imzm(15), vam(16), dsm(17), mim(18), mvm(19), mcm(20);
        DWORD stationID;  // INTEGER, 0..4294967295;
    };
    
    struct MIMAvmE2EProtection {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        WORD length;  // INTEGER, 0..65535;
        WORD rollingCounter;  // INTEGER, 0..65535;
        DWORD dataID;  // INTEGER, 0..4294967295;
        DWORD crc32;  // INTEGER, 0..4294967295;
    };
    
    struct MIMMIMDataControlField_rollingCounterFromMvm {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        INT length;
        WORD arrayValue[10];  // INTEGER, 0..65535;
    };
    
    struct MIMMIMDataControlField {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        struct OPT_DWORD_ASN checksum;  // INTEGER, OPTIONAL, 0..4294967295;
        struct OPT_QWORD_ASN mimGenerationTime;  // INTEGER, OPTIONAL, 0..4398046511103;
        struct MIMMIMDataControlField_rollingCounterFromMvm rollingCounterFromMvm;  // SEQUENCEOF;
        struct OPT_WORD_ASN proprietaryExtensionField;  // INTEGER, OPTIONAL, 0..65535;
    };
    
    struct MIMSessionMissionID {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        CHAR string[33];
        INT  stringLength;
    };
    
    struct MIMVehicleID {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        CHAR string[18];
        INT  stringLength;
    };
    
    struct MIMFacilityID {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        CHAR string[33];
        INT  stringLength;
    };
    
    struct MIMSystemManagementData {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        struct MIMSessionMissionID sessionID;  // IA5STRING, OPTIONAL;
        struct MIMSessionMissionID missionID;  // IA5STRING, OPTIONAL;
        struct MIMVehicleID vehicleID;  // IA5STRING, OPTIONAL;
        struct MIMFacilityID facilityID;  // IA5STRING, OPTIONAL;
    };
    
    struct MIMBlinking {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        QWORD vidRoPublicKey;  // INTEGER, 0..18446744073709551615;
        BYTE codeLength;  // INTEGER, 0..255;
        INT blinkingCommand;  // ENUMERATED, generateNewCode(0), generateNewCodeAndPrepareForFlashing(1), flashing(2), successful(3);
    };
    
    struct MIMVidRequest {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        INT choice;
        struct MIMBlinking blinking;  // SEQUENCE;
    };
    
    struct MIMDrivingPermission {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        QWORD expirationTime;  // INTEGER, 0..4398046511103;
        INT velocityMax;  // INTEGER, -16383..16383, negativeOutOfRange(-16383), positiveOutOfRange(16382), unavailable(16383);
        INT curvatureMin;  // INTEGER, -32768..32767, outOfRangeNegative(-32767), straight(0), outOfRangePositive(32767), unavailable(-32768);
        INT curvatureMax;  // INTEGER, -32768..32767, outOfRangeNegative(-32767), straight(0), outOfRangePositive(32767), unavailable(-32768);
        DWORD checksum;  // INTEGER, 0..4294967295;
    };
    
    struct MIMSafetyTimeSyncRequest {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        WORD challenge;  // INTEGER, 0..65535;
        DWORD checksum;  // INTEGER, 0..4294967295;
    };
    
    struct MIMDriveCommand {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        INT driveCommandAction;  // ENUMERATED, sleep(0), initialize(1), wait(2), drive(3), terminate(4);
        INT terminateReason;  // ENUMERATED, proceed(0), destinationReached(1), infrastructureError(2), vehicleError(3), backend(4), vehicleIdentificationError(5);
        struct OPT_ENUM_ASN gearRequest;  // ENUMERATED, OPTIONAL, park(0), backwards(1), neutral(2), forwards(3), unknown(4);
        struct OPT_ENUM_ASN directionIndicatorRequest;  // ENUMERATED, OPTIONAL, off(0), right(1), left(2), both(3), unknown(4);
        struct OPT_ENUM_ASN parkingBrakeRequest;  // ENUMERATED, OPTIONAL, disengage(0), engage(1);
        struct OPT_ENUM_ASN motorSystemRequest;  // ENUMERATED, OPTIONAL, off(0), on(1), unknown(2);
        struct OPT_ENUM_ASN emergencyStopRequest;  // ENUMERATED, OPTIONAL, inactive(0), precharge(1), active(2), tempError(3), suspend(4);
        struct OPT_ENUM_ASN interlockRequest;  // ENUMERATED, OPTIONAL, none(0), zonalInterlock(1), globalStop(2);
        struct OPT_ENUM_ASN hornRequest;  // ENUMERATED, OPTIONAL, none(0), singleHorn(1), doubleHorn(2), holdHorn(3);
    };
    
    struct MIMPose {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        LONG x;  // INTEGER, -524288..524287, negativeOutOfRange(-524287), positiveOutOfRange(524287), unavailable(-524288);
        LONG y;  // INTEGER, -524288..524287, negativeOutOfRange(-524287), positiveOutOfRange(524287), unavailable(-524288);
        WORD psi;  // INTEGER, 0..62833, xDirection(0), outOfRange(62832), unavailable(62833);
    };
    
    struct MIMDetectedVehiclePose {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        struct MIMPose detectedPose;  // SEQUENCE;
        QWORD poseMeasurementTime;  // INTEGER, 0..4398046511103;
    };
    
    struct MIMWayPoint {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        struct OPT_WORD_ASN index;  // INTEGER, OPTIONAL, 0..65535;
        struct MIMPose wayPointPose;  // SEQUENCE;
        INT velocity;  // INTEGER, -16383..16383, negativeOutOfRange(-16383), positiveOutOfRange(16382), unavailable(16383);
        INT curvature;  // INTEGER, -32768..32767, outOfRangeNegative(-32767), straight(0), outOfRangePositive(32767), unavailable(-32768);
        struct OPT_WORD_ASN pitchAngle;  // INTEGER, OPTIONAL, 0..3601, valueNotUsed(3600), unavailable(3601);
    };
    
    struct MIMPathSnippet {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        INT length;
        struct MIMWayPoint arrayValue[200];  // SEQUENCE;
    };
    
    struct MIMPathControl {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        struct MIMPathSnippet pathSnippet;  // SEQUENCEOF, OPTIONAL;
        LONG clearedDistanceOnPath;  // INTEGER, -524288..524287, negativeOutOfRange(-524287), positiveOutOfRange(524287), unavailable(-524288);
        struct OPT_INT_ASN situationalVelocityLimit;  // INTEGER, OPTIONAL, -16383..16383, negativeOutOfRange(-16383), positiveOutOfRange(16382), unavailable(16383);
    };
    
    struct MIMControlVelocity {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        INT velocity;  // INTEGER, -16383..16383, negativeOutOfRange(-16383), positiveOutOfRange(16382), unavailable(16383);
        struct OPT_LONG_ASN distanceToStop;  // INTEGER, OPTIONAL, -524288..524287, negativeOutOfRange(-524287), positiveOutOfRange(524287), unavailable(-524288);
    };
    
    struct MIMControlParameter {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        INT choice;
        INT controlAcceleration;  // INTEGER, -160..161, negativeOutOfRange(-160), positiveOutOfRange(160), unavailable(161);
        struct MIMControlVelocity controlVelocity;  // SEQUENCE;
    };
    
    struct MIMControlPoint {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        INT curvature;  // INTEGER, -32768..32767, outOfRangeNegative(-32767), straight(0), outOfRangePositive(32767), unavailable(-32768);
        struct MIMControlParameter controlParameter;  // CHOICE;
    };
    
    struct MIMControlTrajectory {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        INT length;
        struct MIMControlPoint arrayValue[50];  // SEQUENCE;
    };
    
    struct MIMStatePoint {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        struct MIMPose statePose;  // SEQUENCE;
        INT velocity;  // INTEGER, -16383..16383, negativeOutOfRange(-16383), positiveOutOfRange(16382), unavailable(16383);
    };
    
    struct MIMStateTrajectory {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        INT length;
        struct MIMStatePoint arrayValue[50];  // SEQUENCE;
    };
    
    struct MIMTrajectoryControl {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        QWORD timeReference;  // INTEGER, 0..4398046511103;
        struct OPT_ENUM_ASN driveDirection;  // ENUMERATED, OPTIONAL, forwards(0), backwards(1);
        struct MIMControlTrajectory controlTrajectory;  // SEQUENCEOF;
        struct MIMStateTrajectory stateTrajectory;  // SEQUENCEOF, OPTIONAL;
    };
    
    struct MIMControlInterface {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        INT choice;
        struct MIMPathControl pathControl;  // SEQUENCE;
        struct MIMTrajectoryControl trajectoryControl;  // SEQUENCE;
    };
    
    struct MIMMim {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        struct MIMMIMDataControlField mimDataControlField;  // SEQUENCE, OPTIONAL;
        struct MIMSystemManagementData systemManagementData;  // SEQUENCE, OPTIONAL;
        struct MIMVidRequest vehicleIdentification;  // CHOICE, OPTIONAL;
        struct MIMDrivingPermission drivingPermission;  // SEQUENCE, OPTIONAL;
        struct MIMSafetyTimeSyncRequest safetyTimeSyncRequest;  // SEQUENCE, OPTIONAL;
        struct MIMDriveCommand driveCommand;  // SEQUENCE, OPTIONAL;
        struct MIMDetectedVehiclePose detectedVehiclePose;  // SEQUENCE, OPTIONAL;
        struct MIMControlInterface controlInterface;  // CHOICE, OPTIONAL;
    };
    
    struct MIMMIM_mims {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        INT length;
        struct MIMMim arrayValue[32];  // SEQUENCE;
    };
    
    struct MIM {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        struct MIMItsPduHeader header;  // SEQUENCE;
        struct MIMAvmE2EProtection e2eProtection;  // SEQUENCE;
        struct MIMMIM_mims mims;  // SEQUENCEOF;
    };
    
}

/*
// init function to create a simple packet handle
*/ 
LONG API_InitMIMPacket()
{
  return C2xInitPacket("MIM"); 
}

/*
// init function to create a simple packet handle and
// initialize the struct with valid data
*/ 
LONG API_InitMIMPacket(struct MIM msgStruct)
{
  long pktHandle;

  pktHandle = API_InitMIMPacket();

  if (pktHandle != 0)
  {
    // create valid message and application data
    if (C2xCompletePacket(pktHandle) == 0) 
    {
      API_GetMIMParams(pktHandle, msgStruct);
    }
  }
  return pktHandle;
}

/*
// init function to create a packet with security layer and
// initialize the struct with valid data
*/ 
LONG API_InitMIMPacket(struct MIM msgStruct, char packetTypeDesignator[], char certificateName[])
{
  long pktHandle, certHdl;

  // initialize the packet
  pktHandle = C2xInitPacket("MIM", packetTypeDesignator);

  if (pktHandle != 0)
  {
    certHdl = C2xSecCertificateGetHandle(certificateName);  // get the certificate handle for the cert with name "certificateName"
    if (certHdl != 0) 
    {
      C2xSecPacketSetSignerHandle(pktHandle, certHdl); // set the certHdl to the packet
    }

    // create valid message and application data
    if (C2xCompletePacket(pktHandle) == 0) 
    {
      // copy application data to the application structure
      API_GetMIMParams(pktHandle, msgStruct);
    }
  }
  return pktHandle;
}
    

int GetMIMItsPduHeaderParams(LONG packetHandle, struct MIMItsPduHeader value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "protocolVersion");
  value.protocolVersion = C2xGetTokenInt(packetHandle, "MIM", newPath);
  result = CheckLastError("MIM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "messageID");
  value.messageID = C2xGetTokenInt(packetHandle, "MIM", newPath);
  result = CheckLastError("MIM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "stationID");
  value.stationID = C2xGetTokenInt64(packetHandle, "MIM", newPath);
  result = CheckLastError("MIM", gkFuncRefGet, result);

  return result;
}

int SetMIMItsPduHeaderParams(LONG packetHandle, struct MIMItsPduHeader value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "protocolVersion");
  C2xSetTokenInt(packetHandle, "MIM", newPath, value.protocolVersion);
  result = CheckLastError("MIM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "messageID");
  C2xSetTokenInt(packetHandle, "MIM", newPath, value.messageID);
  result = CheckLastError("MIM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "stationID");
  C2xSetTokenInt64(packetHandle, "MIM", newPath, value.stationID);
  result = CheckLastError("MIM", gkFuncRefGet, result);

  return result;
}

