  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "vehicleID");
  if(value.vehicleID.isValidFlag==1)
  {
    C2xSetTokenData(packetHandle, "MIM", newPath, value.vehicleID.stringLength, value.vehicleID.string);
    result = CheckLastError("MIM", gkFuncRefGet, result);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "MIM", newPath) )
    {
      C2xRemoveToken(packetHandle, "MIM", newPath);
    }
  }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "facilityID");
  if(value.facilityID.isValidFlag==1)
  {
    C2xSetTokenData(packetHandle, "MIM", newPath, value.facilityID.stringLength, value.facilityID.string);
    result = CheckLastError("MIM", gkFuncRefGet, result);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "MIM", newPath) )
    {
      C2xRemoveToken(packetHandle, "MIM", newPath);
    }
  }

  return result;
}

