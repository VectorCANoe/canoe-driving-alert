//  LONG packetHandle;
//  struct MIM payload;
//  //you need to set the values of the variable "payload" yourself
//  packetHandle = API_InitMIMPacket();
//  if (packetHandle!=0) {
//    if (API_SetMIMParams(packetHandle, payload)==0) {
