int GetMIMMIMDataControlField_rollingCounterFromMvmParams(LONG packetHandle, struct MIMMIMDataControlField_rollingCounterFromMvm value, char oldPath[])
{
  char newPath[300]; 
  int i;
  int result;

  result = 0;

  value.length = C2xGetTokenInt(packetHandle, "MIM", oldPath);
  if((result = CheckLastError("MIM", gkFuncRefGet, result))==0)
  {
    for(i=0; i<value.length; i++)
    {
      snprintf(newPath, elcount(newPath), "%s[%d]", oldPath, i);
      value.arrayValue[i] = C2xGetTokenInt64(packetHandle, "MIM", newPath);
      result = CheckLastError("MIM", gkFuncRefGet, result);
    }
  }
  return result;
}

int SetMIMMIMDataControlField_rollingCounterFromMvmParams(LONG packetHandle, struct MIMMIMDataControlField_rollingCounterFromMvm value, char oldPath[])
{
  char newPath[300]; 
  int i;
  int result;

  result = 0;

  C2xRemoveToken(packetHandle, "MIM", oldPath);
  for(i=0; i<value.length; i++)
  {
    snprintf(newPath, elcount(newPath), "%s[%d]", oldPath, i);
    C2xSetTokenInt64(packetHandle, "MIM", newPath, value.arrayValue[i]);
    result = CheckLastError("MIM", gkFuncRefGet, result);
  }
  return result;
}

int GetMIMMIMDataControlFieldParams(LONG packetHandle, struct MIMMIMDataControlField value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "checksum");
  value.checksum.isValidFlag = C2xIsTokenAvailable(packetHandle, "MIM", newPath);
  if(value.checksum.isValidFlag==1)
  {
    value.checksum.value = C2xGetTokenInt64(packetHandle, "MIM", newPath);
    result = CheckLastError("MIM", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "mimGenerationTime");
  value.mimGenerationTime.isValidFlag = C2xIsTokenAvailable(packetHandle, "MIM", newPath);
  if(value.mimGenerationTime.isValidFlag==1)
  {
    value.mimGenerationTime.value = C2xGetTokenInt64(packetHandle, "MIM", newPath);
    result = CheckLastError("MIM", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "rollingCounterFromMvm");
  GetMIMMIMDataControlField_rollingCounterFromMvmParams(packetHandle, value.rollingCounterFromMvm, newPath);
  result = CheckLastError("MIM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "proprietaryExtensionField");
  value.proprietaryExtensionField.isValidFlag = C2xIsTokenAvailable(packetHandle, "MIM", newPath);
  if(value.proprietaryExtensionField.isValidFlag==1)
  {
    value.proprietaryExtensionField.value = C2xGetTokenInt(packetHandle, "MIM", newPath);
    result = CheckLastError("MIM", gkFuncRefGet, result);
  }
  return result;
}

int SetMIMMIMDataControlFieldParams(LONG packetHandle, struct MIMMIMDataControlField value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "checksum");
  if(value.checksum.isValidFlag==1)
  {
    C2xSetTokenInt64(packetHandle, "MIM", newPath, value.checksum.value);
    result = CheckLastError("MIM", gkFuncRefGet, result);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "MIM", newPath) )
    {
      C2xRemoveToken(packetHandle, "MIM", newPath);
    }
  }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "mimGenerationTime");
  if(value.mimGenerationTime.isValidFlag==1)
  {
    C2xSetTokenInt64(packetHandle, "MIM", newPath, value.mimGenerationTime.value);
    result = CheckLastError("MIM", gkFuncRefGet, result);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "MIM", newPath) )
    {
      C2xRemoveToken(packetHandle, "MIM", newPath);
    }
  }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "rollingCounterFromMvm");
  SetMIMMIMDataControlField_rollingCounterFromMvmParams(packetHandle, value.rollingCounterFromMvm, newPath);
  result = CheckLastError("MIM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "proprietaryExtensionField");
  if(value.proprietaryExtensionField.isValidFlag==1)
  {
    C2xSetTokenInt(packetHandle, "MIM", newPath, value.proprietaryExtensionField.value);
    result = CheckLastError("MIM", gkFuncRefGet, result);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "MIM", newPath) )
    {
      C2xRemoveToken(packetHandle, "MIM", newPath);
    }
  }

  return result;
}

int GetMIMSystemManagementDataParams(LONG packetHandle, struct MIMSystemManagementData value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "sessionID");
  value.sessionID.isValidFlag = C2xIsTokenAvailable(packetHandle, "MIM", newPath);
  if(value.sessionID.isValidFlag==1)
  {
    value.sessionID.stringLength = C2xGetTokenData(packetHandle, "MIM", newPath, elcount(value.sessionID.string), value.sessionID.string);
    result = CheckLastError("MIM", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "missionID");
  value.missionID.isValidFlag = C2xIsTokenAvailable(packetHandle, "MIM", newPath);
  if(value.missionID.isValidFlag==1)
  {
    value.missionID.stringLength = C2xGetTokenData(packetHandle, "MIM", newPath, elcount(value.missionID.string), value.missionID.string);
    result = CheckLastError("MIM", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "vehicleID");
  value.vehicleID.isValidFlag = C2xIsTokenAvailable(packetHandle, "MIM", newPath);
  if(value.vehicleID.isValidFlag==1)
  {
    value.vehicleID.stringLength = C2xGetTokenData(packetHandle, "MIM", newPath, elcount(value.vehicleID.string), value.vehicleID.string);
    result = CheckLastError("MIM", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "facilityID");
  value.facilityID.isValidFlag = C2xIsTokenAvailable(packetHandle, "MIM", newPath);
  if(value.facilityID.isValidFlag==1)
  {
    value.facilityID.stringLength = C2xGetTokenData(packetHandle, "MIM", newPath, elcount(value.facilityID.string), value.facilityID.string);
    result = CheckLastError("MIM", gkFuncRefGet, result);
  }
  return result;
}

int SetMIMSystemManagementDataParams(LONG packetHandle, struct MIMSystemManagementData value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "sessionID");
  if(value.sessionID.isValidFlag==1)
  {
    C2xSetTokenData(packetHandle, "MIM", newPath, value.sessionID.stringLength, value.sessionID.string);
    result = CheckLastError("MIM", gkFuncRefGet, result);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "MIM", newPath) )
    {
      C2xRemoveToken(packetHandle, "MIM", newPath);
    }
  }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "missionID");
  if(value.missionID.isValidFlag==1)
  {
    C2xSetTokenData(packetHandle, "MIM", newPath, value.missionID.stringLength, value.missionID.string);
    result = CheckLastError("MIM", gkFuncRefGet, result);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "MIM", newPath) )
