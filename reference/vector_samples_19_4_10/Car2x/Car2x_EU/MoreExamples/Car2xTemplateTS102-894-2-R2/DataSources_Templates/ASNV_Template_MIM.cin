int GetMIMPathSnippetParams(LONG packetHandle, struct MIMPathSnippet value, char oldPath[])
{
  char newPath[300]; 
  int i;
  int result;

  result = 0;

  value.length = C2xGetTokenInt(packetHandle, "MIM", oldPath);
  if((result = CheckLastError("MIM", gkFuncRefGet, result))==0)
  {
    for(i=0; i<value.length; i++)
    {
      snprintf(newPath, elcount(newPath), "%s[%d]", oldPath, i);
      GetMIMWayPointParams(packetHandle, value.arrayValue[i], newPath);
      result = CheckLastError("MIM", gkFuncRefGet, result);
    }
  }
  return result;
}

int SetMIMPathSnippetParams(LONG packetHandle, struct MIMPathSnippet value, char oldPath[])
{
  char newPath[300]; 
  int i;
  int result;

  result = 0;

  C2xRemoveToken(packetHandle, "MIM", oldPath);
  for(i=0; i<value.length; i++)
  {
    snprintf(newPath, elcount(newPath), "%s[%d]", oldPath, i);
    SetMIMWayPointParams(packetHandle, value.arrayValue[i], newPath);
    result = CheckLastError("MIM", gkFuncRefGet, result);
  }
  return result;
}

