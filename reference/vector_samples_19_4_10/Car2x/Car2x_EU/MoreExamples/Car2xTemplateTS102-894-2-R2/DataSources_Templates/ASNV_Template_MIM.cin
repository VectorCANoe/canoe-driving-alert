int API_GetMIMParams(LONG packetHandle, struct MIM value)
{
  int result;
  result = 0;

  value.header.isValidFlag = 1;
  GetMIMItsPduHeaderParams(packetHandle, value.header, "header");
  result = CheckLastError("MIM", gkFuncRefGet, result);

  value.e2eProtection.isValidFlag = 1;
  GetMIMAvmE2EProtectionParams(packetHandle, value.e2eProtection, "e2eProtection");
  result = CheckLastError("MIM", gkFuncRefGet, result);

  value.mims.isValidFlag = 1;
  GetMIMMIM_mimsParams(packetHandle, value.mims, "mims");
  result = CheckLastError("MIM", gkFuncRefGet, result);

  return result;
}

int API_SetMIMParams(LONG packetHandle, struct MIM value)
{
  int result;
  result = 0;

  SetMIMItsPduHeaderParams(packetHandle, value.header, "header");
  result = CheckLastError("MIM", gkFuncRefGet, result);

  SetMIMAvmE2EProtectionParams(packetHandle, value.e2eProtection, "e2eProtection");
  result = CheckLastError("MIM", gkFuncRefGet, result);

  SetMIMMIM_mimsParams(packetHandle, value.mims, "mims");
  result = CheckLastError("MIM", gkFuncRefGet, result);

  return result;
}

