    GetMVMVehicleErrorParams(packetHandle, value.vehicleError, newPath);
    result = CheckLastError("MVM", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "vehicleSafetyFeedback");
  value.vehicleSafetyFeedback.isValidFlag = C2xIsTokenAvailable(packetHandle, "MVM", newPath);
  if(value.vehicleSafetyFeedback.isValidFlag==1)
  {
    GetMVMVehicleSafetyFeedbackParams(packetHandle, value.vehicleSafetyFeedback, newPath);
    result = CheckLastError("MVM", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "vehicleProperties");
  value.vehicleProperties.isValidFlag = C2xIsTokenAvailable(packetHandle, "MVM", newPath);
