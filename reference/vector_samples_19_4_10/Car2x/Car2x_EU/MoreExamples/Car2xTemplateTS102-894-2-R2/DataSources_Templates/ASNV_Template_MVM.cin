    GetMVMSafeVehicleTypeConfirmationParams(packetHandle, value.safeVehicleTypeConfirmation, newPath);
    result = CheckLastError("MVM", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "vehicleError");
  value.vehicleError.isValidFlag = C2xIsTokenAvailable(packetHandle, "MVM", newPath);
  if(value.vehicleError.isValidFlag==1)
