int API_GetMVMParams(LONG packetHandle, struct MVM value)
{
  int result;
  result = 0;

  value.header.isValidFlag = 1;
  GetMVMItsPduHeaderParams(packetHandle, value.header, "header");
  result = CheckLastError("MVM", gkFuncRefGet, result);

  value.e2eProtection.isValidFlag = 1;
  GetMVMAvmE2EProtectionParams(packetHandle, value.e2eProtection, "e2eProtection");
  result = CheckLastError("MVM", gkFuncRefGet, result);

  value.mvm.isValidFlag = 1;
  GetMVMMvmParams(packetHandle, value.mvm, "mvm");
  result = CheckLastError("MVM", gkFuncRefGet, result);

  return result;
}

int API_SetMVMParams(LONG packetHandle, struct MVM value)
{
  int result;
  result = 0;

  SetMVMItsPduHeaderParams(packetHandle, value.header, "header");
  result = CheckLastError("MVM", gkFuncRefGet, result);

  SetMVMAvmE2EProtectionParams(packetHandle, value.e2eProtection, "e2eProtection");
  result = CheckLastError("MVM", gkFuncRefGet, result);

  SetMVMMvmParams(packetHandle, value.mvm, "mvm");
  result = CheckLastError("MVM", gkFuncRefGet, result);

  return result;
}

