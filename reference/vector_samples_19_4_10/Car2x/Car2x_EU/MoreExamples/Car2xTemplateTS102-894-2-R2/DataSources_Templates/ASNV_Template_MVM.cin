includes
{
 
}
variables
{
    struct MVMItsPduHeader {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        BYTE protocolVersion;  // INTEGER, 0..255;
        BYTE messageID;  // INTEGER, 0..255, denm(1), cam(2), poim(3), spatem(4), mapem(5), ivim(6), rfu1(7), rfu2(8), srem(9), ssem(10), evcsn(11), saem(12), rtcmem(13), cpm(14), imzm(15), vam(16), dsm(17), mim(18), mvm(19), mcm(20);
        DWORD stationID;  // INTEGER, 0..4294967295;
    };
    
    struct MVMAvmE2EProtection {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        WORD length;  // INTEGER, 0..65535;
        WORD rollingCounter;  // INTEGER, 0..65535;
        DWORD dataID;  // INTEGER, 0..4294967295;
        DWORD crc32;  // INTEGER, 0..4294967295;
    };
    
    struct MVMMVMDataControlField_rollingCounterFromMim {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        INT length;
        WORD arrayValue[10];  // INTEGER, 0..65535;
    };
    
    struct MVMMVMDataControlField {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        struct OPT_QWORD_ASN mvmGenerationTime;  // INTEGER, OPTIONAL, 0..4398046511103;
        struct MVMMVMDataControlField_rollingCounterFromMim rollingCounterFromMim;  // SEQUENCEOF;
        struct OPT_WORD_ASN proprietaryExtensionField;  // INTEGER, OPTIONAL, 0..65535;
    };
    
    struct MVMSessionMissionID {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        CHAR string[33];
        INT  stringLength;
    };
    
    struct MVMVehicleID {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        CHAR string[18];
        INT  stringLength;
    };
    
    struct MVMFacilityID {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        CHAR string[33];
        INT  stringLength;
    };
    
    struct MVMSystemManagementData {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        struct MVMSessionMissionID sessionID;  // IA5STRING, OPTIONAL;
        struct MVMSessionMissionID missionID;  // IA5STRING, OPTIONAL;
        struct MVMVehicleID vehicleID;  // IA5STRING, OPTIONAL;
        struct MVMFacilityID facilityID;  // IA5STRING, OPTIONAL;
    };
    
    struct MVMPose {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        LONG x;  // INTEGER, -524288..524287, negativeOutOfRange(-524287), positiveOutOfRange(524287), unavailable(-524288);
        LONG y;  // INTEGER, -524288..524287, negativeOutOfRange(-524287), positiveOutOfRange(524287), unavailable(-524288);
        WORD psi;  // INTEGER, 0..62833, xDirection(0), outOfRange(62832), unavailable(62833);
    };
    
    struct MVMVehicleState {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        struct OPT_QWORD_ASN vehicleStateGenerationTime;  // INTEGER, OPTIONAL, 0..4398046511103;
        INT operationMode;  // ENUMERATED, unknown(0), initializing(1), prepared(2), driving(3), terminating(4), suspend(5), tempError(6), humanInControl(7), stationHold(8);
        INT gearState;  // ENUMERATED, park(0), backwards(1), neutral(2), forwards(3), unknown(4);
        INT directionIndicatorState;  // ENUMERATED, off(0), right(1), left(2), both(3), unknown(4);
        INT parkingBrakeState;  // ENUMERATED, unknown(0), engaging(1), engaged(2), disengaging(3), disengaged(4);
        INT motorSystemState;  // ENUMERATED, off(0), on(1), unknown(2);
        INT currentVelocity;  // INTEGER, -16383..16383, negativeOutOfRange(-16383), positiveOutOfRange(16382), unavailable(16383);
        INT currentCurvature;  // INTEGER, -32768..32767, outOfRangeNegative(-32767), straight(0), outOfRangePositive(32767), unavailable(-32768);
        INT secureStandstill;  // BOOLEAN;
        struct OPT_WORD_ASN idxLastWayPoint;  // INTEGER, OPTIONAL, 0..65535;
        struct MVMPose localizedPose;  // SEQUENCE, OPTIONAL;
    };
    
    struct MVMVidResponse {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        INT vidVehicleState;  // ENUMERATED, undefined(0), ready(1), lightFlashingInProgress(2), lightFlashingCompleted(3), lightFlashingFailed(4), authorized(5);
        QWORD vidVehiclePublicKey;  // INTEGER, 0..18446744073709551615;
    };
    
    struct MVMSafetyTimeSyncResponse {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        WORD challenge;  // INTEGER, 0..65535;
        QWORD vehicleSafetyClockReceiveTimestamp;  // INTEGER, 0..4398046511103;
        QWORD vehicleSafetyClockTransmitTimestamp;  // INTEGER, 0..4398046511103;
        DWORD checksum;  // INTEGER, 0..4294967295;
    };
    
    struct MVMSafeVehicleTypeConfirmation_vehicleType {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        CHAR string[33];
        INT  stringLength;
    };
    
    struct MVMSafeVehicleTypeConfirmation_safetyProfile {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        CHAR string[33];
        INT  stringLength;
    };
    
    struct MVMSafeVehicleTypeConfirmation {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        struct MVMSafeVehicleTypeConfirmation_vehicleType vehicleType;  // IA5STRING;
        struct MVMSafeVehicleTypeConfirmation_safetyProfile safetyProfile;  // IA5STRING;
        DWORD checksum;  // INTEGER, 0..4294967295;
    };
    
    struct MVMDescription {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        CHAR string[201];
        INT  stringLength;
    };
    
    struct MVMVehicleError {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        QWORD time;  // INTEGER, 0..4398046511103;
        INT vehCode;  // ENUMERATED, unspecified(0), pathNotDriveable(1), onboardVehicleFault(2), communicationFault(3), vehicleEgressFault(4);
        BYTE customCode;  // INTEGER, 0..255;
        struct MVMDescription description;  // IA5STRING, OPTIONAL;
    };
    
    struct MVMSafetyViolationsContainer {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        INT length;
        INT arrayValue[5];  // ENUMERATED, noViolation(0), noDrivingPermissionReceived(1), lastDrivingPermissionTooOld(2), crcViolationClockSyncRequest(3), crcViolationDrivingPermission(4), expirationTimeViolation(5), drivingDirectionMismatch(6), velocityViolation(7), curvatureMinViolation(8), curvatureMaxViolation(9), expirationTimeTooHigh(10), monitoring(11);
    };
    
    struct MVMVehicleSafetyFeedbackContainer {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        INT remainingTimeToStartBraking;  // INTEGER, -32768..32767;
        struct MVMSafetyViolationsContainer safetyViolations;  // SEQUENCEOF;
        QWORD currentVehicleSafetyClockTime;  // INTEGER, 0..4398046511103;
    };
    
    struct MVMVehicleSafetyFeedback {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        INT length;
        struct MVMVehicleSafetyFeedbackContainer arrayValue[20];  // SEQUENCE;
    };
    
    struct MVMVehicleProperties {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        INT basicVehicleClass;  // ENUMERATED, none(0), unknown(1), special(2), moto(3), car(4), carOther(5), bus(6), axleCnt2(7), axleCnt3(8), axleCnt4(9), axleCnt4Trailer(10), axleCnt5Trailer(11), axleCnt6Trailer(12), axleCnt5MultiTrailer(13), axleCnt6MultiTrailer(14), axleCnt7MultiTrailer(15);
        LONG vehicleLength;  // INTEGER, -524288..524287, negativeOutOfRange(-524287), positiveOutOfRange(524287), unavailable(-524288);
        LONG vehicleWheelbase;  // INTEGER, -524288..524287, negativeOutOfRange(-524287), positiveOutOfRange(524287), unavailable(-524288);
        LONG vehicleRearOverhang;  // INTEGER, -524288..524287, negativeOutOfRange(-524287), positiveOutOfRange(524287), unavailable(-524288);
        LONG vehicleWidth;  // INTEGER, -524288..524287, negativeOutOfRange(-524287), positiveOutOfRange(524287), unavailable(-524288);
        LONG vehicleTireWidth;  // INTEGER, -524288..524287, negativeOutOfRange(-524287), positiveOutOfRange(524287), unavailable(-524288);
        LONG vehicleTrackWidth;  // INTEGER, -524288..524287, negativeOutOfRange(-524287), positiveOutOfRange(524287), unavailable(-524288);
        WORD vehicleMass;  // INTEGER, 1..1024, outOfRange(1023), unavailable(1024);
        INT vehicleSpeedLimit;  // INTEGER, -16383..16383, negativeOutOfRange(-16383), positiveOutOfRange(16382), unavailable(16383);
        INT vehicleCuvatureLimit;  // INTEGER, -32768..32767, outOfRangeNegative(-32767), straight(0), outOfRangePositive(32767), unavailable(-32768);
        INT vehicleMaxAngularSteeringRate;  // INTEGER, -32767..32766, negativeOutOfRange(-32766), positiveOutOfRange(32766), unavailable(-32767);
    };
    
    struct MVMMvm {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        struct MVMMVMDataControlField mvmDataControlField;  // SEQUENCE, OPTIONAL;
        struct MVMSystemManagementData systemManagementData;  // SEQUENCE, OPTIONAL;
        struct MVMVehicleState vehicleState;  // SEQUENCE, OPTIONAL;
        struct MVMVidResponse vidResponse;  // SEQUENCE, OPTIONAL;
        struct MVMSafetyTimeSyncResponse safetyTimeSyncResponse;  // SEQUENCE, OPTIONAL;
        struct MVMSafeVehicleTypeConfirmation safeVehicleTypeConfirmation;  // SEQUENCE, OPTIONAL;
        struct MVMVehicleError vehicleError;  // SEQUENCE, OPTIONAL;
        struct MVMVehicleSafetyFeedback vehicleSafetyFeedback;  // SEQUENCEOF, OPTIONAL;
        struct MVMVehicleProperties vehicleProperties;  // SEQUENCE, OPTIONAL;
    };
    
    struct MVM {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        struct MVMItsPduHeader header;  // SEQUENCE;
        struct MVMAvmE2EProtection e2eProtection;  // SEQUENCE;
        struct MVMMvm mvm;  // SEQUENCE;
    };
    
}

/*
// init function to create a simple packet handle
*/ 
LONG API_InitMVMPacket()
{
  return C2xInitPacket("MVM"); 
}

/*
// init function to create a simple packet handle and
// initialize the struct with valid data
*/ 
LONG API_InitMVMPacket(struct MVM msgStruct)
{
  long pktHandle;

  pktHandle = API_InitMVMPacket();

  if (pktHandle != 0)
  {
    // create valid message and application data
    if (C2xCompletePacket(pktHandle) == 0) 
    {
      API_GetMVMParams(pktHandle, msgStruct);
    }
  }
  return pktHandle;
}

/*
// init function to create a packet with security layer and
// initialize the struct with valid data
*/ 
LONG API_InitMVMPacket(struct MVM msgStruct, char packetTypeDesignator[], char certificateName[])
{
  long pktHandle, certHdl;

  // initialize the packet
  pktHandle = C2xInitPacket("MVM", packetTypeDesignator);

  if (pktHandle != 0)
  {
    certHdl = C2xSecCertificateGetHandle(certificateName);  // get the certificate handle for the cert with name "certificateName"
    if (certHdl != 0) 
    {
      C2xSecPacketSetSignerHandle(pktHandle, certHdl); // set the certHdl to the packet
    }

    // create valid message and application data
    if (C2xCompletePacket(pktHandle) == 0) 
    {
      // copy application data to the application structure
      API_GetMVMParams(pktHandle, msgStruct);
    }
  }
  return pktHandle;
}
    

int GetMVMItsPduHeaderParams(LONG packetHandle, struct MVMItsPduHeader value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "protocolVersion");
  value.protocolVersion = C2xGetTokenInt(packetHandle, "MVM", newPath);
  result = CheckLastError("MVM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "messageID");
  value.messageID = C2xGetTokenInt(packetHandle, "MVM", newPath);
  result = CheckLastError("MVM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "stationID");
  value.stationID = C2xGetTokenInt64(packetHandle, "MVM", newPath);
  result = CheckLastError("MVM", gkFuncRefGet, result);

  return result;
}

int SetMVMItsPduHeaderParams(LONG packetHandle, struct MVMItsPduHeader value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "protocolVersion");
  C2xSetTokenInt(packetHandle, "MVM", newPath, value.protocolVersion);
  result = CheckLastError("MVM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "messageID");
  C2xSetTokenInt(packetHandle, "MVM", newPath, value.messageID);
  result = CheckLastError("MVM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "stationID");
  C2xSetTokenInt64(packetHandle, "MVM", newPath, value.stationID);
  result = CheckLastError("MVM", gkFuncRefGet, result);

  return result;
}

