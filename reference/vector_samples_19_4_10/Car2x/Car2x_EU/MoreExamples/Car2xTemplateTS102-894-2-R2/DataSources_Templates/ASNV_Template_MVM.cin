  C2xSetTokenInt(packetHandle, "MVM", newPath, value.vehicleTireWidth);
  result = CheckLastError("MVM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "vehicleTrackWidth");
  C2xSetTokenInt(packetHandle, "MVM", newPath, value.vehicleTrackWidth);
  result = CheckLastError("MVM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "vehicleMass");
  if (value.vehicleMass < 1)
  {
    C2xSetTokenInt(packetHandle, "MVM", newPath, 1);
  }
  else if (value.vehicleMass > 1024)
  {
    C2xSetTokenInt(packetHandle, "MVM", newPath, 1024);
  }
  else
  {
    C2xSetTokenInt(packetHandle, "MVM", newPath, value.vehicleMass);
  }
  result = CheckLastError("MVM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "vehicleSpeedLimit");
  C2xSetTokenInt(packetHandle, "MVM", newPath, value.vehicleSpeedLimit);
  result = CheckLastError("MVM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "vehicleCuvatureLimit");
  C2xSetTokenInt(packetHandle, "MVM", newPath, value.vehicleCuvatureLimit);
  result = CheckLastError("MVM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "vehicleMaxAngularSteeringRate");
  C2xSetTokenInt(packetHandle, "MVM", newPath, value.vehicleMaxAngularSteeringRate);
  result = CheckLastError("MVM", gkFuncRefGet, result);

  return result;
}

