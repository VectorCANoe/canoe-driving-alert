int GetMVMMVMDataControlField_rollingCounterFromMimParams(LONG packetHandle, struct MVMMVMDataControlField_rollingCounterFromMim value, char oldPath[])
{
  char newPath[300]; 
  int i;
  int result;

  result = 0;

  value.length = C2xGetTokenInt(packetHandle, "MVM", oldPath);
  if((result = CheckLastError("MVM", gkFuncRefGet, result))==0)
  {
    for(i=0; i<value.length; i++)
    {
      snprintf(newPath, elcount(newPath), "%s[%d]", oldPath, i);
      value.arrayValue[i] = C2xGetTokenInt64(packetHandle, "MVM", newPath);
      result = CheckLastError("MVM", gkFuncRefGet, result);
    }
  }
  return result;
}

int SetMVMMVMDataControlField_rollingCounterFromMimParams(LONG packetHandle, struct MVMMVMDataControlField_rollingCounterFromMim value, char oldPath[])
{
  char newPath[300]; 
  int i;
  int result;

  result = 0;

  C2xRemoveToken(packetHandle, "MVM", oldPath);
  for(i=0; i<value.length; i++)
  {
    snprintf(newPath, elcount(newPath), "%s[%d]", oldPath, i);
    C2xSetTokenInt64(packetHandle, "MVM", newPath, value.arrayValue[i]);
    result = CheckLastError("MVM", gkFuncRefGet, result);
  }
  return result;
}

int GetMVMMVMDataControlFieldParams(LONG packetHandle, struct MVMMVMDataControlField value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "mvmGenerationTime");
  value.mvmGenerationTime.isValidFlag = C2xIsTokenAvailable(packetHandle, "MVM", newPath);
  if(value.mvmGenerationTime.isValidFlag==1)
  {
    value.mvmGenerationTime.value = C2xGetTokenInt64(packetHandle, "MVM", newPath);
    result = CheckLastError("MVM", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "rollingCounterFromMim");
  GetMVMMVMDataControlField_rollingCounterFromMimParams(packetHandle, value.rollingCounterFromMim, newPath);
  result = CheckLastError("MVM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "proprietaryExtensionField");
  value.proprietaryExtensionField.isValidFlag = C2xIsTokenAvailable(packetHandle, "MVM", newPath);
  if(value.proprietaryExtensionField.isValidFlag==1)
  {
    value.proprietaryExtensionField.value = C2xGetTokenInt(packetHandle, "MVM", newPath);
    result = CheckLastError("MVM", gkFuncRefGet, result);
  }
  return result;
}

int SetMVMMVMDataControlFieldParams(LONG packetHandle, struct MVMMVMDataControlField value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "mvmGenerationTime");
  if(value.mvmGenerationTime.isValidFlag==1)
  {
    C2xSetTokenInt64(packetHandle, "MVM", newPath, value.mvmGenerationTime.value);
    result = CheckLastError("MVM", gkFuncRefGet, result);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "MVM", newPath) )
    {
      C2xRemoveToken(packetHandle, "MVM", newPath);
    }
  }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "rollingCounterFromMim");
  SetMVMMVMDataControlField_rollingCounterFromMimParams(packetHandle, value.rollingCounterFromMim, newPath);
  result = CheckLastError("MVM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "proprietaryExtensionField");
  if(value.proprietaryExtensionField.isValidFlag==1)
  {
    C2xSetTokenInt(packetHandle, "MVM", newPath, value.proprietaryExtensionField.value);
    result = CheckLastError("MVM", gkFuncRefGet, result);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "MVM", newPath) )
    {
      C2xRemoveToken(packetHandle, "MVM", newPath);
    }
  }

  return result;
}

