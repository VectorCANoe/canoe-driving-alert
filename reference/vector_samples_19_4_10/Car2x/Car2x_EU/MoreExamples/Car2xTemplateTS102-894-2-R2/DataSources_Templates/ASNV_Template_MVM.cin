  if(value.sessionID.isValidFlag==1)
  {
    value.sessionID.stringLength = C2xGetTokenData(packetHandle, "MVM", newPath, elcount(value.sessionID.string), value.sessionID.string);
    result = CheckLastError("MVM", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "missionID");
  value.missionID.isValidFlag = C2xIsTokenAvailable(packetHandle, "MVM", newPath);
  if(value.missionID.isValidFlag==1)
  {
    value.missionID.stringLength = C2xGetTokenData(packetHandle, "MVM", newPath, elcount(value.missionID.string), value.missionID.string);
    result = CheckLastError("MVM", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "vehicleID");
  value.vehicleID.isValidFlag = C2xIsTokenAvailable(packetHandle, "MVM", newPath);
  if(value.vehicleID.isValidFlag==1)
  {
    value.vehicleID.stringLength = C2xGetTokenData(packetHandle, "MVM", newPath, elcount(value.vehicleID.string), value.vehicleID.string);
    result = CheckLastError("MVM", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "facilityID");
  value.facilityID.isValidFlag = C2xIsTokenAvailable(packetHandle, "MVM", newPath);
  if(value.facilityID.isValidFlag==1)
