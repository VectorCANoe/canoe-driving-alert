        struct OPT_DWORD_ASN subjectStation;  // INTEGER, OPTIONAL, 0..4294967295;
        INT safeDistanceIndicator;  // BOOLEAN;
        struct OPT_BYTE_ASN timeToCollision;  // INTEGER, OPTIONAL, 0..127, unavailable(127);
    };
    
    struct VAMSequenceOfSafeDistanceIndication {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        INT length;
        struct VAMSafeDistanceIndication arrayValue[8];  // SEQUENCE;
    };
    
    struct VAMTrajectoryInterceptionIndication {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        struct OPT_DWORD_ASN subjectStation;  // INTEGER, OPTIONAL, 0..4294967295;
        BYTE trajectoryInterceptionProbability;  // INTEGER, 0..63, unavailable(63);
        struct OPT_BYTE_ASN trajectoryInterceptionConfidence;  // INTEGER, OPTIONAL, 0..3, lessthan50percent(0), between50and70Percent(1), between70and90Percent(2), above90Percent(3);
    };
    
    struct VAMSequenceOfTrajectoryInterceptionIndication {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        INT length;
        struct VAMTrajectoryInterceptionIndication arrayValue[8];  // SEQUENCE;
    };
    
    struct VAMAccelerationChangeIndication {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        INT accelOrDecel;  // ENUMERATED, accelerate(0), decelerate(1);
        BYTE actionDeltaTime;  // INTEGER, 0..127, unavailable(127);
    };
    
    struct VAMHeadingChangeIndication {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        INT direction;  // ENUMERATED, left(-0), right(1);
        BYTE actionDeltaTime;  // INTEGER, 0..127, unavailable(127);
    };
    
    struct VAMStabilityChangeIndication {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        BYTE lossProbability;  // INTEGER, 0..63, stable(0), totalLossOfStability(50), unavailable(63);
        BYTE actionDeltaTime;  // INTEGER, 0..127, unavailable(127);
    };
    
    struct VAMVruMotionPredictionContainer {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        struct VAMPathHistory pathHistory;  // SEQUENCEOF, OPTIONAL;
        struct VAMPathPredicted pathPrediction;  // SEQUENCEOF, OPTIONAL;
        struct VAMSequenceOfSafeDistanceIndication safeDistance;  // SEQUENCEOF, OPTIONAL;
        struct VAMSequenceOfTrajectoryInterceptionIndication trajectoryInterceptionIndication;  // SEQUENCEOF, OPTIONAL;
        struct VAMAccelerationChangeIndication accelerationChangeIndication;  // SEQUENCE, OPTIONAL;
        struct VAMHeadingChangeIndication headingChangeIndication;  // SEQUENCE, OPTIONAL;
        struct VAMStabilityChangeIndication stabilityChangeIndication;  // SEQUENCE, OPTIONAL;
    };
    
    struct VAMVamParameters {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        struct VAMBasicContainer basicContainer;  // SEQUENCE;
        struct VAMVruHighFrequencyContainer vruHighFrequencyContainer;  // SEQUENCE;
        struct VAMVruLowFrequencyContainer vruLowFrequencyContainer;  // SEQUENCE, OPTIONAL;
        struct VAMVruClusterInformationContainer vruClusterInformationContainer;  // SEQUENCE, OPTIONAL;
        struct VAMVruClusterOperationContainer vruClusterOperationContainer;  // SEQUENCE, OPTIONAL;
        struct VAMVruMotionPredictionContainer vruMotionPredictionContainer;  // SEQUENCE, OPTIONAL;
    };
    
    struct VAMVruAwareness {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        WORD generationDeltaTime;  // INTEGER, 0..65535, oneMilliSec(1);
        struct VAMVamParameters vamParameters;  // SEQUENCE;
    };
    
    struct VAM {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        struct VAMItsPduHeader header;  // SEQUENCE;
        struct VAMVruAwareness vam;  // SEQUENCE;
    };
    
}

/*
// init function to create a simple packet handle
*/ 
LONG API_InitVAMPacket()
{
  return C2xInitPacket("VAM"); 
}

/*
// init function to create a simple packet handle and
// initialize the struct with valid data
*/ 
LONG API_InitVAMPacket(struct VAM msgStruct)
{
  long pktHandle;

  pktHandle = API_InitVAMPacket();

  if (pktHandle != 0)
  {
    // create valid message and application data
    if (C2xCompletePacket(pktHandle) == 0) 
    {
      API_GetVAMParams(pktHandle, msgStruct);
    }
  }
  return pktHandle;
}

/*
// init function to create a packet with security layer and
// initialize the struct with valid data
*/ 
LONG API_InitVAMPacket(struct VAM msgStruct, char packetTypeDesignator[], char certificateName[])
{
  long pktHandle, certHdl;

  // initialize the packet
  pktHandle = C2xInitPacket("VAM", packetTypeDesignator);

  if (pktHandle != 0)
  {
    certHdl = C2xSecCertificateGetHandle(certificateName);  // get the certificate handle for the cert with name "certificateName"
    if (certHdl != 0) 
    {
      C2xSecPacketSetSignerHandle(pktHandle, certHdl); // set the certHdl to the packet
    }

    // create valid message and application data
    if (C2xCompletePacket(pktHandle) == 0) 
    {
      // copy application data to the application structure
      API_GetVAMParams(pktHandle, msgStruct);
    }
  }
  return pktHandle;
}
    

int GetVAMItsPduHeaderParams(LONG packetHandle, struct VAMItsPduHeader value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "protocolVersion");
  value.protocolVersion = C2xGetTokenInt(packetHandle, "VAM", newPath);
  result = CheckLastError("VAM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "messageID");
  value.messageID = C2xGetTokenInt(packetHandle, "VAM", newPath);
  result = CheckLastError("VAM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "StationID");
  value.StationID = C2xGetTokenInt64(packetHandle, "VAM", newPath);
  result = CheckLastError("VAM", gkFuncRefGet, result);

  return result;
}

