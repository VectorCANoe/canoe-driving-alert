int GetVAMLanePositionAndTypeParams(LONG packetHandle, struct VAMLanePositionAndType value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "transversalPosition");
  value.transversalPosition = C2xGetTokenInt(packetHandle, "VAM", newPath);
  result = CheckLastError("VAM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "laneType");
  value.laneType.isValidFlag = C2xIsTokenAvailable(packetHandle, "VAM", newPath);
  if(value.laneType.isValidFlag==1)
  {
    value.laneType.value = C2xGetTokenInt(packetHandle, "VAM", newPath);
    result = CheckLastError("VAM", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "direction");
  value.direction.isValidFlag = C2xIsTokenAvailable(packetHandle, "VAM", newPath);
  if(value.direction.isValidFlag==1)
  {
    value.direction.value = C2xGetTokenInt(packetHandle, "VAM", newPath);
    result = CheckLastError("VAM", gkFuncRefGet, result);
  }
  return result;
}

int SetVAMLanePositionAndTypeParams(LONG packetHandle, struct VAMLanePositionAndType value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "transversalPosition");
  C2xSetTokenInt(packetHandle, "VAM", newPath, value.transversalPosition);
  result = CheckLastError("VAM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "laneType");
  if(value.laneType.isValidFlag==1)
  {
    C2xSetTokenInt(packetHandle, "VAM", newPath, value.laneType.value);
