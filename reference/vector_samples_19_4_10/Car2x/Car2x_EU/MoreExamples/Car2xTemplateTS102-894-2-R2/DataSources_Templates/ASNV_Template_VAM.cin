int SetVAMWgs84AngleParams(LONG packetHandle, struct VAMWgs84Angle value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "value");
  C2xSetTokenInt(packetHandle, "VAM", newPath, value.value);
  result = CheckLastError("VAM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "confidence");
  if (value.confidence < 1)
  {
    C2xSetTokenInt(packetHandle, "VAM", newPath, 1);
  }
  else if (value.confidence > 127)
  {
    C2xSetTokenInt(packetHandle, "VAM", newPath, 127);
  }
  else
  {
    C2xSetTokenInt(packetHandle, "VAM", newPath, value.confidence);
  }
  result = CheckLastError("VAM", gkFuncRefGet, result);

  return result;
}

