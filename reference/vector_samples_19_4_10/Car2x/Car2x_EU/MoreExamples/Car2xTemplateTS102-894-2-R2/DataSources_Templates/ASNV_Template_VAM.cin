int GetVAMMetaInformationParams(LONG packetHandle, struct VAMMetaInformation value, char oldPath[])
{
  char newPath[300]; 
  int j; 
  int k;
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "usedDetectionInformation");
  value.usedDetectionInformation.isValidFlag = 1;
  value.usedDetectionInformation.stringLength = C2xGetTokenLengthBit(packetHandle, "VAM", newPath);
  if ((result = CheckLastError("VAM", gkFuncRefGet, result))==0)
  {
    if(value.usedDetectionInformation.stringLength > 0)
    {
      for(j=0; j<value.usedDetectionInformation.stringLength; j++)
      {
        if(C2xGetTokenBitOfBitString(packetHandle, "VAM", newPath, j) == 0)
        {
          value.usedDetectionInformation.string[j] = '0';
        }
        else if(C2xGetTokenBitOfBitString(packetHandle, "VAM", newPath, j) == 1)
        {
          value.usedDetectionInformation.string[j] = '1';
        }

        if(value.usedDetectionInformation.stringLength == 1)
        {
          value.usedDetectionInformation.string[1] = '0';
        }
        result = CheckLastError("VAM", gkFuncRefGet, result);
      }
    }
    else
    {
      for(k = value.usedDetectionInformation.stringLength+1; k > -1; k--)
      {
        if(value.usedDetectionInformation.string[k] == '1')
        {
          value.usedDetectionInformation.string[k] = '0';
        }
      }
    }
  }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "usedStoredInformation");
  value.usedStoredInformation.isValidFlag = 1;
  value.usedStoredInformation.stringLength = C2xGetTokenLengthBit(packetHandle, "VAM", newPath);
  if ((result = CheckLastError("VAM", gkFuncRefGet, result))==0)
  {
    if(value.usedStoredInformation.stringLength > 0)
    {
      for(j=0; j<value.usedStoredInformation.stringLength; j++)
      {
        if(C2xGetTokenBitOfBitString(packetHandle, "VAM", newPath, j) == 0)
        {
          value.usedStoredInformation.string[j] = '0';
        }
        else if(C2xGetTokenBitOfBitString(packetHandle, "VAM", newPath, j) == 1)
        {
          value.usedStoredInformation.string[j] = '1';
        }

        if(value.usedStoredInformation.stringLength == 1)
        {
          value.usedStoredInformation.string[1] = '0';
        }
        result = CheckLastError("VAM", gkFuncRefGet, result);
      }
    }
    else
    {
      for(k = value.usedStoredInformation.stringLength+1; k > -1; k--)
      {
        if(value.usedStoredInformation.string[k] == '1')
        {
          value.usedStoredInformation.string[k] = '0';
        }
      }
    }
  }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "confidenceValue");
  value.confidenceValue.isValidFlag = C2xIsTokenAvailable(packetHandle, "VAM", newPath);
  if(value.confidenceValue.isValidFlag==1)
  {
    value.confidenceValue.value = C2xGetTokenInt(packetHandle, "VAM", newPath);
    result = CheckLastError("VAM", gkFuncRefGet, result);
  }
  return result;
}

int SetVAMMetaInformationParams(LONG packetHandle, struct VAMMetaInformation value, char oldPath[])
{
  char newPath[300]; 
  int j;
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "usedDetectionInformation");
    for(j=0; j<value.usedDetectionInformation.stringLength; j++)
    {
      if(value.usedDetectionInformation.string[j] == '0')
      {
        C2xSetTokenBitOfBitString(packetHandle, "VAM", newPath, j, 0);
      }
      else
      {
        C2xSetTokenBitOfBitString(packetHandle, "VAM", newPath, j, 1);
      }
      result = CheckLastError("VAM", gkFuncRefGet, result);
    }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "usedStoredInformation");
    for(j=0; j<value.usedStoredInformation.stringLength; j++)
    {
      if(value.usedStoredInformation.string[j] == '0')
      {
        C2xSetTokenBitOfBitString(packetHandle, "VAM", newPath, j, 0);
      }
      else
      {
        C2xSetTokenBitOfBitString(packetHandle, "VAM", newPath, j, 1);
      }
      result = CheckLastError("VAM", gkFuncRefGet, result);
    }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "confidenceValue");
  if(value.confidenceValue.isValidFlag==1)
  {
    if (value.confidenceValue.value < 1)
    {
        C2xSetTokenInt(packetHandle, "VAM", newPath, 1);
    }
    else if (value.confidenceValue.value > 101)
    {
        C2xSetTokenInt(packetHandle, "VAM", newPath, 101);
    }
    else
    {
        C2xSetTokenInt(packetHandle, "VAM", newPath, value.confidenceValue.value);
    }
    result = CheckLastError("VAM", gkFuncRefGet, result);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "VAM", newPath) )
    {
      C2xRemoveToken(packetHandle, "VAM", newPath);
    }
  }

  return result;
}

