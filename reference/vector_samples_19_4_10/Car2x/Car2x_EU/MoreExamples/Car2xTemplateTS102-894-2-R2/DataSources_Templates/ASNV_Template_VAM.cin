int GetVAMVruExteriorLightsParams(LONG packetHandle, struct VAMVruExteriorLights value, char oldPath[])
{
  char newPath[300]; 
  int j; 
  int k;
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "vehicular");
  value.vehicular.isValidFlag = 1;
  value.vehicular.stringLength = C2xGetTokenLengthBit(packetHandle, "VAM", newPath);
  if ((result = CheckLastError("VAM", gkFuncRefGet, result))==0)
  {
    if(value.vehicular.stringLength > 0)
    {
      for(j=0; j<value.vehicular.stringLength; j++)
      {
        if(C2xGetTokenBitOfBitString(packetHandle, "VAM", newPath, j) == 0)
        {
          value.vehicular.string[j] = '0';
        }
        else if(C2xGetTokenBitOfBitString(packetHandle, "VAM", newPath, j) == 1)
        {
          value.vehicular.string[j] = '1';
        }

        if(value.vehicular.stringLength == 1)
        {
          value.vehicular.string[1] = '0';
        }
        result = CheckLastError("VAM", gkFuncRefGet, result);
      }
    }
    else
    {
      for(k = value.vehicular.stringLength+1; k > -1; k--)
      {
        if(value.vehicular.string[k] == '1')
        {
          value.vehicular.string[k] = '0';
        }
      }
    }
  }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "vruSpecific");
  value.vruSpecific.isValidFlag = 1;
  value.vruSpecific.stringLength = C2xGetTokenLengthBit(packetHandle, "VAM", newPath);
  if ((result = CheckLastError("VAM", gkFuncRefGet, result))==0)
  {
    if(value.vruSpecific.stringLength > 0)
    {
      for(j=0; j<value.vruSpecific.stringLength; j++)
      {
        if(C2xGetTokenBitOfBitString(packetHandle, "VAM", newPath, j) == 0)
        {
          value.vruSpecific.string[j] = '0';
        }
        else if(C2xGetTokenBitOfBitString(packetHandle, "VAM", newPath, j) == 1)
        {
          value.vruSpecific.string[j] = '1';
        }

        if(value.vruSpecific.stringLength == 1)
        {
          value.vruSpecific.string[1] = '0';
        }
        result = CheckLastError("VAM", gkFuncRefGet, result);
      }
    }
    else
    {
      for(k = value.vruSpecific.stringLength+1; k > -1; k--)
      {
        if(value.vruSpecific.string[k] == '1')
        {
          value.vruSpecific.string[k] = '0';
        }
      }
    }
  }

  return result;
}

