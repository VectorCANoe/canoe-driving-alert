int GetVAMVruClusterInformationParams(LONG packetHandle, struct VAMVruClusterInformation value, char oldPath[])
{
  char newPath[300]; 
  int j; 
  int k;
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "clusterId");
  value.clusterId.isValidFlag = C2xIsTokenAvailable(packetHandle, "VAM", newPath);
  if(value.clusterId.isValidFlag==1)
  {
    value.clusterId.value = C2xGetTokenInt(packetHandle, "VAM", newPath);
    result = CheckLastError("VAM", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "clusterBoundingBoxShape");
  value.clusterBoundingBoxShape.isValidFlag = C2xIsTokenAvailable(packetHandle, "VAM", newPath);
  if(value.clusterBoundingBoxShape.isValidFlag==1)
  {
    GetVAMShapeParams(packetHandle, value.clusterBoundingBoxShape, newPath);
    result = CheckLastError("VAM", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "clusterCardinalitySize");
  value.clusterCardinalitySize = C2xGetTokenInt(packetHandle, "VAM", newPath);
  result = CheckLastError("VAM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "clusterProfiles");
  value.clusterProfiles.isValidFlag = C2xIsTokenAvailable(packetHandle, "VAM", newPath);
  if(value.clusterProfiles.isValidFlag==1)
  {
    value.clusterProfiles.isValidFlag = 1;
    value.clusterProfiles.stringLength = C2xGetTokenLengthBit(packetHandle, "VAM", newPath);
    if ((result = CheckLastError("VAM", gkFuncRefGet, result))==0)
    {
      if(value.clusterProfiles.stringLength > 0)
      {
        for(j=0; j<value.clusterProfiles.stringLength; j++)
        {
          if(C2xGetTokenBitOfBitString(packetHandle, "VAM", newPath, j) == 0)
          {
            value.clusterProfiles.string[j] = '0';
          }
          else if(C2xGetTokenBitOfBitString(packetHandle, "VAM", newPath, j) == 1)
          {
            value.clusterProfiles.string[j] = '1';
          }

          if(value.clusterProfiles.stringLength == 1)
          {
            value.clusterProfiles.string[1] = '0';
          }
          result = CheckLastError("VAM", gkFuncRefGet, result);
        }
      }
      else
      {
        for(k = value.clusterProfiles.stringLength+1; k > -1; k--)
        {
          if(value.clusterProfiles.string[k] == '1')
          {
            value.clusterProfiles.string[k] = '0';
          }
        }
      }
    }

  }
  return result;
}

int SetVAMVruClusterInformationParams(LONG packetHandle, struct VAMVruClusterInformation value, char oldPath[])
{
  char newPath[300]; 
  int j;
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "clusterId");
  if(value.clusterId.isValidFlag==1)
  {
    C2xSetTokenInt(packetHandle, "VAM", newPath, value.clusterId.value);
    result = CheckLastError("VAM", gkFuncRefGet, result);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "VAM", newPath) )
    {
      C2xRemoveToken(packetHandle, "VAM", newPath);
    }
  }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "clusterBoundingBoxShape");
  if(value.clusterBoundingBoxShape.isValidFlag==1)
  {
    SetVAMShapeParams(packetHandle, value.clusterBoundingBoxShape, newPath);
    result = CheckLastError("VAM", gkFuncRefGet, result);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "VAM", newPath) )
    {
      C2xRemoveToken(packetHandle, "VAM", newPath);
    }
  }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "clusterCardinalitySize");
  C2xSetTokenInt(packetHandle, "VAM", newPath, value.clusterCardinalitySize);
  result = CheckLastError("VAM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "clusterProfiles");
  if(value.clusterProfiles.isValidFlag==1)
  {
      for(j=0; j<value.clusterProfiles.stringLength; j++)
      {
        if(value.clusterProfiles.string[j] == '0')
        {
          C2xSetTokenBitOfBitString(packetHandle, "VAM", newPath, j, 0);
        }
        else
        {
          C2xSetTokenBitOfBitString(packetHandle, "VAM", newPath, j, 1);
        }
        result = CheckLastError("VAM", gkFuncRefGet, result);
      }
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "VAM", newPath) )
    {
      C2xRemoveToken(packetHandle, "VAM", newPath);
    }
  }

  return result;
}

