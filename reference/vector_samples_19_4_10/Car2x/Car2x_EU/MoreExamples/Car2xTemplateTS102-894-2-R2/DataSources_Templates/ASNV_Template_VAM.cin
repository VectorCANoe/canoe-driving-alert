int GetVAMVruAwarenessParams(LONG packetHandle, struct VAMVruAwareness value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "generationDeltaTime");
  value.generationDeltaTime = C2xGetTokenInt(packetHandle, "VAM", newPath);
  result = CheckLastError("VAM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "vamParameters");
  GetVAMVamParametersParams(packetHandle, value.vamParameters, newPath);
  result = CheckLastError("VAM", gkFuncRefGet, result);

  return result;
}

int SetVAMVruAwarenessParams(LONG packetHandle, struct VAMVruAwareness value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "generationDeltaTime");
  C2xSetTokenInt(packetHandle, "VAM", newPath, value.generationDeltaTime);
  result = CheckLastError("VAM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "vamParameters");
  SetVAMVamParametersParams(packetHandle, value.vamParameters, newPath);
  result = CheckLastError("VAM", gkFuncRefGet, result);

  return result;
}

int API_GetVAMParams(LONG packetHandle, struct VAM value)
{
  int result;
  result = 0;

  value.header.isValidFlag = 1;
  GetVAMItsPduHeaderParams(packetHandle, value.header, "header");
  result = CheckLastError("VAM", gkFuncRefGet, result);

  value.vam.isValidFlag = 1;
  GetVAMVruAwarenessParams(packetHandle, value.vam, "vam");
  result = CheckLastError("VAM", gkFuncRefGet, result);

  return result;
}

int API_SetVAMParams(LONG packetHandle, struct VAM value)
{
  int result;
  result = 0;

  SetVAMItsPduHeaderParams(packetHandle, value.header, "header");
  result = CheckLastError("VAM", gkFuncRefGet, result);

  SetVAMVruAwarenessParams(packetHandle, value.vam, "vam");
  result = CheckLastError("VAM", gkFuncRefGet, result);

  return result;
}

