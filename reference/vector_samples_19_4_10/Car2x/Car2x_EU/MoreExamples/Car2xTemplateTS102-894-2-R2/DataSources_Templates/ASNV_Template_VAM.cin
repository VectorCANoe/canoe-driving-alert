int GetVAMVruProfileAndSubprofileParams(LONG packetHandle, struct VAMVruProfileAndSubprofile value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  value.choice = C2xGetTokenInt(packetHandle, "VAM", oldPath);

  switch(value.choice)
  {
    case 0:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "pedestrian");
      value.pedestrian = C2xGetTokenInt(packetHandle, "VAM", newPath);
      result = CheckLastError("VAM", gkFuncRefGet, result);
    }
    break;
    case 1:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "bicyclistAndLightVruVehicle");
      value.bicyclistAndLightVruVehicle = C2xGetTokenInt(packetHandle, "VAM", newPath);
      result = CheckLastError("VAM", gkFuncRefGet, result);
    }
    break;
    case 2:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "motorcyclist");
      value.motorcyclist = C2xGetTokenInt(packetHandle, "VAM", newPath);
      result = CheckLastError("VAM", gkFuncRefGet, result);
    }
    break;
    case 3:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "animal");
      value.animal = C2xGetTokenInt(packetHandle, "VAM", newPath);
      result = CheckLastError("VAM", gkFuncRefGet, result);
    }
    break;
  }
  return result;
}

