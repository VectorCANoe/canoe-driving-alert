        BYTE containerId;  // INTEGER, 1..16, twoWheelerContainer(1), eHorizonLocationSharingContainer(2), veryLowFrequencyContainer(3), pathPredictionContainer(4), generalizedLanePositionsContainer(5), vehicleMovementControlContainer(6);
        struct CAMExtensionContainers containerData;  // TABLE;
    };
    
    struct CAMWrappedExtensionContainers {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
