    case 2:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "deltaTimeMidRange");
      value.deltaTimeMidRange = C2xGetTokenInt(packetHandle, "CAM", newPath);
      result = CheckLastError("CAM", gkFuncRefGet, result);
