int GetCAMVehicleMovementControlParams(LONG packetHandle, struct CAMVehicleMovementControl value, char oldPath[])
{
  char newPath[300]; 
  int j; 
  int k;
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "accelerationPedalStatus");
  GetCAMPedalStatusParams(packetHandle, value.accelerationPedalStatus, newPath);
  result = CheckLastError("CAM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "brakePedalStatus");
  GetCAMPedalStatusParams(packetHandle, value.brakePedalStatus, newPath);
  result = CheckLastError("CAM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "saeAutomationLevel");
  value.saeAutomationLevel.isValidFlag = C2xIsTokenAvailable(packetHandle, "CAM", newPath);
  if(value.saeAutomationLevel.isValidFlag==1)
  {
    value.saeAutomationLevel.value = C2xGetTokenInt(packetHandle, "CAM", newPath);
    result = CheckLastError("CAM", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "automationControl");
  value.automationControl.isValidFlag = C2xIsTokenAvailable(packetHandle, "CAM", newPath);
  if(value.automationControl.isValidFlag==1)
  {
    value.automationControl.isValidFlag = 1;
    value.automationControl.stringLength = C2xGetTokenLengthBit(packetHandle, "CAM", newPath);
    if ((result = CheckLastError("CAM", gkFuncRefGet, result))==0)
    {
      if(value.automationControl.stringLength > 0)
      {
        for(j=0; j<value.automationControl.stringLength; j++)
        {
          if(C2xGetTokenBitOfBitString(packetHandle, "CAM", newPath, j) == 0)
          {
            value.automationControl.string[j] = '0';
          }
          else if(C2xGetTokenBitOfBitString(packetHandle, "CAM", newPath, j) == 1)
          {
            value.automationControl.string[j] = '1';
          }

          if(value.automationControl.stringLength == 1)
          {
            value.automationControl.string[1] = '0';
          }
          result = CheckLastError("CAM", gkFuncRefGet, result);
        }
      }
      else
      {
        for(k = value.automationControl.stringLength+1; k > -1; k--)
        {
          if(value.automationControl.string[k] == '1')
          {
            value.automationControl.string[k] = '0';
          }
        }
      }
    }

  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "accelerationControl");
  value.accelerationControl.isValidFlag = C2xIsTokenAvailable(packetHandle, "CAM", newPath);
  if(value.accelerationControl.isValidFlag==1)
  {
    value.accelerationControl.isValidFlag = 1;
    value.accelerationControl.stringLength = C2xGetTokenLengthBit(packetHandle, "CAM", newPath);
    if ((result = CheckLastError("CAM", gkFuncRefGet, result))==0)
    {
      if(value.accelerationControl.stringLength > 0)
      {
        for(j=0; j<value.accelerationControl.stringLength; j++)
        {
          if(C2xGetTokenBitOfBitString(packetHandle, "CAM", newPath, j) == 0)
          {
            value.accelerationControl.string[j] = '0';
          }
          else if(C2xGetTokenBitOfBitString(packetHandle, "CAM", newPath, j) == 1)
          {
            value.accelerationControl.string[j] = '1';
          }

          if(value.accelerationControl.stringLength == 1)
          {
            value.accelerationControl.string[1] = '0';
          }
          result = CheckLastError("CAM", gkFuncRefGet, result);
        }
      }
      else
      {
        for(k = value.accelerationControl.stringLength+1; k > -1; k--)
        {
          if(value.accelerationControl.string[k] == '1')
          {
            value.accelerationControl.string[k] = '0';
          }
        }
      }
    }

  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "accelerationControlExtension");
  value.accelerationControlExtension.isValidFlag = C2xIsTokenAvailable(packetHandle, "CAM", newPath);
  if(value.accelerationControlExtension.isValidFlag==1)
  {
    value.accelerationControlExtension.isValidFlag = 1;
    value.accelerationControlExtension.stringLength = C2xGetTokenLengthBit(packetHandle, "CAM", newPath);
    if ((result = CheckLastError("CAM", gkFuncRefGet, result))==0)
    {
      if(value.accelerationControlExtension.stringLength > 0)
      {
        for(j=0; j<value.accelerationControlExtension.stringLength; j++)
        {
          if(C2xGetTokenBitOfBitString(packetHandle, "CAM", newPath, j) == 0)
          {
            value.accelerationControlExtension.string[j] = '0';
          }
          else if(C2xGetTokenBitOfBitString(packetHandle, "CAM", newPath, j) == 1)
          {
            value.accelerationControlExtension.string[j] = '1';
          }

          if(value.accelerationControlExtension.stringLength == 1)
          {
            value.accelerationControlExtension.string[1] = '0';
          }
          result = CheckLastError("CAM", gkFuncRefGet, result);
        }
      }
      else
      {
        for(k = value.accelerationControlExtension.stringLength+1; k > -1; k--)
        {
          if(value.accelerationControlExtension.string[k] == '1')
          {
            value.accelerationControlExtension.string[k] = '0';
          }
        }
      }
    }

  }
  return result;
}

