    if( C2xIsTokenAvailable(packetHandle, "CAM", newPath) )
    {
      C2xRemoveToken(packetHandle, "CAM", newPath);
    }
  }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "altitudeConfidence");
  if(value.altitudeConfidence.isValidFlag==1)
  {
    C2xSetTokenInt(packetHandle, "CAM", newPath, value.altitudeConfidence.value);
    result = CheckLastError("CAM", gkFuncRefGet, result);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "CAM", newPath) )
    {
      C2xRemoveToken(packetHandle, "CAM", newPath);
    }
  }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "pathDeltaTime");
  if(value.pathDeltaTime.isValidFlag==1)
  {
    SetCAMPathDeltaTimeChoiceParams(packetHandle, value.pathDeltaTime, newPath);
    result = CheckLastError("CAM", gkFuncRefGet, result);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "CAM", newPath) )
    {
      C2xRemoveToken(packetHandle, "CAM", newPath);
    }
  }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "symmetricAreaOffset");
  if(value.symmetricAreaOffset.isValidFlag==1)
  {
    C2xSetTokenInt(packetHandle, "CAM", newPath, value.symmetricAreaOffset.value);
    result = CheckLastError("CAM", gkFuncRefGet, result);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "CAM", newPath) )
    {
      C2xRemoveToken(packetHandle, "CAM", newPath);
    }
  }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "asymmetricAreaOffset");
  if(value.asymmetricAreaOffset.isValidFlag==1)
  {
    C2xSetTokenInt(packetHandle, "CAM", newPath, value.asymmetricAreaOffset.value);
    result = CheckLastError("CAM", gkFuncRefGet, result);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "CAM", newPath) )
    {
      C2xRemoveToken(packetHandle, "CAM", newPath);
    }
  }

  return result;
}

