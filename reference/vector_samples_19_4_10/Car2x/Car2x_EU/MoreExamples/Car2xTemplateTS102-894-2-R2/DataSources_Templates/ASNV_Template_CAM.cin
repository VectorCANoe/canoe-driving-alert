int GetCAMLanePositionOptionsParams(LONG packetHandle, struct CAMLanePositionOptions value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  value.choice = C2xGetTokenInt(packetHandle, "CAM", oldPath);

  switch(value.choice)
  {
    case 0:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "simplelanePosition");
      value.simplelanePosition = C2xGetTokenInt(packetHandle, "CAM", newPath);
      result = CheckLastError("CAM", gkFuncRefGet, result);
    }
    break;
    case 1:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "simpleLaneType");
      value.simpleLaneType = C2xGetTokenInt(packetHandle, "CAM", newPath);
      result = CheckLastError("CAM", gkFuncRefGet, result);
    }
    break;
    case 2:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "detailedlanePosition");
      GetCAMLanePositionAndTypeParams(packetHandle, value.detailedlanePosition, newPath);
      result = CheckLastError("CAM", gkFuncRefGet, result);
    }
    break;
    case 3:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "lanePositionWithLateralDetails");
      GetCAMLanePositionWithLateralDetailsParams(packetHandle, value.lanePositionWithLateralDetails, newPath);
      result = CheckLastError("CAM", gkFuncRefGet, result);
    }
    break;
    case 4:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "trafficIslandPosition");
      GetCAMTrafficIslandPositionParams(packetHandle, value.trafficIslandPosition, newPath);
      result = CheckLastError("CAM", gkFuncRefGet, result);
    }
    break;
  }
  return result;
}

