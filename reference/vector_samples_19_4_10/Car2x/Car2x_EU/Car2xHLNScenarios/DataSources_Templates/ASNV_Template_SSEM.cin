int GetSSEMDSRC_SignalRequesterInfoParams(LONG packetHandle, struct SSEMDSRC_SignalRequesterInfo value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "id");
  GetSSEMDSRC_VehicleIDParams(packetHandle, value.id, newPath);
  result = CheckLastError("SSEM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "request");
  value.request = C2xGetTokenInt(packetHandle, "SSEM", newPath);
  result = CheckLastError("SSEM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "sequenceNumber");
  value.sequenceNumber = C2xGetTokenInt(packetHandle, "SSEM", newPath);
  result = CheckLastError("SSEM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "role");
  value.role.isValidFlag = C2xIsTokenAvailable(packetHandle, "SSEM", newPath);
  if(value.role.isValidFlag==1)
  {
    value.role.value = C2xGetTokenInt(packetHandle, "SSEM", newPath);
    result = CheckLastError("SSEM", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "typeData");
  value.typeData.isValidFlag = C2xIsTokenAvailable(packetHandle, "SSEM", newPath);
  if(value.typeData.isValidFlag==1)
  {
    GetSSEMDSRC_RequestorTypeParams(packetHandle, value.typeData, newPath);
    result = CheckLastError("SSEM", gkFuncRefGet, result);
  }
  return result;
}

int SetSSEMDSRC_SignalRequesterInfoParams(LONG packetHandle, struct SSEMDSRC_SignalRequesterInfo value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "id");
