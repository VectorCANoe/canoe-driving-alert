  if(value.sequenceNumber.isValidFlag==1)
  {
    value.sequenceNumber.value = C2xGetTokenInt(packetHandle, "SSEM", newPath);
    result = CheckLastError("SSEM", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "status");
  GetSSEMDSRC_SignalStatusListParams(packetHandle, value.status, newPath);
  result = CheckLastError("SSEM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "regional");
  value.regional.isValidFlag = C2xIsTokenAvailable(packetHandle, "SSEM", newPath);
  if(value.regional.isValidFlag==1)
  {
    GetSSEMDSRC_SignalStatusMessage_regionalParams(packetHandle, value.regional, newPath);
    result = CheckLastError("SSEM", gkFuncRefGet, result);
  }
  return result;
}

int SetSSEMDSRC_SignalStatusMessageParams(LONG packetHandle, struct SSEMDSRC_SignalStatusMessage value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "timeStamp");
  if(value.timeStamp.isValidFlag==1)
  {
    C2xSetTokenInt(packetHandle, "SSEM", newPath, value.timeStamp.value);
    result = CheckLastError("SSEM", gkFuncRefGet, result);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "SSEM", newPath) )
    {
      C2xRemoveToken(packetHandle, "SSEM", newPath);
    }
  }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "second");
  C2xSetTokenInt(packetHandle, "SSEM", newPath, value.second);
  result = CheckLastError("SSEM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "sequenceNumber");
  if(value.sequenceNumber.isValidFlag==1)
  {
    C2xSetTokenInt(packetHandle, "SSEM", newPath, value.sequenceNumber.value);
    result = CheckLastError("SSEM", gkFuncRefGet, result);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "SSEM", newPath) )
    {
      C2xRemoveToken(packetHandle, "SSEM", newPath);
    }
  }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "status");
  SetSSEMDSRC_SignalStatusListParams(packetHandle, value.status, newPath);
  result = CheckLastError("SSEM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "regional");
  if(value.regional.isValidFlag==1)
  {
    SetSSEMDSRC_SignalStatusMessage_regionalParams(packetHandle, value.regional, newPath);
    result = CheckLastError("SSEM", gkFuncRefGet, result);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "SSEM", newPath) )
    {
      C2xRemoveToken(packetHandle, "SSEM", newPath);
    }
  }

  return result;
}

int API_GetSSEMParams(LONG packetHandle, struct SSEM value)
{
  int result;
  result = 0;

  value.header.isValidFlag = 1;
  GetSSEMITS_Container_ItsPduHeaderParams(packetHandle, value.header, "header");
  result = CheckLastError("SSEM", gkFuncRefGet, result);

  value.ssm.isValidFlag = 1;
  GetSSEMDSRC_SignalStatusMessageParams(packetHandle, value.ssm, "ssm");
  result = CheckLastError("SSEM", gkFuncRefGet, result);

  return result;
}

int API_SetSSEMParams(LONG packetHandle, struct SSEM value)
{
  int result;
  result = 0;

  SetSSEMITS_Container_ItsPduHeaderParams(packetHandle, value.header, "header");
  result = CheckLastError("SSEM", gkFuncRefGet, result);

  SetSSEMDSRC_SignalStatusMessageParams(packetHandle, value.ssm, "ssm");
  result = CheckLastError("SSEM", gkFuncRefGet, result);

  return result;
}

