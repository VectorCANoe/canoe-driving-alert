        struct CPMObjectDistanceWithConfidence xDistance;  // SEQUENCE;
        struct CPMObjectDistanceWithConfidence yDistance;  // SEQUENCE;
        struct CPMObjectDistanceWithConfidence zDistance;  // SEQUENCE, OPTIONAL;
        struct CPMSpeedExtended xSpeed;  // SEQUENCE;
        struct CPMSpeedExtended ySpeed;  // SEQUENCE;
        struct CPMSpeedExtended zSpeed;  // SEQUENCE, OPTIONAL;
        struct CPMLongitudinalAcceleration xAcceleration;  // SEQUENCE, OPTIONAL;
        struct CPMLateralAcceleration yAcceleration;  // SEQUENCE, OPTIONAL;
        struct CPMVerticalAcceleration zAcceleration;  // SEQUENCE, OPTIONAL;
        struct CPMCartesianAngle yawAngle;  // SEQUENCE, OPTIONAL;
        struct CPMObjectDimension planarObjectDimension1;  // SEQUENCE, OPTIONAL;
        struct CPMObjectDimension planarObjectDimension2;  // SEQUENCE, OPTIONAL;
        struct CPMObjectDimension verticalObjectDimension;  // SEQUENCE, OPTIONAL;
        struct OPT_BYTE_ASN objectRefPoint;  // INTEGER, OPTIONAL, 0..8, mid(0), bottomLeft(1), midLeft(2), topLeft(3), bottomMid(4), topMid(5), bottomRight(6), midRight(7), topRight(8);
        struct OPT_BYTE_ASN dynamicStatus;  // INTEGER, OPTIONAL, 0..2, dynamic(0), hasBeenDynamic(1), static(2);
        struct CPMObjectClassDescription classification;  // SEQUENCEOF, OPTIONAL;
        struct CPMMatchedPosition matchedPosition;  // SEQUENCE, OPTIONAL;
    };
    
    struct CPMPerceivedObjectContainer {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        INT length;
        struct CPMPerceivedObject arrayValue[128];  // SEQUENCE;
    };
    
    struct CPMFreeSpaceArea {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        INT choice;
        struct CPMAreaPolygon freeSpacePolygon;  // SEQUENCE;
        struct CPMAreaCircular freeSpaceCircular;  // SEQUENCE;
        struct CPMAreaEllipse freeSpaceEllipse;  // SEQUENCE;
        struct CPMAreaRectangle freeSpaceRectangle;  // SEQUENCE;
    };
    
    struct CPMFreeSpaceAddendum {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        BYTE freeSpaceConfidence;  // INTEGER, 0..101, unknown(0), onePercent(1), oneHundredPercent(100), unavailable(101);
        struct CPMFreeSpaceArea freeSpaceArea;  // CHOICE;
        struct CPMSensorIdList sensorIDList;  // SEQUENCEOF, OPTIONAL;
        struct OPT_BOOL_ASN shadowingApplies;  // BOOLEAN, OPTIONAL;
    };
    
    struct CPMFreeSpaceAddendumContainer {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        INT length;
        struct CPMFreeSpaceAddendum arrayValue[128];  // SEQUENCE;
    };
    
    struct CPMCpmParameters {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        struct CPMCpmManagementContainer managementContainer;  // SEQUENCE;
        struct CPMStationDataContainer stationDataContainer;  // CHOICE, OPTIONAL;
        struct CPMSensorInformationContainer sensorInformationContainer;  // SEQUENCEOF, OPTIONAL;
        struct CPMPerceivedObjectContainer perceivedObjectContainer;  // SEQUENCEOF, OPTIONAL;
        struct CPMFreeSpaceAddendumContainer freeSpaceAddendumContainer;  // SEQUENCEOF, OPTIONAL;
        BYTE numberOfPerceivedObjects;  // INTEGER, 0..255;
    };
    
    struct CPMCollectivePerceptionMessage {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        WORD generationDeltaTime;  // INTEGER, 0..65535, oneMilliSec(1);
        struct CPMCpmParameters cpmParameters;  // SEQUENCE;
    };
    
    struct CPM {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        struct CPMItsPduHeader header;  // SEQUENCE;
        struct CPMCollectivePerceptionMessage cpm;  // SEQUENCE;
    };
    
}

/*
// init function to create a simple packet handle
*/ 
LONG API_InitCPMPacket()
{
  return C2xInitPacket("CPM"); 
}

/*
// init function to create a simple packet handle and
// initialize the struct with valid data
*/ 
LONG API_InitCPMPacket(struct CPM msgStruct)
{
  long pktHandle;

  pktHandle = API_InitCPMPacket();

  if (pktHandle != 0)
  {
    // create valid message and application data
    if (C2xCompletePacket(pktHandle) == 0) 
    {
      API_GetCPMParams(pktHandle, msgStruct);
    }
  }
  return pktHandle;
}

/*
// init function to create a packet with security layer and
// initialize the struct with valid data
*/ 
LONG API_InitCPMPacket(struct CPM msgStruct, char packetTypeDesignator[], char certificateName[])
{
  long pktHandle, certHdl;

  // initialize the packet
  pktHandle = C2xInitPacket("CPM", packetTypeDesignator);

  if (pktHandle != 0)
  {
    certHdl = C2xSecCertificateGetHandle(certificateName);  // get the certificate handle for the cert with name "certificateName"
    if (certHdl != 0) 
    {
      C2xSecPacketSetSignerHandle(pktHandle, certHdl); // set the certHdl to the packet
    }

    // create valid message and application data
    if (C2xCompletePacket(pktHandle) == 0) 
    {
      // copy application data to the application structure
      API_GetCPMParams(pktHandle, msgStruct);
    }
  }
  return pktHandle;
}
    

int GetCPMItsPduHeaderParams(LONG packetHandle, struct CPMItsPduHeader value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "protocolVersion");
  value.protocolVersion = C2xGetTokenInt(packetHandle, "CPM", newPath);
  result = CheckLastError("CPM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "messageID");
  value.messageID = C2xGetTokenInt(packetHandle, "CPM", newPath);
  result = CheckLastError("CPM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "stationID");
  value.stationID = C2xGetTokenInt64(packetHandle, "CPM", newPath);
  result = CheckLastError("CPM", gkFuncRefGet, result);

  return result;
}

int SetCPMItsPduHeaderParams(LONG packetHandle, struct CPMItsPduHeader value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "protocolVersion");
  C2xSetTokenInt(packetHandle, "CPM", newPath, value.protocolVersion);
  result = CheckLastError("CPM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "messageID");
  C2xSetTokenInt(packetHandle, "CPM", newPath, value.messageID);
  result = CheckLastError("CPM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "stationID");
  C2xSetTokenInt64(packetHandle, "CPM", newPath, value.stationID);
  result = CheckLastError("CPM", gkFuncRefGet, result);

  return result;
}

