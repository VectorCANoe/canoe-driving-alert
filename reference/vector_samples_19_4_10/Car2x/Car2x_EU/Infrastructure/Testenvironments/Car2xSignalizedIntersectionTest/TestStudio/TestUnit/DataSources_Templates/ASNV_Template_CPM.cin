int GetCPMDetectionAreaParams(LONG packetHandle, struct CPMDetectionArea value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  value.choice = C2xGetTokenInt(packetHandle, "CPM", oldPath);

  switch(value.choice)
  {
    case 0:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "vehicleSensor");
      GetCPMVehicleSensorParams(packetHandle, value.vehicleSensor, newPath);
      result = CheckLastError("CPM", gkFuncRefGet, result);
    }
    break;
    case 1:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "stationarySensorRadial");
      GetCPMAreaRadialParams(packetHandle, value.stationarySensorRadial, newPath);
      result = CheckLastError("CPM", gkFuncRefGet, result);
    }
    break;
    case 2:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "stationarySensorPolygon");
      GetCPMAreaPolygonParams(packetHandle, value.stationarySensorPolygon, newPath);
      result = CheckLastError("CPM", gkFuncRefGet, result);
    }
    break;
    case 3:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "stationarySensorCircular");
      GetCPMAreaCircularParams(packetHandle, value.stationarySensorCircular, newPath);
      result = CheckLastError("CPM", gkFuncRefGet, result);
    }
    break;
    case 4:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "stationarySensorEllipse");
      GetCPMAreaEllipseParams(packetHandle, value.stationarySensorEllipse, newPath);
      result = CheckLastError("CPM", gkFuncRefGet, result);
    }
    break;
    case 5:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "stationarySensorRectangle");
      GetCPMAreaRectangleParams(packetHandle, value.stationarySensorRectangle, newPath);
      result = CheckLastError("CPM", gkFuncRefGet, result);
    }
    break;
  }
  return result;
}

