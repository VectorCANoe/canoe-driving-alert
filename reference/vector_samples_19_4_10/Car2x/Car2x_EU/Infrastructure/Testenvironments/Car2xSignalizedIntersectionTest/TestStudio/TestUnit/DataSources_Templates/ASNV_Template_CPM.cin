int GetCPMPerceivedObjectContainerParams(LONG packetHandle, struct CPMPerceivedObjectContainer value, char oldPath[])
{
  char newPath[300]; 
  int i;
  int result;

  result = 0;

  value.length = C2xGetTokenInt(packetHandle, "CPM", oldPath);
  if((result = CheckLastError("CPM", gkFuncRefGet, result))==0)
  {
    for(i=0; i<value.length; i++)
    {
      snprintf(newPath, elcount(newPath), "%s[%d]", oldPath, i);
      GetCPMPerceivedObjectParams(packetHandle, value.arrayValue[i], newPath);
      result = CheckLastError("CPM", gkFuncRefGet, result);
    }
  }
  return result;
}

int SetCPMPerceivedObjectContainerParams(LONG packetHandle, struct CPMPerceivedObjectContainer value, char oldPath[])
{
  char newPath[300]; 
  int i;
  int result;

  result = 0;

  C2xRemoveToken(packetHandle, "CPM", oldPath);
  for(i=0; i<value.length; i++)
  {
    snprintf(newPath, elcount(newPath), "%s[%d]", oldPath, i);
    SetCPMPerceivedObjectParams(packetHandle, value.arrayValue[i], newPath);
    result = CheckLastError("CPM", gkFuncRefGet, result);
  }
  return result;
}

int GetCPMFreeSpaceAreaParams(LONG packetHandle, struct CPMFreeSpaceArea value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  value.choice = C2xGetTokenInt(packetHandle, "CPM", oldPath);

  switch(value.choice)
  {
    case 0:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "freeSpacePolygon");
      GetCPMAreaPolygonParams(packetHandle, value.freeSpacePolygon, newPath);
      result = CheckLastError("CPM", gkFuncRefGet, result);
    }
    break;
    case 1:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "freeSpaceCircular");
      GetCPMAreaCircularParams(packetHandle, value.freeSpaceCircular, newPath);
      result = CheckLastError("CPM", gkFuncRefGet, result);
    }
    break;
    case 2:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "freeSpaceEllipse");
      GetCPMAreaEllipseParams(packetHandle, value.freeSpaceEllipse, newPath);
      result = CheckLastError("CPM", gkFuncRefGet, result);
    }
    break;
    case 3:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "freeSpaceRectangle");
      GetCPMAreaRectangleParams(packetHandle, value.freeSpaceRectangle, newPath);
      result = CheckLastError("CPM", gkFuncRefGet, result);
    }
    break;
  }
  return result;
}

