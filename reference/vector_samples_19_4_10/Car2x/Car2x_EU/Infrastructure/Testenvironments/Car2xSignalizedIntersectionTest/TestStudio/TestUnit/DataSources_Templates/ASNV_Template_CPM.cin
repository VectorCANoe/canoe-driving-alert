int GetCPMOriginatingRSUContainerParams(LONG packetHandle, struct CPMOriginatingRSUContainer value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  value.choice = C2xGetTokenInt(packetHandle, "CPM", oldPath);

  switch(value.choice)
  {
    case 0:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "intersectionReferenceId");
      GetCPMIntersectionReferenceIDParams(packetHandle, value.intersectionReferenceId, newPath);
      result = CheckLastError("CPM", gkFuncRefGet, result);
    }
    break;
    case 1:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "roadSegmentReferenceId");
      GetCPMRoadSegmentReferenceIDParams(packetHandle, value.roadSegmentReferenceId, newPath);
      result = CheckLastError("CPM", gkFuncRefGet, result);
    }
    break;
  }
  return result;
}

