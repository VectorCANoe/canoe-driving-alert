int GetCPMTrailerDataContainerParams(LONG packetHandle, struct CPMTrailerDataContainer value, char oldPath[])
{
  char newPath[300]; 
  int i;
  int result;

  result = 0;

  value.length = C2xGetTokenInt(packetHandle, "CPM", oldPath);
  if((result = CheckLastError("CPM", gkFuncRefGet, result))==0)
  {
    for(i=0; i<value.length; i++)
    {
      snprintf(newPath, elcount(newPath), "%s[%d]", oldPath, i);
      GetCPMTrailerDataParams(packetHandle, value.arrayValue[i], newPath);
      result = CheckLastError("CPM", gkFuncRefGet, result);
    }
  }
  return result;
}

int SetCPMTrailerDataContainerParams(LONG packetHandle, struct CPMTrailerDataContainer value, char oldPath[])
{
