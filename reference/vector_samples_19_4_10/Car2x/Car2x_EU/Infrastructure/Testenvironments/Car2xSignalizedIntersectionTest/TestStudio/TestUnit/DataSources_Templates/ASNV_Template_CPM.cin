int GetCPMCpmManagementContainerParams(LONG packetHandle, struct CPMCpmManagementContainer value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "stationType");
  value.stationType = C2xGetTokenInt(packetHandle, "CPM", newPath);
  result = CheckLastError("CPM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "perceivedObjectContainerSegmentInfo");
  value.perceivedObjectContainerSegmentInfo.isValidFlag = C2xIsTokenAvailable(packetHandle, "CPM", newPath);
  if(value.perceivedObjectContainerSegmentInfo.isValidFlag==1)
  {
    GetCPMPerceivedObjectContainerSegmentInfoParams(packetHandle, value.perceivedObjectContainerSegmentInfo, newPath);
    result = CheckLastError("CPM", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "referencePosition");
  GetCPMReferencePositionParams(packetHandle, value.referencePosition, newPath);
  result = CheckLastError("CPM", gkFuncRefGet, result);

  return result;
}

int SetCPMCpmManagementContainerParams(LONG packetHandle, struct CPMCpmManagementContainer value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "stationType");
  C2xSetTokenInt(packetHandle, "CPM", newPath, value.stationType);
  result = CheckLastError("CPM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "perceivedObjectContainerSegmentInfo");
  if(value.perceivedObjectContainerSegmentInfo.isValidFlag==1)
  {
    SetCPMPerceivedObjectContainerSegmentInfoParams(packetHandle, value.perceivedObjectContainerSegmentInfo, newPath);
    result = CheckLastError("CPM", gkFuncRefGet, result);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "CPM", newPath) )
    {
      C2xRemoveToken(packetHandle, "CPM", newPath);
    }
  }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "referencePosition");
  SetCPMReferencePositionParams(packetHandle, value.referencePosition, newPath);
  result = CheckLastError("CPM", gkFuncRefGet, result);

  return result;
}

