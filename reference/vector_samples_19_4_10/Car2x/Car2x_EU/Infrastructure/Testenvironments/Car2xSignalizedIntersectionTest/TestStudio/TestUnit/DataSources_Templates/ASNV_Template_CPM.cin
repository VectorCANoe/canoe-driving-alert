  {
    SetCPMSensorIdListParams(packetHandle, value.sensorIDList, newPath);
    result = CheckLastError("CPM", gkFuncRefGet, result);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "CPM", newPath) )
    {
      C2xRemoveToken(packetHandle, "CPM", newPath);
    }
  }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "shadowingApplies");
  if(value.shadowingApplies.isValidFlag==1)
  {
    C2xSetTokenInt64(packetHandle, "CPM", newPath, value.shadowingApplies.value);
    result = CheckLastError("CPM", gkFuncRefGet, result);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "CPM", newPath) )
    {
      C2xRemoveToken(packetHandle, "CPM", newPath);
    }
  }

  return result;
}

int GetCPMFreeSpaceAddendumContainerParams(LONG packetHandle, struct CPMFreeSpaceAddendumContainer value, char oldPath[])
{
  char newPath[300]; 
  int i;
  int result;

  result = 0;

  value.length = C2xGetTokenInt(packetHandle, "CPM", oldPath);
  if((result = CheckLastError("CPM", gkFuncRefGet, result))==0)
  {
    for(i=0; i<value.length; i++)
    {
      snprintf(newPath, elcount(newPath), "%s[%d]", oldPath, i);
      GetCPMFreeSpaceAddendumParams(packetHandle, value.arrayValue[i], newPath);
      result = CheckLastError("CPM", gkFuncRefGet, result);
    }
  }
  return result;
}

int SetCPMFreeSpaceAddendumContainerParams(LONG packetHandle, struct CPMFreeSpaceAddendumContainer value, char oldPath[])
{
  char newPath[300]; 
  int i;
  int result;

  result = 0;

  C2xRemoveToken(packetHandle, "CPM", oldPath);
  for(i=0; i<value.length; i++)
  {
    snprintf(newPath, elcount(newPath), "%s[%d]", oldPath, i);
    SetCPMFreeSpaceAddendumParams(packetHandle, value.arrayValue[i], newPath);
    result = CheckLastError("CPM", gkFuncRefGet, result);
  }
  return result;
}

int GetCPMCpmParametersParams(LONG packetHandle, struct CPMCpmParameters value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "managementContainer");
  GetCPMCpmManagementContainerParams(packetHandle, value.managementContainer, newPath);
  result = CheckLastError("CPM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "stationDataContainer");
  value.stationDataContainer.isValidFlag = C2xIsTokenAvailable(packetHandle, "CPM", newPath);
  if(value.stationDataContainer.isValidFlag==1)
  {
    GetCPMStationDataContainerParams(packetHandle, value.stationDataContainer, newPath);
    result = CheckLastError("CPM", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "sensorInformationContainer");
  value.sensorInformationContainer.isValidFlag = C2xIsTokenAvailable(packetHandle, "CPM", newPath);
  if(value.sensorInformationContainer.isValidFlag==1)
  {
    GetCPMSensorInformationContainerParams(packetHandle, value.sensorInformationContainer, newPath);
    result = CheckLastError("CPM", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "perceivedObjectContainer");
  value.perceivedObjectContainer.isValidFlag = C2xIsTokenAvailable(packetHandle, "CPM", newPath);
  if(value.perceivedObjectContainer.isValidFlag==1)
  {
    GetCPMPerceivedObjectContainerParams(packetHandle, value.perceivedObjectContainer, newPath);
    result = CheckLastError("CPM", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "freeSpaceAddendumContainer");
  value.freeSpaceAddendumContainer.isValidFlag = C2xIsTokenAvailable(packetHandle, "CPM", newPath);
  if(value.freeSpaceAddendumContainer.isValidFlag==1)
  {
    GetCPMFreeSpaceAddendumContainerParams(packetHandle, value.freeSpaceAddendumContainer, newPath);
    result = CheckLastError("CPM", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "numberOfPerceivedObjects");
  value.numberOfPerceivedObjects = C2xGetTokenInt(packetHandle, "CPM", newPath);
  result = CheckLastError("CPM", gkFuncRefGet, result);

  return result;
}

