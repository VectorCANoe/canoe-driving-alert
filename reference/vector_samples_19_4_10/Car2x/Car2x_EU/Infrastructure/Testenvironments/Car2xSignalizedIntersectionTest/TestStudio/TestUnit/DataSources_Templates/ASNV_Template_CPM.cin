int GetCPMCollectivePerceptionMessageParams(LONG packetHandle, struct CPMCollectivePerceptionMessage value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "generationDeltaTime");
  value.generationDeltaTime = C2xGetTokenInt(packetHandle, "CPM", newPath);
  result = CheckLastError("CPM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "cpmParameters");
  GetCPMCpmParametersParams(packetHandle, value.cpmParameters, newPath);
  result = CheckLastError("CPM", gkFuncRefGet, result);

