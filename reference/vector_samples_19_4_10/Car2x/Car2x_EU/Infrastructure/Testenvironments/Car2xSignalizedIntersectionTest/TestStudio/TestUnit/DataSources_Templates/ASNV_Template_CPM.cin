int GetCPMObjectClass_classParams(LONG packetHandle, struct CPMObjectClass_class value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  value.choice = C2xGetTokenInt(packetHandle, "CPM", oldPath);

  switch(value.choice)
  {
    case 0:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "vehicle");
      GetCPMVehicleSubclassParams(packetHandle, value.vehicle, newPath);
      result = CheckLastError("CPM", gkFuncRefGet, result);
    }
    break;
    case 1:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "person");
      GetCPMPersonSubclassParams(packetHandle, value.person, newPath);
      result = CheckLastError("CPM", gkFuncRefGet, result);
    }
    break;
    case 2:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "animal");
      GetCPMAnimalSubclassParams(packetHandle, value.animal, newPath);
      result = CheckLastError("CPM", gkFuncRefGet, result);
    }
    break;
    case 3:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "other");
      GetCPMOtherSubclassParams(packetHandle, value.other, newPath);
      result = CheckLastError("CPM", gkFuncRefGet, result);
    }
    break;
  }
  return result;
}

