int GetSREMDSRC_RequestorDescriptionParams(LONG packetHandle, struct SREMDSRC_RequestorDescription value, char oldPath[])
{
  char newPath[300]; 
  int j; 
  int k;
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "id");
  GetSREMDSRC_VehicleIDParams(packetHandle, value.id, newPath);
  result = CheckLastError("SREM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "type");
  value.type.isValidFlag = C2xIsTokenAvailable(packetHandle, "SREM", newPath);
  if(value.type.isValidFlag==1)
  {
    GetSREMDSRC_RequestorTypeParams(packetHandle, value.type, newPath);
    result = CheckLastError("SREM", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "position");
  value.position.isValidFlag = C2xIsTokenAvailable(packetHandle, "SREM", newPath);
  if(value.position.isValidFlag==1)
  {
    GetSREMDSRC_RequestorPositionVectorParams(packetHandle, value.position, newPath);
    result = CheckLastError("SREM", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "name");
  value.name.isValidFlag = C2xIsTokenAvailable(packetHandle, "SREM", newPath);
  if(value.name.isValidFlag==1)
  {
    value.name.stringLength = C2xGetTokenData(packetHandle, "SREM", newPath, elcount(value.name.string), value.name.string);
    result = CheckLastError("SREM", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "routeName");
  value.routeName.isValidFlag = C2xIsTokenAvailable(packetHandle, "SREM", newPath);
  if(value.routeName.isValidFlag==1)
  {
    value.routeName.stringLength = C2xGetTokenData(packetHandle, "SREM", newPath, elcount(value.routeName.string), value.routeName.string);
    result = CheckLastError("SREM", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "transitStatus");
  value.transitStatus.isValidFlag = C2xIsTokenAvailable(packetHandle, "SREM", newPath);
  if(value.transitStatus.isValidFlag==1)
  {
    value.transitStatus.isValidFlag = 1;
    value.transitStatus.stringLength = C2xGetTokenLengthBit(packetHandle, "SREM", newPath);
    if ((result = CheckLastError("SREM", gkFuncRefGet, result))==0)
    {
      if(value.transitStatus.stringLength > 0)
      {
        for(j=0; j<value.transitStatus.stringLength; j++)
        {
          if(C2xGetTokenBitOfBitString(packetHandle, "SREM", newPath, j) == 0)
          {
            value.transitStatus.string[j] = '0';
          }
          else if(C2xGetTokenBitOfBitString(packetHandle, "SREM", newPath, j) == 1)
          {
            value.transitStatus.string[j] = '1';
          }

          if(value.transitStatus.stringLength == 1)
          {
            value.transitStatus.string[1] = '0';
          }
          result = CheckLastError("SREM", gkFuncRefGet, result);
        }
      }
      else
      {
        for(k = value.transitStatus.stringLength+1; k > -1; k--)
        {
          if(value.transitStatus.string[k] == '1')
          {
            value.transitStatus.string[k] = '0';
          }
        }
      }
    }

  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "transitOccupancy");
  value.transitOccupancy.isValidFlag = C2xIsTokenAvailable(packetHandle, "SREM", newPath);
  if(value.transitOccupancy.isValidFlag==1)
  {
    value.transitOccupancy.value = C2xGetTokenInt(packetHandle, "SREM", newPath);
    result = CheckLastError("SREM", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "transitSchedule");
  value.transitSchedule.isValidFlag = C2xIsTokenAvailable(packetHandle, "SREM", newPath);
  if(value.transitSchedule.isValidFlag==1)
  {
    value.transitSchedule.value = C2xGetTokenInt(packetHandle, "SREM", newPath);
    result = CheckLastError("SREM", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "regional");
  value.regional.isValidFlag = C2xIsTokenAvailable(packetHandle, "SREM", newPath);
  if(value.regional.isValidFlag==1)
  {
    GetSREMDSRC_RequestorDescription_regionalParams(packetHandle, value.regional, newPath);
    result = CheckLastError("SREM", gkFuncRefGet, result);
  }
  return result;
}

