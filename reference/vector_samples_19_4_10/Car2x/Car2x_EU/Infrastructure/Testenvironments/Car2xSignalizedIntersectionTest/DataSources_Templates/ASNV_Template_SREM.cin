    if( C2xIsTokenAvailable(packetHandle, "SREM", newPath) )
    {
      C2xRemoveToken(packetHandle, "SREM", newPath);
    }
  }

  return result;
}

int API_GetSREMParams(LONG packetHandle, struct SREM value)
{
  int result;
  result = 0;

  value.header.isValidFlag = 1;
  GetSREMITS_Container_ItsPduHeaderParams(packetHandle, value.header, "header");
  result = CheckLastError("SREM", gkFuncRefGet, result);

  value.srm.isValidFlag = 1;
  GetSREMDSRC_SignalRequestMessageParams(packetHandle, value.srm, "srm");
  result = CheckLastError("SREM", gkFuncRefGet, result);

  return result;
}

int API_SetSREMParams(LONG packetHandle, struct SREM value)
{
  int result;
  result = 0;

  SetSREMITS_Container_ItsPduHeaderParams(packetHandle, value.header, "header");
  result = CheckLastError("SREM", gkFuncRefGet, result);

  SetSREMDSRC_SignalRequestMessageParams(packetHandle, value.srm, "srm");
  result = CheckLastError("SREM", gkFuncRefGet, result);

  return result;
}

