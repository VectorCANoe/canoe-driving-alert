int SetSREMDSRC_RegionalExtensionEmptyParams(LONG packetHandle, struct SREMDSRC_RegionalExtensionEmpty value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;


  return result;
}

int GetSREMDSRC_SignalRequest_regionalParams(LONG packetHandle, struct SREMDSRC_SignalRequest_regional value, char oldPath[])
{
  char newPath[300]; 
  int i;
  int result;

  result = 0;

  value.length = C2xGetTokenInt(packetHandle, "SREM", oldPath);
  if((result = CheckLastError("SREM", gkFuncRefGet, result))==0)
  {
    for(i=0; i<value.length; i++)
    {
      snprintf(newPath, elcount(newPath), "%s[%d]", oldPath, i);
      GetSREMDSRC_RegionalExtensionEmptyParams(packetHandle, value.arrayValue[i], newPath);
      result = CheckLastError("SREM", gkFuncRefGet, result);
    }
  }
  return result;
}

int SetSREMDSRC_SignalRequest_regionalParams(LONG packetHandle, struct SREMDSRC_SignalRequest_regional value, char oldPath[])
{
  char newPath[300]; 
  int i;
  int result;

  result = 0;

  C2xRemoveToken(packetHandle, "SREM", oldPath);
  for(i=0; i<value.length; i++)
  {
    snprintf(newPath, elcount(newPath), "%s[%d]", oldPath, i);
    SetSREMDSRC_RegionalExtensionEmptyParams(packetHandle, value.arrayValue[i], newPath);
    result = CheckLastError("SREM", gkFuncRefGet, result);
  }
  return result;
}

int GetSREMDSRC_SignalRequestParams(LONG packetHandle, struct SREMDSRC_SignalRequest value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "id");
  GetSREMDSRC_IntersectionReferenceIDParams(packetHandle, value.id, newPath);
  result = CheckLastError("SREM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "requestID");
  value.requestID = C2xGetTokenInt(packetHandle, "SREM", newPath);
  result = CheckLastError("SREM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "requestType");
  value.requestType = C2xGetTokenInt(packetHandle, "SREM", newPath);
  result = CheckLastError("SREM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "inBoundLane");
  GetSREMDSRC_IntersectionAccessPointParams(packetHandle, value.inBoundLane, newPath);
  result = CheckLastError("SREM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "outBoundLane");
  value.outBoundLane.isValidFlag = C2xIsTokenAvailable(packetHandle, "SREM", newPath);
  if(value.outBoundLane.isValidFlag==1)
  {
    GetSREMDSRC_IntersectionAccessPointParams(packetHandle, value.outBoundLane, newPath);
    result = CheckLastError("SREM", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "regional");
  value.regional.isValidFlag = C2xIsTokenAvailable(packetHandle, "SREM", newPath);
  if(value.regional.isValidFlag==1)
  {
    GetSREMDSRC_SignalRequest_regionalParams(packetHandle, value.regional, newPath);
    result = CheckLastError("SREM", gkFuncRefGet, result);
  }
  return result;
}

int SetSREMDSRC_SignalRequestParams(LONG packetHandle, struct SREMDSRC_SignalRequest value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "id");
  SetSREMDSRC_IntersectionReferenceIDParams(packetHandle, value.id, newPath);
  result = CheckLastError("SREM", gkFuncRefGet, result);

