/*
// init function to create a simple packet handle
*/ 
LONG API_InitSREMPacket()
{
  return C2xInitPacket("SREM"); 
}

/*
// init function to create a simple packet handle and
// initialize the struct with valid data
*/ 
LONG API_InitSREMPacket(struct SREM msgStruct)
{
  long pktHandle;

  pktHandle = API_InitSREMPacket();

  if (pktHandle != 0)
  {
    // create valid message and application data
    if (C2xCompletePacket(pktHandle) == 0) 
    {
      API_GetSREMParams(pktHandle, msgStruct);
    }
  }
  return pktHandle;
}

/*
// init function to create a packet with security layer and
// initialize the struct with valid data
*/ 
LONG API_InitSREMPacket(struct SREM msgStruct, char packetTypeDesignator[], char certificateName[])
{
  long pktHandle, certHdl;

  // initialize the packet
  pktHandle = C2xInitPacket("SREM", packetTypeDesignator);

  if (pktHandle != 0)
  {
    certHdl = C2xSecCertificateGetHandle(certificateName);  // get the certificate handle for the cert with name "certificateName"
    if (certHdl != 0) 
    {
      C2xSecPacketSetSignerHandle(pktHandle, certHdl); // set the certHdl to the packet
    }

    // create valid message and application data
    if (C2xCompletePacket(pktHandle) == 0) 
    {
      // copy application data to the application structure
      API_GetSREMParams(pktHandle, msgStruct);
    }
  }
  return pktHandle;
}
    

int GetSREMITS_Container_ItsPduHeaderParams(LONG packetHandle, struct SREMITS_Container_ItsPduHeader value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "protocolVersion");
  value.protocolVersion = C2xGetTokenInt(packetHandle, "SREM", newPath);
  result = CheckLastError("SREM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "messageID");
  value.messageID = C2xGetTokenInt(packetHandle, "SREM", newPath);
  result = CheckLastError("SREM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "stationID");
  value.stationID = C2xGetTokenInt64(packetHandle, "SREM", newPath);
  result = CheckLastError("SREM", gkFuncRefGet, result);

  return result;
}

int SetSREMITS_Container_ItsPduHeaderParams(LONG packetHandle, struct SREMITS_Container_ItsPduHeader value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "protocolVersion");
  C2xSetTokenInt(packetHandle, "SREM", newPath, value.protocolVersion);
  result = CheckLastError("SREM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "messageID");
  C2xSetTokenInt(packetHandle, "SREM", newPath, value.messageID);
  result = CheckLastError("SREM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "stationID");
  C2xSetTokenInt64(packetHandle, "SREM", newPath, value.stationID);
  result = CheckLastError("SREM", gkFuncRefGet, result);

  return result;
}

int GetSREMDSRC_IntersectionReferenceIDParams(LONG packetHandle, struct SREMDSRC_IntersectionReferenceID value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "region");
  value.region.isValidFlag = C2xIsTokenAvailable(packetHandle, "SREM", newPath);
  if(value.region.isValidFlag==1)
  {
    value.region.value = C2xGetTokenInt(packetHandle, "SREM", newPath);
    result = CheckLastError("SREM", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "id");
  value.id = C2xGetTokenInt(packetHandle, "SREM", newPath);
  result = CheckLastError("SREM", gkFuncRefGet, result);

  return result;
}

int SetSREMDSRC_IntersectionReferenceIDParams(LONG packetHandle, struct SREMDSRC_IntersectionReferenceID value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "region");
  if(value.region.isValidFlag==1)
  {
    C2xSetTokenInt(packetHandle, "SREM", newPath, value.region.value);
    result = CheckLastError("SREM", gkFuncRefGet, result);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "SREM", newPath) )
    {
      C2xRemoveToken(packetHandle, "SREM", newPath);
    }
  }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "id");
  C2xSetTokenInt(packetHandle, "SREM", newPath, value.id);
  result = CheckLastError("SREM", gkFuncRefGet, result);

  return result;
}

int GetSREMDSRC_IntersectionAccessPointParams(LONG packetHandle, struct SREMDSRC_IntersectionAccessPoint value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  value.choice = C2xGetTokenInt(packetHandle, "SREM", oldPath);

  switch(value.choice)
  {
    case 0:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "lane");
      value.lane = C2xGetTokenInt(packetHandle, "SREM", newPath);
      result = CheckLastError("SREM", gkFuncRefGet, result);
    }
    break;
    case 1:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "approach");
      value.approach = C2xGetTokenInt(packetHandle, "SREM", newPath);
      result = CheckLastError("SREM", gkFuncRefGet, result);
    }
    break;
    case 2:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "connection");
      value.connection = C2xGetTokenInt(packetHandle, "SREM", newPath);
      result = CheckLastError("SREM", gkFuncRefGet, result);
    }
    break;
  }
  return result;
}

int SetSREMDSRC_IntersectionAccessPointParams(LONG packetHandle, struct SREMDSRC_IntersectionAccessPoint value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  switch(value.choice)
  {
    case 0:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "lane");
      C2xSetTokenInt(packetHandle, "SREM", newPath, value.lane);
      result = CheckLastError("SREM", gkFuncRefGet, result);
    }
    break;
    case 1:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "approach");
      C2xSetTokenInt(packetHandle, "SREM", newPath, value.approach);
      result = CheckLastError("SREM", gkFuncRefGet, result);
    }
    break;
    case 2:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "connection");
      C2xSetTokenInt(packetHandle, "SREM", newPath, value.connection);
      result = CheckLastError("SREM", gkFuncRefGet, result);
    }
    break;
  }
  return result;
}

