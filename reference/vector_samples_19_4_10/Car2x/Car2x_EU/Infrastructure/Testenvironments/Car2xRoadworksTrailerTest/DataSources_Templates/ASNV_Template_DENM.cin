int SetDENMWGS84AngleParams(LONG packetHandle, struct DENMWGS84Angle value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "value");
  C2xSetTokenInt(packetHandle, "DENM", newPath, value.value);
  result = CheckLastError("DENM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "confidence");
  if (value.confidence < 1)
  {
    C2xSetTokenInt(packetHandle, "DENM", newPath, 1);
  }
  else if (value.confidence > 127)
  {
    C2xSetTokenInt(packetHandle, "DENM", newPath, 127);
  }
  else
  {
    C2xSetTokenInt(packetHandle, "DENM", newPath, value.confidence);
  }
  result = CheckLastError("DENM", gkFuncRefGet, result);

  return result;
}

