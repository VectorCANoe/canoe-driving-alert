int GetDENMObjectClassDescriptionParams(LONG packetHandle, struct DENMObjectClassDescription value, char oldPath[])
{
  char newPath[300]; 
  int i;
  int result;

  result = 0;

  value.length = C2xGetTokenInt(packetHandle, "DENM", oldPath);
  if((result = CheckLastError("DENM", gkFuncRefGet, result))==0)
  {
    for(i=0; i<value.length; i++)
    {
      snprintf(newPath, elcount(newPath), "%s[%d]", oldPath, i);
      GetDENMObjectClassParams(packetHandle, value.arrayValue[i], newPath);
      result = CheckLastError("DENM", gkFuncRefGet, result);
    }
  }
  return result;
}

int SetDENMObjectClassDescriptionParams(LONG packetHandle, struct DENMObjectClassDescription value, char oldPath[])
{
