int GetCPMShapeParams(LONG packetHandle, struct CPMShape value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  value.choice = C2xGetTokenInt(packetHandle, "CPM", oldPath);

  switch(value.choice)
  {
    case 0:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "rectangular");
      GetCPMRectangularShapeParams(packetHandle, value.rectangular, newPath);
      result = CheckLastError("CPM", gkFuncRefGet, result);
    }
    break;
    case 1:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "circular");
      GetCPMCircularShapeParams(packetHandle, value.circular, newPath);
      result = CheckLastError("CPM", gkFuncRefGet, result);
    }
    break;
    case 2:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "polygonal");
      GetCPMPolygonalShapeParams(packetHandle, value.polygonal, newPath);
      result = CheckLastError("CPM", gkFuncRefGet, result);
    }
    break;
    case 3:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "elliptical");
      GetCPMEllipticalShapeParams(packetHandle, value.elliptical, newPath);
      result = CheckLastError("CPM", gkFuncRefGet, result);
    }
    break;
    case 4:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "radial");
      GetCPMRadialShapeParams(packetHandle, value.radial, newPath);
      result = CheckLastError("CPM", gkFuncRefGet, result);
    }
    break;
    case 5:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "radialShapes");
      GetCPMRadialShapesParams(packetHandle, value.radialShapes, newPath);
      result = CheckLastError("CPM", gkFuncRefGet, result);
    }
    break;
  }
  return result;
}

