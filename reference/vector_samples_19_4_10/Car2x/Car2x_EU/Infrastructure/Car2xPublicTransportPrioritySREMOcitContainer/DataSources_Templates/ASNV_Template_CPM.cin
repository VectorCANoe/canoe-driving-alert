  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "sensorIdList");
  value.sensorIdList.isValidFlag = C2xIsTokenAvailable(packetHandle, "CPM", newPath);
  if(value.sensorIdList.isValidFlag==1)
  {
    GetCPMSequenceOfIdentifier1BParams(packetHandle, value.sensorIdList, newPath);
    result = CheckLastError("CPM", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "numberOfPerceivedObjects");
  value.numberOfPerceivedObjects.isValidFlag = C2xIsTokenAvailable(packetHandle, "CPM", newPath);
  if(value.numberOfPerceivedObjects.isValidFlag==1)
  {
    value.numberOfPerceivedObjects.value = C2xGetTokenInt(packetHandle, "CPM", newPath);
    result = CheckLastError("CPM", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "perceivedObjectIds");
  value.perceivedObjectIds.isValidFlag = C2xIsTokenAvailable(packetHandle, "CPM", newPath);
  if(value.perceivedObjectIds.isValidFlag==1)
  {
    GetCPMPerceivedObjectIdsParams(packetHandle, value.perceivedObjectIds, newPath);
    result = CheckLastError("CPM", gkFuncRefGet, result);
  }
  return result;
}

int SetCPMPerceptionRegionParams(LONG packetHandle, struct CPMPerceptionRegion value, char oldPath[])
{
  char newPath[300];
  int result;

