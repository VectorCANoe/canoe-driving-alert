  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "measurementDeltaTime");
  C2xSetTokenInt(packetHandle, "CPM", newPath, value.measurementDeltaTime);
  result = CheckLastError("CPM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "perceptionRegionConfidence");
  if (value.perceptionRegionConfidence < 1)
  {
    C2xSetTokenInt(packetHandle, "CPM", newPath, 1);
  }
  else if (value.perceptionRegionConfidence > 101)
  {
    C2xSetTokenInt(packetHandle, "CPM", newPath, 101);
  }
