int GetCPMVelocity3dWithConfidenceParams(LONG packetHandle, struct CPMVelocity3dWithConfidence value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  value.choice = C2xGetTokenInt(packetHandle, "CPM", oldPath);

  switch(value.choice)
  {
    case 0:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "polarVelocity");
      GetCPMVelocityPolarWithZParams(packetHandle, value.polarVelocity, newPath);
      result = CheckLastError("CPM", gkFuncRefGet, result);
    }
    break;
    case 1:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "cartesianVelocity");
      GetCPMVelocityCartesianParams(packetHandle, value.cartesianVelocity, newPath);
      result = CheckLastError("CPM", gkFuncRefGet, result);
    }
    break;
  }
  return result;
}

