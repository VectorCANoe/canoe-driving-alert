  value.perceptionRegionShape.isValidFlag = C2xIsTokenAvailable(packetHandle, "CPM", newPath);
  if(value.perceptionRegionShape.isValidFlag==1)
  {
    GetCPMShapeParams(packetHandle, value.perceptionRegionShape, newPath);
    result = CheckLastError("CPM", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "perceptionRegionConfidence");
  value.perceptionRegionConfidence.isValidFlag = C2xIsTokenAvailable(packetHandle, "CPM", newPath);
  if(value.perceptionRegionConfidence.isValidFlag==1)
  {
    value.perceptionRegionConfidence.value = C2xGetTokenInt(packetHandle, "CPM", newPath);
    result = CheckLastError("CPM", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "shadowingApplies");
  value.shadowingApplies = C2xGetTokenInt64(packetHandle, "CPM", newPath);
  result = CheckLastError("CPM", gkFuncRefGet, result);

  return result;
}

int SetCPMSensorInformationParams(LONG packetHandle, struct CPMSensorInformation value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "sensorId");
  C2xSetTokenInt(packetHandle, "CPM", newPath, value.sensorId);
  result = CheckLastError("CPM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "sensorType");
  C2xSetTokenInt(packetHandle, "CPM", newPath, value.sensorType);
  result = CheckLastError("CPM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "perceptionRegionShape");
  if(value.perceptionRegionShape.isValidFlag==1)
  {
    SetCPMShapeParams(packetHandle, value.perceptionRegionShape, newPath);
    result = CheckLastError("CPM", gkFuncRefGet, result);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "CPM", newPath) )
    {
      C2xRemoveToken(packetHandle, "CPM", newPath);
    }
  }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "perceptionRegionConfidence");
  if(value.perceptionRegionConfidence.isValidFlag==1)
  {
    if (value.perceptionRegionConfidence.value < 1)
    {
        C2xSetTokenInt(packetHandle, "CPM", newPath, 1);
    }
    else if (value.perceptionRegionConfidence.value > 101)
    {
        C2xSetTokenInt(packetHandle, "CPM", newPath, 101);
    }
    else
    {
        C2xSetTokenInt(packetHandle, "CPM", newPath, value.perceptionRegionConfidence.value);
    }
    result = CheckLastError("CPM", gkFuncRefGet, result);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "CPM", newPath) )
    {
      C2xRemoveToken(packetHandle, "CPM", newPath);
    }
  }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "shadowingApplies");
  C2xSetTokenInt64(packetHandle, "CPM", newPath, value.shadowingApplies);
  result = CheckLastError("CPM", gkFuncRefGet, result);

  return result;
}

