int GetCPMManagementContainerParams(LONG packetHandle, struct CPMManagementContainer value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "referenceTime");
  value.referenceTime = C2xGetTokenInt64(packetHandle, "CPM", newPath);
  result = CheckLastError("CPM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "referencePosition");
  GetCPMReferencePositionParams(packetHandle, value.referencePosition, newPath);
  result = CheckLastError("CPM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "segmentationInfo");
  value.segmentationInfo.isValidFlag = C2xIsTokenAvailable(packetHandle, "CPM", newPath);
  if(value.segmentationInfo.isValidFlag==1)
  {
    GetCPMMessageSegmentationInfoParams(packetHandle, value.segmentationInfo, newPath);
    result = CheckLastError("CPM", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "messageRateRange");
  value.messageRateRange.isValidFlag = C2xIsTokenAvailable(packetHandle, "CPM", newPath);
  if(value.messageRateRange.isValidFlag==1)
  {
    GetCPMMessageRateRangeParams(packetHandle, value.messageRateRange, newPath);
    result = CheckLastError("CPM", gkFuncRefGet, result);
  }
  return result;
}

int SetCPMManagementContainerParams(LONG packetHandle, struct CPMManagementContainer value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "referenceTime");
  C2xSetTokenInt64(packetHandle, "CPM", newPath, value.referenceTime);
  result = CheckLastError("CPM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "referencePosition");
  SetCPMReferencePositionParams(packetHandle, value.referencePosition, newPath);
  result = CheckLastError("CPM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "segmentationInfo");
  if(value.segmentationInfo.isValidFlag==1)
  {
    SetCPMMessageSegmentationInfoParams(packetHandle, value.segmentationInfo, newPath);
    result = CheckLastError("CPM", gkFuncRefGet, result);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "CPM", newPath) )
    {
      C2xRemoveToken(packetHandle, "CPM", newPath);
    }
  }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "messageRateRange");
  if(value.messageRateRange.isValidFlag==1)
  {
    SetCPMMessageRateRangeParams(packetHandle, value.messageRateRange, newPath);
    result = CheckLastError("CPM", gkFuncRefGet, result);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "CPM", newPath) )
    {
      C2xRemoveToken(packetHandle, "CPM", newPath);
    }
  }

  return result;
}

