int GetCPMCpmContainersParams(LONG packetHandle, WORD tableKey, struct CPMCpmContainers value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  switch(tableKey)
  {
    case 1:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "originatingVehicleContainer");
      GetCPMOriginatingVehicleContainerParams(packetHandle, value.originatingVehicleContainer, newPath);
      result = CheckLastError("CPM", gkFuncRefGet, result);
    }
    break;
    case 2:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "originatingRsuContainer");
      GetCPMOriginatingRsuContainerParams(packetHandle, value.originatingRsuContainer, newPath);
      result = CheckLastError("CPM", gkFuncRefGet, result);
    }
    break;
    case 3:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "sensorInformationContainer");
      GetCPMSensorInformationContainerParams(packetHandle, value.sensorInformationContainer, newPath);
      result = CheckLastError("CPM", gkFuncRefGet, result);
    }
    break;
    case 4:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "perceptionRegionContainer");
      GetCPMPerceptionRegionContainerParams(packetHandle, value.perceptionRegionContainer, newPath);
      result = CheckLastError("CPM", gkFuncRefGet, result);
    }
    break;
    case 5:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "perceivedObjectContainer");
      GetCPMPerceivedObjectContainerParams(packetHandle, value.perceivedObjectContainer, newPath);
      result = CheckLastError("CPM", gkFuncRefGet, result);
    }
    break;
  }
  return result;
}

int SetCPMCpmContainersParams(LONG packetHandle, WORD tableKey, struct CPMCpmContainers value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  switch(tableKey)
  {
    case 1:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "originatingVehicleContainer");
      SetCPMOriginatingVehicleContainerParams(packetHandle, value.originatingVehicleContainer, newPath);
      result = CheckLastError("CPM", gkFuncRefGet, result);
    }
    break;
    case 2:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "originatingRsuContainer");
      SetCPMOriginatingRsuContainerParams(packetHandle, value.originatingRsuContainer, newPath);
      result = CheckLastError("CPM", gkFuncRefGet, result);
    }
    break;
    case 3:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "sensorInformationContainer");
      SetCPMSensorInformationContainerParams(packetHandle, value.sensorInformationContainer, newPath);
      result = CheckLastError("CPM", gkFuncRefGet, result);
    }
    break;
    case 4:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "perceptionRegionContainer");
      SetCPMPerceptionRegionContainerParams(packetHandle, value.perceptionRegionContainer, newPath);
      result = CheckLastError("CPM", gkFuncRefGet, result);
    }
    break;
    case 5:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "perceivedObjectContainer");
      SetCPMPerceivedObjectContainerParams(packetHandle, value.perceivedObjectContainer, newPath);
      result = CheckLastError("CPM", gkFuncRefGet, result);
    }
    break;
  }
  return result;
}

int GetCPMWrappedCpmContainerParams(LONG packetHandle, struct CPMWrappedCpmContainer value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "containerId");
  value.containerId = C2xGetTokenInt(packetHandle, "CPM", newPath);
  result = CheckLastError("CPM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "containerData");
  GetCPMCpmContainersParams(packetHandle, value.containerId, value.containerData, newPath);
  result = CheckLastError("CPM", gkFuncRefGet, result);

  return result;
}

int SetCPMWrappedCpmContainerParams(LONG packetHandle, struct CPMWrappedCpmContainer value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;


  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "containerData");
  SetCPMCpmContainersParams(packetHandle, value.containerId, value.containerData, newPath);
  result = CheckLastError("CPM", gkFuncRefGet, result);

  return result;
}

int GetCPMWrappedCpmContainersParams(LONG packetHandle, struct CPMWrappedCpmContainers value, char oldPath[])
{
  char newPath[300]; 
  int i;
  int result;

  result = 0;

  value.length = C2xGetTokenInt(packetHandle, "CPM", oldPath);
  if((result = CheckLastError("CPM", gkFuncRefGet, result))==0)
  {
    for(i=0; i<value.length; i++)
    {
      snprintf(newPath, elcount(newPath), "%s[%d]", oldPath, i);
      GetCPMWrappedCpmContainerParams(packetHandle, value.arrayValue[i], newPath);
      result = CheckLastError("CPM", gkFuncRefGet, result);
    }
  }
  return result;
}

int SetCPMWrappedCpmContainersParams(LONG packetHandle, struct CPMWrappedCpmContainers value, char oldPath[])
{
  char newPath[300]; 
  int i;
  int result;

  result = 0;

  C2xRemoveToken(packetHandle, "CPM", oldPath);
  for(i=0; i<value.length; i++)
  {
    snprintf(newPath, elcount(newPath), "%s[%d]", oldPath, i);
    SetCPMWrappedCpmContainerParams(packetHandle, value.arrayValue[i], newPath);
    result = CheckLastError("CPM", gkFuncRefGet, result);
  }
  return result;
}

int GetCPMCollectivePerceptionMessageParams(LONG packetHandle, struct CPMCollectivePerceptionMessage value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "managementContainer");
  GetCPMManagementContainerParams(packetHandle, value.managementContainer, newPath);
  result = CheckLastError("CPM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "cpmContainers");
  GetCPMWrappedCpmContainersParams(packetHandle, value.cpmContainers, newPath);
  result = CheckLastError("CPM", gkFuncRefGet, result);

  return result;
}

int SetCPMCollectivePerceptionMessageParams(LONG packetHandle, struct CPMCollectivePerceptionMessage value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "managementContainer");
  SetCPMManagementContainerParams(packetHandle, value.managementContainer, newPath);
  result = CheckLastError("CPM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "cpmContainers");
  SetCPMWrappedCpmContainersParams(packetHandle, value.cpmContainers, newPath);
  result = CheckLastError("CPM", gkFuncRefGet, result);

  return result;
}

int API_GetCPMParams(LONG packetHandle, struct CPM value)
{
  int result;
  result = 0;

  value.header.isValidFlag = 1;
  GetCPMItsPduHeaderParams(packetHandle, value.header, "header");
  result = CheckLastError("CPM", gkFuncRefGet, result);

  value.cpm.isValidFlag = 1;
  GetCPMCollectivePerceptionMessageParams(packetHandle, value.cpm, "cpm");
  result = CheckLastError("CPM", gkFuncRefGet, result);

  return result;
}

int API_SetCPMParams(LONG packetHandle, struct CPM value)
{
  int result;
  result = 0;

  SetCPMItsPduHeaderParams(packetHandle, value.header, "header");
  result = CheckLastError("CPM", gkFuncRefGet, result);

  SetCPMCollectivePerceptionMessageParams(packetHandle, value.cpm, "cpm");
  result = CheckLastError("CPM", gkFuncRefGet, result);

  return result;
}

