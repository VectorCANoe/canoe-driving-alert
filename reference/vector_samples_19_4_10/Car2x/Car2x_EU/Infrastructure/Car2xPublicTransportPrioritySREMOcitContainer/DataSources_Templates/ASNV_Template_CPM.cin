      result = CheckLastError("CPM", gkFuncRefGet, result);
    }
    break;
  }
  return result;
}

int GetCPMObjectClassWithConfidenceParams(LONG packetHandle, struct CPMObjectClassWithConfidence value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "objectClass");
  GetCPMObjectClassParams(packetHandle, value.objectClass, newPath);
  result = CheckLastError("CPM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "confidence");
  value.confidence = C2xGetTokenInt(packetHandle, "CPM", newPath);
  result = CheckLastError("CPM", gkFuncRefGet, result);

  return result;
}

int SetCPMObjectClassWithConfidenceParams(LONG packetHandle, struct CPMObjectClassWithConfidence value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "objectClass");
  SetCPMObjectClassParams(packetHandle, value.objectClass, newPath);
  result = CheckLastError("CPM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "confidence");
  if (value.confidence < 1)
  {
    C2xSetTokenInt(packetHandle, "CPM", newPath, 1);
  }
  else if (value.confidence > 101)
  {
    C2xSetTokenInt(packetHandle, "CPM", newPath, 101);
  }
  else
  {
    C2xSetTokenInt(packetHandle, "CPM", newPath, value.confidence);
  }
  result = CheckLastError("CPM", gkFuncRefGet, result);

  return result;
}

