int SetCPMMessageSegmentationInfoParams(LONG packetHandle, struct CPMMessageSegmentationInfo value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "totalMsgNo");
  if (value.totalMsgNo < 1)
  {
    C2xSetTokenInt(packetHandle, "CPM", newPath, 1);
  }
  else if (value.totalMsgNo > 8)
  {
    C2xSetTokenInt(packetHandle, "CPM", newPath, 8);
  }
  else
  {
    C2xSetTokenInt(packetHandle, "CPM", newPath, value.totalMsgNo);
  }
  result = CheckLastError("CPM", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "thisMsgNo");
  if (value.thisMsgNo < 1)
  {
    C2xSetTokenInt(packetHandle, "CPM", newPath, 1);
  }
  else if (value.thisMsgNo > 8)
  {
    C2xSetTokenInt(packetHandle, "CPM", newPath, 8);
  }
  else
  {
    C2xSetTokenInt(packetHandle, "CPM", newPath, value.thisMsgNo);
  }
  result = CheckLastError("CPM", gkFuncRefGet, result);

  return result;
}

