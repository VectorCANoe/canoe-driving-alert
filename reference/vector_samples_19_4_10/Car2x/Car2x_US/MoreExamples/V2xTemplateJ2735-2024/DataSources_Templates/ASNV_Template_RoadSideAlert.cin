          {
            value.heading.string[j] = '0';
          }
          else if(C2xGetTokenBitOfBitString(packetHandle, "RoadSideAlert", newPath, j) == 1)
          {
            value.heading.string[j] = '1';
          }

          if(value.heading.stringLength == 1)
          {
            value.heading.string[1] = '0';
          }
          result = CheckLastError("RoadSideAlert", gkFuncRefGet, result);
        }
      }
      else
      {
        for(k = value.heading.stringLength+1; k > -1; k--)
        {
          if(value.heading.string[k] == '1')
          {
            value.heading.string[k] = '0';
          }
        }
      }
    }

  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "extent");
  value.extent.isValidFlag = C2xIsTokenAvailable(packetHandle, "RoadSideAlert", newPath);
  if(value.extent.isValidFlag==1)
