/*
// init function to create a simple packet handle
*/ 
LONG API_InitRoadSideAlertPacket()
{
  return C2xInitPacket("RoadSideAlert"); 
}

/*
// init function to create a simple packet handle and
// initialize the struct with valid data
*/ 
LONG API_InitRoadSideAlertPacket(struct RoadSideAlert msgStruct)
{
  long pktHandle;

  pktHandle = API_InitRoadSideAlertPacket();

  if (pktHandle != 0)
  {
    // create valid message and application data
    if (C2xCompletePacket(pktHandle) == 0) 
    {
      API_GetRoadSideAlertParams(pktHandle, msgStruct);
    }
  }
  return pktHandle;
}

/*
// init function to create a packet with security layer and
// initialize the struct with valid data
*/ 
LONG API_InitRoadSideAlertPacket(struct RoadSideAlert msgStruct, char packetTypeDesignator[], char certificateName[])
{
  long pktHandle, certHdl;

  // initialize the packet
  pktHandle = C2xInitPacket("RoadSideAlert", packetTypeDesignator);

  if (pktHandle != 0)
  {
    certHdl = C2xSecCertificateGetHandle(certificateName);  // get the certificate handle for the cert with name "certificateName"
    if (certHdl != 0) 
    {
      C2xSecPacketSetSignerHandle(pktHandle, certHdl); // set the certHdl to the packet
    }

    // create valid message and application data
    if (C2xCompletePacket(pktHandle) == 0) 
    {
      // copy application data to the application structure
      API_GetRoadSideAlertParams(pktHandle, msgStruct);
    }
  }
  return pktHandle;
}
    

int GetRoadSideAlertRoadSideAlert_descriptionParams(LONG packetHandle, struct RoadSideAlertRoadSideAlert_description value, char oldPath[])
{
  char newPath[300]; 
  int i;
  int result;

  result = 0;

  value.length = C2xGetTokenInt(packetHandle, "RoadSideAlert", oldPath);
  if((result = CheckLastError("RoadSideAlert", gkFuncRefGet, result))==0)
  {
    for(i=0; i<value.length; i++)
    {
      snprintf(newPath, elcount(newPath), "%s[%d]", oldPath, i);
      value.arrayValue[i] = C2xGetTokenInt64(packetHandle, "RoadSideAlert", newPath);
      result = CheckLastError("RoadSideAlert", gkFuncRefGet, result);
    }
  }
  return result;
}

int SetRoadSideAlertRoadSideAlert_descriptionParams(LONG packetHandle, struct RoadSideAlertRoadSideAlert_description value, char oldPath[])
{
  char newPath[300]; 
  int i;
  int result;

  result = 0;

  C2xRemoveToken(packetHandle, "RoadSideAlert", oldPath);
  for(i=0; i<value.length; i++)
  {
    snprintf(newPath, elcount(newPath), "%s[%d]", oldPath, i);
    C2xSetTokenInt64(packetHandle, "RoadSideAlert", newPath, value.arrayValue[i]);
    result = CheckLastError("RoadSideAlert", gkFuncRefGet, result);
  }
  return result;
}

int GetRoadSideAlertCommon_DDateTimeParams(LONG packetHandle, struct RoadSideAlertCommon_DDateTime value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "year");
  value.year.isValidFlag = C2xIsTokenAvailable(packetHandle, "RoadSideAlert", newPath);
  if(value.year.isValidFlag==1)
  {
    value.year.value = C2xGetTokenInt(packetHandle, "RoadSideAlert", newPath);
    result = CheckLastError("RoadSideAlert", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "month");
  value.month.isValidFlag = C2xIsTokenAvailable(packetHandle, "RoadSideAlert", newPath);
  if(value.month.isValidFlag==1)
  {
    value.month.value = C2xGetTokenInt(packetHandle, "RoadSideAlert", newPath);
    result = CheckLastError("RoadSideAlert", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "day");
  value.day.isValidFlag = C2xIsTokenAvailable(packetHandle, "RoadSideAlert", newPath);
  if(value.day.isValidFlag==1)
  {
    value.day.value = C2xGetTokenInt(packetHandle, "RoadSideAlert", newPath);
    result = CheckLastError("RoadSideAlert", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "hour");
  value.hour.isValidFlag = C2xIsTokenAvailable(packetHandle, "RoadSideAlert", newPath);
  if(value.hour.isValidFlag==1)
  {
    value.hour.value = C2xGetTokenInt(packetHandle, "RoadSideAlert", newPath);
    result = CheckLastError("RoadSideAlert", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "minute");
  value.minute.isValidFlag = C2xIsTokenAvailable(packetHandle, "RoadSideAlert", newPath);
  if(value.minute.isValidFlag==1)
  {
    value.minute.value = C2xGetTokenInt(packetHandle, "RoadSideAlert", newPath);
    result = CheckLastError("RoadSideAlert", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "second");
  value.second.isValidFlag = C2xIsTokenAvailable(packetHandle, "RoadSideAlert", newPath);
  if(value.second.isValidFlag==1)
  {
    value.second.value = C2xGetTokenInt(packetHandle, "RoadSideAlert", newPath);
    result = CheckLastError("RoadSideAlert", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "offset");
  value.offset.isValidFlag = C2xIsTokenAvailable(packetHandle, "RoadSideAlert", newPath);
  if(value.offset.isValidFlag==1)
  {
    value.offset.value = C2xGetTokenInt(packetHandle, "RoadSideAlert", newPath);
    result = CheckLastError("RoadSideAlert", gkFuncRefGet, result);
  }
  return result;
}

int SetRoadSideAlertCommon_DDateTimeParams(LONG packetHandle, struct RoadSideAlertCommon_DDateTime value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "year");
  if(value.year.isValidFlag==1)
  {
    C2xSetTokenInt(packetHandle, "RoadSideAlert", newPath, value.year.value);
    result = CheckLastError("RoadSideAlert", gkFuncRefGet, result);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "RoadSideAlert", newPath) )
    {
      C2xRemoveToken(packetHandle, "RoadSideAlert", newPath);
    }
  }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "month");
  if(value.month.isValidFlag==1)
  {
    C2xSetTokenInt(packetHandle, "RoadSideAlert", newPath, value.month.value);
    result = CheckLastError("RoadSideAlert", gkFuncRefGet, result);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "RoadSideAlert", newPath) )
    {
      C2xRemoveToken(packetHandle, "RoadSideAlert", newPath);
    }
  }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "day");
  if(value.day.isValidFlag==1)
  {
    C2xSetTokenInt(packetHandle, "RoadSideAlert", newPath, value.day.value);
    result = CheckLastError("RoadSideAlert", gkFuncRefGet, result);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "RoadSideAlert", newPath) )
    {
      C2xRemoveToken(packetHandle, "RoadSideAlert", newPath);
    }
  }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "hour");
  if(value.hour.isValidFlag==1)
  {
    C2xSetTokenInt(packetHandle, "RoadSideAlert", newPath, value.hour.value);
    result = CheckLastError("RoadSideAlert", gkFuncRefGet, result);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "RoadSideAlert", newPath) )
    {
      C2xRemoveToken(packetHandle, "RoadSideAlert", newPath);
    }
  }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "minute");
  if(value.minute.isValidFlag==1)
  {
    C2xSetTokenInt(packetHandle, "RoadSideAlert", newPath, value.minute.value);
    result = CheckLastError("RoadSideAlert", gkFuncRefGet, result);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "RoadSideAlert", newPath) )
    {
      C2xRemoveToken(packetHandle, "RoadSideAlert", newPath);
    }
  }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "second");
  if(value.second.isValidFlag==1)
  {
    C2xSetTokenInt(packetHandle, "RoadSideAlert", newPath, value.second.value);
    result = CheckLastError("RoadSideAlert", gkFuncRefGet, result);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "RoadSideAlert", newPath) )
    {
      C2xRemoveToken(packetHandle, "RoadSideAlert", newPath);
    }
  }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "offset");
  if(value.offset.isValidFlag==1)
  {
    C2xSetTokenInt(packetHandle, "RoadSideAlert", newPath, value.offset.value);
    result = CheckLastError("RoadSideAlert", gkFuncRefGet, result);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "RoadSideAlert", newPath) )
    {
      C2xRemoveToken(packetHandle, "RoadSideAlert", newPath);
    }
  }

  return result;
}

