    struct TrafficLightStatusMessageTrafficLightID {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        INT choice;
        BYTE id;  // INTEGER, ..;
        struct TrafficLightStatusMessageTrafficLightID_oid oid;  // OBJECTIDENTIFIER;
    };
    
    struct TrafficLightStatusMessageTrafficLightOperationStatus {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        CHAR string[9];
        INT  stringLength;
    };
    
    struct TrafficLightStatusMessageTrafficLightControllerStatus {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        CHAR string[9];
        INT  stringLength;
    };
    
    struct TrafficLightStatusMessageCommon_DDateTime {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        struct OPT_WORD_ASN year;  // INTEGER, OPTIONAL, 0..4095;
        struct OPT_BYTE_ASN month;  // INTEGER, OPTIONAL, 0..12;
        struct OPT_BYTE_ASN day;  // INTEGER, OPTIONAL, 0..31;
        struct OPT_BYTE_ASN hour;  // INTEGER, OPTIONAL, 0..31;
        struct OPT_BYTE_ASN minute;  // INTEGER, OPTIONAL, 0..60;
        struct OPT_WORD_ASN second;  // INTEGER, OPTIONAL, 0..65535;
        struct OPT_INT_ASN offset;  // INTEGER, OPTIONAL, -840..840;
    };
    
    struct TrafficLightStatusMessageTrafficLightStatus {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        INT trafficLightType;  // ENUMERATED, reserved(0), straight(1), left_turn(2), pedestrian(3), bicycle(4), right_turn(5), bus(6), u_turn(7);
        INT consecutiveTrafficLight;  // ENUMERATED, none(0), first(1), second(2);
        INT trafficLightIntervalType;  // ENUMERATED, static(0), variable(1);
        INT pedestrianCall;  // BOOLEAN;
        INT actuatedinterval;  // BOOLEAN;
        INT permissiveNonProtected;  // ENUMERATED, none(0), permissive(1);
        INT lightingStatus;  // ENUMERATED, off(0), red_on(1), yellow_on(2), green_on(3), red_blinking(4), yellow_blinking(5), green_blinking(6);
        BYTE maxIntervalLength;  // INTEGER, 0..255;
        BYTE remainingTime;  // INTEGER, 0..255;
        WORD directionCode;  // INTEGER, 0..359;
        INT reserved;  // BOOLEAN;
    };
    
    struct TrafficLightStatusMessageTrafficLightStatusList {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        INT length;
        struct TrafficLightStatusMessageTrafficLightStatus arrayValue[255];  // SEQUENCE;
    };
    
    struct TrafficLightStatusMessage_TrafficLightStatusMessage {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        struct TrafficLightStatusMessageTrafficLightID trafficLightID;  // CHOICE;
        struct OPT_LONG_ASN lon;  // INTEGER, OPTIONAL, -1799999999..1800000001;
        struct OPT_LONG_ASN lat;  // INTEGER, OPTIONAL, -900000000..900000001;
        struct TrafficLightStatusMessageTrafficLightOperationStatus operationStatus;  // BITSTRING;
        struct TrafficLightStatusMessageTrafficLightControllerStatus controllerStatus;  // BITSTRING;
        WORD cyclecounter;  // INTEGER, 0..65535;
        WORD cycletime;  // INTEGER, 0..65535;
        struct TrafficLightStatusMessageCommon_DDateTime currentTime;  // SEQUENCE;
        struct TrafficLightStatusMessageTrafficLightStatusList trafficLightStatus;  // SEQUENCEOF;
    };
    
    struct TrafficLightStatusMessageMESSAGE_ID_AND_TYPE {
        struct TrafficLightStatusMessage_TrafficLightStatusMessage trafficLightStatusMessage;  // SEQUENCE;
    };
    
    struct TrafficLightStatusMessage {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        WORD messageId;  // INTEGER, 0..32767, mapData(18), signalPhaseAndTimingMessage(19), basicSafetyMessage(20), commonSafetyRequest(21), emergencyVehicleAlert(22), intersectionCollision(23), nmeaCorrections(24), probeDataManagement(25), probeVehicleData(26), roadSideAlert(27), rtcmCorrections(28), signalRequestMessage(29), signalStatusMessage(30), travelerInformation(31), personalSafetyMessage(32), roadSafetyMessage(33), roadWeatherMessage(34), probeDataConfigMessage(35), probeDataReportMessage(36), tollAdvertisementMessage(37), tollUsageMessage(38), tollUsageAckMessage(39), cooperativeControlMessage(40), sensorDataSharingMessage(41), maneuverSharingAndCoordinatingMessage(42), roadGeometryAndAttributes(43), personalSafetyMessage2(44), trafficSignalPhaseAndTiming(45), signalControlAndPrioritizationRequest(46), signalControlAndPrioritizationStatus(47), roadUserChargingConfigMessage(48), roadUserChargingReportMessage(49), trafficLightStatusMessage(50);
        struct TrafficLightStatusMessageMESSAGE_ID_AND_TYPE value;  // TABLE;
    };
    
}

/*
// init function to create a simple packet handle
*/ 
LONG API_InitTrafficLightStatusMessagePacket()
{
  return C2xInitPacket("TrafficLightStatusMessage"); 
}

/*
// init function to create a simple packet handle and
// initialize the struct with valid data
*/ 
LONG API_InitTrafficLightStatusMessagePacket(struct TrafficLightStatusMessage msgStruct)
{
  long pktHandle;

  pktHandle = API_InitTrafficLightStatusMessagePacket();

  if (pktHandle != 0)
  {
    // create valid message and application data
    if (C2xCompletePacket(pktHandle) == 0) 
    {
      API_GetTrafficLightStatusMessageParams(pktHandle, msgStruct);
    }
  }
  return pktHandle;
}

/*
// init function to create a packet with security layer and
// initialize the struct with valid data
*/ 
LONG API_InitTrafficLightStatusMessagePacket(struct TrafficLightStatusMessage msgStruct, char packetTypeDesignator[], char certificateName[])
{
  long pktHandle, certHdl;

  // initialize the packet
  pktHandle = C2xInitPacket("TrafficLightStatusMessage", packetTypeDesignator);

  if (pktHandle != 0)
  {
    certHdl = C2xSecCertificateGetHandle(certificateName);  // get the certificate handle for the cert with name "certificateName"
    if (certHdl != 0) 
    {
      C2xSecPacketSetSignerHandle(pktHandle, certHdl); // set the certHdl to the packet
    }

    // create valid message and application data
    if (C2xCompletePacket(pktHandle) == 0) 
    {
      // copy application data to the application structure
      API_GetTrafficLightStatusMessageParams(pktHandle, msgStruct);
    }
  }
  return pktHandle;
}
    

int GetTrafficLightStatusMessageTrafficLightIDParams(LONG packetHandle, struct TrafficLightStatusMessageTrafficLightID value, char oldPath[])
{
  char newPath[300];
  int i;
  int result;

  result = 0;

  value.choice = C2xGetTokenInt(packetHandle, "TrafficLightStatusMessage", oldPath);

  switch(value.choice)
  {
    case 0:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "id");
      value.id = C2xGetTokenInt64(packetHandle, "TrafficLightStatusMessage", newPath);
      result = CheckLastError("TrafficLightStatusMessage", gkFuncRefGet, result);
    }
    break;
    case 1:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "oid");
      value.oid.length = C2xGetTokenInt(packetHandle, "TrafficLightStatusMessage", newPath);
      if((result = CheckLastError("TrafficLightStatusMessage", gkFuncRefGet, result))==0)
      {
        if(value.oid.length > 0)
        {
          for(i=0; i<value.oid.length; i++)
          {
            value.oid.arrayValue[i].id = C2xGetTokenOidElement(packetHandle, "TrafficLightStatusMessage", newPath, i);
          }
        }
      }
    }
    break;
  }
  return result;
}

int SetTrafficLightStatusMessageTrafficLightIDParams(LONG packetHandle, struct TrafficLightStatusMessageTrafficLightID value, char oldPath[])
{
  char newPath[300];
  int i;
  int result;

  result = 0;

  switch(value.choice)
  {
    case 0:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "id");
      C2xSetTokenInt64(packetHandle, "TrafficLightStatusMessage", newPath, value.id);
      result = CheckLastError("TrafficLightStatusMessage", gkFuncRefGet, result);
    }
    break;
    case 1:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "oid");
      C2xRemoveToken(packetHandle, "TrafficLightStatusMessage", newPath);
      if(value.oid.length > 0)
      {
        for(i=0; i<value.oid.length; i++)
        {
          C2xSetTokenOidElement(packetHandle, "TrafficLightStatusMessage", newPath, i, value.oid.arrayValue[i].id);
        }
      }
      result = CheckLastError("TrafficLightStatusMessage", gkFuncRefGet, result);
    }
    break;
  }
  return result;
}

