int GetTrafficLightStatusMessageTrafficLightStatusListParams(LONG packetHandle, struct TrafficLightStatusMessageTrafficLightStatusList value, char oldPath[])
{
  char newPath[300]; 
  int i;
  int result;

  result = 0;

  value.length = C2xGetTokenInt(packetHandle, "TrafficLightStatusMessage", oldPath);
  if((result = CheckLastError("TrafficLightStatusMessage", gkFuncRefGet, result))==0)
  {
    for(i=0; i<value.length; i++)
    {
      snprintf(newPath, elcount(newPath), "%s[%d]", oldPath, i);
      GetTrafficLightStatusMessageTrafficLightStatusParams(packetHandle, value.arrayValue[i], newPath);
      result = CheckLastError("TrafficLightStatusMessage", gkFuncRefGet, result);
    }
  }
  return result;
}

int SetTrafficLightStatusMessageTrafficLightStatusListParams(LONG packetHandle, struct TrafficLightStatusMessageTrafficLightStatusList value, char oldPath[])
{
  char newPath[300]; 
  int i;
  int result;

  result = 0;

  C2xRemoveToken(packetHandle, "TrafficLightStatusMessage", oldPath);
  for(i=0; i<value.length; i++)
  {
    snprintf(newPath, elcount(newPath), "%s[%d]", oldPath, i);
    SetTrafficLightStatusMessageTrafficLightStatusParams(packetHandle, value.arrayValue[i], newPath);
    result = CheckLastError("TrafficLightStatusMessage", gkFuncRefGet, result);
  }
  return result;
}

