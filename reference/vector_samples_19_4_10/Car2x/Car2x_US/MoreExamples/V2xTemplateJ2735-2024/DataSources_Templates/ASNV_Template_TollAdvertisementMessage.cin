      }
      else
      {
        C2xSetTokenBitOfBitString(packetHandle, "TollAdvertisementMessage", newPath, j, 1);
      }
      result = CheckLastError("TollAdvertisementMessage", gkFuncRefGet, result);
    }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "laneType");
  SetTollAdvertisementMessageMapData_LaneTypeAttributesParams(packetHandle, value.laneType, newPath);
  result = CheckLastError("TollAdvertisementMessage", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "regional");
  if(value.regional.isValidFlag==1)
  {
    SetTollAdvertisementMessageCommon_RegionalExtension_Reg_LaneAttributesParams(packetHandle, value.regional, newPath);
    result = CheckLastError("TollAdvertisementMessage", gkFuncRefGet, result);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "TollAdvertisementMessage", newPath) )
    {
      C2xRemoveToken(packetHandle, "TollAdvertisementMessage", newPath);
    }
  }

  return result;
}

