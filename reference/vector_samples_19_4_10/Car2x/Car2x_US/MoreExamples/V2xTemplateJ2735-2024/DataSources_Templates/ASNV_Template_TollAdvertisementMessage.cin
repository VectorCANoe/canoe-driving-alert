  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "tollPointMap");
  SetTollAdvertisementMessageTollPointMapParams(packetHandle, value.tollPointMap, newPath);
  result = CheckLastError("TollAdvertisementMessage", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "tumPublicKey");
  C2xSetTokenData(packetHandle, "TollAdvertisementMessage", newPath, value.tumPublicKey.stringLength, value.tumPublicKey.string);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "ackPolicy");
  SetTollAdvertisementMessageAckPolicyParams(packetHandle, value.ackPolicy, newPath);
  result = CheckLastError("TollAdvertisementMessage", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "lastTollPtDataReq");
  if(value.lastTollPtDataReq.isValidFlag==1)
  {
    C2xSetTokenInt64(packetHandle, "TollAdvertisementMessage", newPath, value.lastTollPtDataReq.value);
    result = CheckLastError("TollAdvertisementMessage", gkFuncRefGet, result);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "TollAdvertisementMessage", newPath) )
    {
      C2xRemoveToken(packetHandle, "TollAdvertisementMessage", newPath);
    }
  }

  return result;
}

