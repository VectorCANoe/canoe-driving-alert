  if((result = CheckLastError("TollAdvertisementMessage", gkFuncRefGet, result))==0)
  {
    for(i=0; i<value.length; i++)
    {
      snprintf(newPath, elcount(newPath), "%s[%d]", oldPath, i);
      value.arrayValue[i] = C2xGetTokenInt64(packetHandle, "TollAdvertisementMessage", newPath);
      result = CheckLastError("TollAdvertisementMessage", gkFuncRefGet, result);
    }
  }
  return result;
}

int SetTollAdvertisementMessageCommon_NodeAttributeXYListParams(LONG packetHandle, struct TollAdvertisementMessageCommon_NodeAttributeXYList value, char oldPath[])
{
  char newPath[300]; 
  int i;
  int result;

  result = 0;

  C2xRemoveToken(packetHandle, "TollAdvertisementMessage", oldPath);
  for(i=0; i<value.length; i++)
  {
