/*
// init function to create a simple packet handle
*/ 
LONG API_InitTollAdvertisementMessagePacket()
{
  return C2xInitPacket("TollAdvertisementMessage"); 
}

/*
// init function to create a simple packet handle and
// initialize the struct with valid data
*/ 
LONG API_InitTollAdvertisementMessagePacket(struct TollAdvertisementMessage msgStruct)
{
  long pktHandle;

  pktHandle = API_InitTollAdvertisementMessagePacket();

  if (pktHandle != 0)
  {
    // create valid message and application data
    if (C2xCompletePacket(pktHandle) == 0) 
    {
      API_GetTollAdvertisementMessageParams(pktHandle, msgStruct);
    }
  }
  return pktHandle;
}

/*
// init function to create a packet with security layer and
// initialize the struct with valid data
*/ 
LONG API_InitTollAdvertisementMessagePacket(struct TollAdvertisementMessage msgStruct, char packetTypeDesignator[], char certificateName[])
{
  long pktHandle, certHdl;

  // initialize the packet
  pktHandle = C2xInitPacket("TollAdvertisementMessage", packetTypeDesignator);

  if (pktHandle != 0)
  {
    certHdl = C2xSecCertificateGetHandle(certificateName);  // get the certificate handle for the cert with name "certificateName"
    if (certHdl != 0) 
    {
      C2xSecPacketSetSignerHandle(pktHandle, certHdl); // set the certHdl to the packet
    }

    // create valid message and application data
    if (C2xCompletePacket(pktHandle) == 0) 
    {
      // copy application data to the application structure
      API_GetTollAdvertisementMessageParams(pktHandle, msgStruct);
    }
  }
  return pktHandle;
}
    

int GetTollAdvertisementMessageEfcDataDictionary_PaymentFeeParams(LONG packetHandle, struct TollAdvertisementMessageEfcDataDictionary_PaymentFee value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "paymentFeeAmount");
  value.paymentFeeAmount = C2xGetTokenInt(packetHandle, "TollAdvertisementMessage", newPath);
  result = CheckLastError("TollAdvertisementMessage", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "paymentFeeUnit");
  value.paymentFeeUnit.stringLength = C2xGetTokenData(packetHandle, "TollAdvertisementMessage", newPath, elcount(value.paymentFeeUnit.string), value.paymentFeeUnit.string);
  return result;
}

int SetTollAdvertisementMessageEfcDataDictionary_PaymentFeeParams(LONG packetHandle, struct TollAdvertisementMessageEfcDataDictionary_PaymentFee value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "paymentFeeAmount");
  C2xSetTokenInt(packetHandle, "TollAdvertisementMessage", newPath, value.paymentFeeAmount);
  result = CheckLastError("TollAdvertisementMessage", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "paymentFeeUnit");
  C2xSetTokenData(packetHandle, "TollAdvertisementMessage", newPath, value.paymentFeeUnit.stringLength, value.paymentFeeUnit.string);

  return result;
}

