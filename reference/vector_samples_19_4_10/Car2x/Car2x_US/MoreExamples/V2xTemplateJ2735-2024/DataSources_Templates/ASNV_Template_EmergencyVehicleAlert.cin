          {
            value.heading.string[j] = '0';
          }
          else if(C2xGetTokenBitOfBitString(packetHandle, "EmergencyVehicleAlert", newPath, j) == 1)
          {
            value.heading.string[j] = '1';
          }

          if(value.heading.stringLength == 1)
          {
            value.heading.string[1] = '0';
          }
          result = CheckLastError("EmergencyVehicleAlert", gkFuncRefGet, result);
        }
      }
      else
      {
        for(k = value.heading.stringLength+1; k > -1; k--)
