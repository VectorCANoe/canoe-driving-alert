int GetEmergencyVehicleAlertCommon_PrivilegedEventsParams(LONG packetHandle, struct EmergencyVehicleAlertCommon_PrivilegedEvents value, char oldPath[])
{
  char newPath[300]; 
  int j; 
  int k;
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "doNotUse");
  value.doNotUse = C2xGetTokenInt(packetHandle, "EmergencyVehicleAlert", newPath);
  result = CheckLastError("EmergencyVehicleAlert", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "event");
  value.event.isValidFlag = 1;
  value.event.stringLength = C2xGetTokenLengthBit(packetHandle, "EmergencyVehicleAlert", newPath);
  if ((result = CheckLastError("EmergencyVehicleAlert", gkFuncRefGet, result))==0)
  {
    if(value.event.stringLength > 0)
    {
      for(j=0; j<value.event.stringLength; j++)
      {
        if(C2xGetTokenBitOfBitString(packetHandle, "EmergencyVehicleAlert", newPath, j) == 0)
        {
          value.event.string[j] = '0';
        }
        else if(C2xGetTokenBitOfBitString(packetHandle, "EmergencyVehicleAlert", newPath, j) == 1)
        {
          value.event.string[j] = '1';
        }

        if(value.event.stringLength == 1)
        {
          value.event.string[1] = '0';
        }
        result = CheckLastError("EmergencyVehicleAlert", gkFuncRefGet, result);
      }
    }
    else
    {
      for(k = value.event.stringLength+1; k > -1; k--)
      {
        if(value.event.string[k] == '1')
        {
          value.event.string[k] = '0';
        }
      }
    }
  }

  return result;
}

