        }
        result = CheckLastError("CooperativeControlMessage", gkFuncRefGet, result);
      }
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "CooperativeControlMessage", newPath) )
    {
      C2xRemoveToken(packetHandle, "CooperativeControlMessage", newPath);
    }
  }

  return result;
}

