/*
// init function to create a simple packet handle
*/ 
LONG API_InitCooperativeControlMessagePacket()
{
  return C2xInitPacket("CooperativeControlMessage"); 
}

/*
// init function to create a simple packet handle and
// initialize the struct with valid data
*/ 
LONG API_InitCooperativeControlMessagePacket(struct CooperativeControlMessage msgStruct)
{
  long pktHandle;

  pktHandle = API_InitCooperativeControlMessagePacket();

  if (pktHandle != 0)
  {
    // create valid message and application data
    if (C2xCompletePacket(pktHandle) == 0) 
    {
      API_GetCooperativeControlMessageParams(pktHandle, msgStruct);
    }
  }
  return pktHandle;
}

/*
// init function to create a packet with security layer and
// initialize the struct with valid data
*/ 
LONG API_InitCooperativeControlMessagePacket(struct CooperativeControlMessage msgStruct, char packetTypeDesignator[], char certificateName[])
{
  long pktHandle, certHdl;

  // initialize the packet
  pktHandle = C2xInitPacket("CooperativeControlMessage", packetTypeDesignator);

  if (pktHandle != 0)
  {
    certHdl = C2xSecCertificateGetHandle(certificateName);  // get the certificate handle for the cert with name "certificateName"
    if (certHdl != 0) 
    {
      C2xSecPacketSetSignerHandle(pktHandle, certHdl); // set the certHdl to the packet
    }

    // create valid message and application data
    if (C2xCompletePacket(pktHandle) == 0) 
    {
      // copy application data to the application structure
      API_GetCooperativeControlMessageParams(pktHandle, msgStruct);
    }
  }
  return pktHandle;
}
    

int GetCooperativeControlMessageCommon_PositionalAccuracyParams(LONG packetHandle, struct CooperativeControlMessageCommon_PositionalAccuracy value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "semiMajor");
  value.semiMajor = C2xGetTokenInt(packetHandle, "CooperativeControlMessage", newPath);
  result = CheckLastError("CooperativeControlMessage", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "semiMinor");
  value.semiMinor = C2xGetTokenInt(packetHandle, "CooperativeControlMessage", newPath);
  result = CheckLastError("CooperativeControlMessage", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "orientation");
  value.orientation = C2xGetTokenInt(packetHandle, "CooperativeControlMessage", newPath);
  result = CheckLastError("CooperativeControlMessage", gkFuncRefGet, result);

  return result;
}

int SetCooperativeControlMessageCommon_PositionalAccuracyParams(LONG packetHandle, struct CooperativeControlMessageCommon_PositionalAccuracy value, char oldPath[])
{
