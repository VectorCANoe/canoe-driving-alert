    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "lightVehicleCCMExt");
      GetCooperativeControlMessageLightVehicleCCMExtensionsParams(packetHandle, value.lightVehicleCCMExt, newPath);
