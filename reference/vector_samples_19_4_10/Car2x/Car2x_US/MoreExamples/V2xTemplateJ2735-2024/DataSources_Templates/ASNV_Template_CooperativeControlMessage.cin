    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "vehicleSafetyExt");
      GetCooperativeControlMessageCommon_VehicleSafetyExtensionsParams(packetHandle, value.vehicleSafetyExt, newPath);
      result = CheckLastError("CooperativeControlMessage", gkFuncRefGet, result);
    }
