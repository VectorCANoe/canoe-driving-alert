      GetCooperativeControlMessageHeavyTruckCCMExtensionsParams(packetHandle, value.heavyTruckCCMExt, newPath);
      result = CheckLastError("CooperativeControlMessage", gkFuncRefGet, result);
    }
    break;
  }
  return result;
}

