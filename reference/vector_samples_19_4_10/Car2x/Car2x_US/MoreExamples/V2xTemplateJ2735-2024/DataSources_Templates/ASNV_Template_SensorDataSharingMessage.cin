  {
    GetSensorDataSharingMessageAttitudeConfidenceParams(packetHandle, value.vehAttitudeConfidence, newPath);
    result = CheckLastError("SensorDataSharingMessage", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "vehAngVel");
  value.vehAngVel.isValidFlag = C2xIsTokenAvailable(packetHandle, "SensorDataSharingMessage", newPath);
  if(value.vehAngVel.isValidFlag==1)
  {
    GetSensorDataSharingMessageAngularVelocityParams(packetHandle, value.vehAngVel, newPath);
    result = CheckLastError("SensorDataSharingMessage", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "vehAngVelConfidence");
  value.vehAngVelConfidence.isValidFlag = C2xIsTokenAvailable(packetHandle, "SensorDataSharingMessage", newPath);
  if(value.vehAngVelConfidence.isValidFlag==1)
  {
    GetSensorDataSharingMessageAngularVelocityConfidenceParams(packetHandle, value.vehAngVelConfidence, newPath);
    result = CheckLastError("SensorDataSharingMessage", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "size");
  value.size.isValidFlag = C2xIsTokenAvailable(packetHandle, "SensorDataSharingMessage", newPath);
  if(value.size.isValidFlag==1)
  {
    GetSensorDataSharingMessageCommon_VehicleSizeParams(packetHandle, value.size, newPath);
    result = CheckLastError("SensorDataSharingMessage", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "height");
  value.height.isValidFlag = C2xIsTokenAvailable(packetHandle, "SensorDataSharingMessage", newPath);
  if(value.height.isValidFlag==1)
  {
    value.height.value = C2xGetTokenInt(packetHandle, "SensorDataSharingMessage", newPath);
    result = CheckLastError("SensorDataSharingMessage", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "vehicleSizeConfidence");
  value.vehicleSizeConfidence.isValidFlag = C2xIsTokenAvailable(packetHandle, "SensorDataSharingMessage", newPath);
  if(value.vehicleSizeConfidence.isValidFlag==1)
  {
    GetSensorDataSharingMessageVehicleSizeConfidenceParams(packetHandle, value.vehicleSizeConfidence, newPath);
    result = CheckLastError("SensorDataSharingMessage", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "vehicleClass");
  value.vehicleClass.isValidFlag = C2xIsTokenAvailable(packetHandle, "SensorDataSharingMessage", newPath);
  if(value.vehicleClass.isValidFlag==1)
  {
    value.vehicleClass.value = C2xGetTokenInt(packetHandle, "SensorDataSharingMessage", newPath);
    result = CheckLastError("SensorDataSharingMessage", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "classConf");
  value.classConf.isValidFlag = C2xIsTokenAvailable(packetHandle, "SensorDataSharingMessage", newPath);
  if(value.classConf.isValidFlag==1)
  {
    value.classConf.value = C2xGetTokenInt(packetHandle, "SensorDataSharingMessage", newPath);
    result = CheckLastError("SensorDataSharingMessage", gkFuncRefGet, result);
  }
  return result;
}

