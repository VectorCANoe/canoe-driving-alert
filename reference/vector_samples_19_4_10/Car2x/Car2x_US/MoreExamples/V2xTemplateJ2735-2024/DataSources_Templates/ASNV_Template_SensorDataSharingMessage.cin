int GetSensorDataSharingMessageDetectedVehicleDataParams(LONG packetHandle, struct SensorDataSharingMessageDetectedVehicleData value, char oldPath[])
{
  char newPath[300]; 
  int j; 
  int k;
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "lights");
  value.lights.isValidFlag = C2xIsTokenAvailable(packetHandle, "SensorDataSharingMessage", newPath);
  if(value.lights.isValidFlag==1)
  {
    value.lights.isValidFlag = 1;
    value.lights.stringLength = C2xGetTokenLengthBit(packetHandle, "SensorDataSharingMessage", newPath);
    if ((result = CheckLastError("SensorDataSharingMessage", gkFuncRefGet, result))==0)
    {
      if(value.lights.stringLength > 0)
      {
        for(j=0; j<value.lights.stringLength; j++)
        {
          if(C2xGetTokenBitOfBitString(packetHandle, "SensorDataSharingMessage", newPath, j) == 0)
          {
            value.lights.string[j] = '0';
          }
          else if(C2xGetTokenBitOfBitString(packetHandle, "SensorDataSharingMessage", newPath, j) == 1)
          {
            value.lights.string[j] = '1';
          }

          if(value.lights.stringLength == 1)
          {
            value.lights.string[1] = '0';
          }
          result = CheckLastError("SensorDataSharingMessage", gkFuncRefGet, result);
        }
      }
      else
      {
        for(k = value.lights.stringLength+1; k > -1; k--)
        {
          if(value.lights.string[k] == '1')
          {
            value.lights.string[k] = '0';
          }
        }
      }
    }

  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "vehAttitude");
  value.vehAttitude.isValidFlag = C2xIsTokenAvailable(packetHandle, "SensorDataSharingMessage", newPath);
  if(value.vehAttitude.isValidFlag==1)
  {
    GetSensorDataSharingMessageAttitudeParams(packetHandle, value.vehAttitude, newPath);
    result = CheckLastError("SensorDataSharingMessage", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "vehAttitudeConfidence");
  value.vehAttitudeConfidence.isValidFlag = C2xIsTokenAvailable(packetHandle, "SensorDataSharingMessage", newPath);
