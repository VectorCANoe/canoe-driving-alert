  value.choice = C2xGetTokenInt(packetHandle, "SensorDataSharingMessage", oldPath);

  switch(value.choice)
  {
    case 0:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "human");
      value.human = C2xGetTokenInt(packetHandle, "SensorDataSharingMessage", newPath);
      result = CheckLastError("SensorDataSharingMessage", gkFuncRefGet, result);
    }
    break;
    case 1:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "animal");
      value.animal = C2xGetTokenInt(packetHandle, "SensorDataSharingMessage", newPath);
      result = CheckLastError("SensorDataSharingMessage", gkFuncRefGet, result);
