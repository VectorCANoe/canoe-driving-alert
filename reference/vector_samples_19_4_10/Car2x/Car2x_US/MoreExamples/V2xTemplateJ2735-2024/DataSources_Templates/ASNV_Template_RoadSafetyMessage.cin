int GetRoadSafetyMessageCommon_DescriptionOfRoadSurfaceParams(LONG packetHandle, struct RoadSafetyMessageCommon_DescriptionOfRoadSurface value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  value.choice = C2xGetTokenInt(packetHandle, "RoadSafetyMessage", oldPath);

  switch(value.choice)
  {
    case 0:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "portlandCement");
      GetRoadSafetyMessageCommon_PortlandCementParams(packetHandle, value.portlandCement, newPath);
      result = CheckLastError("RoadSafetyMessage", gkFuncRefGet, result);
    }
    break;
    case 1:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "asphaltOrTar");
      GetRoadSafetyMessageCommon_AsphaltOrTarParams(packetHandle, value.asphaltOrTar, newPath);
      result = CheckLastError("RoadSafetyMessage", gkFuncRefGet, result);
    }
    break;
    case 2:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "gravel");
      GetRoadSafetyMessageCommon_GravelParams(packetHandle, value.gravel, newPath);
      result = CheckLastError("RoadSafetyMessage", gkFuncRefGet, result);
    }
    break;
    case 3:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "grass");
      GetRoadSafetyMessageCommon_GrassParams(packetHandle, value.grass, newPath);
      result = CheckLastError("RoadSafetyMessage", gkFuncRefGet, result);
    }
    break;
    case 4:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "cinders");
      GetRoadSafetyMessageCommon_CindersParams(packetHandle, value.cinders, newPath);
      result = CheckLastError("RoadSafetyMessage", gkFuncRefGet, result);
    }
    break;
    case 5:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "rock");
      GetRoadSafetyMessageCommon_RockParams(packetHandle, value.rock, newPath);
      result = CheckLastError("RoadSafetyMessage", gkFuncRefGet, result);
    }
    break;
    case 6:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "ice");
      GetRoadSafetyMessageCommon_IceParams(packetHandle, value.ice, newPath);
      result = CheckLastError("RoadSafetyMessage", gkFuncRefGet, result);
    }
    break;
    case 7:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "snow");
      GetRoadSafetyMessageCommon_SnowParams(packetHandle, value.snow, newPath);
      result = CheckLastError("RoadSafetyMessage", gkFuncRefGet, result);
    }
    break;
  }
  return result;
}

