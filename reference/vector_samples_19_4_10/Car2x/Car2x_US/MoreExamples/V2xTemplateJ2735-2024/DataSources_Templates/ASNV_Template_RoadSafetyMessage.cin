int GetRoadSafetyMessageContentContainerParams(LONG packetHandle, struct RoadSafetyMessageContentContainer value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  value.choice = C2xGetTokenInt(packetHandle, "RoadSafetyMessage", oldPath);

  switch(value.choice)
  {
    case 0:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "rszContainer");
      GetRoadSafetyMessageReducedSpeedZoneContainerParams(packetHandle, value.rszContainer, newPath);
      result = CheckLastError("RoadSafetyMessage", gkFuncRefGet, result);
    }
    break;
    case 1:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "laneClosureContainer");
      GetRoadSafetyMessageLaneClosureContainerParams(packetHandle, value.laneClosureContainer, newPath);
      result = CheckLastError("RoadSafetyMessage", gkFuncRefGet, result);
    }
    break;
    case 2:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "curveContainer");
      GetRoadSafetyMessageCurveContainerParams(packetHandle, value.curveContainer, newPath);
      result = CheckLastError("RoadSafetyMessage", gkFuncRefGet, result);
    }
    break;
    case 3:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "dynamicInfoContainer");
      GetRoadSafetyMessageDynamicInfoContainerParams(packetHandle, value.dynamicInfoContainer, newPath);
      result = CheckLastError("RoadSafetyMessage", gkFuncRefGet, result);
    }
    break;
    case 4:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "incidentsContainer");
      GetRoadSafetyMessageIncidentsContainerParams(packetHandle, value.incidentsContainer, newPath);
      result = CheckLastError("RoadSafetyMessage", gkFuncRefGet, result);
    }
    break;
    case 5:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "situationalContainer");
      GetRoadSafetyMessageSituationalContainerParams(packetHandle, value.situationalContainer, newPath);
      result = CheckLastError("RoadSafetyMessage", gkFuncRefGet, result);
    }
    break;
  }
  return result;
}

