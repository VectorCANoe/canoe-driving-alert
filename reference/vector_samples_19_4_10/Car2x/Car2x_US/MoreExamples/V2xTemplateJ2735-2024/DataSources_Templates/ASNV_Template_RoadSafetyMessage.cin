        struct RoadSafetyMessageObstructions obstructions;  // SEQUENCE, OPTIONAL;
        struct OPT_DWORD_ASN visibility;  // INTEGER, OPTIONAL, 0..1000001;
        struct OPT_BOOL_ASN peoplePresent;  // BOOLEAN, OPTIONAL;
        struct OPT_BOOL_ASN anomalousTraffic;  // BOOLEAN, OPTIONAL;
        struct RoadSafetyMessageRegionInfo applicableRegion;  // SEQUENCE;
    };
    
    struct RoadSafetyMessageContentContainer {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        INT choice;
        struct RoadSafetyMessageReducedSpeedZoneContainer rszContainer;  // SEQUENCE;
        struct RoadSafetyMessageLaneClosureContainer laneClosureContainer;  // SEQUENCE;
        struct RoadSafetyMessageCurveContainer curveContainer;  // SEQUENCE;
        struct RoadSafetyMessageDynamicInfoContainer dynamicInfoContainer;  // SEQUENCE;
        struct RoadSafetyMessageIncidentsContainer incidentsContainer;  // SEQUENCE;
        struct RoadSafetyMessageSituationalContainer situationalContainer;  // SEQUENCE;
    };
    
    struct RoadSafetyMessageRoadSafetyMessage_content {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        INT length;
        struct RoadSafetyMessageContentContainer arrayValue[4];  // CHOICE;
    };
    
    struct RoadSafetyMessage_RoadSafetyMessage {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        struct RoadSafetyMessageCommonContainer commonContainer;  // SEQUENCE;
        struct RoadSafetyMessageRoadSafetyMessage_content content;  // SEQUENCEOF;
    };
    
    struct RoadSafetyMessageMESSAGE_ID_AND_TYPE {
        struct RoadSafetyMessage_RoadSafetyMessage roadSafetyMessage;  // SEQUENCE;
    };
    
    struct RoadSafetyMessage {
        INT isValidFlag;   // necessary if this struct is used as an optional field of a SEQUENCE
        WORD messageId;  // INTEGER, 0..32767, mapData(18), signalPhaseAndTimingMessage(19), basicSafetyMessage(20), commonSafetyRequest(21), emergencyVehicleAlert(22), intersectionCollision(23), nmeaCorrections(24), probeDataManagement(25), probeVehicleData(26), roadSideAlert(27), rtcmCorrections(28), signalRequestMessage(29), signalStatusMessage(30), travelerInformation(31), personalSafetyMessage(32), roadSafetyMessage(33), roadWeatherMessage(34), probeDataConfigMessage(35), probeDataReportMessage(36), tollAdvertisementMessage(37), tollUsageMessage(38), tollUsageAckMessage(39), cooperativeControlMessage(40), sensorDataSharingMessage(41), maneuverSharingAndCoordinatingMessage(42), roadGeometryAndAttributes(43), personalSafetyMessage2(44), trafficSignalPhaseAndTiming(45), signalControlAndPrioritizationRequest(46), signalControlAndPrioritizationStatus(47), roadUserChargingConfigMessage(48), roadUserChargingReportMessage(49), trafficLightStatusMessage(50);
        struct RoadSafetyMessageMESSAGE_ID_AND_TYPE value;  // TABLE;
    };
    
}

/*
// init function to create a simple packet handle
*/ 
LONG API_InitRoadSafetyMessagePacket()
{
  return C2xInitPacket("RoadSafetyMessage"); 
}

/*
// init function to create a simple packet handle and
// initialize the struct with valid data
*/ 
LONG API_InitRoadSafetyMessagePacket(struct RoadSafetyMessage msgStruct)
{
  long pktHandle;

  pktHandle = API_InitRoadSafetyMessagePacket();

  if (pktHandle != 0)
  {
    // create valid message and application data
    if (C2xCompletePacket(pktHandle) == 0) 
    {
      API_GetRoadSafetyMessageParams(pktHandle, msgStruct);
    }
  }
  return pktHandle;
}

/*
// init function to create a packet with security layer and
// initialize the struct with valid data
*/ 
LONG API_InitRoadSafetyMessagePacket(struct RoadSafetyMessage msgStruct, char packetTypeDesignator[], char certificateName[])
{
  long pktHandle, certHdl;

  // initialize the packet
  pktHandle = C2xInitPacket("RoadSafetyMessage", packetTypeDesignator);

  if (pktHandle != 0)
  {
    certHdl = C2xSecCertificateGetHandle(certificateName);  // get the certificate handle for the cert with name "certificateName"
    if (certHdl != 0) 
    {
      C2xSecPacketSetSignerHandle(pktHandle, certHdl); // set the certHdl to the packet
    }

    // create valid message and application data
    if (C2xCompletePacket(pktHandle) == 0) 
    {
      // copy application data to the application structure
      API_GetRoadSafetyMessageParams(pktHandle, msgStruct);
    }
  }
  return pktHandle;
}
    

int GetRoadSafetyMessageCommon_RoadAuthorityIDParams(LONG packetHandle, struct RoadSafetyMessageCommon_RoadAuthorityID value, char oldPath[])
{
  char newPath[300];
  int i;
  int result;

  result = 0;

  value.choice = C2xGetTokenInt(packetHandle, "RoadSafetyMessage", oldPath);

  switch(value.choice)
  {
    case 0:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "fullRdAuthID");
      value.fullRdAuthID.length = C2xGetTokenInt(packetHandle, "RoadSafetyMessage", newPath);
      if((result = CheckLastError("RoadSafetyMessage", gkFuncRefGet, result))==0)
      {
        if(value.fullRdAuthID.length > 0)
        {
          for(i=0; i<value.fullRdAuthID.length; i++)
          {
            value.fullRdAuthID.arrayValue[i].id = C2xGetTokenOidElement(packetHandle, "RoadSafetyMessage", newPath, i);
          }
        }
      }
    }
    break;
    case 1:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "relRdAuthID");
      value.relRdAuthID.length = C2xGetTokenInt(packetHandle, "RoadSafetyMessage", newPath);
      if((result = CheckLastError("RoadSafetyMessage", gkFuncRefGet, result))==0)
      {
        if(value.relRdAuthID.length > 0)
        {
          for(i=0; i<value.relRdAuthID.length; i++)
          {
            value.relRdAuthID.arrayValue[i].id = C2xGetTokenOidElement(packetHandle, "RoadSafetyMessage", newPath, i);
          }
        }
      }
    }
    break;
  }
  return result;
}

int SetRoadSafetyMessageCommon_RoadAuthorityIDParams(LONG packetHandle, struct RoadSafetyMessageCommon_RoadAuthorityID value, char oldPath[])
{
  char newPath[300];
  int i;
  int result;

  result = 0;

  switch(value.choice)
  {
    case 0:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "fullRdAuthID");
      C2xRemoveToken(packetHandle, "RoadSafetyMessage", newPath);
      if(value.fullRdAuthID.length > 0)
      {
        for(i=0; i<value.fullRdAuthID.length; i++)
        {
          C2xSetTokenOidElement(packetHandle, "RoadSafetyMessage", newPath, i, value.fullRdAuthID.arrayValue[i].id);
        }
      }
      result = CheckLastError("RoadSafetyMessage", gkFuncRefGet, result);
    }
    break;
    case 1:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "relRdAuthID");
      C2xRemoveToken(packetHandle, "RoadSafetyMessage", newPath);
      if(value.relRdAuthID.length > 0)
      {
        for(i=0; i<value.relRdAuthID.length; i++)
        {
          C2xSetTokenOidElement(packetHandle, "RoadSafetyMessage", newPath, i, value.relRdAuthID.arrayValue[i].id);
        }
      }
      result = CheckLastError("RoadSafetyMessage", gkFuncRefGet, result);
    }
    break;
  }
  return result;
}

