  int result;

  result = 0;

  C2xRemoveToken(packetHandle, "RoadSafetyMessage", oldPath);
  for(i=0; i<value.length; i++)
  {
    snprintf(newPath, elcount(newPath), "%s[%d]", oldPath, i);
    SetRoadSafetyMessageLaneInfoParams(packetHandle, value.arrayValue[i], newPath);
    result = CheckLastError("RoadSafetyMessage", gkFuncRefGet, result);
  }
  return result;
}

int GetRoadSafetyMessageLaneClosureContainerParams(LONG packetHandle, struct RoadSafetyMessageLaneClosureContainer value, char oldPath[])
