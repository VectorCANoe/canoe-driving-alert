  {
    GetRoadSafetyMessageLaneClosureContainer_laneStatusParams(packetHandle, value.laneStatus, newPath);
    result = CheckLastError("RoadSafetyMessage", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "laneStatusVaries");
