  char newPath[300]; 
  int i;
  int result;

  result = 0;

  value.length = C2xGetTokenInt(packetHandle, "RoadSafetyMessage", oldPath);
  if((result = CheckLastError("RoadSafetyMessage", gkFuncRefGet, result))==0)
  {
    for(i=0; i<value.length; i++)
    {
      snprintf(newPath, elcount(newPath), "%s[%d]", oldPath, i);
      GetRoadSafetyMessageLaneInfoParams(packetHandle, value.arrayValue[i], newPath);
      result = CheckLastError("RoadSafetyMessage", gkFuncRefGet, result);
    }
  }
  return result;
}

int SetRoadSafetyMessageLaneClosureContainer_laneStatusParams(LONG packetHandle, struct RoadSafetyMessageLaneClosureContainer_laneStatus value, char oldPath[])
{
  char newPath[300]; 
