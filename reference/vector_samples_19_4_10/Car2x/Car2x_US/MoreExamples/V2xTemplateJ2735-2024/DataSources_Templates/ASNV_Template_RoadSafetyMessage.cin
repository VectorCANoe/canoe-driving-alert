  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "closureRegion");
  GetRoadSafetyMessageRegionInfoParams(packetHandle, value.closureRegion, newPath);
  result = CheckLastError("RoadSafetyMessage", gkFuncRefGet, result);

  return result;
}

