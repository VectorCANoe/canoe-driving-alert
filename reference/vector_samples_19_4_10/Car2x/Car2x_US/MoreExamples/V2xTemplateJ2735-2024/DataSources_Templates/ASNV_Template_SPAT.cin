    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "signalPhaseAndTimingMessage");
      GetSPAT_SPATParams(packetHandle, value.signalPhaseAndTimingMessage, newPath);
      result = CheckLastError("SPAT", gkFuncRefGet, result);
