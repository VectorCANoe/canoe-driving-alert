int GetSPATCommon_RoadAuthorityIDParams(LONG packetHandle, struct SPATCommon_RoadAuthorityID value, char oldPath[])
{
  char newPath[300];
  int i;
  int result;

  result = 0;

  value.choice = C2xGetTokenInt(packetHandle, "SPAT", oldPath);

  switch(value.choice)
  {
    case 0:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "fullRdAuthID");
      value.fullRdAuthID.length = C2xGetTokenInt(packetHandle, "SPAT", newPath);
      if((result = CheckLastError("SPAT", gkFuncRefGet, result))==0)
      {
        if(value.fullRdAuthID.length > 0)
        {
          for(i=0; i<value.fullRdAuthID.length; i++)
          {
            value.fullRdAuthID.arrayValue[i].id = C2xGetTokenOidElement(packetHandle, "SPAT", newPath, i);
          }
        }
      }
    }
    break;
    case 1:
    {
      snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "relRdAuthID");
      value.relRdAuthID.length = C2xGetTokenInt(packetHandle, "SPAT", newPath);
      if((result = CheckLastError("SPAT", gkFuncRefGet, result))==0)
      {
        if(value.relRdAuthID.length > 0)
        {
          for(i=0; i<value.relRdAuthID.length; i++)
          {
            value.relRdAuthID.arrayValue[i].id = C2xGetTokenOidElement(packetHandle, "SPAT", newPath, i);
          }
        }
      }
    }
    break;
  }
  return result;
}

