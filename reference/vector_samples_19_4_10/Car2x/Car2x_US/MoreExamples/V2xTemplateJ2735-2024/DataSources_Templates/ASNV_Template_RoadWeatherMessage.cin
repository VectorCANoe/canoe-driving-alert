int GetRoadWeatherMessageTravelerInformation_RoadSignIDParams(LONG packetHandle, struct RoadWeatherMessageTravelerInformation_RoadSignID value, char oldPath[])
{
  char newPath[300]; 
  int j; 
  int k;
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "position");
  GetRoadWeatherMessageCommon_Position3DParams(packetHandle, value.position, newPath);
  result = CheckLastError("RoadWeatherMessage", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "viewAngle");
  value.viewAngle.isValidFlag = 1;
  value.viewAngle.stringLength = C2xGetTokenLengthBit(packetHandle, "RoadWeatherMessage", newPath);
  if ((result = CheckLastError("RoadWeatherMessage", gkFuncRefGet, result))==0)
  {
    if(value.viewAngle.stringLength > 0)
    {
      for(j=0; j<value.viewAngle.stringLength; j++)
      {
        if(C2xGetTokenBitOfBitString(packetHandle, "RoadWeatherMessage", newPath, j) == 0)
        {
          value.viewAngle.string[j] = '0';
        }
        else if(C2xGetTokenBitOfBitString(packetHandle, "RoadWeatherMessage", newPath, j) == 1)
        {
          value.viewAngle.string[j] = '1';
        }

        if(value.viewAngle.stringLength == 1)
        {
          value.viewAngle.string[1] = '0';
        }
        result = CheckLastError("RoadWeatherMessage", gkFuncRefGet, result);
      }
    }
    else
    {
      for(k = value.viewAngle.stringLength+1; k > -1; k--)
      {
        if(value.viewAngle.string[k] == '1')
        {
          value.viewAngle.string[k] = '0';
        }
      }
    }
  }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "mutcdCode");
  value.mutcdCode.isValidFlag = C2xIsTokenAvailable(packetHandle, "RoadWeatherMessage", newPath);
  if(value.mutcdCode.isValidFlag==1)
  {
    value.mutcdCode.value = C2xGetTokenInt(packetHandle, "RoadWeatherMessage", newPath);
    result = CheckLastError("RoadWeatherMessage", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "crc");
  value.crc.isValidFlag = C2xIsTokenAvailable(packetHandle, "RoadWeatherMessage", newPath);
  if(value.crc.isValidFlag==1)
  {
    value.crc.isValidFlag = 1;
    value.crc.stringLength = C2xGetTokenData(packetHandle, "RoadWeatherMessage", newPath, elcount(value.crc.string), value.crc.string);
  }
  return result;
}

int SetRoadWeatherMessageTravelerInformation_RoadSignIDParams(LONG packetHandle, struct RoadWeatherMessageTravelerInformation_RoadSignID value, char oldPath[])
{
  char newPath[300]; 
  int j;
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "position");
