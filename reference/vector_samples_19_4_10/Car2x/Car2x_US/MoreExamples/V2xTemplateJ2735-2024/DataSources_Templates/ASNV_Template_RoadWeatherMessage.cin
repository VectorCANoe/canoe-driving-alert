int GetRoadWeatherMessageProbeVehicleData_VehicleStatusParams(LONG packetHandle, struct RoadWeatherMessageProbeVehicleData_VehicleStatus value, char oldPath[])
{
  char newPath[300]; 
  int j; 
  int k;
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "lights");
  value.lights.isValidFlag = C2xIsTokenAvailable(packetHandle, "RoadWeatherMessage", newPath);
  if(value.lights.isValidFlag==1)
  {
    value.lights.isValidFlag = 1;
    value.lights.stringLength = C2xGetTokenLengthBit(packetHandle, "RoadWeatherMessage", newPath);
    if ((result = CheckLastError("RoadWeatherMessage", gkFuncRefGet, result))==0)
    {
      if(value.lights.stringLength > 0)
      {
        for(j=0; j<value.lights.stringLength; j++)
        {
          if(C2xGetTokenBitOfBitString(packetHandle, "RoadWeatherMessage", newPath, j) == 0)
          {
            value.lights.string[j] = '0';
          }
          else if(C2xGetTokenBitOfBitString(packetHandle, "RoadWeatherMessage", newPath, j) == 1)
          {
            value.lights.string[j] = '1';
          }

          if(value.lights.stringLength == 1)
          {
            value.lights.string[1] = '0';
          }
          result = CheckLastError("RoadWeatherMessage", gkFuncRefGet, result);
        }
      }
      else
      {
        for(k = value.lights.stringLength+1; k > -1; k--)
        {
          if(value.lights.string[k] == '1')
          {
            value.lights.string[k] = '0';
          }
        }
      }
    }

  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "lightBar");
  value.lightBar.isValidFlag = C2xIsTokenAvailable(packetHandle, "RoadWeatherMessage", newPath);
  if(value.lightBar.isValidFlag==1)
  {
    value.lightBar.value = C2xGetTokenInt(packetHandle, "RoadWeatherMessage", newPath);
    result = CheckLastError("RoadWeatherMessage", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "wipers");
  value.wipers.isValidFlag = C2xIsTokenAvailable(packetHandle, "RoadWeatherMessage", newPath);
  if(value.wipers.isValidFlag==1)
  {
    GetRoadWeatherMessageCommon_WiperSetParams(packetHandle, value.wipers, newPath);
    result = CheckLastError("RoadWeatherMessage", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "brakeStatus");
  value.brakeStatus.isValidFlag = C2xIsTokenAvailable(packetHandle, "RoadWeatherMessage", newPath);
  if(value.brakeStatus.isValidFlag==1)
  {
    GetRoadWeatherMessageCommon_BrakeSystemStatusParams(packetHandle, value.brakeStatus, newPath);
    result = CheckLastError("RoadWeatherMessage", gkFuncRefGet, result);
