        BYTE doNotUse1;  // INTEGER, 0..31;
        INT frameType;  // ENUMERATED, unknown(0), advisory(1), roadSignage(2), commercialSignage(3);
        struct RoadWeatherMessageTravelerInformation_TravelerDataFrame_msgId msgId;  // CHOICE;
        struct OPT_WORD_ASN startYear;  // INTEGER, OPTIONAL, 0..4095;
        DWORD startTime;  // INTEGER, 0..527040;
        WORD durationTime;  // INTEGER, 0..32000;
        BYTE priority;  // INTEGER, 0..7;
        BYTE doNotUse2;  // INTEGER, 0..31;
        struct RoadWeatherMessageTravelerInformation_TravelerDataFrame_regions regions;  // SEQUENCEOF;
        BYTE doNotUse3;  // INTEGER, 0..31;
        BYTE doNotUse4;  // INTEGER, 0..31;
        struct RoadWeatherMessageTravelerInformation_TravelerDataFrame_content content;  // CHOICE;
        struct RoadWeatherMessageTravelerInformation_URL_Short url;  // IA5STRING, OPTIONAL;
        struct RoadWeatherMessageTravelerInformation_TravelerDataFrameNewPartIIIContent contentNew;  // CHOICE;
    };
    
