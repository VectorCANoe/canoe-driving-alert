int GetRoadWeatherMessageNtcipAirTemperatureParams(LONG packetHandle, struct RoadWeatherMessageNtcipAirTemperature value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "temperature");
  value.temperature = C2xGetTokenInt(packetHandle, "RoadWeatherMessage", newPath);
  result = CheckLastError("RoadWeatherMessage", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "measurementStdDev");
  value.measurementStdDev.isValidFlag = C2xIsTokenAvailable(packetHandle, "RoadWeatherMessage", newPath);
  if(value.measurementStdDev.isValidFlag==1)
  {
    value.measurementStdDev.value = C2xGetTokenInt(packetHandle, "RoadWeatherMessage", newPath);
    result = CheckLastError("RoadWeatherMessage", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "tempSensorHeight");
  value.tempSensorHeight.isValidFlag = C2xIsTokenAvailable(packetHandle, "RoadWeatherMessage", newPath);
  if(value.tempSensorHeight.isValidFlag==1)
  {
    value.tempSensorHeight.value = C2xGetTokenInt(packetHandle, "RoadWeatherMessage", newPath);
    result = CheckLastError("RoadWeatherMessage", gkFuncRefGet, result);
  }
  return result;
}

int SetRoadWeatherMessageNtcipAirTemperatureParams(LONG packetHandle, struct RoadWeatherMessageNtcipAirTemperature value, char oldPath[])
{
  char newPath[300];
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "temperature");
  C2xSetTokenInt(packetHandle, "RoadWeatherMessage", newPath, value.temperature);
  result = CheckLastError("RoadWeatherMessage", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "measurementStdDev");
  if(value.measurementStdDev.isValidFlag==1)
  {
    if (value.measurementStdDev.value < 1)
    {
        C2xSetTokenInt(packetHandle, "RoadWeatherMessage", newPath, 1);
    }
    else if (value.measurementStdDev.value > 16)
    {
        C2xSetTokenInt(packetHandle, "RoadWeatherMessage", newPath, 16);
    }
    else
    {
        C2xSetTokenInt(packetHandle, "RoadWeatherMessage", newPath, value.measurementStdDev.value);
    }
    result = CheckLastError("RoadWeatherMessage", gkFuncRefGet, result);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "RoadWeatherMessage", newPath) )
    {
      C2xRemoveToken(packetHandle, "RoadWeatherMessage", newPath);
    }
  }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "tempSensorHeight");
  if(value.tempSensorHeight.isValidFlag==1)
  {
    C2xSetTokenInt(packetHandle, "RoadWeatherMessage", newPath, value.tempSensorHeight.value);
    result = CheckLastError("RoadWeatherMessage", gkFuncRefGet, result);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "RoadWeatherMessage", newPath) )
    {
      C2xRemoveToken(packetHandle, "RoadWeatherMessage", newPath);
    }
  }

  return result;
}

