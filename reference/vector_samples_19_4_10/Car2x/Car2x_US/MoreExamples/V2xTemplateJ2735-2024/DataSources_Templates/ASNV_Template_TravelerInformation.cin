int GetTravelerInformationGeometricProjectionParams(LONG packetHandle, struct TravelerInformationGeometricProjection value, char oldPath[])
{
  char newPath[300]; 
  int j; 
  int k;
  int result;

  result = 0;

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "direction");
  value.direction.isValidFlag = 1;
  value.direction.stringLength = C2xGetTokenLengthBit(packetHandle, "TravelerInformation", newPath);
  if ((result = CheckLastError("TravelerInformation", gkFuncRefGet, result))==0)
  {
    if(value.direction.stringLength > 0)
    {
      for(j=0; j<value.direction.stringLength; j++)
      {
        if(C2xGetTokenBitOfBitString(packetHandle, "TravelerInformation", newPath, j) == 0)
        {
          value.direction.string[j] = '0';
        }
        else if(C2xGetTokenBitOfBitString(packetHandle, "TravelerInformation", newPath, j) == 1)
        {
          value.direction.string[j] = '1';
        }

        if(value.direction.stringLength == 1)
        {
          value.direction.string[1] = '0';
        }
        result = CheckLastError("TravelerInformation", gkFuncRefGet, result);
      }
    }
    else
    {
      for(k = value.direction.stringLength+1; k > -1; k--)
      {
        if(value.direction.string[k] == '1')
        {
          value.direction.string[k] = '0';
        }
      }
    }
  }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "extent");
  value.extent.isValidFlag = C2xIsTokenAvailable(packetHandle, "TravelerInformation", newPath);
  if(value.extent.isValidFlag==1)
  {
    value.extent.value = C2xGetTokenInt(packetHandle, "TravelerInformation", newPath);
    result = CheckLastError("TravelerInformation", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "laneWidth");
  value.laneWidth.isValidFlag = C2xIsTokenAvailable(packetHandle, "TravelerInformation", newPath);
  if(value.laneWidth.isValidFlag==1)
  {
    value.laneWidth.value = C2xGetTokenInt(packetHandle, "TravelerInformation", newPath);
    result = CheckLastError("TravelerInformation", gkFuncRefGet, result);
  }
  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "circle");
  GetTravelerInformationCircleParams(packetHandle, value.circle, newPath);
  result = CheckLastError("TravelerInformation", gkFuncRefGet, result);

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "regional");
  value.regional.isValidFlag = C2xIsTokenAvailable(packetHandle, "TravelerInformation", newPath);
  if(value.regional.isValidFlag==1)
  {
    GetTravelerInformationGeometricProjection_regionalParams(packetHandle, value.regional, newPath);
    result = CheckLastError("TravelerInformation", gkFuncRefGet, result);
  }
  return result;
}

