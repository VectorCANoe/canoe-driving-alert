    if( C2xIsTokenAvailable(packetHandle, "TravelerInformation", newPath) )
    {
      C2xRemoveToken(packetHandle, "TravelerInformation", newPath);
    }
  }

  snprintf(newPath, elcount(newPath), "%s.%s", oldPath, "crc");
  if(value.crc.isValidFlag==1)
  {
    C2xSetTokenData(packetHandle, "TravelerInformation", newPath, value.crc.stringLength, value.crc.string);
  }
  else
  {
    if( C2xIsTokenAvailable(packetHandle, "TravelerInformation", newPath) )
    {
      C2xRemoveToken(packetHandle, "TravelerInformation", newPath);
    }
  }

  return result;
}

