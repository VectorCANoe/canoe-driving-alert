version 2.0;

import module "SilKit";

namespace RoomTemperatureControl
{
  enum State : uint8
  {
    OFF,
    COOLING,
    HEATING
  }
    
  [Binding="SilKit"]
  interface ISensor
  {
    provided data double Temperature;
  }

  [Binding="SilKit"]
  interface IHeating
  {
    consumed data State HeaterState;
  }

  ISensor Sensor1;
  ISensor Sensor2;
  ISensor Sensor3;

  IHeating Heating;
}
