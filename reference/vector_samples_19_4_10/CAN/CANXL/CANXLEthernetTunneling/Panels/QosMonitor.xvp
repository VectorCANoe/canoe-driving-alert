    <Object Type="Vector.CANalyzer.Panels.Design.StaticTextControl, Vector.CANalyzer.Panels.CommonControls, Version=18.0.150.0, Culture=neutral, PublicKeyToken=null" Name="X2c1d0039ee8c5e4183e86bee5e599df5b4af" ControlName="Static Text 2">
      <Property Name="Name">X2c1d0039ee8c5e4183e86bee5e599df5b4af</Property>
      <Property Name="Size">484, 83</Property>
      <Property Name="Location">20, 212</Property>
      <Property Name="TextAlign">TopCenter</Property>
      <Property Name="ForeColor">255, 127, 127, 127</Property>
      <Property Name="Text">The 'bus access time' is the time that it takes for a CAN message to actually being transmitted after it has been sent by the application. It is especially important for high-priority messages. This time is influcenced e.g. by other messages occupying the bus. In this demo, large CAN XL frames which tunnel ethernet traffic occupy the bus for longer time. By using the fragmentation of large CAN XL frames, this time can be improved. For this metric, tha maximum over the last N measurements is used.</Property>
    </Object>
    <Object Type="Vector.CANalyzer.Panels.Design.StaticTextControl, Vector.CANalyzer.Panels.CommonControls, Version=18.0.150.0, Culture=neutral, PublicKeyToken=null" Name="X62250dd0e59d5e4b44ebcafe7344c9bbccef" ControlName="Static Text 1">
