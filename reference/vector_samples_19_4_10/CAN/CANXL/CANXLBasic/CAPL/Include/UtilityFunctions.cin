void ReadOutProperty(dword mediaTypeHandle, char property[])
{
  dword result;
  dword value;
  char valueAsString[255];
  byte valueAsByteArray[1024];
  dword length;
  if(mediaProperties.containsKey(property))
  {
    if(mediaProperties[property].MediaValueType == eMediaDword)
    {
      result = MediaGetProperty(mediaTypeHandle, property, value);
    }
    else if(mediaProperties[property].MediaValueType == eMediaString)
    {
      result = MediaGetProperty(mediaTypeHandle, property, elcount(valueAsString), valueAsString);
      value = ConvertStringValueToDword(property, valueAsString);
    }
    else if(mediaProperties[property].MediaValueType == eMediaByteArray)
    {
      int i;
      length = elcount(valueAsByteArray);
      result = MediaGetProperty(mediaTypeHandle, property, length, valueAsByteArray);     
    }
  
    if(result == 0)
    {
       mediaProperties[property].HasValue = 1;
       mediaProperties[property].DwordValue = value;
    }
  }
}

