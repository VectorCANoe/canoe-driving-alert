  //ReadOutProperty(mediaTypeHandle, "AacAudioProfileLevelIndication");
  //ReadOutProperty(mediaTypeHandle, "AacPayloadType");
  ReadOutProperty(mediaTypeHandle, "AudioAvgBytesPerSecond");
  ReadOutProperty(mediaTypeHandle, "AudioBitsPerSample");
  ReadOutProperty(mediaTypeHandle, "AudioBlockAlignment");
 // ReadOutProperty(mediaTypeHandle, "AudioChannelMask");
 // ReadOutProperty(mediaTypeHandle, "AudioFloatSamplesPerSecond");
 // ReadOutProperty(mediaTypeHandle, "AudioFolddownMatrix");
  ReadOutProperty(mediaTypeHandle, "AudioNumChannels");
  //ReadOutProperty(mediaTypeHandle, "AudioSamplesPerBlock");
  ReadOutProperty(mediaTypeHandle, "AudioSamplesPerSecond");
  //ReadOutProperty(mediaTypeHandle, "AudioValidBitsPerSample");
  //ReadOutProperty(mediaTypeHandle, "AudioWmadrcAvgref");
  //ReadOutProperty(mediaTypeHandle, "AudioWmadrcAvgtarget");
  //ReadOutProperty(mediaTypeHandle, "AudioWmadrcPeakref");
  //ReadOutProperty(mediaTypeHandle, "AudioWmadrcPeaktarget");
  //ReadOutProperty(mediaTypeHandle, "OriginalWaveFormatTag");
}

on sysvar MediaFileServer::FrameFormat
{
  if(@MediaFileServer::Status == eNotInitalized || @MediaFileServer::Status == eStreamFinished)
  {
    InitializFrameFormat();
  }
}

void InitializFrameFormat()
{
 if(@MediaFileServer::FrameFormat == 0)
  {
    streamingMessage.fdf = 1;
	  streamingMessage.brs = 0;
    streamingMessage.xlf = 1;
    mediaTypeSinkConfigMessage.FDF = 1;
	  mediaTypeSinkConfigMessage.brs = 0;
    mediaTypeSinkConfigMessage.XLF = 1;
	  maxPayloadLength = 2048;
  }
  else
  {
    streamingMessage.fdf = 1;
	  streamingMessage.brs = 1;
    streamingMessage.xlf = 0;
    mediaTypeSinkConfigMessage.FDF = 1;
	  mediaTypeSinkConfigMessage.brs = 1;
    mediaTypeSinkConfigMessage.XLF = 0;
	  maxPayloadLength = 64;
  }


}

void InitializeStream()
{
  dword mediaTypeHandle;
  char wavFile[255];  
  char propValue[255];

  @MediaFileServer::Status = eNotInitalized;
  
  InitializFrameFormat();
  
  InitalizePropertyMetaInforamtion();
  
  
  sysGetVariableString(sysvar::TransmissionStatistic::MediaFile, wavFile, elcount(wavFile));  
  sourceReaderHandle = MediaCreateSourceReaderFromUrl(wavFile);
  mediaTypeHandle = MediaGetMediaType(sourceReaderHandle, streamIndex);
  
  if(mediaTypeHandle == kInvalidHandle)
  {
    @MediaFileServer::Status = eMediaTypesGatheringFailed;
  }
  else
  {
    ReadOutMediaPropertiesAudio(mediaTypeHandle);
    @MediaFileServer::Status = eMediaTypesGathered;
    MediaReleaseMediaType(mediaTypeHandle);
  }
  
  TransmitMediaTypeInformation();
  @MediaFileServer::SampleRate = mediaProperties["AudioSamplesPerSecond"].DwordValue;
  ConvertDwordToString("Subtype", mediaProperties["Subtype"].DwordValue, propValue);
  sysSetVariableString(sysvar::MediaFileServer::Format, propValue);
}

void ReadFromSourceStream(dword talkerHandle, byte buffer[])
{
  dword ret, length;
    
  length = elCount(buffer);
  
  if (talkerHandle != kInvalidHandle)
  {
    ret = MediaRead(talkerHandle, streamIndex, buffer, elcount(buffer), "OnMediaRead");
  }
}

void CreateStreamMessage(byte buffer[], dword length)
{
 
  int dataIndex;
  dword messageLength;
  dword offsetInBuffer;
 
  
  if(remainLength == 0)
  {
    remainLength = length;
  } 
  else
  {
    length = remainLength;
  }  
  messageLength = length > maxPayloadLength ? @MediaFileServer::FrameDataLength : length;
  
  if(streamingMessage.xlf == 0)
  {
    streamingMessage.dlc = messageLength;
  }
  else
  {
    payload.PduLength = messageLength;
  }
  
  offsetInBuffer = chunkCount * chunkSize;
  
  for(dataIndex = 0; dataIndex < messageLength; ++dataIndex)
  {   
   if(streamingMessage.xlf == 0)
   {
     streamingMessage.byte(dataIndex) = buffer[offsetInBuffer + dataIndex];    
   }
   else
   {
     payload.byte(dataIndex) = buffer[offsetInBuffer + dataIndex];    
   }
  }  
  
  remainLength = remainLength - messageLength;
  if(remainLength > 0)
  {
    ++chunkCount;
  }
  else
  {
    remainLength = 0;
    chunkCount = 0;
  }
  
 
}

void SendStreamEndMessage()
{
   if(mediaTypeSinkConfigMessage.xlf == 0)
   {
     mediaTypeSinkConfigMessage.dlc = 1;
     mediaTypeSinkConfigMessage.byte(0) = 2;
   }
   else
   {
     mediaTypeSinkConfigMessage.dlc = 1;
     mediaTypeSinkConfigMessage.AF = 0x2;
     mediaTypeSinkConfigMessage.dword(0) = streamFlags;
   }

   @MediaFileServer::Status = eStreamFinished;
   output(mediaTypeSinkConfigMessage);
   MediaReleaseSourceReader(sourceReaderHandle);
}

void TransmitStream(byte buffer[], dword streamFlags, dword length)
{
  if(streamFlags == SOURCE_READERF_ENDOFSTREAM)
  {
   SendStreamEndMessage();
  }
  else
  {
    CreateStreamMessage(buffer, length);   
	  if(streamingMessage.xlf == 0)
	  {
	    output(streamingMessage);
	  }
	  else
	  {
	    triggerPDU(payload);
	  }
  }  
}

void WritePropertyNameAndValue(dword nextDataIndex, long propertyNameLength, int& dataLength,  char keyString[])
{
  int currentDataIndex;
  
  for(currentDataIndex = 0; currentDataIndex < propertyNameLength; ++currentDataIndex)
  {
    mediaTypeSinkConfigMessage.byte(dataLength) = keyString[currentDataIndex];
    ++dataLength;
  }
	mediaTypeSinkConfigMessage.byte(dataLength) = 0x00;
  ++dataLength;
  mediaTypeSinkConfigMessage.dword(dataLength) = mediaProperties[keyString].DwordValue;
  dataLength +=4;
  mediaTypeSinkConfigMessage.word(nextDataIndex)   = dataLength;
}

void TransmitMediaTypeInformation()
{
  dword lengthNeededForProperty;
  long  propertyNameLength;
  dword propertyValue;
  int   propertyIndex;
  int   dataLength;
  int   currentDataIndex;
  dword nextData;
  char keyString[255];
  dataLength = 0;
  mediaTypeSinkConfigMessage.AF = 0x1;
  for(char[] aKey : mediaProperties)
  {
    if(mediaProperties[aKey].HasValue == 1)
    {
      nextData = dataLength;
      dataLength += 2; 
  
      strncpy(keyString, aKey, elcount(keyString));
      propertyNameLength = strlen(keyString); 
	    lengthNeededForProperty = propertyNameLength + 1 + 4; //1:= Null-Termination 4:=Dword Value 
      
	    if((lengthNeededForProperty + dataLength) <= maxPayloadLength)
	    {
        WritePropertyNameAndValue(nextData, propertyNameLength, dataLength, keyString);
	    }
	    else
	    {
	      if(mediaTypeSinkConfigMessage.xlf == 0)
		    {
		      mediaTypeSinkConfigMessage.dlc = nextData;
		    }
		    else
		    {
          mediaTypeSinkConfigMessage.dlc = nextData-1;
		    }		
        output(mediaTypeSinkConfigMessage);
		    nextData = 0;
		    dataLength = 2;
		    if(lengthNeededForProperty <= maxPayloadLength)
	      {
          WritePropertyNameAndValue(nextData, propertyNameLength, dataLength, keyString);
	      }
	    }
	  }     
  }
  
  if(dataLength > 0)
  {
    if(mediaTypeSinkConfigMessage.xlf == 0)
    {
	    mediaTypeSinkConfigMessage.dlc = nextData;
	  }
	  else
	  {
      mediaTypeSinkConfigMessage.dlc = dataLength -1;
	  }
    
    output(mediaTypeSinkConfigMessage);
    
	  if(mediaTypeSinkConfigMessage.xlf == 0)
	  {
      mediaTypeSinkConfigMessage.dlc = 1;
	    mediaTypeSinkConfigMessage.byte(0) = 1;
	    output(mediaTypeSinkConfigMessage);
	  }
	
  }
}

void OnMediaRead(dword sourceReaderHandle, long result, dword streamIndex, dword streamFlags, int64 timestamp, byte buffer[], dword length)
{
  byte endReached;
  
  if (result != 0)
  {    
    return;
  }
  streamFlags = streamFlags;
  @MediaFileServer::Status = eStreamingRunning;
  TransmitStream(buffer,streamFlags, length);
}

on stopMeasurement
{
   @MediaFileServer::Status = eNotInitalized;
}

on message CAN1.0x221
{
  if(burstMode == 1)
  {
    if(this.dir == txrequest)
    {
      SendNextData();
    }
  }
}

