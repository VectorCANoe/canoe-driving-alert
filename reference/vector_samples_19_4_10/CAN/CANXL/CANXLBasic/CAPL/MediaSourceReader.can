/*@!Encoding:1252*/
includes
{
  #include "Include\UtilityFunctions.cin"

}

variables
{
  pdu AudioDataFilePayload payload;
  dword sourceReaderHandle;
  const dword kInvalidHandle = 0;
  byte txBuffer[128*1024];  
  dword remainLength;
  dword chunkCount = 0;
  dword chunkSize = 0;
  const dword streamIndex = 0;
  dword streamFlags;
  message 0x221 streamingMessage;
  message 0x220 mediaTypeSinkConfigMessage;
  
  	
  const dword SOURCE_READERF_ERROR = 0x00000001;       //An error occurred. If you receive this flag, do not make any further calls to SourceReader methods.
  const dword SOURCE_READERF_ENDOFSTREAM = 0x00000002; //The source reader reached the end of the stream.
  const dword SOURCE_READERF_NEWSTREAM = 0x00000004;   //One or more new streams were created. Respond to this flag by doing at least one of the following:
                                                        // a) Set the output types on the new streams.
                                                        // b) Update the stream selection by selecting or deselecting streams.
  const dword SOURCE_READERF_NATIVEMEDIATYPECHANGED = 0x00000010;  //The native format has changed for one or more streams. The native format is the format delivered by the media source before any decoders are inserted.
  const dword SOURCE_READERF_CURRENTMEDIATYPECHANGED = 0x00000020; //The current media has type changed for one or more streams. To get the current media type, call the source reader’s GetMediaType method.
  const dword MF_SOURCE_READERF_STREAMTICK = 0x00000100;           //There is a gap in the stream.
  const dword SOURCE_READERF_ALLEFFECTSREMOVED = 0x00000200;       //All transforms inserted by the application have been removed for a particular stream. This could be due to a dynamic format change from a source or decoder that prevents custom transforms from being used because they cannot handle the new media type.
  
  
  enum StreamingSourceStatus
  {
    eNotInitalized = 0,
    eInitialized = 1,
    eMediaTypesGatheringFailed = 2,
    eMediaTypesGathered = 3,
    eMediaSourceAvailable = 4,
    eMediaSourceNotAvailable = 5,
    eStreamingRunning = 6,
    eStreamFinished = 7
  };
  
  dword maxPayloadLength = 64;
  mstimer transmitTimer;
  dword burstMode;
}

void SendNextData()
{
  if(@MediaFileServer::Status == eStreamingRunning)
  {
    if(remainLength > 0)
    {
      TransmitStream(txBuffer, streamFlags, elcount(txBuffer));
    }
    else
    {     
      MediaRead(sourceReaderHandle, streamIndex, txBuffer, elcount(txBuffer), "OnMediaRead");
    }
  }
  else if(@MediaFileServer::Status == eStreamFinished)
  {
    if(burstMode == 0)
	{
      cancelTimer(transmitTimer);
	}
  }
  else
  {
     ReadFromSourceStream(sourceReaderHandle, txBuffer);  
  }
}

on timer transmitTimer
{
  SendNextData();
}

on start
{
 @MediaFileServer::Status = eNotInitalized;
}


byte ProcessMessage(message * receiveMessage)
{
  byte processMessage;
  processMessage = 0;
  if(isSimulated() > 0)
  {
    processMessage = receiveMessage.can == 2 ? 1 : 0;
  }
  else
  {
    processMessage = (receiveMessage.can == 1 && receiveMessage.dir == rx) ? 1 : 0;
  }
  return processMessage;
}

on message 0x219
{  
  if(ProcessMessage(this) == 1)
  {
    if(this.byte(0) == 1)
    {
      if(@MediaFileServer::Status == eNotInitalized || @MediaFileServer::Status == eStreamFinished)
      {
        InitializeStream();
      }    
      if(@MediaFileServer::Status == eMediaTypesGathered)
      {
        CalculateFrameRate();
	      if(burstMode == 0)
	      {
          setTimerCyclic(transmitTimer, @MediaFileServer::FramePeriod);
	      }
	      else
	      {
	        ReadFromSourceStream(sourceReaderHandle, txBuffer);  
	      }
      }
    }
    else if(this.byte(0) == 2)
    {
       if(@MediaFileServer::Status == eStreamingRunning)
      {
        cancelTimer(transmitTimer);
        SendStreamEndMessage();
        @MediaFileServer::Status = eStreamFinished;
        remainLength = 0;
        chunkCount = 0;        
      }
    }
  }
}

void CalculateFrameRate()
{
  dword sampleRate;
  double transmitRate;
  if( mediaProperties["AudioAvgBytesPerSecond"].HasValue == 1)
  {    
    sampleRate = mediaProperties["AudioAvgBytesPerSecond"].DwordValue;
    transmitRate = maxPayloadLength * 1000 / sampleRate;
	  if(transmitRate == 0)
	  {
	    burstMode = 1;
	    @MediaFileServer::FramePeriod = 0;
	    @MediaFileServer::FrameDataLength = maxPayloadLength;
	    chunkSize = @MediaFileServer::FrameDataLength;
	  }
	  else
	  {
	    burstMode = 0;
      @MediaFileServer::FramePeriod = _round(transmitRate); 
      @MediaFileServer::FrameDataLength = sampleRate / (1000/@MediaFileServer::FramePeriod);
      chunkSize = @MediaFileServer::FrameDataLength;
	  }
  }  
}

