    @sysvar::LightSystem::TurnIndicationLeft=0;
    if(!gWarningOn) {
      $%NODE_NAME%_2::Active = %NODE_NAME%_2.Active::Turn_right;
      setTimer(tPhase, cPhaseTime);
    }
  }
  else if (gTurnIndicatorLastStatus == %NODE_NAME%_2.Active::Turn_right)
  {
    gTurnIndicatorLastStatus = %NODE_NAME%_2.Active::None;
    if(!gWarningOn) {
      $%NODE_NAME%_2::Active = %NODE_NAME%_2.Active::None;
      cancelTimer(tPhase);
    }
  }
}


  
on sysvar_update sysvar::Headlights::Headlight_switch
{
  if(Ig_15R==1){
    @sysvar::Headlights::Headlight=@this;
  }
  else {
    @sysvar::Headlights::Headlight = 0;
  }
}


on sysvar_update sysvar::LightSystem::SwitchHazardLights
{
  if(Ig_15R==1 && @sysvar::LightSystem::SwitchHazardLights==1){
    gWarningOn = 1;
  }
  else{
    gWarningOn=0;
  }
  
  if(gWarningOn)
  {
    cancelTimer(tPhase);
    setTimer(tPhase, cPhaseTime);
    $%NODE_NAME%_2::Active = 3;
  }
  else 
  {
    $%NODE_NAME%_2::Active = gTurnIndicatorLastStatus;
    if(gTurnIndicatorLastStatus == 0)
    {
      cancelTimer(tPhase);
    }
   }
}

on pdu msgchannel2.Gateway_1{
  Ig_15R_prev=Ig_15R;
  Ig_15R=this.Ig_15R;
  
  
  if (Ig_15R_prev!=Ig_15R){ //== 0 && Ig_15R == 1) {
    @sysvar::Headlights::Headlight_switch     = @sysvar::Headlights::Headlight_switch;
    @sysvar::LightSystem::SwitchHazardLights  = @sysvar::LightSystem::SwitchHazardLights;
  }
}



