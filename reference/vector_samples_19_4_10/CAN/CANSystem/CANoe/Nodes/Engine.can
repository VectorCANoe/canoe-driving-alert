on start
{
  
  ILSetOperationMode (2, 0); // form 1
  
  setTimer(mstTimestep, 0); 
  setTimer(TimestepSlow, 5000);
  @sysvar::PowerTrain::EngineStatus=2; //Engine status set to GoSleep on start of configuration
  $GearBoxInfo::Gear = 0;
  $PetrolLevel.raw = 250;
  $EngTemp = 80;
  // Start CAPL includes and node's modules/DLLs
  //--- begin generated part --- Block start #Hdr_OnStart#; do not delete this line and do not add application code in this code block!
  /* #ChannelStart# |CAN1| #BusStart# |PowerTrain| */
  /* #ChannelEnd# |CAN1| #BusEnd# |PowerTrain| */
  //--- end generated part --- Block end #Hdr_OnStart#; do not delete this line! Add application code below this line.
