on timer TimestepSlow 
{
  setTimer(TimestepSlow, 5000);


  EngineTempCalc();
}

on timer mstTimestep
{
  setTimer(mstTimestep, tTimestep_Interval);                      // timer is set at beginning of on timer so that mstTimestep intervalls dont vary 
  
  // not allowing capl sequences to be activated while engine is off or car is moving
  if(@sysvar::PowerTrain::EngineStatus!=1 || @sysvar::PowerTrain::CarSpeed_kmh>0){
    enableControl("Control","Switch / Indicator 6",0); 
    enableControl("Control","Switch / Indicator 7",0); 
  }
  else{
    enableControl("Control","Switch / Indicator 6",1); 
    enableControl("Control","Switch / Indicator 7",1); 
  }
  
  // for simplification purposes the user will not be able to turn the key to the "GoSleep", nor the "WakeUp" state while the Car is moving
  if (@sysvar::PowerTrain::CarSpeed_kmh>0){
    enableControl("MainPanel","Switch / Indicator 2",0);        // disables ignition switch control
    enableControl("MainPanel","Switch / Indicator 1",0); 
  }
  else {
    enableControl("MainPanel","Switch / Indicator 2",1);        // enables ignition switch control
    enableControl("MainPanel","Switch / Indicator 1",1); 
  }
  
  // allowing the capl sequences to be deactivated when running
  if(@sysvar::CruiseControl::DrivingCycleAcceleration_Switch ==1){ 
    enableControl("Control","Switch / Indicator 7",1); 
  }
  else if(@sysvar::CruiseControl::DrivingCycleDeceleration_Switch ==1){
    enableControl("Control","Switch / Indicator 6",1);
  }
  

  
  // simulating car behaviour according to engine status
  switch(@sysvar::PowerTrain::EngineStatus){
    
    case 0: // WakeUp
      if(@sysvar::PowerTrain::CarSpeed_kmh!=0){
       compute_vehicledynamics();
       compute_enginespeed(@sysvar::PowerTrain::Gear);            // calculates engine speed from car speed
       PetrolLevelCalc();
      }
      break;
      
      
    case 1: // Running
            
      if (@sysvar::CruiseControl::CC_Active == 1) {
        @sysvar::PowerTrain::ThrottlePosition = CCThrottleCalc();   // automatically calculating new throttle value in case cruise control is activated
      }
      
      compute_vehicledynamics();                                    // approximates engine power, air resistance etc. and therefore longitudinal acceleration on car as well as car speed
      compute_enginespeed(@sysvar::PowerTrain::Gear);               // calculates engine speed from car speed

      
      AutomaticGearShifting();                                      //automatically shifting gears
      compute_distance_travelled();                                 // calculating distance travelled since simulation start
      PetrolLevelCalc();
      
      //update database values
      update_database();
      break;
      
      
    case 2: //GoSleep
      @sysvar::PowerTrain::EngSpeed=0;
      @sysvar::PowerTrain::CarSpeed_kmh=0;
      @sysvar::PowerTrain::CarSpeed_m_per_s=0;
      @sysvar::PowerTrain::Gear=0;
      update_database();
      break;
    
    case 3: //Error
        
    break; 
  }
}

// updating database values
void update_database(){
  $PowerTrain::Engine::EngineData::EngSpeed=@sysvar::PowerTrain::EngSpeed;
  $ABSdata::CarSpeed=@sysvar::PowerTrain::CarSpeed_kmh;
  $EngSpeed = $EngSpeedIEEE;
  $EngForce = @sysvar::PowerTrain::EngForce;
  $EngPower = @sysvar::PowerTrain::EngPower;
  $EngineStatus::Status= @sysvar::PowerTrain::EngineStatus;
  $GearBoxInfo::Gear= @sysvar::PowerTrain::Gear;
  $ABSdata::AccelerationForce=@sysvar::PowerTrain::Vehicle_Acceleration*car_mass; // F [N] = m [kg] * a [m/(s^2)]
}

// calculating overall distance travelled since simulation start
void compute_distance_travelled(){
  distance_travelled = distance_travelled + ( @sysvar::PowerTrain::CarSpeed_m_per_s*0.001 ) /1000; // [km]
}

// reacting to actuation of the ignition switch
on sysvar_update sysvar::IL::IgnitionSwitch
{
  switch(@this){
    case 0:
      sysSetVariableString(sysvar::IL::IgnitionSwitch_Status,"OFF");
      @sysvar::PowerTrain::EngSpeed=0;
      @sysvar::PowerTrain::CarSpeed_kmh=0;
      @sysvar::PowerTrain::CarSpeed_m_per_s=0;
      @sysvar::PowerTrain::Gear=0;
      update_database();
      
      @sysvar::IL::Klemme15=0;
      @sysvar::ComfortBus::IG_15R=0;
      @sysvar::PowerTrain::EngineStatus=2;             // setting EngineStatus to "GoSleep"
      prev_engStatus=2;                                // needed in order to instantly update a variable, autosar database has a cyclic delay
      
      break;
    case 1: 
      sysSetVariableString(sysvar::IL::IgnitionSwitch_Status,"ON");
      @sysvar::IL::Klemme15=1;
      @sysvar::ComfortBus::IG_15R=1;
      if(prev_engStatus!=1){
        @sysvar::PowerTrain::EngineStatus=0;           // setting EngineStatus to "WakeUp", if previous EngineStatus wasn`t "Running"
        prev_engStatus=0;                              // needed in order to instantly update a variable, autosar database has a cyclic delay
      }
      break;
    case 2: 
      sysSetVariableString(sysvar::IL::IgnitionSwitch_Status,"START");
      @sysvar::IL::Klemme15=1;
      @sysvar::ComfortBus::IG_15R=0;
      setTimer(tIgSwitch,cIgSwitchTimer_Interval+500);     // setting a timer to simulate engine cranking process delay
      enableControl("MainPanel","Switch / Indicator 2",0);
      break;
  }
}

on timer tIgSwitch{
  if(@sysvar::IL::IgnitionSwitch==2){
    
    // simulating engine cranking, increasing EngSpeed to idle engine speed of 800rpm
    if(@sysvar::PowerTrain::EngSpeed<EngSpeed_idle_rpm){
      setTimer(tIgSwitch,cIgSwitchTimer_Interval);
      @sysvar::PowerTrain::EngSpeed=@sysvar::PowerTrain::EngSpeed+40;
    }
    else{
      @sysvar::PowerTrain::EngineStatus=1;               // setting EngineStatus to "Running"
      prev_engStatus=1;                                  // needed in order to instantly update a variable, AUTOSAR database has a cyclic delay
      @sysvar::IL::IgnitionSwitch=1;                     // letting ignition switch rotate back into position 2
      enableControl("MainPanel","Switch / Indicator 2",1);
    }
    
    $EngSpeedIEEE=@sysvar::PowerTrain::EngSpeed;
  }
}




// calculates engine RPM
void compute_vehicledynamics(){
  
  // total force off vehicle in forward direction
  // the usage of the stack keyword to create a non static local variable
  stack double vehiclelongitudinal_force=0;          //  [N]
  stack double airresistance_force=0;                //  [N]
  stack double braking_force=0;                      //  [N]
  stack double engbraking_force=0;                   //  [N]  
  stack double rollingresistance_force=0;            //  [N]
  stack double resulting_force=0;                    //  [N]
  stack double vehicle_acelleration=0;               //  [m/(s^2)]
  
  stack double speed_result=0;                       //  [m/s] 
  

  
  airresistance_force=calculate_airresistance();   // calculating air resistance
  engtorque=gettorque_value();                     //gets engine torque value depending on current rpm
  
  if (@sysvar::PowerTrain::ThrottlePosition>0)     //Acelleration, gas pedal pressed
  {
    vehiclelongitudinal_force=longitudinalforce_calc(engtorque);   //calculating longitudinal force caused by opening the throttle 
    @sysvar::PowerTrain::EngForce=vehiclelongitudinal_force;                           // reading the engine force value to the 
    @sysvar::PowerTrain::EngPower=EnginePowerCalc(engtorque);
  }
  else if (@sysvar::PowerTrain::BrakePressure>0 && @sysvar::PowerTrain::CarSpeed_m_per_s>0) //Braking, 
  {
    
    braking_force = brakingforce_calc();
    
    
    @sysvar::PowerTrain::ThrottlePosition = 0;   // making sure that there is no concurrent braking and accelerating
    @sysvar::CruiseControl::CC_Active = 0;       // braking deactivates cruise control
    @sysvar::PowerTrain::EngForce=0;
    @sysvar::PowerTrain::EngPower=0;
  }
  else if(@sysvar::PowerTrain::PedalPressure_Gas==0 && @sysvar::PowerTrain::PedalPressure_Brake==0 && @sysvar::PowerTrain::Gear > 0) // engine braking
  {
    // engine assumed to rise linearily until plateau_lowervalue and pleateau at higher rpm
    double engbrake_torque;        // [Nm]
    long engbrake_torque_max=100;  // [Nm]
    long plateau_lowervalue=4000;  // [1/min]
    
    
    if(@sysvar::PowerTrain::EngSpeed <= EngSpeed_idle_rpm)
    {
      engbrake_torque  =  engbrake_torque_max * ( @sysvar::PowerTrain::EngSpeed / plateau_lowervalue);
    }
    else if(@sysvar::PowerTrain::EngSpeed<=plateau_lowervalue)
    {
      engbrake_torque  =  engbrake_torque_max * ( @sysvar::PowerTrain::EngSpeed / plateau_lowervalue);
    }
    else if(@sysvar::PowerTrain::EngSpeed<plateau_lowervalue)
    {
      engbrake_torque  =  100; 
    }
    @sysvar::PowerTrain::EngForce=0;
    @sysvar::PowerTrain::EngPower=0;
  }
  

  rollingresistance_force = rollingresistance_calc();
    
  resulting_force = vehiclelongitudinal_force - airresistance_force - braking_force - engbraking_force - rollingresistance_force;
  $AccelerationForce = resulting_force;
  
  
  // acceleration is force devided by mass
  vehicle_acelleration = resulting_force / car_mass;
  @sysvar::PowerTrain::Vehicle_Acceleration=vehicle_acelleration;
  
  // the vehicle acelleration was now calculated for this moment, it will be calculated again the next time that mstTimestep timer is called
  // therefore the speed and rpm value that the car will have in 1ms will be calculated and set in order to bridge that time and simulate realistic car behaviour
  // nextspeed [m/s] = speed [m/s] + acceleration [m/(s^2)] * one ms intervall [s] 
  
  if(resulting_force>0 || @sysvar::PowerTrain::CarSpeed_m_per_s>0 ){
    speed_result = @sysvar::PowerTrain::CarSpeed_m_per_s + vehicle_acelleration * 0.001;
    
    if(speed_result>0.0){
      @sysvar::PowerTrain::CarSpeed_m_per_s = speed_result;
    }
    else{
      @sysvar::PowerTrain::CarSpeed_m_per_s = 0;
    }
    
    @sysvar::PowerTrain::CarSpeed_kmh = @sysvar::PowerTrain::CarSpeed_m_per_s * 3.6;
  }
  
}
    
double calculate_airresistance(){
  //                            
  // force caused by airresistance =   0.5  * air density   * car front cross section * drag coefficient * (car speed)^2
  // note: drag significantly increases with car speed 
  double airdensity =1.225;       //  [kg/(m^3)]
  double front_crossection=2.2;   //  [m^2]
  double dragcoefficient=0.285;   //  unitless
  double airresistance;           //  [N]
  
  airresistance= 0.5 * airdensity * front_crossection * dragcoefficient * (@sysvar::PowerTrain::CarSpeed_m_per_s*@sysvar::PowerTrain::CarSpeed_m_per_s);
  
  return airresistance;
}

double longitudinalforce_calc(double engine_torque){
  double vehiclelongitudinal_force;
  //                                 EngineTorque [Nm]  * gear ratio * differential ratio * drivetrain efficiency
  // force in forward direction [N] =   ------------------------------------------------------------------------------
  //                                                        effective wheel radius  [m]

  if(@sysvar::PowerTrain::Gear > 0 && @sysvar::PowerTrain::ThrottlePosition > 0 ){ 
    vehiclelongitudinal_force = (  engtorque  *    transmitionratio_overall[@sysvar::PowerTrain::Gear] *     drivetrain_efficiency       ) /  wheelradius_effective;
    vehiclelongitudinal_force = vehiclelongitudinal_force * ( @sysvar::PowerTrain::ThrottlePosition / 100.0 );
    
  }
  else{
    vehiclelongitudinal_force = 0; // when gear is in neutral, no force is forwarded by the drivetrain
  }

  return vehiclelongitudinal_force;
}

double brakingforce_calc(){
  //                                                                brake pressure [bar]
  // braking force = mass * maximum deceleration [m/(s^2)] * ------------------------------------
  //                                                            maximum brake pressure  [bar]
  
  long brakepressure_max=100;   // [bar]
  double deceleration_max=9.81; // [m/(s^2)]
  double braking_force=0;       // [N]
    
  if(@sysvar::PowerTrain::CarSpeed_m_per_s>0){
    braking_force = car_mass  *  deceleration_max  *  ( @sysvar::PowerTrain::BrakePressure /  brakepressure_max ); // [N]
  }
  else{
    braking_force=0;
  } 
  
  return braking_force;
}

double engbrakingforce_calc(double engbrake_torque){  
  // calculating force in forward direction
  //                                 EngineTorque [Nm]  * gear ratio * differential ratio * drivetrain efficiency
  // force in forward direction [N] =   ------------------------------------------------------------------------------
  //                                                        effective wheel radius  [m]
    
  double engbraking_force;
  
  engbraking_force = (  engbrake_torque  *    transmitionratio_overall[@sysvar::PowerTrain::Gear] *     drivetrain_efficiency       ) /  wheelradius_effective;

  return engbraking_force;
}

double rollingresistance_calc(){
  // rolling resistance allways applies, assumed to be approximately constant as it only increases slightly at high speeds
  //
  // rolling resistance force [N]  =  rolling resistance coefficient * vehicle mass * gravitational acceleration
  //
  
  double rollingresistance_force;
  
  if(@sysvar::PowerTrain::CarSpeed_m_per_s>0){
    rollingresistance_force  =  rollingresistance_coefficient * car_mass * gravitational_acceleration; 
  }
  else{
    rollingresistance_force  =  0;
  }
  
  return rollingresistance_force;
}

double gettorque_value(){
  // the following engine torque/rpm specs are a very rough approximation and w
  // the Assumption is that torque rises linearily until it plateaus from rpm_plateau_lowerbarrier to rpm_plateau_upperbarrier
  // then torque decreases linearily again
  // values are inspired by a Volkswagen 1.5l four cylinder tsi engine with about 110kW
  double engtorque;
  double maxtorque=250;                  // [Nm]
  double rpm_plateau_lowerbarrier=1500;  // [1/min] 
  double rpm_plateau_upperbarrier=3500;  // [1/min]
  
  if(downshift_active != 1 || upshift_active != 1 ){
    if(@sysvar::PowerTrain::EngSpeed<rpm_plateau_lowerbarrier){
      engtorque  =    maxtorque   *   (         @sysvar::PowerTrain::EngSpeed  /  rpm_plateau_lowerbarrier  );
    }
    else if (@sysvar::PowerTrain::EngSpeed>rpm_plateau_upperbarrier){
      engtorque  =     maxtorque * ( ( -1.0 / 6250.0 ) * (@sysvar::PowerTrain::EngSpeed - 3500.0) + 1.0 );
    }
    else{
      engtorque  =    maxtorque;
    }
  }
  else{
    if(@sysvar::PowerTrain::EngSpeed<rpm_plateau_lowerbarrier){
      engtorque  =  0.7 *   maxtorque   *   (         @sysvar::PowerTrain::EngSpeed  /  rpm_plateau_lowerbarrier  );
    }
    else if (@sysvar::PowerTrain::EngSpeed>rpm_plateau_upperbarrier){
      engtorque  =  0.7 *   maxtorque * ( ( -1.0 / 6250.0 ) * (@sysvar::PowerTrain::EngSpeed - 3500.0) + 1.0 );
    }
    else{
      engtorque  =    maxtorque;
    }
  }
  
  // assuming quadratic dependency of torque on throttle position
  engtorque  =  engtorque  *  ( (@sysvar::PowerTrain::ThrottlePosition/100.0) * (@sysvar::PowerTrain::ThrottlePosition/100.0) ); 

  return engtorque;
  }


long compute_enginespeed(int gear){
  // assuming there is no tire slip
  //                           car speed [km/h] * gear ratio * differential ratio * 60
  // engine speed [1/min] = ----------------------------------------------------------------
  //                                        wheel circumference [m]
  
  double wheel_circumference ;
  stack long engspeed=0;
  wheel_circumference = 2 * wheelradius_effective * pi;
  
  if(@sysvar::PowerTrain::Gear>0 && @sysvar::PowerTrain::CarSpeed_m_per_s>2 ){
    engspeed = ( @sysvar::PowerTrain::CarSpeed_m_per_s * transmitionratio_overall[gear]  * 60 ) / 
                                          ( wheel_circumference );
  }
  else if (@sysvar::PowerTrain::Gear>0 && @sysvar::PowerTrain::CarSpeed_m_per_s<=2 ) {
    engspeed = 0.8 * EngSpeed_idle_rpm + 0.2 * EngSpeed_idle_rpm * (@sysvar::PowerTrain::CarSpeed_m_per_s/2);
  }

  
  if(upshift_active!=1 && downshift_active!=1){
    if(@sysvar::PowerTrain::Gear>0 && @sysvar::PowerTrain::CarSpeed_m_per_s>2 ){
      @sysvar::PowerTrain::EngSpeed = engspeed;
    }
    else if (@sysvar::PowerTrain::Gear==0 && @sysvar::PowerTrain::EngineStatus==1) {
      @sysvar::PowerTrain::EngSpeed = EngSpeed_idle_rpm;
    }
    else if (@sysvar::PowerTrain::Gear>0 && @sysvar::PowerTrain::CarSpeed_m_per_s<=2 ){
      @sysvar::PowerTrain::EngSpeed = engspeed;
    }
  }
  // if upshift or downshift are active, engine speed calculation will be handled by the AutomaticGearShifting() function

  
  
  return engspeed;
} 


// calculate the throttle position for cruise control
double CCThrottleCalc() 
{ 
  double P = 50;
  double I = 10000;
  double cc_integral;
  double dt=0.001;
  

  TargetSpeed = @sysvar::CruiseControl::CCTargetSpeed ;  // or just use CCTargetSpeed
  SpeedDiff = TargetSpeed - @sysvar::PowerTrain::CarSpeed_kmh;

  cc_integral += SpeedDiff * dt; // true integral

  SollPedal = P * SpeedDiff + I * cc_integral + (SpeedDiff - SpeedDiff_last);

  if (SollPedal > 100) {
    SollPedal = 100;
    cc_integral *= 0.9; 
  }
  else if (SollPedal < 0) {
    SollPedal = 0;
    cc_integral *= 0.9;
  }
  
  if(SollPedal>70){
    SollPedal=80;
  }

  SpeedDiff_last = SpeedDiff;
  return SollPedal;
  
}



void EngineTempCalc()
{
  if ($EngTemp >= 80 && $EngTemp <= 127){
    if ($EngTemp <= 126 && @sysvar::PowerTrain::ThrottlePosition > 50) 
    {
      $EngTemp = $EngTemp + 1;
    }
    else if ($EngTemp >= 81 && @sysvar::PowerTrain::ThrottlePosition < 50) 
    {
      $EngTemp = $EngTemp - 1;
    }
  }
}


void PetrolLevelCalc() 
{ 
  // fuel consumption is mostly dependant on engine power and engine efficiency
  //                    engine power [kW] * specific fuel consumption [g/kWh]
  // fuel flow [g/s] = --------------------------------------------------------
  //                                           3600 [s/h]
  
  long specific_fuelconsumption = 250;    // [g/kWh]
  double fuel_flow_weight;                // [g/s]     
  double fuel_flow_volume;                // [L/s] 
  double fuel_density=0.745;              // [kg/L]
  
  fuel_flow_weight = ( $EngPower  *  specific_fuelconsumption )  /  3600.0;
  fuel_flow_volume = fuel_flow_weight / ( 1000.0 * fuel_density);
  
  if(@sysvar::PowerTrain::CarSpeed_kmh>0){
    @sysvar::PowerTrain::fuelconsumption_momentary = ( fuel_flow_volume * 3600.0 * 100.0 ) / @sysvar::PowerTrain::CarSpeed_kmh;
  }
  else{
    // when throttle no throttle is applied, fuel consumption will be assumed to be zero for simplification
    @sysvar::PowerTrain::fuelconsumption_momentary = 0;
  }
  
  
  fuel_consumption_total = fuel_consumption_total + fuel_flow_volume * 0.001;
  
  if(distance_travelled!=0){
    @sysvar::PowerTrain::fuelconsumption_average = (fuel_consumption_total / distance_travelled ) * 100  ;
  }
  else{
    @sysvar::PowerTrain::fuelconsumption_average=0;
  }
  
  $EngineData::PetrolLevel = petrollevel_initial - fuel_consumption_total;
}




double EnginePowerCalc (double engine_torque)
{
  double engine_power;      // [kW]
  double angular_velocity;  // [1/s]
  
  //  calculating engine power from engine torque
  //                          engine torque [Nm]  *  angular velocity [1/s]
  //  engine power [kW]  =  -------------------------------------------------
  //                                             1000
  
  angular_velocity = ( 2.0 * pi * @sysvar::PowerTrain::EngSpeed ) / 60.0;
  
  engine_power = ( engine_torque * angular_velocity ) / 1000.0;
  
  
  return engine_power;
}

void AutomaticGearShifting()
{ 
  // new engine speed after shift is: =oldenginespeed*(newgearratio/oldgearratio)
  
  // Upshift gear 1 to gear 6
  if (upshift_active!=1 && downshift_active!=1){
    
    if (@sysvar::PowerTrain::Gear < 6 &&  @sysvar::PowerTrain::Gear>0 &&  @sysvar::PowerTrain::EngSpeed > upshiftRpm[@sysvar::PowerTrain::Gear] && @sysvar::PowerTrain::ThrottlePosition != 0) {
      setTimer(tupshift_active,upshift_active_Interval);
      upshift_active=1;
    }
    
    // Upshift from neutral
    else if (@sysvar::PowerTrain::Gear== 0 && @sysvar::PowerTrain::ThrottlePosition > 20)
    {
      @sysvar::PowerTrain::Gear += 1;
      @sysvar::PowerTrain::EngSpeed=@sysvar::PowerTrain::EngSpeed*0.8;
    }
    
    // Downshift between gear 6 and gear 1
    else if (@sysvar::PowerTrain::Gear > 1 && @sysvar::PowerTrain::EngSpeed < downshiftRpm[@sysvar::PowerTrain::Gear] && @sysvar::PowerTrain::ThrottlePosition == 0) {
      setTimer(tdownshift_active,downshift_active_Interval);
      downshift_active=1;
    }
    
    //Downshift to neutral
    else if (@sysvar::PowerTrain::Gear == 1 && @sysvar::PowerTrain::EngSpeed < downshiftRpm[@sysvar::PowerTrain::Gear] && @sysvar::PowerTrain::ThrottlePosition <20 ){
      @sysvar::PowerTrain::Gear -= 1;  
      
    }
  }
  
  // handling upshift behaviour during shifting
  else if(upshift_active==1){
    
    // approximating DCT behaviour with linear rpm decrease during shifting
    if (upshift_completed!=1){
      stack int upshift_rpmdelta=0;
      upshift_timecounter=upshift_timecounter+1;
      upshift_rpmdelta  =  @sysvar::PowerTrain::EngSpeed - @sysvar::PowerTrain::EngSpeed * (gear_ratio[@sysvar::PowerTrain::Gear +1] / gear_ratio[@sysvar::PowerTrain::Gear ]);
      @sysvar::PowerTrain::EngSpeed =   @sysvar::PowerTrain::EngSpeed  -  (1.0 / upshift_active_Interval ) * upshift_rpmdelta;
    }
    
    else{
      upshift_timecounter=0;
      
      @sysvar::PowerTrain::Gear += 1;
      upshift_completed=0;
      upshift_active=0;
    }
  }
  
  // handling downshift behaviour during shifting
  else if (downshift_active==1){
    
    // approximating double clutch transmission behaviour with linear rpm increase during shifting
    if (downshift_completed!=1){
      stack int downshift_rpmdelta=0;
      stack long theoretical_engspeed;
      downshift_timecounter=downshift_timecounter+1;
      downshift_rpmdelta  = - @sysvar::PowerTrain::EngSpeed + @sysvar::PowerTrain::EngSpeed * (gear_ratio[@sysvar::PowerTrain::Gear-1] / gear_ratio[@sysvar::PowerTrain::Gear ]);
      
      // adjusting engine speed during downshift so that it also is realistic when the car is braking
      theoretical_engspeed=compute_enginespeed(@sysvar::PowerTrain::Gear-1);
      if(@sysvar::PowerTrain::EngSpeed<theoretical_engspeed){
        @sysvar::PowerTrain::EngSpeed =   @sysvar::PowerTrain::EngSpeed  +  (1.0 / downshift_active_Interval ) * downshift_rpmdelta ; //( upshift_timecounter / upshift_active_Interval );
      }
      else{
        @sysvar::PowerTrain::EngSpeed=theoretical_engspeed;
      }
    }
    else{
      @sysvar::PowerTrain::Gear -= 1;
      downshift_timecounter=0;
      
      downshift_completed=0;
      downshift_active=0;
    }
  }
}

on timer tupshift_active{
  upshift_completed=1;
}

on timer tdownshift_active{
  downshift_completed=1;
}

