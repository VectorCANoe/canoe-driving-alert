// Use diagnostic class to save some lines of code
on diagRequest %BASE_FILE_NAME_NO_EXT%.Periodic_Data::*
{
  diagResponse this resp;
  long DID;
  long TransmissionMode;
  long size;
  
  refreshS3Timer();

  size=diagGetPrimitiveSize(this);
  if (size<=1) {
    diagSendNegativeResponse(resp, cNRC_IncorrectMessageLengthOrInvalidFormat);
    return;
  }
  TransmissionMode=diagGetParameter(this, "TransmissionMode");
  if (size==2) { // Sawtooth_Stop_all or SineWave_Stop_all or Dynamically_Define_Periodic_Data_Stop, containing no DID information
    if (TransmissionMode==Off) {
      gSineSendMode=Off;
      gSawtoothSendMode=Off; 
      gDDDIDSendMode=Off;

      @sysvar::Tester::BtnInternalsCyclicRead=0;
      
      diagSendPositiveResponse(resp);
    }
    else {
      ResetSessionAndSendNegativeResponse( resp, cNRC_RequestOutOfRange);
    };
    return;
  }
  
  DID=diagGetParameter(this, "PeriodicDataIdentifier");
  writeDbgLvlPrefix( 3, "DID=%d", DID);
  
  switch (TransmissionMode) {
    case Once:
      switch (DID) {
        case 0x00: // SineWave
          diagSetParameter(resp, cParamAccessPhysical, "SineValue", @sysvarMember::%BASE_FILE_NAME_NO_EXT%::InternalData.SineWave);
          gSineSendMode=Off;
          @sysvar::Tester::BtnInternalsCyclicRead=0;
          break;
        case 0x01: // Sawtooth
          diagSetParameter(resp, cParamAccessPhysical, "SawtoothValue", @sysvarMember::%BASE_FILE_NAME_NO_EXT%::InternalData.Sawtooth);
          gSawtoothSendMode=Off;  
          @sysvar::Tester::BtnInternalsCyclicRead=0;
          break;
        default:
          ResetSessionAndSendNegativeResponse( resp, cNRC_RequestOutOfRange);
          return;
      }
      break;
      
    case Fast:
    case Medium:
    case Slow:
      switch (DID) {
        case 0x00: // SineWave
          gSineSendMode=(enum eDIDSendMode)TransmissionMode;
          break;
        case 0x01: // Sawtooth
          gSawtoothSendMode=(enum eDIDSendMode)TransmissionMode;
          break;
        default:
          ResetSessionAndSendNegativeResponse( resp, cNRC_RequestOutOfRange);
          return;
      }
      diagResize(resp,1);
      DiagSetPrimitiveByte(resp,0,0x6A);
      break;
    case Off:
      switch (DID) {
        case 0x00: // SineWave
          gSineSendMode=Off;
          @sysvar::Tester::BtnInternalsCyclicRead=0;
          break;
        case 0x01: // Sawtooth
          gSawtoothSendMode=Off;  
          @sysvar::Tester::BtnInternalsCyclicRead=0;
          break;
        default:
          ResetSessionAndSendNegativeResponse( resp, cNRC_RequestOutOfRange);
          return;
      }
      break;
    default:
      ResetSessionAndSendNegativeResponse( resp, cNRC_RequestOutOfRange);
      return;
  }
  diagSendPositiveResponse(resp);
}

on diagRequest %BASE_FILE_NAME_NO_EXT%.Dynamically_Define_Periodic_Data_Define_By_Identifier
{
  diagResponse this resp;
  long sizeOfPrimitive;
  word NumberOfDIDsInPDU;
  word maxDataLength;
  word k;
  word DID;
  word DIDPosition;
  word DIDSizeRequested;
  int DIDSize;

  save_DDDID_Definition();
  maxDataLength=gCANFDavailable?63:7;
  
  refreshS3Timer();

  sizeOfPrimitive=diagGetPrimitiveSize(this);
  if (((sizeOfPrimitive-4)%4)>0) {
    ResetSessionAndSendNegativeResponse( resp, cNRC_RequestOutOfRange);
    return;
  }
  else {
    NumberOfDIDsInPDU=(sizeOfPrimitive-4)/4;
    if (NumberOfDIDsInPDU+gNumberOfDDDIDs>cMaxNumberOfDDDIDs) {
      ResetSessionAndSendNegativeResponse( resp, cNRC_RequestOutOfRange);
      return;
    }
    else {
      for (k=0; k<NumberOfDIDsInPDU; k++) {
        DID=diagGetComplexParameter(this, "ListOfParameter", k, "SourceDID");
        DIDPosition=diagGetComplexParameter(this, "ListOfParameter", k, "PositionInSourceDID");
        DIDSizeRequested=diagGetComplexParameter(this, "ListOfParameter", k, "MemorySize");
        DIDSize=sizeOfDID(DID);
        if (1!=DIDPosition || DIDSize<0 || DIDSizeRequested!=DIDSize) {
          ResetSessionAndSendNegativeResponse( resp, cNRC_RequestOutOfRange);
          restore_DDDID_Definition();
          return;
        }
        else {
          if (gSizeOfDDDID+DIDSize>maxDataLength) { // Length of DDDID too long
            ResetSessionAndSendNegativeResponse( resp, cNRC_RequestOutOfRange); 
            restore_DDDID_Definition();
            return;
          }
          else {
            if (DID_AlreadyDynamicallyDefined(DID)) {
              ResetSessionAndSendNegativeResponse( resp, cNRC_RequestOutOfRange);
              restore_DDDID_Definition();
              return;
            }
            else {
              char tempStr[50];
              gDDDID[gNumberOfDDDIDs++]=DID;
              gSizeOfDDDID+=DIDSize;
              snprintf(tempStr, elcount(tempStr), "DIDSize=%d, gSizeOfDDDID=%d, maxDataLength=%d",DIDSize, gSizeOfDDDID, maxDataLength);
              writeDbgLvlPrefix( 3, tempStr);
            }
          }
        }
      }
      diagSendPositiveResponse(resp);
    }
  }
}

save_DDDID_Definition()
{
  previousSizeOfDDDID=gSizeOfDDDID;
  previousNumberOfDDDIDs=gNumberOfDDDIDs;
}

restore_DDDID_Definition()
{
  gSizeOfDDDID=previousSizeOfDDDID;
  gNumberOfDDDIDs=previousNumberOfDDDIDs;
}

word DID_AlreadyDynamicallyDefined(word DID)
{
  word k;
  
  for (k=0; k<gNumberOfDDDIDs; k++) {
    if (gDDDID[k]==DID) {
      return 1;
    }
  }
  return 0;
}

on diagRequest %BASE_FILE_NAME_NO_EXT%.Dynamically_Define_Periodic_Data_Read
{
  diagResponse this resp;
  byte buffer[100];
  dword count;  
  
  refreshS3Timer();

  if (0xF0 != diagGetParameter(this, "Identifier")) {
    ResetSessionAndSendNegativeResponse( resp, cNRC_RequestOutOfRange);
  }
  else {
    buffer[0]=0x62;
    buffer[1]=0xF2;
    buffer[2]=0xF0;
    count=PrepareDIDParameters(buffer, 3, gDDDID, gNumberOfDDDIDs, FALSE);
    diagResize(resp, count);
    diagSetPrimitiveData(resp, buffer, count);
    diagSendPositiveResponse(resp);
  }
}

on diagRequest %BASE_FILE_NAME_NO_EXT%.Dynamically_Define_Periodic_Data_Clear
{
  diagResponse this resp;
  
  refreshS3Timer();

  if (0xF0 != diagGetParameter(this, "DynamicallyDefinedIdentifier")) {
    ResetSessionAndSendNegativeResponse( resp, cNRC_RequestOutOfRange);
  }
  else {
    gDDDIDSendMode=Off;
    InitDDDIDs();
    diagSendPositiveResponse(resp);
  }
}

on diagRequest %BASE_FILE_NAME_NO_EXT%.Dynamically_Define_Periodic_Data_ClearAll
{
  diagResponse this resp;
  
  refreshS3Timer();

  gDDDIDSendMode=Off;
  InitDDDIDs();
  diagSendPositiveResponse(resp);
}

on diagRequest %BASE_FILE_NAME_NO_EXT%.Dynamically_Define_Periodic_Data::*
{
  diagResponse this resp;
  long TransmissionMode;
  
  if (PreventAccessInsideDefaultSession(this, cNRC_RequestOutOfRange)) return;

  refreshS3Timer();

  TransmissionMode=diagGetParameter(this, "TransmissionMode");

  switch (TransmissionMode) {
    case Fast:
    case Medium:
    case Slow:
      gDDDIDSendMode=(enum eDIDSendMode)TransmissionMode;
      diagResize(resp,1);
      DiagSetPrimitiveByte(resp,0,0x6A);
      break;
    case Off:
      gDDDIDSendMode=Off;
      diagResize(resp,1);
      DiagSetPrimitiveByte(resp,0,0x6A);
      break;
    default:
      ResetSessionAndSendNegativeResponse( resp, cNRC_RequestOutOfRange);
      return;
  }
  diagSendPositiveResponse(resp);
}

setDoorStatusValuesAndSendResponse(diagResponse * resp)
{
  if (@sysvar::%BASE_FILE_NAME_NO_EXT%::DoorContactStatusOverwritten & 0x01) {
    diagSetParameter(resp, "Door_contact_front_left", @sysvarMember::%BASE_FILE_NAME_NO_EXT%::OverwrittenDoorContacts.FrontLeft);
  }
  else {
    diagSetParameter(resp, "Door_contact_front_left", @sysvarMember::ExternalSignals::OpenDoorContacts.FrontLeft);
  }

  if (@sysvar::%BASE_FILE_NAME_NO_EXT%::DoorContactStatusOverwritten & 0x02) {
    diagSetParameter(resp, "Door_contact_front_right", @sysvarMember::%BASE_FILE_NAME_NO_EXT%::OverwrittenDoorContacts.FrontRight);
  }
  else {
    diagSetParameter(resp, "Door_contact_front_right", @sysvarMember::ExternalSignals::OpenDoorContacts.FrontRight);
  }
  
  if (@sysvar::%BASE_FILE_NAME_NO_EXT%::DoorContactStatusOverwritten & 0x04) {
    diagSetParameter(resp, "Door_contact_rear_left", @sysvarMember::%BASE_FILE_NAME_NO_EXT%::OverwrittenDoorContacts.RearLeft);
  }
  else {
    diagSetParameter(resp, "Door_contact_rear_left", @sysvarMember::ExternalSignals::OpenDoorContacts.RearLeft);
  }

  if (@sysvar::%BASE_FILE_NAME_NO_EXT%::DoorContactStatusOverwritten & 0x08) {
    diagSetParameter(resp, "Door_contact_rear_right", @sysvarMember::%BASE_FILE_NAME_NO_EXT%::OverwrittenDoorContacts.RearRight);
  }
  else {
    diagSetParameter(resp, "Door_contact_rear_right", @sysvarMember::ExternalSignals::OpenDoorContacts.RearRight);
  }
  
  diagSendPositiveResponse(resp);    
}

on diagRequest %BASE_FILE_NAME_NO_EXT%.Door_Status_Read
{
  diagResponse this resp;
  
  refreshS3Timer();
  
  setDoorStatusValuesAndSendResponse(resp);  
}

on diagRequest %BASE_FILE_NAME_NO_EXT%.Door_Status_Control
{
  diagResponse this resp;
  long ret;
  
  refreshS3Timer();
  
  @sysvar::%BASE_FILE_NAME_NO_EXT%::DoorContactStatusOverwritten|=(word)diagGetParameter(this, "CEMR_Byte_0");

  if (diagGetParameter(this, "CEMR_Byte_0.EM_Door_contact_front_left")) {
    ret=diagGetParameter(this, "Door_contact_front_left");
    @sysvarMember::%BASE_FILE_NAME_NO_EXT%::OverwrittenDoorContacts.FrontLeft=ret;
  }

  if (diagGetParameter(this, "CEMR_Byte_0.EM_Door_contact_front_right")) {
    ret=diagGetParameter(this, "Door_contact_front_right");
    @sysvarMember::%BASE_FILE_NAME_NO_EXT%::OverwrittenDoorContacts.FrontRight=ret;
  }
  
  if (diagGetParameter(this, "CEMR_Byte_0.EM_Door_contact_rear_left")) {
    ret=diagGetParameter(this, "Door_contact_rear_left");
    @sysvarMember::%BASE_FILE_NAME_NO_EXT%::OverwrittenDoorContacts.RearLeft=ret;
  }

  if (diagGetParameter(this, "CEMR_Byte_0.EM_Door_contact_rear_right")) {
    ret=diagGetParameter(this, "Door_contact_rear_right");
    @sysvarMember::%BASE_FILE_NAME_NO_EXT%::OverwrittenDoorContacts.RearRight=ret;
  }
  
  setDoorStatusValuesAndSendResponse(resp);  
}

on diagRequest %BASE_FILE_NAME_NO_EXT%.Door_Status_ReturnControl
{
  diagResponse this resp;

  refreshS3Timer();

  @sysvar::%BASE_FILE_NAME_NO_EXT%::DoorContactStatusOverwritten&=((~((word)diagGetParameter(this, "CEMR_Byte_0"))) & 0xFF);

  setDoorStatusValuesAndSendResponse(resp);  
}

on diagRequest %BASE_FILE_NAME_NO_EXT%.Door_Status_Freeze
{
  diagResponse this resp;

  refreshS3Timer();

  if (diagGetParameter(this, "CEMR_Byte_0.EM_Door_contact_front_left") && !(@sysvar::%BASE_FILE_NAME_NO_EXT%::DoorContactStatusOverwritten & 0x01)) {  // Only freeze if not already overwritten
    @sysvarMember::%BASE_FILE_NAME_NO_EXT%::OverwrittenDoorContacts.FrontLeft=@sysvarMember::ExternalSignals::OpenDoorContacts.FrontLeft;
  }

  if (diagGetParameter(this, "CEMR_Byte_0.EM_Door_contact_front_right") && !(@sysvar::%BASE_FILE_NAME_NO_EXT%::DoorContactStatusOverwritten & 0x02)) {
    @sysvarMember::%BASE_FILE_NAME_NO_EXT%::OverwrittenDoorContacts.FrontRight=@sysvarMember::ExternalSignals::OpenDoorContacts.FrontRight;
  }
  
  if (diagGetParameter(this, "CEMR_Byte_0.EM_Door_contact_rear_left") && !(@sysvar::%BASE_FILE_NAME_NO_EXT%::DoorContactStatusOverwritten & 0x04)) {
    @sysvarMember::%BASE_FILE_NAME_NO_EXT%::OverwrittenDoorContacts.RearLeft=@sysvarMember::ExternalSignals::OpenDoorContacts.RearLeft;
  }

  if (diagGetParameter(this, "CEMR_Byte_0.EM_Door_contact_rear_right") && !(@sysvar::%BASE_FILE_NAME_NO_EXT%::DoorContactStatusOverwritten & 0x08)) {
    @sysvarMember::%BASE_FILE_NAME_NO_EXT%::OverwrittenDoorContacts.RearRight=@sysvarMember::ExternalSignals::OpenDoorContacts.RearRight;
  }
  
  @sysvar::%BASE_FILE_NAME_NO_EXT%::DoorContactStatusOverwritten|=(word)diagGetParameter(this, "CEMR_Byte_0");
  setDoorStatusValuesAndSendResponse(resp);  
}

on diagRequest %BASE_FILE_NAME_NO_EXT%.Door_Status_Reset
{
  diagResponse this resp;

  refreshS3Timer();
  
  @sysvar::%BASE_FILE_NAME_NO_EXT%::DoorContactStatusOverwritten&=((~((word)diagGetParameter(this, "CEMR_Byte_0"))) & 0xFF);

  if (diagGetParameter(this, "CEMR_Byte_0.EM_Door_contact_front_left")) {
    diagSetParameter(resp, "Door_contact_front_left", @sysvarMember::ExternalSignals::OpenDoorContacts.FrontLeft);
    @sysvarMember::%BASE_FILE_NAME_NO_EXT%::OverwrittenDoorContacts.FrontLeft=@sysvarMember::ExternalSignals::OpenDoorContacts.FrontLeft;
  }

  if (diagGetParameter(this, "CEMR_Byte_0.EM_Door_contact_front_right")) {
    diagSetParameter(resp, "Door_contact_front_right", @sysvarMember::ExternalSignals::OpenDoorContacts.FrontRight );
    @sysvarMember::%BASE_FILE_NAME_NO_EXT%::OverwrittenDoorContacts.FrontRight=@sysvarMember::ExternalSignals::OpenDoorContacts.FrontRight;
  }
  
  if (diagGetParameter(this, "CEMR_Byte_0.EM_Door_contact_rear_left")) {
    diagSetParameter(resp, "Door_contact_rear_left", @sysvarMember::ExternalSignals::OpenDoorContacts.RearLeft);
    @sysvarMember::%BASE_FILE_NAME_NO_EXT%::OverwrittenDoorContacts.RearLeft=@sysvarMember::ExternalSignals::OpenDoorContacts.RearLeft;
  }

  if (diagGetParameter(this, "CEMR_Byte_0.EM_Door_contact_rear_right")) {
    diagSetParameter(resp, "Door_contact_rear_right", @sysvarMember::ExternalSignals::OpenDoorContacts.RearRight);
    @sysvarMember::%BASE_FILE_NAME_NO_EXT%::OverwrittenDoorContacts.RearRight=@sysvarMember::ExternalSignals::OpenDoorContacts.RearRight;
  }

  setDoorStatusValuesAndSendResponse(resp);  
}

// Dummy positive responses to satisfy flash tool requirements, use diagnostic class to save some lines of code
on diagRequest %BASE_FILE_NAME_NO_EXT%.Communication_Control::*
{
  diagResponse this resp;  

  refreshS3Timer();
  diagSendPositiveResponse( resp);
}

// Handle both Hard and soft reset within one function (i.e. handle all services within one class)
on diagRequest %BASE_FILE_NAME_NO_EXT%.Reset::*
{
  diagResponse this resp;
  byte subFunction;

  subFunction=diagGetPrimitiveByte(this, 1);
  
  refreshS3Timer();
  
  if (subFunction==0x01) { // simulate HW Reset taking longer than SW reset
    sendNegativeResponse(this, cNRC_RequestCorrectlyReceivedResponsePending);
    setTimer(tDelayedResponse, cHardResetDuration_ms); // positive response needs to be sent within P2ext after RP
  }
  else {
    diagSetPrimitiveByte(resp, 1, subFunction);
    diagSendPositiveResponse(resp);
  }
  InitECU();
}