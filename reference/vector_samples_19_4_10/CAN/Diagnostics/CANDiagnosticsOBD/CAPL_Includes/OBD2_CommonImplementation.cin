on diagRequest %BASE_FILE_NAME_NO_EXT%._PID_41_Enable_status_of_supported_monitors_this_monitoring_cycl_REQUEST_CURR_PWRTRAIN_DATA
{
  diagResponse this resp;
  byte bSuppContTests, bSuppTestRunMinOnce, bSuppTestStatus;
  
  refreshS3Timer();
  
  bSuppContTests=@ECM_OBD2_CAN::SupportedMonitors.Misfire |
  ((@ECM_OBD2_CAN::SupportedMonitors.FuelSystem) << 1) |
  ((@ECM_OBD2_CAN::SupportedMonitors.ComprehensiveComponent) << 2) |
  ((@ECM_OBD2_CAN::IncompleteMonitors.Misfire) << 4) |
  ((@ECM_OBD2_CAN::IncompleteMonitors.FuelSystem) << 5) |
  ((@ECM_OBD2_CAN::IncompleteMonitors.ComprehensiveComponent) << 6);
  
  bSuppTestRunMinOnce=@ECM_OBD2_CAN::SupportedMonitors.Catalyst  |
  ((@ECM_OBD2_CAN::SupportedMonitors.HeatedCatalyst) << 1) |
  ((@ECM_OBD2_CAN::SupportedMonitors.EvaporativeSystem) << 2) |
  ((@ECM_OBD2_CAN::SupportedMonitors.SecondaryAir) << 3) |
  ((@ECM_OBD2_CAN::SupportedMonitors.A_C_SystemRefrigerant) << 4) |
  ((@ECM_OBD2_CAN::SupportedMonitors.OxygenSensor) << 5) |
  ((@ECM_OBD2_CAN::SupportedMonitors.OxygenSensorHeater) << 6) |
  ((@ECM_OBD2_CAN::SupportedMonitors.EgrSystem) << 7);

  bSuppTestStatus=@ECM_OBD2_CAN::IncompleteMonitors.Catalyst  |
  ((@ECM_OBD2_CAN::IncompleteMonitors.HeatedCatalyst) << 1) |
  ((@ECM_OBD2_CAN::IncompleteMonitors.EvaporativeSystem) << 2) |
  ((@ECM_OBD2_CAN::IncompleteMonitors.SecondaryAir) << 3) |
  ((@ECM_OBD2_CAN::IncompleteMonitors.A_C_SystemRefrigerant) << 4) |
  ((@ECM_OBD2_CAN::IncompleteMonitors.OxygenSensor) << 5) |
  ((@ECM_OBD2_CAN::IncompleteMonitors.OxygenSensorHeater) << 6) |
  ((@ECM_OBD2_CAN::IncompleteMonitors.EgrSystem) << 7);
  
  resp.SetParameter("SuppContTests", bSuppContTests); 
  resp.SetParameter("SuppTestRunMinOnce", bSuppTestRunMinOnce); 
  resp.SetParameter("SuppTestStatus", bSuppTestStatus); 
  resp.SendResponse();
}  

