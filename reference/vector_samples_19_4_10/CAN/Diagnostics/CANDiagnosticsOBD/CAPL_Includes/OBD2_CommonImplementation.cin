on diagRequest %BASE_FILE_NAME_NO_EXT%._InfoType_02_Vehicle_Identification_Number_Read_InfoType_Data
{
  diagResponse this resp;
  char VIN_String[18];
  byte VIN[17];
  
  refreshS3Timer();
  sysGetVariableString(sysvar::Vehicle::VIN, VIN_String, elcount(VIN_String));
  memcpy(VIN,VIN_String, elcount(VIN));
  resp.SetComplexParameterRaw("List_of_InfoType_Data", 0, "Data.Vehicle_Identification_Number", VIN, elcount(VIN));

  if (strncmp("%BASE_FILE_NAME_NO_EXT%", "ECM_OBD2_CAN", 8)) {
    resp.SendResponse();
  }
}

