    resp.SetComplexParameter("OBDMIDIteration", 1, "Min_Test_Limit", 0xF5BF);
    resp.SetComplexParameter("OBDMIDIteration", 1, "Max_Test_Limit", 0x7FFF);
    resp.SetComplexParameter("OBDMIDIteration", 2, "OBDMID", 0x08);
    resp.SetComplexParameter("OBDMIDIteration", 2, "Standard_Manufacturer_Defined_TID", 0x8A);
    resp.SetComplexParameter("OBDMIDIteration", 2, "Unit_And_Scaling_ID", 0x85);
    resp.SetComplexParameter("OBDMIDIteration", 2, "TestValueMultiplexer", 0x0012);
    resp.SetComplexParameter("OBDMIDIteration", 2, "Min_Test_Limit", 0x8000);
    resp.SetComplexParameter("OBDMIDIteration", 2, "Max_Test_Limit", 0x0A3F);
    resp.SetComplexParameter("OBDMIDIteration", 3, "OBDMID", 0x08);
    resp.SetComplexParameter("OBDMIDIteration", 3, "Standard_Manufacturer_Defined_TID", 0x85);
    resp.SetComplexParameter("OBDMIDIteration", 3, "Unit_And_Scaling_ID", 0x33);
    resp.SetComplexParameter("OBDMIDIteration", 3, "TestValueMultiplexer", 0x103E);
    resp.SetComplexParameter("OBDMIDIteration", 3, "Min_Test_Limit", 0x0000);
    resp.SetComplexParameter("OBDMIDIteration", 3, "Max_Test_Limit", 0x3800);
    resp.SetComplexParameter("OBDMIDIteration", 4, "OBDMID", 0x08);
