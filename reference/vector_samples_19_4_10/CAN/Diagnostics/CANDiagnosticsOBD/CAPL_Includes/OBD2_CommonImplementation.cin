/*@!Encoding:1252*/
variables
{
  char VIN[18]="VECT0RVEH1CLE0001";
}


on sysvar sysvarMember::%BASE_FILE_NAME_NO_EXT%::FaultMemoryGui.BtnStoreDTC
{
  byte status, severity;
  
  if (@this) { // only when button was pressed (not when released)
    status =   (@sysvarMember::%BASE_FILE_NAME_NO_EXT%::FaultMemoryGui.StatusByte[7] << 7)
             | (@sysvarMember::%BASE_FILE_NAME_NO_EXT%::FaultMemoryGui.StatusByte[6] << 6)
             | (@sysvarMember::%BASE_FILE_NAME_NO_EXT%::FaultMemoryGui.StatusByte[5] << 5)
             | (@sysvarMember::%BASE_FILE_NAME_NO_EXT%::FaultMemoryGui.StatusByte[4] << 4)
             | (@sysvarMember::%BASE_FILE_NAME_NO_EXT%::FaultMemoryGui.StatusByte[3] << 3)
             | (@sysvarMember::%BASE_FILE_NAME_NO_EXT%::FaultMemoryGui.StatusByte[2] << 2)
             | (@sysvarMember::%BASE_FILE_NAME_NO_EXT%::FaultMemoryGui.StatusByte[1] << 1)
             |  @sysvarMember::%BASE_FILE_NAME_NO_EXT%::FaultMemoryGui.StatusByte[0];
    
    severity = (@sysvarMember::%BASE_FILE_NAME_NO_EXT%::FaultMemoryGui.SeverityByte[7] << 7)
             | (@sysvarMember::%BASE_FILE_NAME_NO_EXT%::FaultMemoryGui.SeverityByte[6] << 6)
             | (@sysvarMember::%BASE_FILE_NAME_NO_EXT%::FaultMemoryGui.SeverityByte[5] << 5)
             | (@sysvarMember::%BASE_FILE_NAME_NO_EXT%::FaultMemoryGui.SeverityByte[4] << 4)
             | (@sysvarMember::%BASE_FILE_NAME_NO_EXT%::FaultMemoryGui.SeverityByte[3] << 3)
             | (@sysvarMember::%BASE_FILE_NAME_NO_EXT%::FaultMemoryGui.SeverityByte[2] << 2)
             | (@sysvarMember::%BASE_FILE_NAME_NO_EXT%::FaultMemoryGui.SeverityByte[1] << 1)
             |  @sysvarMember::%BASE_FILE_NAME_NO_EXT%::FaultMemoryGui.SeverityByte[0];
    
    AddFault(@sysvarMember::%BASE_FILE_NAME_NO_EXT%::FaultMemoryGui.DTC_ToStore, status, severity);
  }
}

on sysvar sysvarMember::%BASE_FILE_NAME_NO_EXT%::FaultMemoryInternal.FaultMemoryActivated
{
  setControlVisibility("%BASE_FILE_NAME_NO_EXT%_FaultMemory", "DtcStorageWarningText", @this?0:1);
}

determineSupportedIdsAndSendResponse(diagResponse * resp, word offset, char parameterName[], byte supportedIDs[])
{
  byte supportedIDsWithOffset[4];
  
  memcpy_off(supportedIDsWithOffset, 0, supportedIDs, offset, elcount(supportedIDsWithOffset));
  
  resp.SetParameterRaw(parameterName, supportedIDsWithOffset, elcount(supportedIDsWithOffset));
  resp.SendResponse();
}

on diagRequest %BASE_FILE_NAME_NO_EXT%.*
{
  diagResponse this resp;
  
  // As this handler should only be called in case of functional requests for services 
  // which are not supported by this ECU, send no response at all as specified in J1979-2, chapter 6.2.5
}

