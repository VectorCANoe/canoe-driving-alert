on diagRequest %BASE_FILE_NAME_NO_EXT%.PID_F401_Monitor_Status_since_DTCs_cleared_Read
{
  diagResponse this resp;
  
  refreshS3Timer();
  resp.SetParameter("NbrOfEmissionRelatedDTCsAndMILStatus.MILStatus", @sysvarMember::%BASE_FILE_NAME_NO_EXT%::OBD.MIL_Status); 
  resp.SetParameter("NbrOfEmissionRelatedDTCsAndMILStatus.NumEmissionRelatedDTCs", @sysvarMember::%BASE_FILE_NAME_NO_EXT%::FaultMemoryInternal.NumberOfStoredEmissionRelatedDTCs); 

  resp.SetParameter("SuppContTests.ComprehensiveComponentMonitoringComplete", @sysvarMember::ECM_OBDonUDS_CAN::IncompleteMonitors.ComprehensiveComponent); 
  resp.SetParameter("SuppContTests.ComprehensiveComponentMonitoringSupported", @sysvarMember::ECM_OBDonUDS_CAN::SupportedMonitors.ComprehensiveComponent); 
  resp.SetParameter("SuppContTests.FuelSystemMonitoringComplete", @sysvarMember::ECM_OBDonUDS_CAN::IncompleteMonitors.FuelSystem); 
  resp.SetParameter("SuppContTests.FuelSystemMonitoringSupported", @sysvarMember::ECM_OBDonUDS_CAN::SupportedMonitors.FuelSystem); 
  resp.SetParameter("SuppContTests.MisfireMonitoringComplete", @sysvarMember::ECM_OBDonUDS_CAN::IncompleteMonitors.Misfire); 
  resp.SetParameter("SuppContTests.MisfireMonitoringSupported", @sysvarMember::ECM_OBDonUDS_CAN::SupportedMonitors.Misfire); 
  
  resp.SetParameter("SuppTestRunMinOnce.ACSysRefrigMonRunOnce", @sysvarMember::ECM_OBDonUDS_CAN::SupportedMonitors.A_C_SystemRefrigerant);
  resp.SetParameter("SuppTestRunMinOnce.EgrSysMon", @sysvarMember::ECM_OBDonUDS_CAN::SupportedMonitors.EgrSystem);
  resp.SetParameter("SuppTestRunMinOnce.OxySensHeaterMonRunOnce", @sysvarMember::ECM_OBDonUDS_CAN::SupportedMonitors.OxygenSensorHeater);
  resp.SetParameter("SuppTestRunMinOnce.OxySensMonRunOnce", @sysvarMember::ECM_OBDonUDS_CAN::SupportedMonitors.OxygenSensor);
  resp.SetParameter("SuppTestRunMinOnce.SecondaryAirSysMonRunOnce", @sysvarMember::ECM_OBDonUDS_CAN::SupportedMonitors.SecondaryAir);
  resp.SetParameter("SuppTestRunMinOnce.SuppCatalystMon", @sysvarMember::ECM_OBDonUDS_CAN::SupportedMonitors.Catalyst);
  resp.SetParameter("SuppTestRunMinOnce.SuppEvaporativeSystemMon", @sysvarMember::ECM_OBDonUDS_CAN::SupportedMonitors.EvaporativeSystem);
  resp.SetParameter("SuppTestRunMinOnce.SuppHeatedCatalystMon", @sysvarMember::ECM_OBDonUDS_CAN::SupportedMonitors.HeatedCatalyst);
  
  resp.SetParameter("SuppTestStatus.ACSystemRefrigMonStat", @sysvarMember::ECM_OBDonUDS_CAN::IncompleteMonitors.A_C_SystemRefrigerant); 
  resp.SetParameter("SuppTestStatus.CatalystMonStat", @sysvarMember::ECM_OBDonUDS_CAN::IncompleteMonitors.Catalyst); 
  resp.SetParameter("SuppTestStatus.EgrSystemMonStat", @sysvarMember::ECM_OBDonUDS_CAN::IncompleteMonitors.EgrSystem); 
  resp.SetParameter("SuppTestStatus.EvaporativeSystemMonStat", @sysvarMember::ECM_OBDonUDS_CAN::IncompleteMonitors.EvaporativeSystem); 
  resp.SetParameter("SuppTestStatus.HeatedCatalystMonStat", @sysvarMember::ECM_OBDonUDS_CAN::IncompleteMonitors.HeatedCatalyst); 
  resp.SetParameter("SuppTestStatus.OxygenSensorMonStatus", @sysvarMember::ECM_OBDonUDS_CAN::IncompleteMonitors.OxygenSensor); 
  resp.SetParameter("SuppTestStatus.OxySensHeaterMonStat", @sysvarMember::ECM_OBDonUDS_CAN::IncompleteMonitors.OxygenSensorHeater); 
  resp.SetParameter("SuppTestStatus.SecondaryAirSystemMonStat", @sysvarMember::ECM_OBDonUDS_CAN::IncompleteMonitors.SecondaryAir); 

  resp.SendResponse();
}  

