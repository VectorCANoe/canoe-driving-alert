on diagRequest %BASE_FILE_NAME_NO_EXT%.PID_F441_Monitor_status_of_driving_cycle_Read
{
  diagResponse this resp;
  byte bSuppContTests, bSuppTestRunMinOnce, bSuppTestStatus;
  
  refreshS3Timer();
  
  bSuppContTests=@ECM_OBDonUDS_CAN::SupportedMonitors.Misfire |
  ((@ECM_OBDonUDS_CAN::SupportedMonitors.FuelSystem) << 1) |
  ((@ECM_OBDonUDS_CAN::SupportedMonitors.ComprehensiveComponent) << 2) |
  ((@ECM_OBDonUDS_CAN::IncompleteMonitors.Misfire) << 4) |
  ((@ECM_OBDonUDS_CAN::IncompleteMonitors.FuelSystem) << 5) |
  ((@ECM_OBDonUDS_CAN::IncompleteMonitors.ComprehensiveComponent) << 6);
  
  bSuppTestRunMinOnce=@ECM_OBDonUDS_CAN::SupportedMonitors.Catalyst  |
  ((@ECM_OBDonUDS_CAN::SupportedMonitors.HeatedCatalyst) << 1) |
  ((@ECM_OBDonUDS_CAN::SupportedMonitors.EvaporativeSystem) << 2) |
  ((@ECM_OBDonUDS_CAN::SupportedMonitors.SecondaryAir) << 3) |
  ((@ECM_OBDonUDS_CAN::SupportedMonitors.A_C_SystemRefrigerant) << 4) |
  ((@ECM_OBDonUDS_CAN::SupportedMonitors.OxygenSensor) << 5) |
  ((@ECM_OBDonUDS_CAN::SupportedMonitors.OxygenSensorHeater) << 6) |
  ((@ECM_OBDonUDS_CAN::SupportedMonitors.EgrSystem) << 7);

  bSuppTestStatus=@ECM_OBDonUDS_CAN::IncompleteMonitors.Catalyst  |
  ((@ECM_OBDonUDS_CAN::IncompleteMonitors.HeatedCatalyst) << 1) |
  ((@ECM_OBDonUDS_CAN::IncompleteMonitors.EvaporativeSystem) << 2) |
  ((@ECM_OBDonUDS_CAN::IncompleteMonitors.SecondaryAir) << 3) |
  ((@ECM_OBDonUDS_CAN::IncompleteMonitors.A_C_SystemRefrigerant) << 4) |
  ((@ECM_OBDonUDS_CAN::IncompleteMonitors.OxygenSensor) << 5) |
  ((@ECM_OBDonUDS_CAN::IncompleteMonitors.OxygenSensorHeater) << 6) |
  ((@ECM_OBDonUDS_CAN::IncompleteMonitors.EgrSystem) << 7);
  
  resp.SetParameter("SuppContTests", bSuppContTests); 
  resp.SetParameter("SuppTestRunMinOnce", bSuppTestRunMinOnce); 
  resp.SetParameter("SuppTestStatus", bSuppTestStatus); 
  resp.SendResponse();
}  

