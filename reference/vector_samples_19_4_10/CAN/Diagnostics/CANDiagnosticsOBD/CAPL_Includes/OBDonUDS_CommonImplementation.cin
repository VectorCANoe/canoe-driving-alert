on diagRequest %BASE_FILE_NAME_NO_EXT%.InfoType_F802_Vehicle_Identification_Number_Read_with_Iterations
{
  diagResponse this resp;
  char VIN_String[18];
  byte VIN[17];

  refreshS3Timer();
  sysGetVariableString(sysvar::Vehicle::VIN, VIN_String, elcount(VIN_String));
  memcpy(VIN,VIN_String, elcount(VIN));
  if (!strncmp("%BASE_FILE_NAME_NO_EXT%", "ECM_OBDonUDS_CAN", 17)) {
    resp.SetComplexParameterRaw("Iteration", 0, "Vehicle_Identification_Number", VIN, elcount(VIN));
    resp.SendResponse();
  }
}

on diagRequest %BASE_FILE_NAME_NO_EXT%.InfoType_F808_In_use_Performance_Tracking_Read
{
