    <Object Type="Vector.CANalyzer.Panels.Design.StaticTextControl, Vector.CANalyzer.Panels.CommonControls, Version=17.3.91.0, Culture=neutral, PublicKeyToken=null" Name="StaticTextControl4" Children="Controls" ControlName="Static Text 2">
      <Property Name="Name">StaticTextControl4</Property>
      <Property Name="Size">266, 218</Property>
      <Property Name="Location">227, 25</Property>
      <Property Name="Text">1. Start the measurement:
    The message "DEMOFLOAT_MSG_1" is 
    sent by the Replay Block.

2. Activate check box Signal Temp_A_33:
    The signal "IOM_DEMO_VFG_OIL_TEMP_A_33"
    is changed and transmitted cyclically.

3. Change slider Signal Temp_A_31:
    The respective signal is transmitted 
    immediately.

4. Change slider Signal Temp_A_32:
    The respective signal is transmitted after a 
    minimum gap of 2 seconds.
</Property>
    </Object>
    <Object Type="Vector.CANalyzer.Panels.Design.StaticTextControl, Vector.CANalyzer.Panels.CommonControls, Version=17.3.91.0, Culture=neutral, PublicKeyToken=null" Name="StaticTextControl1" Children="Controls" ControlName="Static Text">
      <Property Name="Name">StaticTextControl1</Property>
      <Property Name="Size">50, 13</Property>
      <Property Name="Location">227, 4</Property>
      <Property Name="Font">Microsoft Sans Serif, 8.25pt, style=Bold</Property>
      <Property Name="Text">Usage</Property>
    </Object>
    <Object Type="Vector.CANalyzer.Panels.Design.StaticTextControl, Vector.CANalyzer.Panels.CommonControls, Version=17.3.91.0, Culture=neutral, PublicKeyToken=null" Name="StaticTextControl5" Children="Controls" ControlName="Static Text 2">
      <Property Name="Name">StaticTextControl5</Property>
      <Property Name="Size">205, 196</Property>
      <Property Name="Location">3, 47</Property>
      <Property Name="Text">This configuration illustrates how an 
AFDX packet can be send by a 
simulated node (CAPL program). 
The node “IOM_APP1” is sending 
signals if one of the sliders in group 
“IOM_APP1” is changed. 
Node “IOM_APP2” displays the 
received signal values within group 
“IOM_APP2”. 
All signals are transmitted via the 
message “DEMOMSG_INT3” or 
"DEMOFLOAT_MSG_1".

</Property>
    </Object>
    <Object Type="Vector.CANalyzer.Panels.Design.StaticTextControl, Vector.CANalyzer.Panels.CommonControls, Version=17.3.91.0, Culture=neutral, PublicKeyToken=null" Name="StaticTextControl2" Children="Controls" ControlName="Static Text">
      <Property Name="Name">StaticTextControl2</Property>
      <Property Name="Size">80, 13</Property>
      <Property Name="Location">3, 4</Property>
      <Property Name="Font">Microsoft Sans Serif, 8.25pt, style=Bold</Property>
      <Property Name="Text">Information</Property>
    </Object>
    <Property Name="Name">Panel</Property>
    <Property Name="Size">1023, 250</Property>
    <Property Name="BackColor">White</Property>
