void determineCoding(byte b[]){ 
  
  byte output[10];
  //write("input before determination: %X %X", b[0], b[1]);
  write("Response:");
  if(b[0] == 0x0){
    output[0] = 0x0;
    write("Message Type: Framework Message");
  }else if(b[0] == 0x1){
    output[0] = 0x1;
    write("Message Type: SE Message");
  }else if(b[0] == 0x2){
    output[0] = 0x2;
    write("Message Type: UWB Ranging Service Message");
  }else if(b[0] == 0x3){
    output[0] = 0x3;
    write("Message Type: DK Event Notification");
  }else if(b[0] == 0x4){
    output[0] = 0x4;
    write("Message Type: Vehicle OEM App Message");
  }else if(b[0] == 0x5){
    output[0] = 0x5;
    write("Message Type: Supplementary Service Message");
  }else if(b[0] == 0x6){
    output[0] = 0x6;
    write("Message Type: Head Unit Pairing Message");
  }else{
    output[0] = 0;
    write("Unknown Message Type");
  }
}


