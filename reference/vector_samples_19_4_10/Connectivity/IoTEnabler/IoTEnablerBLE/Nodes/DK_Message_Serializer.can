on value_update DK::Vehicle_Response.Capability
{
  encode_header($this.message_header);
  encode_uint8($this.protocol_version.major);
  encode_uint8($this.protocol_version.minor);
  encode_uint16($this.config_id);
  encode_uint8($this.pulseshape_combo);
  transmit_buffer[3] = length - 4;
  IoTEnabler::Smartphone_L2CAP.write.CallAsync($PanelUtil::smartphonePanel.l2cap_socket, transmit_buffer);
}

