{
	NO_PACKETS = 0,
	LE_1M = 1,
	LE_2M = 3,
	LE_CODED = 4
}

enum HCILESecondaryPhyEnum : uint32
{
	NO_PACKETS = 0,
	LE_1M = 1,
	LE_2M = 3,
	LE_CODED = 4
}

struct HCIEventLEExtAdvReportType
{
    uint16 event_type;
    bool connectable;
    bool scannable;
    bool directed;
    bool scan_response;
    bool legacy_pdu;
    HCILEDataStatusEnum data_status;
    HCILEAddrEnum address_type;
    string address;
    HCILEPrimaryPhyEnum primary_phy;
    HCILESecondaryPhyEnum secondary_phy;
    uint8 sid;
    uint8 tx_power;
    uint8 rssi;
    uint16 interval;
    HCILEAddrEnum direct_address_type;
    string direct_address;
    uint8 data_len;
    bytes data;
}

typedef HCIEventLEExtAdvReportTypeList = list<HCIEventLEExtAdvReportType>;

struct HCIEventLEExtAdvType
{
    uint8 num_reports;
    HCIEventLEExtAdvReportTypeList reports;
}

struct HCIEventLEExtConnCompleteType
{
    HCIStatusEnum status;
