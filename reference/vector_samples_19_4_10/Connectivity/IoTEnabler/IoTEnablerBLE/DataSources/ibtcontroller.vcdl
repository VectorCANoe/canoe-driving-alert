typedef stringList = list<string>;

struct adapter_info_type
{
    string address;
    string addresstype;
    string name;
    bool powered;
    uint32 discoverabletimeout;
    uint32 pairabletimeout;
    bool discovering;
    stringList uuids;
    stringList roles;
    string alias;
}

struct pairing_trace_type
{
    string action;
    string reply;
    string device;
    string uuid;
    string entered;
}

enum return_code_enum { OK, ERROR }
struct result
{
  return_code_enum return_code;
  [Optional]
  string additional_info;
}


interface IBTController
{
    // !
    // @brief Configure which bluetooth adapter to use
    // @param[in] adapter_id The HCI adapter ID of the bluetooth dongle
    // @return Success
    consumed method result configure(string adapter_id);

    // !
    // @brief Enable or disable Resovable Private Address (RPA)
    // @param[in] enable Enable or disable RPA
    // @param[in] irk Identity key
    // @return Success
    consumed method result rpa_set(bool enable, string irk);

    // !
    // @brief Return current Resovable Private Address (RPA) settings
    // @param[out] public_address Public address
    // @param[out] private_address Private address
    // @param[out] irk Identity key
    // @return Success
    consumed method result rpa_get(out string public_address, out string private_address, out string irk);

    // !
    // @brief Enable or disable tracing of lower level Bluetooth protocol data
    // @param[in] enable Enable or disable tracing
    // @return Success
    consumed method result trace(bool enable);

    // !
    // @brief Enable or disable reporting of statistics, such as min/avg/max advertisement interval
    // @param[in] enable Enable or disable reporting
    // @return Success
    consumed method result stats(bool enable);

    // !
    // @brief Set Maximum Transmission Unit (MTU) size for GATT
    // @param[in] mtu_size MTU size (value must be 23-517)
    // @return Success
    consumed method result gatt_mtu_set(uint16 mtu_size);

    // !
    // @brief Get Maximum Transmission Unit (MTU) size for GATT
    // @param[out] mtu_size MTU size
    // @return Success
    consumed method result gatt_mtu_get(out uint16 mtu_size);

    // !
    // @brief Configure the BLE connection settings
    // @param[in] scan_window How long to scan (in units of 0.625ms)
    // @param[in] scan_interval How long to wait between scans (in units of 0.625ms)
    // @return Success
    consumed method result le_connect_config_set(uint16 scan_window, uint16 scan_interval);

    // !
    // @brief Get information about Bluetooth system parameters
    // @param[out] parameters List of system parameters and values
    // @return Success
    consumed method result system_parameters_get(out SystemParameterTypeList parameters);

    // !
    // @brief Set a given Bluetooth system parameter
    // @param[in] name Name of the parameter (use get_system_parameters() to get all parameter names)
    // @param[in] value Value of the parameter
    // @return Success
    consumed method result system_parameter_set(SystemParameterEnum name, bytes value);

    // !
    // @brief Get information about the adapter in use
    // @param[out] adapter_info Information about the found adapter
    // @return Error if no adapter found or configured, otherwise success
    consumed method result adapter_info(out adapter_info_type adapter_info);

    // !
    // @brief Get the local BLE Out of Band (OOB) data
    // @param[out] random_value The local randomizer (P-256)
    // @param[out] confirm_value The local hash (P-256)
    // @return Error if reading OOB data failed, otherwise success
    consumed method result oob_local_data_get(out string random_value, out string confirm_value);

    // !
    // @brief Inject an Identity Resolving Key (IRK) to be used for a BLE connection
    // @param[in] device The device to be associated with the IRK
    // @param[in] irk Identity Resolving Key
    // @return Success
    consumed method result irk_set(string device, string irk);

    // !
    // @brief Inject a Long Term Key (LTK) to be used for a BLE connection
    // @param[in] device The device to be associated with the LTK
    // @param[in] ltk Long Term Key
    // @return Success
    consumed method result ltk_set(string device, string ltk);

    // !
    // @brief Get all stored Identity Resolving Keys (IRKs) associated with the currently used bluetooth adapter
    // @param[out] irks List of Identity Resolving Keys (IRKs) and their addresses
    // @return Success
    consumed method result irks(out KeyInfoTypeList irks);

    // !
    // @brief Get all stored Long Term Keys (LTKs) associated with the currently used bluetooth adapter
    // @param[out] ltks List of Long Term Keys (LTKs) and their addresses
    // @return Success
    consumed method result ltks(out KeyInfoTypeList ltks);

    // !
    // @brief Get paired devices associated with the currently used bluetooth adapter
    // @param[out] devices List of device MAC addresses
    // @return Error if error while reading paired devices, otherwise success
    consumed method result paired_devices(out stringList devices);

    // !
    // @brief Get the stored cache of a given device
    // @param[in] device MAC address of the device
    // @param[out] cache Stored bytes in the cache of the given device
    // @return Error if error while reading cached devices, otherwise success
    consumed method result device_cache_get(string device, out bytes cache);

    // !
    // @brief Write in the stored cache of a given device
    // @param[in] device MAC address of the device
    // @param[in] cache Bytes to be written in the cache of the given device
    // @return Error if error while reading cached devices or writing to the cache, otherwise success
    consumed method result device_cache_set(string device, bytes cache);

    // !
    // @brief Restart bluetooth services on the system
    // @return Success
    consumed method result reset_soft();

    // !
    // @brief Wipe all bonding data and restart bluetooth services on the system
    // @return Success
    consumed method result reset_hard();

    // !
    // @brief Set the remote BLE Out of Band (OOB) data on a given device
    // @param[in] device MAC address of the device
    // @param[in] random_value The remote randomizer (P-256), must be a hex string of length 32
    // @param[in] confirm_value The remote hash (P-256), must be a hex string of length 32
    // @return Error if setting OOB data failed, otherwise success
    consumed method result oob_remote_data_set(string device, string random_value, string confirm_value);

    // !
    // @brief Remove the remote BLE Out of Band (OOB) data for all devices
    // @return Error if setting OOB data failed, otherwise success
    consumed method result oob_remote_data_clear();

    // !
    // @brief Pair with a remote device (request)
    // @param[in] device MAC address of the device
    // @param[in] capability Override the global IO (display/keyboard) capabilities for this pairing event only
    // @return Error if OOB pairing fails, otherwise success
    consumed method result pairing_request(string device, CapabilityEnum capability);

    // !
    // @brief Enable or disable responding to a pairing request
    // @param[in] enable Enable or disable
    // @param[in] capability Override the global IO (display/keyboard) capabilities for this pairing event only
    // @return Error if OOB pairing fails, otherwise success
    consumed method result pairing_respond(bool enable, CapabilityEnum capability);

    // !
    // @brief Unpair with a remote device
    // @param[in] device MAC address of the device
    // @return Success
    consumed method result pairing_remove(string device);

    // !
    // @brief Disconnect a connected remote device
    // @param[in] device MAC address of the device
    // @return Success
    consumed method result disconnect(string device);

    // !
    // @brief Set code for passkey pairing
    // @param[in] passkey Passkey used for pairing
    // @param[in] accept Accept or reject the pairing request
    // @return Success
    consumed method result pairing_passkey(uint32 passkey, bool accept);

    // !
    // @brief Set code for (legacy) pin pairing
    // @param[in] device MAC address of the device
    // @param[in] pin Pin used for pairing
    // @param[in] accept Accept or reject the pairing request
    // @return Success
    consumed method result pairing_pin(string device, string pin, bool accept);

    // !
    // @brief Confirm pairing without providing passkey or pin
    // @param[in] accept Accept or reject the pairing request
    // @return Success
    consumed method result pairing_confirm(bool accept);

    // !
    // @brief Set a static passkey (instead of generating a random one)
    // @param[in] passkey Passkey
    // @return Success
    consumed method result pairing_static_passkey_set(uint64 passkey);

    // !
    // @brief Send a raw HCI command to the controller
    // @param[in] ogf Object group field
    // @param[in] ocf Object command field
    // @param[in] parameters Command parameters
    // @return Success
    consumed method result hci_command_transmit(uint8 ogf, uint16 ocf, bytes parameters, out bytes response);

    consumed data pairing_trace_type pairing_trace;

    consumed data AdvertisementStatsType advertisement_stats;

    consumed data HCIEventLEAdvType hci_event_le_advertisement;

    consumed data HCIEventLEExtAdvType hci_event_le_ext_advertisement;

    consumed data HCIEventCmdCompleteType hci_event_cmd_complete;

    consumed data HCIEventCmdStatusType hci_event_cmd_status;

    consumed data HCIEventLEConnCompleteType hci_event_le_conn_complete;

    consumed data HCIEventLEExtConnCompleteType hci_event_le_ext_conn_complete;

    consumed data HCIEventLERemoteFeaturesCompleteType hci_event_le_remote_features_complete;

    consumed data HCIEventLEConnUpdateCompleteType hci_event_le_conn_update_complete;

    consumed data HCIEventType hci_event;

    consumed data HCICommandType hci_command;

    consumed data HCICommandLEExtCreateConnType hci_le_ext_create_conn;

    consumed data HCICommandLEReadRemoteFeaturesType hci_le_read_remote_features;

    consumed data HCICommandLEConnUpdateType hci_le_conn_update;

    consumed data ACLType acl_data;

    consumed data L2CAPType l2cap_data;

    consumed data ATTType att_data;

    consumed data ATTReadRequestType att_read_request;

    consumed data ATTReadResponseType att_read_response;

    consumed data ATTReadTypeRequestType att_read_type_request;

    consumed data ATTReadTypeResponseType att_read_type_response;

    consumed data ATTWriteRequestType att_write_request;

    consumed data ATTWriteResponseType att_write_response;

    consumed data ATTExchangeMTURequestType att_exchange_mtu_request;

    consumed data ATTExchangeMTUResponseType att_exchange_mtu_response;

    consumed data L2CAPSignalType l2cap_signal;

    consumed data L2CAPSignalLEConnectionRequestType l2cap_signal_le_connection_request;

    consumed data L2CAPSignalLEConnectionResponseType l2cap_signal_le_connection_response;

    consumed data L2CAPSignalLEConnectionFlowControlType l2cap_signal_le_flow_control;

    consumed data SMPType smp;

    consumed data SMPPairingRequestType smp_pairing_request;

    consumed data SMPPairingResponseType smp_pairing_response;

    consumed data MgmtEventNewIRKType irk_available;

    consumed data MgmtEventNewLTKType ltk_available;

    consumed data MgmtEventNewCSRKType csrk_available;

    consumed data MgmtEventRequestConfirmType request_confirm;

    consumed data MgmtEventRequestPINType request_pin;

    consumed data MgmtEventRequestPasskeyType request_passkey;

    consumed data MgmtEventNotifyPasskeyType notify_passkey;

    consumed data HCIEventDisconnectCompleteType disconnect_complete;

}}
}