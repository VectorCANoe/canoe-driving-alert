version 2.0;
import module "IoTEnabler";
namespace NIoTEnabler
{

namespace NIBTController
{
struct ACLType
{
    uint16 handle;
    uint16 length;
    bool fragment;
    bool auto_flush;
    bool point_to_point;
    bool broadcast;
    bytes payload;
}

struct ATTExchangeMTURequestType
{
    uint16 client_mtu_size;
}

struct ATTExchangeMTUResponseType
{
    uint16 server_mtu_size;
}

struct ATTReadRequestType
{
    uint16 handle;
}

struct ATTReadResponseType
{
    bytes value;
}

struct ATTReadTypeRequestType
{
    uint16 start_handle;
    uint16 end_handle;
    string uuid;
}

struct ATTReadTypeResponseType
{
    uint8 length;
    bytes payload;
}

enum ATTOpCodeEnum : uint32
{
	ERROR = 1,
	EXCHANGE_MTU_REQUEST = 2,
	EXCHANGE_MTU_RESPONSE = 3,
	FIND_INFO_REQUEST = 4,
	FIND_INFO_RESPONE = 5,
	FIND_BY_TYPE_REQUEST = 6,
	FIND_BY_TYPE_RESPONSE = 7,
	READ_BY_TYPE_REQUEST = 8,
	READ_BY_TYPE_RESPONSE = 9,
	READ_REQUEST = 10,
	READ_RESPONSE = 11,
	READ_BLOB_REQUEST = 12,
	READ_BLOB_RESPONSE = 13,
	READ_MULTI_REQUEST = 14,
	READ_MULTI_RESPONSE = 15,
	READ_BY_GROUP_REQUEST = 16,
	READ_BY_GROUP_RESPONSE = 17,
	WRITE_REQUEST = 18,
	WRITE_RESPONSE = 19,
	WRITE_COMMAND = 82,
	PREP_WRITE_REQUEST = 22,
	PREP_WRITE_RESPONSE = 23,
	EXEC_WRITE_REQUEST = 24,
	EXEC_WRITE_RESPONSE = 25,
	HANDLE_VALUE_NOTIFY = 27,
	HANDLE_VALUE_INDICATION = 29,
	HANDLE_VALUE_CONFIGURATION = 30
}

struct ATTType
{
    ATTOpCodeEnum opcode;
    bytes parameters;
}

struct ATTWriteRequestType
{
    uint16 handle;
    bytes value;
}

struct ATTWriteResponseType
{
    bytes payload;
}

struct SampleType
{
    uint32 value;
    float percentage;
}

typedef SampleTypeList = list<SampleType>;

struct AdvertisementStatType
{
    string mac;
    uint32 sample_count;
    int32 avg_rssi;
    SampleTypeList samples;
}

typedef AdvertisementStatTypeList = list<AdvertisementStatType>;

struct AdvertisementStatsType
{
    AdvertisementStatTypeList devices;
}

enum CapabilityEnum : uint32
{
	DisplayOnly = 0,
	DisplayYesNo = 1,
	KeyboardOnly = 2,
	NoInputNoOutput = 3,
	KeyboardDisplay = 4
}

struct HCICommandLEConnUpdateType
{
    uint16 handle;
    uint16 min_interval;
    uint16 max_interval;
    uint16 latency;
    uint16 supervision_timeout;
    uint16 ce_min_length;
    uint16 ce_max_length;
}

struct HCICommandLEExtCreateConnPhyType
{
    uint16 scan_interval;
    uint16 scan_window;
    uint16 min_interval;
    uint16 max_interval;
    uint16 latency;
    uint16 supervision_timeout;
    uint16 ce_min_length;
    uint16 ce_max_length;
}

typedef HCICommandLEExtCreateConnPhyTypeList = list<HCICommandLEExtCreateConnPhyType>;

enum HCILEAddrEnum : uint32
{
	PUBLIC = 0,
	RANDOM = 1,
	LE_RANDOM = 2,
	PUBLIC_IDENTITY = 3,
	RANDOM_IDENTITY = 4,
	NO_ADDRESS = 255
}

struct HCICommandLEExtCreateConnType
{
    uint8 filter_policy;
    HCILEAddrEnum own_address_type;
    HCILEAddrEnum peer_address_type;
    string peer_address;
    uint8 init_phys;
    HCICommandLEExtCreateConnPhyTypeList phys;
}

struct HCICommandLEReadRemoteFeaturesType
{
    uint16 handle;
}

