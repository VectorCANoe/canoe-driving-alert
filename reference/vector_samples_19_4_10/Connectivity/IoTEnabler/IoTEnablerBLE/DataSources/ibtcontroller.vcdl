struct HCIEventCmdCompleteType
{
    uint8 ncmd;
    HCICommandEnum command;
    HCIStatusEnum status;
}

struct HCIEventCmdStatusType
{
    HCIStatusEnum status;
    uint8 ncmd;
    HCICommandEnum command;
}

struct HCIEventDisconnectCompleteType
{
    HCIStatusEnum status;
    uint16 handle;
    HCIStatusEnum reason;
}

struct HCIEventLEAdvType
{
    uint8 num_reports;
    uint8 event_type;
    HCILEAddrEnum address_type;
    string address;
    uint8 data_len;
    bytes data;
    uint8 rssi;
}

struct HCIEventLEConnCompleteType
{
    HCIStatusEnum status;
    uint16 handle;
    uint8 role;
    HCILEAddrEnum peer_address_type;
    string peer_address;
    uint16 interval;
    uint16 latency;
    uint16 supervision_timeout;
    uint8 clock_accuracy;
}

struct HCIEventLEConnUpdateCompleteType
{
    HCIStatusEnum status;
    uint16 handle;
    uint16 interval;
    uint16 latency;
    uint16 supervision_timeout;
}

enum HCILEDataStatusEnum : uint32
{
	COMPLETE = 0,
	INCOMPLETE_MORE = 1,
	INCOMPLETE_TRUNCATED = 2,
	RESERVED = 3
}

