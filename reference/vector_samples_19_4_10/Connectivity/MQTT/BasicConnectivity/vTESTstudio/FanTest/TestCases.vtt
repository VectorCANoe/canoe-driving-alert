    <tc>
      <title>Is fan moving?</title>
      <tcid>c9f8264d-7da5-4e9e-bb76-e83b0cc68a5e</tcid>
      <description>Tests if fan is rotating</description>
      <ttfunction>
        <title>Reset tempeature values</title>
        <name>ResetTemp</name>
      </ttfunction>
      <set>
        <title>Set temperature to value higher threshold</title>
        <in>
          <assignment>
            <sink>
              <dbobject>VE_BEGIN_OF_OBJECT|1|ClimateSimulation::TemperatureSimulation::TemperatureSensorLowerLeft.ProvidedTemperature|END_OF_OBJECT_VE|</dbobject>
            </sink>
            <source>
              <expression>
                <const>1.5 * $ClimateSimulation::Setting::FanSettings.ThresholdTurnOnFan</const>
              </expression>
            </source>
          </assignment>
        </in>
      </set>
      <wait>
        <title>Wait until next interval</title>
        <time>
          <value>
            <dbobject>ChParScalar_BEGIN_OF_OBJECT|1|intervalBetweenSet|END_OF_OBJECT_ChParScalar|</dbobject>
          </value>
          <unit>ms</unit>
        </time>
      </wait>
      <statecheck>
        <title>Check fan is moving</title>
        <expected>
          <compare>
            <value>
              <dbobject>VE_BEGIN_OF_OBJECT|1|ClimateSimulation::FanSimulation::Fan1.ProvidedRotationSpeed|END_OF_OBJECT_VE|</dbobject>
            </value>
            <gt>
              <const>0</const>
            </gt>
          </compare>
        </expected>
      </statecheck>
    </tc>
    <tc>
      <title>Is fan turned off?</title>
      <tcid>cd2a1ea6-c061-45cd-801c-558c0b44e5cc</tcid>
      <description>Tests if fan is not rotating</description>
      <ttfunction>
        <title />
        <name>ResetTemp</name>
      </ttfunction>
      <set>
        <title>Set temperature to value lower threshold</title>
        <in>
          <assignment>
            <sink>
              <dbobject>VE_BEGIN_OF_OBJECT|1|ClimateSimulation::TemperatureSimulation::TemperatureSensorLowerLeft.ProvidedTemperature|END_OF_OBJECT_VE|</dbobject>
            </sink>
            <source>
              <expression>
                <const>0.5 * $ClimateSimulation::Setting::FanSettings.ThresholdTurnOnFan</const>
              </expression>
            </source>
          </assignment>
        </in>
      </set>
      <wait>
        <title>Wait until next interval</title>
        <time>
          <value>
            <dbobject>ChParScalar_BEGIN_OF_OBJECT|1|intervalBetweenSet|END_OF_OBJECT_ChParScalar|</dbobject>
          </value>
          <unit>ms</unit>
        </time>
      </wait>
      <statecheck>
        <title>Check fan is not moving</title>
        <expected>
          <compare>
            <value>
              <dbobject>VE_BEGIN_OF_OBJECT|1|ClimateSimulation::FanSimulation::Fan1.ProvidedRotationSpeed|END_OF_OBJECT_VE|</dbobject>
            </value>
            <eq>
              <const>0</const>
            </eq>
          </compare>
        </expected>
      </statecheck>
    </tc>
  </tt>
