//Wna: Jetzt muss ich bei allen "on svAssign" und "on svUnassign" und "on pg 0x3d00" die Funktion EnableAssignOrUnassign() aufrufen
/*
if "Assign" is activate, then "Unassign has te be deactivated
*/
void EnableAssignOrUnassign(byte functionId, byte enableAssign)
{
  char functionName[64], btnAssign[64], btnUnassign[64];
  GetFunctionNameByFunctionId(functionId, functionName);
  snprintf(btnAssign, elcount(btnAssign), "btn%s_Assign", functionName); 
  snprintf(btnUnassign, elcount(btnUnassign), "btn%s_Unassign", functionName); 
  
  if(functionId <= 32)
  {
    EnableControlOnTwoPanels(sPanelNameClient, sPanelNameAuxValves, btnAssign, enableAssign);
    EnableControlOnTwoPanels(sPanelNameClient, sPanelNameAuxValves, btnUnassign, 1-enableAssign);
  }
  else
  {
    EnableControl(sPanelNameClient, btnAssign, enableAssign);
    EnableControl(sPanelNameClient, btnUnassign, 1-enableAssign);
  }
}

