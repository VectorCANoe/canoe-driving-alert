///////////////////////////////////////////////////////////
// Functions
///////////////////////////////////////////////////////////

void SetAllAuxValveFacilities(byte enable)
{
  byte valveNumber;
  char valveNamespace[100];
  for (valveNumber = 1; valveNumber<=32; ++valveNumber)
  {
    snprintf(valveNamespace, elcount(valveNamespace), "%s::RequiredFacilities::AuxValve%02d", sClientNamespace, valveNumber);
    if (sysSetVariableDWord(valveNamespace, "svState", enable) != 0)
    {
      writeLineEx(cWriteTargetCaplPage, cWriteSeverityError, "%s: Failed to set state value of %s", sClientName, valveNamespace);
    }      
    if (sysSetVariableDWord(valveNamespace, "svFlow", enable) != 0)
    {
      writeLineEx(cWriteTargetCaplPage, cWriteSeverityError, "%s: Failed to set flow value of %s", sClientName, valveNamespace);
    }     
  } 
}

void AssignFunctionIfRequired(int functionId, int required)
{
  if(required)
  {
    AssignFunction(functionId);
  }
}

void AssignFunction(int function)
{
  if(@svIdentifyTIMServerByAddress == 0)
  {
    Iso11783IL_TIMAssignFunction(function, TIMServer);
  }
  else
  {
    Iso11783IL_TIMAssignFunction(function, @svAddressOfTIMServer);
  }
}

void StartClient()
{
  dword fileHandle;

  Plugin_StartClient();
  ReflectRequiredFacilitiesByVisibility();
  EnableAllFunctionGroups(0);
  
  sNumOfReqForTestlabCertToIgnore        = @svNumOfIgnRqstForTestlab;
  sNumOfReqForManufactCertToIgnore       = @svNumOfIgnRqstForManufact;  
  sNumOfReqForManufactSeriesCertToIgnore = @svNumOfIgnRqstForManufactSeries;  
  sNumOfReqForDeviceCertToIgnore         = @svNumOfIgnRqstForDevice;  

  DefaultPreparationSequence_Client();
  
  {
    char varNameWithNamespace[100];
    snprintf(varNameWithNamespace, elcount(varNameWithNamespace), "%s::svTIMClientState", sClientNamespace);
    
    if(@svIdentifyTIMServerByAddress == 0)
      Iso11783IL_TIMConnectSysVarToState(TIMServer, varNameWithNamespace);
    else
      Iso11783IL_TIMConnectSysVarToState(@svAddressOfTIMServer, varNameWithNamespace);
  }
  
  // load LwA key table if file exists
  fileHandle = openFileRead(sLwATableFile, 0);
  if (fileHandle)
  {
    fileClose(fileHandle);
    Iso11783IL_TIMLoadLwATable(sLwATableFile);
  }
  
  if(@svTIMClientFreezeState > 0)
  {
    if(@svIdentifyTIMServerByAddress == 0)
      Iso11783IL_TIMFreezeConnection(TIMServer, @svTIMClientFreezeState);
    else
      Iso11783IL_TIMFreezeConnection(@svAddressOfTIMServer, @svTIMClientFreezeState);
  }
  
  if(@svIdentifyTIMServerByAddress == 0)
    Iso11783IL_TIMConnectToServer(TIMServer);
  else
    Iso11783IL_TIMConnectToServer(@svAddressOfTIMServer);
}

void ReconnectClientToServer()
{ 
  SetRequiredFunctionFacilities();
  ReflectRequiredFacilitiesByVisibility();
  ControlReleased_ResetAll(); //Set all “Control released” switches to “Off”
  EnableAllFunctionGroups(0);
  
  if(@svIdentifyTIMServerByAddress == 0)
  {
    Iso11783IL_TIMConnectToServer(TIMServer);
  }
  else
  {
    Iso11783IL_TIMConnectToServer(@svAddressOfTIMServer);
  }
}

void StopClient()
{
  byte useGracefulShutown;
  useGracefulShutown = Plugin_ClientIsConfiguredFromCT() ? 0 : 1;
  
  if(@svIdentifyTIMServerByAddress == 0)
  {
    Iso11783IL_TIMDisconnectFromServer(TIMServer, useGracefulShutown);
  }
  else
  {
    Iso11783IL_TIMDisconnectFromServer(@svAddressOfTIMServer, useGracefulShutown);
  }
  ReflectRequiredFacilitiesByVisibility_Reset();
  EnableAllFunctionGroups(1);

 Plugin_StopClient();
}

/*
- all user settings (tabs "Settings" and "Behavior") are applied
- all controls on the “Settings” tab are then set to read-only.
- Controls for functions that are not required are hidden
*/
void DefaultPreparationSequence_Client()
{
  char buf[100], version[100];
  
  UpdateDeactivatedCertificateChecks();

  Iso11783IL_TIMSetProperty("useRequestCounter", @svUseRequestCounter);

  Iso11783IL_TIMSetProperty("minimumVersion", @svMinimumVersion);
  Iso11783IL_TIMSetProperty("implementedVersion", @svImplementedVersion);
  Iso11783IL_TIMSetProperty("minimumAuthVersion", @svMinimumAuthVersion);
  Iso11783IL_TIMSetProperty("implementedAuthVersion", @svImplementedAuthVersion);
  //Set product identification
  sysGetVariableString(sysvar::svProductIdentification, buf, elcount(buf));
  Iso11783IL_TIMSetProductIdentification(buf);

  //Set compliance information
  Iso11783IL_TIMSetComplianceCertification( @svCCITestProtocolPublicationYear, 
                                            @svCCITestProtocolRevision, 
                                            @svCCILaboratoryType, 
                                            @svCCILaboratoryID, 
                                            @svCCIReferenceNumber);
  
  // Set sequence of requested certficates
  if (Iso11783IL_TIMSetCertificateSequence( @svCertificateType1, 
                                            @svCertificateType2, 
                                            @svCertificateType3, 
                                            @svCertificateType4) != 0)
  {
    writeLineEx(cWriteTargetCaplPage, cWriteSeverityError, "%s: Failed to set certificate sequence", sClientName);
  }
  
  //Set required functions
  CheckRequiredFunctions();
  if (!Plugin_ClientIsConfiguredFromCT())
  {
     SetRequiredFunctionFacilities();
  }
//  ReflectRequiredFacilitiesByVisibility();
  ControlReleased_ResetAll(); //Set all “Control released” switches to “Off”
  
  // Define which functions have to be assigned to which server
  Iso11783IL_TIMUnAssignFunction(-1);
   
  // Set root certificates
  sysGetVariableString(sysvar::svRootCertificate, buf, elcount(buf));
  Iso11783IL_TIMAddCertificate(cCertificateType_AEFRoot, buf);     
  
  // Set test lab certifiates 
  sysGetVariableString(sysvar::svAEFTestlabCertificate, buf, elcount(buf));
  Iso11783IL_TIMAddCertificate(cCertificateType_Testlab, buf); 
  
  // Set manufacturer certificate
  sysGetVariableString(sysvar::svManufacturerCertificate, buf, elcount(buf));
  Iso11783IL_TIMAddCertificate(cCertificateType_Manufacturer, buf);
  
  // Set manufacturer series certificate (if there is one)
  sysGetVariableString(sysvar::svManufacturerSeriesCertificate, buf, elcount(buf));
  if (strncmp(buf, "-", elcount(buf)) == 0)
  {
    Iso11783IL_TIMRemoveCertificate(cCertificateType_ManufacturerSeries);
  }
  else if (strlen(buf) > 0)
  {
    Iso11783IL_TIMAddCertificate(cCertificateType_ManufacturerSeries, buf);
  }
  
  // Set device certificate
  sysGetVariableString(sysvar::svDeviceCertificate, buf, elcount(buf));
  Iso11783IL_TIMAddCertificate(cCertificateType_Device, buf);
  
  // Set server private key
  sysGetVariableString(sysvar::svPrivateKey, buf, elcount(buf));
  Iso11783IL_TIMSetPrivateKey(buf);
  
  // Set CRL Signing
  sysGetVariableString(sysvar::svCRLSigningCertificate, buf, elcount(buf));
  Iso11783IL_TIMAddCertificate(cCertificateType_CRLSigning, buf);   
  
  // Set CRL
  sysGetVariableString(sysvar::svCRLCertificate, buf, elcount(buf));
  Iso11783IL_TIMSetCRL(cCRLType_CRL, buf);                             

  // Set CRL Sub CA
  sysGetVariableString(sysvar::svCRLSubCACertificate, buf, elcount(buf));
  Iso11783IL_TIMSetCRL(cCRLType_CRLSignCA, buf);                
}

/*
connect system variable to function states
*/
void  ConnectSysVarsToFunctionState()
{
  // connect system variable to function states
  ConnectSystemVariablesToAllAuxValveStates();
  {
    char varNameWithNamespace[100];
    
    snprintf(varNameWithNamespace, elcount(varNameWithNamespace), "%s::Functions::FrontPTO::svState", sClientNamespace);
    Iso11783IL_TIMConnectSysVarToFunctionState(cFrontPTO, varNameWithNamespace);

    snprintf(varNameWithNamespace, elcount(varNameWithNamespace), "%s::Functions::RearPTO::svState", sClientNamespace);
    Iso11783IL_TIMConnectSysVarToFunctionState(cRearPTO, varNameWithNamespace);
    
    snprintf(varNameWithNamespace, elcount(varNameWithNamespace), "%s::Functions::FrontHitch::svState", sClientNamespace);
    Iso11783IL_TIMConnectSysVarToFunctionState(cFrontHitch, varNameWithNamespace);
    
    snprintf(varNameWithNamespace, elcount(varNameWithNamespace), "%s::Functions::RearHitch::svState", sClientNamespace);
    Iso11783IL_TIMConnectSysVarToFunctionState(cRearHitch, varNameWithNamespace);
    
    snprintf(varNameWithNamespace, elcount(varNameWithNamespace), "%s::Functions::VehicleSpeed::svState", sClientNamespace);
    Iso11783IL_TIMConnectSysVarToFunctionState(cVehicleSpeed, varNameWithNamespace);
    
    snprintf(varNameWithNamespace, elcount(varNameWithNamespace), "%s::Functions::ExtGuidance::svState", sClientNamespace);
    Iso11783IL_TIMConnectSysVarToFunctionState(cExternalGuidance, varNameWithNamespace);
    
    snprintf(varNameWithNamespace, elcount(varNameWithNamespace), "%s::Functions::FrontTopLinkage::svState", sClientNamespace);
    Iso11783IL_TIMConnectSysVarToFunctionState(cFrontTopLinkage, varNameWithNamespace);
    
    snprintf(varNameWithNamespace, elcount(varNameWithNamespace), "%s::Functions::RearTopLinkage::svState", sClientNamespace);
    Iso11783IL_TIMConnectSysVarToFunctionState(cRearTopLinkage, varNameWithNamespace);
  }
}

void ConnectSystemVariablesToAllAuxValveStates()
{
  byte valveNumber;
  char valveStateWithNamespace[100];
  
  for (valveNumber = 1; valveNumber<=32; ++valveNumber)
  {
    snprintf(valveStateWithNamespace, elcount(valveStateWithNamespace), "%s::Functions::AuxValve%02d::svState", sClientNamespace, valveNumber);
    Iso11783IL_TIMConnectSysVarToFunctionState(valveNumber, valveStateWithNamespace);
  }
}

/*
Set all “Control released” switches to “Off”
*/
void ControlReleased_ResetAll()
{
  byte valveNumber;
  char valveNamespace[100];
  for (valveNumber = 1; valveNumber<=32; ++valveNumber)
  {
    snprintf(valveNamespace, elcount(valveNamespace), "%s::Functions::AuxValve%02d", sClientNamespace, valveNumber);
    if (sysSetVariableDWord(valveNamespace, "svReleaseControl", 0) != 0)
    {
      writeLineEx(cWriteTargetCaplPage, cWriteSeverityError, "TIM Server: Failed to set release control value of %s", valveNamespace);
    }
  } 
  
  @Functions::FrontPTO::svReleaseControl = 0;
  @Functions::RearPTO::svReleaseControl = 0;

  @Functions::FrontHitch::svReleaseControl = 0;
  @Functions::RearHitch::svReleaseControl = 0;
  
  @Functions::VehicleSpeed::svReleaseControl = 0;
  
  @Functions::ExtGuidance::svReleaseControl = 0;

  @Functions::FrontTopLinkage::svReleaseControl = 0;
  @Functions::RearTopLinkage::svReleaseControl = 0;
}

void CheckRequiredFunctions()
{
  byte valveNumber;
  char valveNamespace[100], facilityStateName[30], facilityFlowName[30];
  dword stateValue, flowValue;

  for (valveNumber = 1; valveNumber<=32; ++valveNumber)
  {
    snprintf(valveNamespace, elcount(valveNamespace), "%s::RequiredFacilities::AuxValve%02d", sClientNamespace, valveNumber); 
    stateValue = sysGetVariableDWord(valveNamespace, "svState");
    flowValue  = sysGetVariableDWord(valveNamespace, "svFlow");
    sRequiredAuxValve[valveNumber] = stateValue | flowValue;
  }
  
  sRequiredFrontPTO = ( @RequiredFacilities::FrontPTO::svDisengagement ||
                        @RequiredFacilities::FrontPTO::svEngagementCounterClockwise ||
                        @RequiredFacilities::FrontPTO::svEngagementClockwise ||
                        @RequiredFacilities::FrontPTO::svSpeedCounterClockwise ||
                        @RequiredFacilities::FrontPTO::svSpeedClockwise);
  
  sRequiredRearPTO = (  @RequiredFacilities::RearPTO::svDisengagement ||
                        @RequiredFacilities::RearPTO::svEngagementCounterClockwise ||
                        @RequiredFacilities::RearPTO::svEngagementClockwise ||
                        @RequiredFacilities::RearPTO::svSpeedCounterClockwise ||
                        @RequiredFacilities::RearPTO::svSpeedClockwise);
  
  sRequiredFrontHitch = ( @RequiredFacilities::FrontHitch::svMotion ||
                          @RequiredFacilities::FrontHitch::svPosition);
  
  sRequiredRearHitch = (@RequiredFacilities::RearHitch::svMotion ||
                        @RequiredFacilities::RearHitch::svPosition);
  
  sRequiredVehicleSpeed = ( @RequiredFacilities::VehicleSpeed::svForwardSpeed ||
                            @RequiredFacilities::VehicleSpeed::svReverseSpeed ||
                            @RequiredFacilities::VehicleSpeed::svStartMotion ||
                            @RequiredFacilities::VehicleSpeed::svStopMotion ||
                            @RequiredFacilities::VehicleSpeed::svForwardDirection ||
                            @RequiredFacilities::VehicleSpeed::svReverseDirection);
  
  sRequiredExtGuidance = @RequiredFacilities::ExtGuidance::svCurvature;

  sRequiredFrontTopLinkage = ( @RequiredFacilities::FrontTopLinkage::svMotion ||
                          @RequiredFacilities::FrontTopLinkage::svPosition);
  
  sRequiredRearTopLinkage = (@RequiredFacilities::RearTopLinkage::svMotion ||
                        @RequiredFacilities::RearTopLinkage::svPosition);
}

void SetRequiredFunctionFacilities()
{
  //Set required functions
  
  Iso11783IL_TIMResetAllRequiredFunctions();
  
  SetRequiredAuxValvuesFacilities();
  
  // Front PTO
  if( sRequiredFrontPTO)
  {
    Iso11783IL_TIMSetRequiredFacility("frontPTODisengagement",             @RequiredFacilities::FrontPTO::svDisengagement);
    Iso11783IL_TIMSetRequiredFacility("frontPTOEngagementCounterClockwise",@RequiredFacilities::FrontPTO::svEngagementCounterClockwise);
    Iso11783IL_TIMSetRequiredFacility("frontPTOEngagementClockwise",       @RequiredFacilities::FrontPTO::svEngagementClockwise);
    Iso11783IL_TIMSetRequiredFacility("frontPTOSpeedCounterClockwise",     @RequiredFacilities::FrontPTO::svSpeedCounterClockwise);
    Iso11783IL_TIMSetRequiredFacility("frontPTOSpeedClockwise",            @RequiredFacilities::FrontPTO::svSpeedClockwise);
  }

  // Rear PTO
  if(sRequiredRearPTO)
  {
    Iso11783IL_TIMSetRequiredFacility("rearPTODisengagement",             @RequiredFacilities::RearPTO::svDisengagement);
    Iso11783IL_TIMSetRequiredFacility("rearPTOEngagementCounterClockwise",@RequiredFacilities::RearPTO::svEngagementCounterClockwise);
    Iso11783IL_TIMSetRequiredFacility("rearPTOEngagementClockwise",       @RequiredFacilities::RearPTO::svEngagementClockwise);
    Iso11783IL_TIMSetRequiredFacility("rearPTOSpeedCounterClockwise",     @RequiredFacilities::RearPTO::svSpeedCounterClockwise);
    Iso11783IL_TIMSetRequiredFacility("rearPTOSpeedClockwise",            @RequiredFacilities::RearPTO::svSpeedClockwise);
  }
  
  // Front Hitch
  if(sRequiredFrontHitch)
  {
    Iso11783IL_TIMSetRequiredFacility("frontHitchMotion",             @RequiredFacilities::FrontHitch::svMotion);
    Iso11783IL_TIMSetRequiredFacility("frontHitchPosition",           @RequiredFacilities::FrontHitch::svPosition);
  }

  // Rear Hitch
  if(sRequiredRearHitch)
  {
    Iso11783IL_TIMSetRequiredFacility("rearHitchMotion",             @RequiredFacilities::RearHitch::svMotion);
    Iso11783IL_TIMSetRequiredFacility("rearHitchPosition",           @RequiredFacilities::RearHitch::svPosition);
  }
  
  // Vehicle Speed
  if( sRequiredVehicleSpeed)
  {  
    Iso11783IL_TIMSetRequiredFacility("vehicleSpeedForward",            @RequiredFacilities::VehicleSpeed::svForwardSpeed);
    Iso11783IL_TIMSetRequiredFacility("vehicleSpeedReverse",            @RequiredFacilities::VehicleSpeed::svReverseSpeed);
    Iso11783IL_TIMSetRequiredFacility("vehicleSpeedStartMotion",        @RequiredFacilities::VehicleSpeed::svStartMotion);
    Iso11783IL_TIMSetRequiredFacility("vehicleSpeedStopMotion",         @RequiredFacilities::VehicleSpeed::svStopMotion);
    Iso11783IL_TIMSetRequiredFacility("vehicleSpeedForwardDirection",   @RequiredFacilities::VehicleSpeed::svForwardDirection);
    Iso11783IL_TIMSetRequiredFacility("vehicleSpeedReverseDirection",   @RequiredFacilities::VehicleSpeed::svReverseDirection);
    if(@svImplementedVersion > 2)
    {
      Iso11783IL_TIMSetRequiredFacility("vehicleSpeedChangeOfDirection", @RequiredFacilities::VehicleSpeed::svChangeOfDirection); // call only succeeds if implemented version is > 2  
    }
  }
  
  //External Guidance
  if(sRequiredExtGuidance)
  {
    Iso11783IL_TIMSetRequiredFacility("externalGuidanceCurvature",   @RequiredFacilities::ExtGuidance::svCurvature);
  }
  
  // Front Top Linkage
  if(sRequiredFrontTopLinkage)
  {
    Iso11783IL_TIMSetRequiredFacility("frontTopLinkageMotion",             @RequiredFacilities::FrontTopLinkage::svMotion);
    Iso11783IL_TIMSetRequiredFacility("frontTopLinkagePosition",           @RequiredFacilities::FrontTopLinkage::svPosition);
  }

  // Rear Top Linkage
  if(sRequiredRearTopLinkage)
  {
    Iso11783IL_TIMSetRequiredFacility("rearTopLinkageMotion",             @RequiredFacilities::RearTopLinkage::svMotion);
    Iso11783IL_TIMSetRequiredFacility("rearTopLinkagePosition",           @RequiredFacilities::RearTopLinkage::svPosition);
  }
}

void SetRequiredAuxValvuesFacilities()
{
  byte valveNumber;
  char valveNamespace[100], facilityStateName[30], facilityFlowName[30];
  dword stateValue, flowValue;
  long result;
  
  for (valveNumber = 1; valveNumber<=32; ++valveNumber)
  {
    snprintf(valveNamespace, elcount(valveNamespace), "%s::RequiredFacilities::AuxValve%02d", sClientNamespace, valveNumber);
    snprintf(facilityStateName, elcount(facilityStateName), "auxiliaryValve%dState", valveNumber);
    snprintf(facilityFlowName, elcount(facilityFlowName), "auxiliaryValve%dFlow", valveNumber);
    
    // get system variable values
    if (sysGetVariableDWord(valveNamespace, "svState", stateValue) != 0)
    {
      writeLineEx(cWriteTargetCaplPage, cWriteSeverityError, "%s: Failed to get state value of %s", sClientName, valveNamespace);
    }      
    if (sysGetVariableDWord(valveNamespace, "svFlow", flowValue) != 0)
    {
      writeLineEx(cWriteTargetCaplPage, cWriteSeverityError, "%s: Failed to get flow value of %s", sClientName, valveNamespace);
    }
    
    // set supported TIM server facilities
    if (stateValue || flowValue)
    {
      if (Iso11783IL_TIMSetRequiredFacility(facilityStateName, stateValue) != 0)
      {
        writeLineEx(cWriteTargetCaplPage, cWriteSeverityError, "%s: Failed to set required state facility of valve %02d", sClientName, valveNumber);
      }
      if (Iso11783IL_TIMSetRequiredFacility(facilityFlowName,  flowValue) != 0)
      {
        writeLineEx(cWriteTargetCaplPage, cWriteSeverityError, "%s: Failed to set supported valve facility of valve %02d", sClientName, valveNumber);
      }
    }
  }
}

void EnableAllFunctionGroups(byte enable)
{
  //Common Controls 
  EnableCommonControlForEveryFunction("btn%s_Assign", enable);
  EnableCommonControlForEveryFunction("btn%s_Unassign", enable);
//  EnableCommonControlForEveryFunction("swControlReleased_%s", enable);
  //AuxValve
  {
    byte valveNumber;
    for (valveNumber = 1; valveNumber<=32; ++valveNumber)
    {
      EnableControls_AuxValve(valveNumber, enable);
    }
  }
  EnableControls_FrontPTO(enable);
  EnableControls_RearPTO(enable);
  EnableControls_FrontHitch(enable);
  EnableControls_RearHitch(enable);
  EnableControls_VehicleSpeed(enable);
  EnableControls_ExtGuidance(enable);
  EnableControls_FrontTopLinkage(enable);
  EnableControls_RearTopLinkage(enable);
}

/*
*/
void EnableControls_AuxValve(byte valveNumber, byte enable)
{
  char controlName[100];
  snprintf(controlName, elcount(controlName), "tbAuxValve%02d_Flow", valveNumber); 
  EnableControlOnTwoPanels(sPanelNameClient, sPanelNameAuxValves, controlName, enable);
  snprintf(controlName, elcount(controlName), "ioAuxValve%02d_Flow", valveNumber); 
  EnableControlOnTwoPanels(sPanelNameClient, sPanelNameAuxValves, controlName, enable);
  snprintf(controlName, elcount(controlName), "btnAuxValve%02d_FOE", valveNumber); 
  EnableControlOnTwoPanels(sPanelNameClient, sPanelNameAuxValves, controlName, enable);
  snprintf(controlName, elcount(controlName), "btnAuxValve%02d_Block", valveNumber); 
  EnableControlOnTwoPanels(sPanelNameClient, sPanelNameAuxValves, controlName, enable);
  snprintf(controlName, elcount(controlName), "btnAuxValve%02d_FOR", valveNumber); 
  EnableControlOnTwoPanels(sPanelNameClient, sPanelNameAuxValves, controlName, enable);
  snprintf(controlName, elcount(controlName), "btnAuxValve%02d_Float", valveNumber); 
  EnableControlOnTwoPanels(sPanelNameClient, sPanelNameAuxValves, controlName, enable);
}

