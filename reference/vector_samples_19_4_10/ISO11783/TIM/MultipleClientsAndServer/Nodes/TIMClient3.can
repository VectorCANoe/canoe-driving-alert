int SetHitchPosition(int funcId, double hitchPos)
{
  int result;
  word rawValue;
  
  rawValue = hitchPos * 100.0;
  result = Iso11783IL_TIMFunctionRequest(funcId, rawValue );
  
  return result;
}

int SetHitchState(int funcId, word hitchState)
{
  return Iso11783IL_TIMFunctionRequest(funcId, hitchState);
}


