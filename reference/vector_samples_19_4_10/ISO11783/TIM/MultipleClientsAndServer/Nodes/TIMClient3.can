on sysvar sysvar::svTIMClientState
{  
  if(@this == 54) // Client state switches to AuthenticationSucceeded
  {
    if(@svAssignAllFunctionsAutomatically == 1)
    {
      AssignAndEnableRequiredFunctions();
    }
    else
    {
      EnableCommonControlForEveryFunction("btn%s_Assign", 1);
      ActivateControlColors(sPanelNameClient, "btnOperatorEnable");
      setControlForeColor(sPanelNameClient, "txtAssignFunctions", makeRGB(0, 150, 0));
    }
  }
}

/*
For each TIM function, the name of a control is created according to the specified pattern and this control is activated or deactivated.
Only controls that occur for each function can be addressed here.
Therefore, the following patterns are currently possible:
  "btn%s_Assign"
  "btn%s_Unassign"
  "swControlReleased_%s"
  "grp%s"
*/
void EnableCommonControlForEveryFunction(char controlNamePatternFormat[], word enable)
{
  char controlName[100];
  EnableCommonControlForAuxValveFunctionsUsingPattern(controlNamePatternFormat, enable);
  EnableCommonControlUsingPattern(sPanelNameClient, "FrontPTO",         enable, controlNamePatternFormat);
  EnableCommonControlUsingPattern(sPanelNameClient, "RearPTO",          enable, controlNamePatternFormat);
  EnableCommonControlUsingPattern(sPanelNameClient, "FrontHitch",       enable, controlNamePatternFormat);
  EnableCommonControlUsingPattern(sPanelNameClient, "RearHitch",        enable, controlNamePatternFormat);
  EnableCommonControlUsingPattern(sPanelNameClient, "VehicleSpeed",     enable, controlNamePatternFormat);
  EnableCommonControlUsingPattern(sPanelNameClient, "ExtGuidance",      enable, controlNamePatternFormat);
  EnableCommonControlUsingPattern(sPanelNameClient, "FrontTopLinkage",  enable, controlNamePatternFormat);
  EnableCommonControlUsingPattern(sPanelNameClient, "RearTopLinkage",   enable, controlNamePatternFormat);
}

/*
For each TIM function, the name of a control is created according to the specified pattern and this control is activated or deactivated.
Examples for control patterns:
  "btn%s_Assign"
  "grp%s"
*/
void EnableCommonControlForAuxValveFunctionsUsingPattern(char controlNamePatternFormat[], word enable)
{
  byte valveNumber;
  char controlName[100];
  for (valveNumber = 1; valveNumber<=32; ++valveNumber)
  {
    snprintf(controlName, elcount(controlName), "AuxValve%02d", valveNumber); 
    EnableCommonControlUsingPattern(sPanelNameClient, controlName, enable, controlNamePatternFormat);
    EnableCommonControlUsingPattern(sPanelNameAuxValves, controlName, enable, controlNamePatternFormat);
  }
}

/*
*/
void EnableCommonControlUsingPattern(char panelName[], char functionName[], word enable, char controlNamePatternFormat[])
{
  char controlName[100];
  snprintf(controlName, elcount(controlName), controlNamePatternFormat, functionName); 
  EnableControl(panelName, controlName, enable);
}

void AssignAndEnableRequiredFunctions()
{
  byte valveNumber;

  //assign all enabled facilities
  for (valveNumber = 1; valveNumber<=32; ++valveNumber)
  {
    AssignFunctionIfRequired(valveNumber, sRequiredAuxValve[valveNumber]);
  }
  AssignFunctionIfRequired(cFrontPTO, sRequiredFrontPTO);
  AssignFunctionIfRequired(cRearPTO, sRequiredRearPTO);
  AssignFunctionIfRequired(cFrontHitch, sRequiredFrontHitch);
  AssignFunctionIfRequired(cRearHitch, sRequiredRearHitch);
  AssignFunctionIfRequired(cVehicleSpeed, sRequiredVehicleSpeed);
  AssignFunctionIfRequired(cExternalGuidance, sRequiredExtGuidance);
  if(@svImplementedVersion > 1)
  {
    AssignFunctionIfRequired(cFrontTopLinkage, sRequiredFrontTopLinkage);
    AssignFunctionIfRequired(cRearTopLinkage, sRequiredRearTopLinkage);
  }
  
  //Now enable it
  if(@svIdentifyTIMServerByAddress == 0)
    Iso11783IL_TIMOperatorEnable(TIMServer);
  else
    Iso11783IL_TIMOperatorEnable(@svAddressOfTIMServer);
}

