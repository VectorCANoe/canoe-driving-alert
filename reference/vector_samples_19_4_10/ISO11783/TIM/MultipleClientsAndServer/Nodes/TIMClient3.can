/*
*/
void ReflectRequiredFacilitiesByVisibility_Reset()
{
  byte valveNumber;

  // Auxiliary Values ----------------------------------------------------------
  for (valveNumber = 1; valveNumber<=32; ++valveNumber)
  {
    AdjustVilibility_AuxValveGroup_Client(sPanelNameClient, sPanelNameAuxValves, valveNumber, 1, 1);
  }
  AdjustVisibility_PTOGroup_Client(sPanelNameClient, "RearPTO", 1, 1, 1, 1, 1);
  AdjustVisibility_PTOGroup_Client(sPanelNameClient, "FrontPTO", 1, 1, 1, 1, 1);
  AdjustVisibility_HitchGroup_Client(sPanelNameClient, "RearHitch", 1, 1);
  AdjustVisibility_HitchGroup_Client(sPanelNameClient, "FrontHitch", 1, 1);
  AdjustVisibility_VehicleSpeed_Client(sPanelNameClient, 1, 1, 1, 1, 1, 1);
  AdjustVisibility_ExtGuidance_Client(sPanelNameClient, 1);
  AdjustVisibility_TopLinkage_Client(sPanelNameClient, "RearTopLinkage", 1, 1);
  AdjustVisibility_TopLinkage_Client(sPanelNameClient, "FrontTopLinkage", 1, 1);
}

void UpdateColorGrp(char panel1[], char panel2[], char control[], int facilityRequired)
{
  long white, gray;
  white = MakeRGB(255,255,255);
  gray = MakeRGB(242,242,242);
  
  if(facilityRequired == 1)
  {
    setControlBackColor(panel1, control, gray);
    setControlBackColor(panel2, control, gray);
  }
  else
  {
    setControlBackColor(panel1, control, white);
    setControlBackColor(panel1, control, white);
  }
}

void ReflectRequiredFacilitiesByVisibility()
{
  byte valveNumber;
  
  
  char valveNamespace[100], facilityStateName[30], facilityFlowName[30], buffer[100];
  dword stateValue, flowValue;

  // Auxiliary Values ----------------------------------------------------------
  for (valveNumber = 1; valveNumber<=32; ++valveNumber)
  {
    dword stateValue, flowValue;
    snprintf(valveNamespace, elcount(valveNamespace), "%s::RequiredFacilities::AuxValve%02d", sClientNamespace, valveNumber); 
    stateValue = sysGetVariableDWord(valveNamespace, "svState");
    flowValue  = sysGetVariableDWord(valveNamespace, "svFlow");
    AdjustVilibility_AuxValveGroup_Client(sPanelNameClient, sPanelNameAuxValves, valveNumber, stateValue, flowValue);
  }
  AdjustVisibility_PTOGroup_Client(sPanelNameClient, "RearPTO",   @RequiredFacilities::RearPTO::svSpeedCounterClockwise, 
                                                                  @RequiredFacilities::RearPTO::svSpeedClockwise,
                                                                  @RequiredFacilities::RearPTO::svEngagementCounterClockwise,
                                                                  @RequiredFacilities::RearPTO::svDisengagement,
                                                                  @RequiredFacilities::RearPTO::svEngagementClockwise);
  AdjustVisibility_PTOGroup_Client(sPanelNameClient, "FrontPTO",  @RequiredFacilities::FrontPTO::svSpeedCounterClockwise, 
                                                                  @RequiredFacilities::FrontPTO::svSpeedClockwise,
                                                                  @RequiredFacilities::FrontPTO::svEngagementCounterClockwise,
                                                                  @RequiredFacilities::FrontPTO::svDisengagement,
                                                                  @RequiredFacilities::FrontPTO::svEngagementClockwise);
  AdjustVisibility_HitchGroup_Client(sPanelNameClient, "RearHitch",  @RequiredFacilities::RearHitch::svMotion,      
                                                              @RequiredFacilities::RearHitch::svPosition);
  AdjustVisibility_HitchGroup_Client(sPanelNameClient, "FrontHitch", @RequiredFacilities::FrontHitch::svMotion,      
                                                              @RequiredFacilities::FrontHitch::svPosition);
  AdjustVisibility_VehicleSpeed_Client(sPanelNameClient,  @RequiredFacilities::VehicleSpeed::svReverseSpeed, 
                                                        @RequiredFacilities::VehicleSpeed::svForwardSpeed, 
                                                        @RequiredFacilities::VehicleSpeed::svStartMotion, 
                                                        @RequiredFacilities::VehicleSpeed::svStopMotion, 
                                                        @RequiredFacilities::VehicleSpeed::svReverseDirection, 
                                                        @RequiredFacilities::VehicleSpeed::svForwardDirection);
  AdjustVisibility_ExtGuidance_Client(sPanelNameClient, @RequiredFacilities::ExtGuidance::svCurvature);
  AdjustVisibility_TopLinkage_Client(sPanelNameClient, "RearTopLinkage",  @RequiredFacilities::RearTopLinkage::svMotion, 
                                                                        @RequiredFacilities::RearTopLinkage::svPosition);
  AdjustVisibility_TopLinkage_Client(sPanelNameClient, "FrontTopLinkage", @RequiredFacilities::FrontTopLinkage::svMotion, 
                                                                        @RequiredFacilities::FrontTopLinkage::svPosition);
}

void UpdateDeactivatedCertificateChecks()
{
  long deactivatedChecks;
  
  deactivatedChecks = 0;
  deactivatedChecks |= (@svDisableICCCheck > 0)             ?  0x01 : 0;   
  deactivatedChecks |= (@svDisableNameCheck > 0)            ?  0x02 : 0;   
  deactivatedChecks |= (@svDisableFctCapabilitiesCheck > 0) ?  0x04 : 0;   
  deactivatedChecks |= (@svDisableCRLCheck > 0)             ?  0x08 : 0;   
  deactivatedChecks |= (@svDisableCertificateTypeCheck > 0) ?  0x10 : 0;   
  
  if (Iso11783IL_TIMSetProperty("deactivateCertificateValidation", deactivatedChecks) != 0)
  {
    writeLineEx(cWriteTargetCaplPage, cWriteSeverityError, "%s: Failed to set deactivated certificate validations", sClientName);
  }
}

void SetValueForFirstFunctionRequest(dword functionID, int supportContinuousFacility, dword rowContinuousValue, dword rowDiscontinuousValue)
{
  if(supportContinuousFacility == 1)
  {
    Iso11783IL_TIMFunctionRequest(functionID, rowContinuousValue );
  }
  else
  {
    Iso11783IL_TIMFunctionRequest(functionID, rowDiscontinuousValue );
  }
}

void Iso11783IL_TIMOnFunctionStateChanged(dword functionID, dword newState) 
{
  switch (newState)
  {
    case 4: // // Automation Pending
    {
      switch(functionID)
      {
        case cAuxValve01:       SetValueForFirstFunctionRequest(functionID, @RequiredFacilities::AuxValve01::svFlow,          0x7D80, 0x7D80);  break;
        case cAuxValve02:       SetValueForFirstFunctionRequest(functionID, @RequiredFacilities::AuxValve02::svFlow,          0x7D80, 0x7D80);  break;
        case cAuxValve03:       SetValueForFirstFunctionRequest(functionID, @RequiredFacilities::AuxValve03::svFlow,          0x7D80, 0x7D80);  break;
        case cAuxValve04:       SetValueForFirstFunctionRequest(functionID, @RequiredFacilities::AuxValve04::svFlow,          0x7D80, 0x7D80);  break;
        case cAuxValve05:       SetValueForFirstFunctionRequest(functionID, @RequiredFacilities::AuxValve05::svFlow,          0x7D80, 0x7D80);  break;
        case cAuxValve06:       SetValueForFirstFunctionRequest(functionID, @RequiredFacilities::AuxValve06::svFlow,          0x7D80, 0x7D80);  break;
        case cAuxValve07:       SetValueForFirstFunctionRequest(functionID, @RequiredFacilities::AuxValve07::svFlow,          0x7D80, 0x7D80);  break;
        case cAuxValve08:       SetValueForFirstFunctionRequest(functionID, @RequiredFacilities::AuxValve08::svFlow,          0x7D80, 0x7D80);  break;
        case cAuxValve09:       SetValueForFirstFunctionRequest(functionID, @RequiredFacilities::AuxValve09::svFlow,          0x7D80, 0x7D80);  break;
        case cAuxValve10:       SetValueForFirstFunctionRequest(functionID, @RequiredFacilities::AuxValve10::svFlow,          0x7D80, 0x7D80);  break;
        case cAuxValve11:       SetValueForFirstFunctionRequest(functionID, @RequiredFacilities::AuxValve11::svFlow,          0x7D80, 0x7D80);  break;
        case cAuxValve12:       SetValueForFirstFunctionRequest(functionID, @RequiredFacilities::AuxValve12::svFlow,          0x7D80, 0x7D80);  break;
        case cAuxValve13:       SetValueForFirstFunctionRequest(functionID, @RequiredFacilities::AuxValve13::svFlow,          0x7D80, 0x7D80);  break;
        case cAuxValve14:       SetValueForFirstFunctionRequest(functionID, @RequiredFacilities::AuxValve14::svFlow,          0x7D80, 0x7D80);  break;
        case cAuxValve15:       SetValueForFirstFunctionRequest(functionID, @RequiredFacilities::AuxValve15::svFlow,          0x7D80, 0x7D80);  break;
        case cAuxValve16:       SetValueForFirstFunctionRequest(functionID, @RequiredFacilities::AuxValve16::svFlow,          0x7D80, 0x7D80);  break;
        case cAuxValve17:       SetValueForFirstFunctionRequest(functionID, @RequiredFacilities::AuxValve17::svFlow,          0x7D80, 0x7D80);  break;
        case cAuxValve18:       SetValueForFirstFunctionRequest(functionID, @RequiredFacilities::AuxValve18::svFlow,          0x7D80, 0x7D80);  break;
        case cAuxValve19:       SetValueForFirstFunctionRequest(functionID, @RequiredFacilities::AuxValve19::svFlow,          0x7D80, 0x7D80);  break;
        case cAuxValve20:       SetValueForFirstFunctionRequest(functionID, @RequiredFacilities::AuxValve20::svFlow,          0x7D80, 0x7D80);  break;
        case cAuxValve21:       SetValueForFirstFunctionRequest(functionID, @RequiredFacilities::AuxValve21::svFlow,          0x7D80, 0x7D80);  break;
        case cAuxValve22:       SetValueForFirstFunctionRequest(functionID, @RequiredFacilities::AuxValve22::svFlow,          0x7D80, 0x7D80);  break;
        case cAuxValve23:       SetValueForFirstFunctionRequest(functionID, @RequiredFacilities::AuxValve23::svFlow,          0x7D80, 0x7D80);  break;
        case cAuxValve24:       SetValueForFirstFunctionRequest(functionID, @RequiredFacilities::AuxValve24::svFlow,          0x7D80, 0x7D80);  break;
        case cAuxValve25:       SetValueForFirstFunctionRequest(functionID, @RequiredFacilities::AuxValve25::svFlow,          0x7D80, 0x7D80);  break;
        case cAuxValve26:       SetValueForFirstFunctionRequest(functionID, @RequiredFacilities::AuxValve26::svFlow,          0x7D80, 0x7D80);  break;
        case cAuxValve27:       SetValueForFirstFunctionRequest(functionID, @RequiredFacilities::AuxValve27::svFlow,          0x7D80, 0x7D80);  break;
        case cAuxValve28:       SetValueForFirstFunctionRequest(functionID, @RequiredFacilities::AuxValve28::svFlow,          0x7D80, 0x7D80);  break;
        case cAuxValve29:       SetValueForFirstFunctionRequest(functionID, @RequiredFacilities::AuxValve29::svFlow,          0x7D80, 0x7D80);  break;
        case cAuxValve30:       SetValueForFirstFunctionRequest(functionID, @RequiredFacilities::AuxValve30::svFlow,          0x7D80, 0x7D80);  break;
        case cAuxValve31:       SetValueForFirstFunctionRequest(functionID, @RequiredFacilities::AuxValve31::svFlow,          0x7D80, 0x7D80);  break;
        case cAuxValve32:       SetValueForFirstFunctionRequest(functionID, @RequiredFacilities::AuxValve32::svFlow,          0x7D80, 0x7D80);  break;

        case cFrontHitch:       SetValueForFirstFunctionRequest(functionID, @RequiredFacilities::FrontHitch::svPosition,      0,      0xFB01);  break;
        case cRearHitch:        SetValueForFirstFunctionRequest(functionID, @RequiredFacilities::RearHitch::svPosition,       0,      0xFB01);  break;
        case cFrontTopLinkage:  SetValueForFirstFunctionRequest(functionID, @RequiredFacilities::FrontTopLinkage::svPosition, 0,      0xFB01);  break;
        case cRearTopLinkage:   SetValueForFirstFunctionRequest(functionID, @RequiredFacilities::RearTopLinkage::svPosition,  0,      0xFB01);  break;
          
        case cExternalGuidance: SetExtGuidanceCurvature(@Functions::ExtGuidance::svCurvature);  break;

        case cFrontPTO:
        {
          dword rowInitValue;
          if      (@RequiredFacilities::FrontPTO::svDisengagement == 1)               {rowInitValue = 0x7D80;}
          else if (@RequiredFacilities::FrontPTO::svSpeedClockwise == 1)              {rowInitValue = 0x7D81;}
          else if (@RequiredFacilities::FrontPTO::svSpeedCounterClockwise == 1)       {rowInitValue = 0x7D7F;}
          else if (@RequiredFacilities::FrontPTO::svEngagementClockwise == 1)         {rowInitValue = 0xFB00;}
          else if (@RequiredFacilities::FrontPTO::svEngagementCounterClockwise == 1)  {rowInitValue = 0;}
          Iso11783IL_TIMFunctionRequest(cFrontPTO, rowInitValue);
          
        }
        break;
        
        case cRearPTO:
        {
          dword rowInitValue;
          if      (@RequiredFacilities::RearPTO::svDisengagement == 1)               {rowInitValue = 0x7D80;}
          else if (@RequiredFacilities::RearPTO::svSpeedClockwise == 1)              {rowInitValue = 0x7D81;}
          else if (@RequiredFacilities::RearPTO::svSpeedCounterClockwise == 1)       {rowInitValue = 0x7D7F;}
          else if (@RequiredFacilities::RearPTO::svEngagementClockwise == 1)         {rowInitValue = 0xFB00;}
          else if (@RequiredFacilities::RearPTO::svEngagementCounterClockwise == 1)  {rowInitValue = 0;}
          Iso11783IL_TIMFunctionRequest(cRearPTO, rowInitValue);
          
        }
        break;

        case cVehicleSpeed:     
        {
          dword rowInitValue;
          if      (@RequiredFacilities::VehicleSpeed::svStopMotion == 1)        {rowInitValue = 0x7D80;}
          else if (@RequiredFacilities::VehicleSpeed::svForwardSpeed == 1)      {rowInitValue = 0x7D81;}
          else if (@RequiredFacilities::VehicleSpeed::svReverseSpeed == 1)      {rowInitValue = 0x7D7F;}
          else if (@RequiredFacilities::VehicleSpeed::svForwardDirection == 1)  {rowInitValue = 0xFB00;}
          else if (@RequiredFacilities::VehicleSpeed::svReverseDirection == 1)  {rowInitValue = 0;}
          Iso11783IL_TIMFunctionRequest(cRearPTO, rowInitValue);
          
        }
        break;
          
        default:
          break;
      }
    }
    default:
      break;
  }
}


long Iso11783IL_OnTxPrepare( pg * txPG )
{ 
  switch( txPG.PGN ) 
  {
    case TIM21.pgn:
    {
      switch (txPG.byte(0))
      {
        case TIMClientStatus_Msg:
        {
          if (sysGetVariableInt(sysvar::svFreezeClientHeartbeatCounter) > 0)
          {
            // if error injection is active we always send the same heartbeat counter
            if (sFreezedHearbeatCounter < 0)
            {
              sFreezedHearbeatCounter =  txPG.byte(1);
            }
            txPG.byte(1) = sFreezedHearbeatCounter;
          }
          else
          {
            // if error injection is deactivated we reset the heartbeat variable  
            sFreezedHearbeatCounter = -1;
          }
          break;
        }
        default:
        {
          break;
        }
      }
      break;
    }
    
    default:
    {
      break;
    }
  }
    
  return Plugin_OnTxPrepare(txPG); // send message
}

long Iso11783IL_OnRxMessage(pg * rxPG)
{
  if((rxPG.pgn == AUTH12.pgn) && (rxPG.byte(0) == 3)) // Client Certificate Request
  {
    switch(rxPG.Byte(4))
    {
      case 1: // testlab
      {
        if(sNumOfReqForTestlabCertToIgnore > 0)
        {
          sNumOfReqForTestlabCertToIgnore--;
          return 0;
        }
        else
        {
          return 1;
        }
      }
      break;

      case 2: // Manufacturer
      {
        if(sNumOfReqForManufactCertToIgnore > 0)
        {
          sNumOfReqForManufactCertToIgnore--;
          return 0;
        }
        else
        {
          return 1;
        }
      }
      break;
      
      case 3: // Manufacturer Series
      {
        if(sNumOfReqForManufactSeriesCertToIgnore > 0)
        {
          sNumOfReqForManufactSeriesCertToIgnore--;
          return 0;
        }
        else
        {
          return 1;
        }
      }
      break;
      
      case 4: // Device
      {
        if(sNumOfReqForDeviceCertToIgnore > 0)
        {
          sNumOfReqForDeviceCertToIgnore--;
          return 0;
        }
        else
        {
          return 1;
        }
      }
      break;
    }
  }
   
  return Plugin_OnRxMessage(rxPG);
}
