/*@!Encoding:1252*/

///////////////////////////////////////
// v. 2.1
///////////////////////////////////////
includes
{
  #include "CommonConst.CIN"
  #include "CommonFunctions.cin"
  #include "Plugin\Plugin_CT_TIMClient.cin"
}

variables
{
  /////////////////////////////////////////////////////////////////////////////////
  //Adjust client number (1, 2, or 3)                                            //
  word sClientNumber=3;                                                          //
  using namespace TIMClient3;                                                    //
  using namespace ISO11783TIMClientAndServerDemo::TIMClient3;                    //
  /////////////////////////////////////////////////////////////////////////////////

  char sPanelNameClient[32];
  char sClientName[32];
  char sPanelNameAuxValves[32];
  char sClientNamespace[32];

  byte sAutoStart = 0; // > 0 if auto start of the server is enabled
  char sLwATableFile[100] = "ClientLwATable.txt";

  int  sFreezedHearbeatCounter = -1;

  int sNumOfReqForTestlabCertToIgnore;
  int sNumOfReqForManufactCertToIgnore;
  int sNumOfReqForManufactSeriesCertToIgnore;
  int sNumOfReqForDeviceCertToIgnore;
  
  int sRequiredAuxValve[33]; // value 0 is not used
  int sRequiredFrontPTO;
  int sRequiredRearPTO;
  int sRequiredFrontHitch;
  int sRequiredRearHitch;
  int sRequiredVehicleSpeed;
  int sRequiredExtGuidance;
  int sRequiredFrontTopLinkage;
  int sRequiredRearTopLinkage;
  
  // Values for the first Function Request (to transit from 'automation pending' to 'active not limited')
}

on start
{
  snprintf(sPanelNameClient, elcount(sPanelNameClient), "TIM Client %d", sClientNumber);
  snprintf(sClientName, elcount(sClientName), "TIM Client %d", sClientNumber);
  snprintf(sPanelNameAuxValves, elcount(sPanelNameAuxValves), "TIM Client %d Auxiliary Valves", sClientNumber);
  snprintf(sClientNamespace, elcount(sClientNamespace), "TIMClient%d", sClientNumber);
  

  sysSetVariableInt(sysvar::svStart, 0);
  @svTIMClientFreezeState = 0;
  
  ConnectSysVarsToFunctionState();

  Iso11783IL_SetVerbosity(cVerbosityErrorsAndWarnings);
  
  ReflectRequiredFacilitiesByVisibility_Reset();
  
  Plugin_OnStart();
  
//  UpdateTextColor("TIM Client 1", "btnRearPTO_EngagementCCW", 0);
}

/*
 Values for the first Function Request (to transit from 'automation pending' to 'active not limited')
*/
void InitFunctionValues()
{
  @Functions::AuxValve01::svValue = 0;
  @Functions::AuxValve02::svValue = 0;
  @Functions::AuxValve03::svValue = 0;
  @Functions::AuxValve04::svValue = 0;
  @Functions::AuxValve05::svValue = 0;
  @Functions::AuxValve06::svValue = 0;
  @Functions::AuxValve07::svValue = 0;
  @Functions::AuxValve08::svValue = 0;
  @Functions::AuxValve09::svValue = 0;
  @Functions::AuxValve10::svValue = 0;
  @Functions::AuxValve11::svValue = 0;
  @Functions::AuxValve12::svValue = 0;
  @Functions::AuxValve13::svValue = 0;
  @Functions::AuxValve14::svValue = 0;
  @Functions::AuxValve15::svValue = 0;
  @Functions::AuxValve16::svValue = 0;
  @Functions::AuxValve17::svValue = 0;
  @Functions::AuxValve18::svValue = 0;
  @Functions::AuxValve19::svValue = 0;
  @Functions::AuxValve20::svValue = 0;
  @Functions::AuxValve21::svValue = 0;
  @Functions::AuxValve22::svValue = 0;
  @Functions::AuxValve23::svValue = 0;
  @Functions::AuxValve24::svValue = 0;
  @Functions::AuxValve25::svValue = 0;
  @Functions::AuxValve26::svValue = 0;
  @Functions::AuxValve27::svValue = 0;
  @Functions::AuxValve28::svValue = 0;
  @Functions::AuxValve29::svValue = 0;
  @Functions::AuxValve30::svValue = 0;
  @Functions::AuxValve31::svValue = 0;
  @Functions::AuxValve32::svValue = 0;
  @Functions::FrontPTO::svSpeed   = 0;
  @Functions::RearPTO::svSpeed    = 0;
  @Functions::VehicleSpeed::svValue= 0;
  @Functions::ExtGuidance::svCurvature = 0;
  
  @Functions::FrontHitch::svPosition      = 0;  // full lower hitch
  @Functions::RearHitch::svPosition       = 0;  // full lower hitch
  @Functions::FrontTopLinkage::svPosition = 0;  //fully retracted top linkage
  @Functions::RearTopLinkage::svPosition  = 0;  //fully retracted top linkage
}

on sysvar sysvar::ILState
{
  if (sAutoStart && @this == 2) //Online
  {
    if(@svIdentifyTIMServerByAddress == 0)
      Iso11783IL_TIMConnectToServer(TIMServer);
    else
      Iso11783IL_TIMConnectToServer(@svAddressOfTIMServer);
  }
}

/*
*/
on pg 0x2400 //TIM21
{
  if(this.sa != Iso11783IL_GetAddress()) //is not my message
  {
    return;
  }
  if(this.byte(0) > 0xEF)
  {
    return; //it isn't a function id
  }
  if((this.byte(1) & 0xF0) != 0)  //TIM Function Request
  {
    return;
  }
  {
    byte functionId;
    dword functionState;
    functionId = this.byte(0);
    Iso11783IL_TIMGetFunctionState(functionId, functionState);
    if(functionState != cAutomationPending)
    {
      return;
    }
    if(functionId <= 32)
    {
      EnableControls_AuxValve(functionId, 1);
    }
    else
    {
      switch(functionId)
      {
        case cFrontPTO:         EnableControls_FrontPTO(1);         break;
        case cRearPTO:          EnableControls_RearPTO(1);          break;
        case cFrontHitch:       EnableControls_FrontHitch(1);       break;
        case cRearHitch:        EnableControls_RearHitch(1);        break;
        case cVehicleSpeed:     EnableControls_VehicleSpeed(1);     break;
        case cExternalGuidance: EnableControls_ExtGuidance(1);      break;
        case cFrontTopLinkage:  EnableControls_FrontTopLinkage(1);  break;
        case cRearTopLinkage:   EnableControls_RearTopLinkage(1);   break;
      }
    }
    EnableAssignOrUnassign(functionId, 0); 
  }
}

/*
*/
on pg 0x3d00 //TIM21_CS
{
  if(this.sa != Iso11783IL_GetAddress()) //is not my message
  {
    return;
  }
  if(this.byte(1) != 0x11)  //request
  {
    return;
  }
  {
    byte functionId;
    dword functionState;
    functionId = this.byte(0);
    Iso11783IL_TIMGetFunctionState(functionId, functionState);
    if(functionState != cAutomationPending)
    {
      return;
    }
    if(functionId <= 32)
    {
      EnableControls_AuxValve(functionId, 1);
    }
    else
    {
      switch(functionId)
      {
        case cFrontPTO:         EnableControls_FrontPTO(1);         break;
        case cRearPTO:          EnableControls_RearPTO(1);          break;
        case cFrontHitch:       EnableControls_FrontHitch(1);       break;
        case cRearHitch:        EnableControls_RearHitch(1);        break;
        case cVehicleSpeed:     EnableControls_VehicleSpeed(1);     break;
        case cExternalGuidance: EnableControls_ExtGuidance(1);      break;
        case cFrontTopLinkage:  EnableControls_FrontTopLinkage(1);  break;
        case cRearTopLinkage:   EnableControls_RearTopLinkage(1);   break;
      }
    }
    EnableAssignOrUnassign(functionId, 0); 
  }
}

on sysvar sysvar::svStart
{
  if(@this > 0)
  {
    Iso11783IL_TIMSetProperty("enableDemoMode", @svDemoModeActive);
    if(@svDemoModeActive == 1)
    {
      writeEx(0, 2, "\n%s: Demo mode is activated (Certificates and keys are not validated)", sClientName);
    }
    InitFunctionValues();
    EnableSettingsControls(0);
    StartClient();
    AdjustControlVisibilityAccordingToVersion(0);
  }
  else
  {
    StopClient();
    EnableSettingsControls(1);
    AdjustControlVisibilityAccordingToVersion(1);
  }
  setDefaultControlColors(sPanelNameClient, "btnOperatorEnable");
  setDefaultControlColors(sPanelNameClient, "txtActivateFunctions");
  
}

on preStop
{
  EnableSettingsControls(1);
  ReflectRequiredFacilitiesByVisibility_Reset();  
  EnableAllFunctionGroups(1);
  setDefaultControlColors(sPanelNameClient, "btnOperatorEnable");
  setDefaultControlColors(sPanelNameClient, "txtActivateFunctions");
  @svStart = 0;
}

void AdjustControlVisibilityAccordingToVersion(word visible)
{
  if(@svImplementedVersion < 2)
  {
    SetControlVisibility(sPanelNameClient, "grpReqFacilities_FTL", visible);
    SetControlVisibility(sPanelNameClient, "grpReqFacilities_RTL", visible);
    SetControlVisibility(sPanelNameClient, "cbChangeOfDirection", visible);
    SetControlVisibility(sPanelNameClient, "grpFrontTopLinkage", visible);
    SetControlVisibility(sPanelNameClient, "grpRearTopLinkage", visible);
  }
}


void EnableSettingsControls(word enable) 
{
  char varNameWithNamespace[100];
  snprintf(varNameWithNamespace, elcount(varNameWithNamespace), "%s::svTIMClientState", sClientNamespace);
  
  EnableControl(sPanelNameClient, "grpCertSequence", enable);
  EnableControl(sPanelNameClient, "grpNumOfCertRequestsToIgnore", enable);
  EnableControl(sPanelNameClient, "grpDeactivatedChecks", enable);
  
  EnableControl(sPanelNameClient, "gbCertificates", enable);
  EnableControl(sPanelNameClient, "gbComplianceInformation", enable);
  EnableControl(sPanelNameClient, "gbRequiredFacilities", enable);
  EnableControl(sPanelNameClient, "ioMinVersion", enable);
  EnableControl(sPanelNameClient, "ioImplVersion", enable);
  EnableControl(sPanelNameClient, "cbServerMaster", enable);
  EnableControl(sPanelNameClient, "ioProductId", enable);
  EnableControl(sPanelNameClient, "ioBootTime", enable);
  EnableControl(sPanelNameClient, "ioMinAuthVersion", enable);
  EnableControl(sPanelNameClient, "ioImplAuthVersion", enable);
}

on sysvar sysvar::svReconnectClientToServer
{
  if(@this > 0)
  {
    ReconnectClientToServer();
  }
}

on sysvar sysvar::svRestartAuthentication
{
  if(@this > 0)
  {
    if(@svIdentifyTIMServerByAddress == 0)
      Iso11783IL_TIMRestartAuthentication(TIMServer);
    else
      Iso11783IL_TIMRestartAuthentication(@svAddressOfTIMServer);
  }
}

on sysvar sysvar::svOperatorEnable
{
  if(@this == 0)
  {
    if(@svIdentifyTIMServerByAddress == 0)
      Iso11783IL_TIMOperatorEnable(TIMServer);
    else
      Iso11783IL_TIMOperatorEnable(@svAddressOfTIMServer);
  }
  setDefaultControlColors(sPanelNameClient, "btnOperatorEnable");
}

on sysvar sysvar::svStoreLwAKeyTable
{
  if(@this > 0)
  {
    Iso11783IL_TIMSaveLwATable(sLwATableFile);
  }
}

on sysvar sysvar::svClearLwAKeyTable
{
  if(@this > 0)
  {
    Iso11783IL_TIMClearLwATable();
    Iso11783IL_TIMSaveLwATable(sLwATableFile);
  }
}

on sysvar sysvar::svContinue
{
  if(@this > 0)
  {
    if(@svIdentifyTIMServerByAddress == 0)
      Iso11783IL_TIMContinueConnection(TIMServer);
    else
      Iso11783IL_TIMContinueConnection(@svAddressOfTIMServer);
  } 
}

on sysvar sysvar::svContinueAndFreeze
{
  if(@this > 0)
  {
    if(@svIdentifyTIMServerByAddress == 0)
      Iso11783IL_TIMContinueConnection(TIMServer);
    else
      Iso11783IL_TIMContinueConnection(@svAddressOfTIMServer);
  } 
  
  // set new freeze state if state has been changed
  if (@svTIMClientFreezeState > 0)
  {
    if(@svIdentifyTIMServerByAddress == 0)
      Iso11783IL_TIMFreezeConnection(TIMServer, @svTIMClientFreezeState);
    else
      Iso11783IL_TIMFreezeConnection(@svAddressOfTIMServer, @svTIMClientFreezeState);
  }
}

on sysvar sysvar::svDisableNameCheck
{
  UpdateDeactivatedCertificateChecks();
}

on sysvar sysvar::svDisableICCCheck
{
  UpdateDeactivatedCertificateChecks();
}

on sysvar sysvar::svDisableFctCapabilitiesCheck
{
  UpdateDeactivatedCertificateChecks();
}

on sysvar sysvar::svDisableCRLCheck
{
  UpdateDeactivatedCertificateChecks();
}

on sysvar sysvar::svDisableCertificateTypeCheck
{
  UpdateDeactivatedCertificateChecks();
}

/*
*/
void HighlightOperatorEnableButtonIfNecessary()
{
  if(@svAssignAllFunctionsAutomatically != 0)
  {
    return;
  }
  if(@svTIMClientState != @svTIMClientState::AuthenticationSucceed)
  {
    return;
  }
  ActivateControlColors(sPanelNameClient, "btnOperatorEnable");
}

////////////////////////////////////////////////////////
//            Rear PTO                               //
////////////////////////////////////////////////////////

on sysvar sysvar::Functions::RearPTO::svAssignFct
{
  if (@this == 0)
  {
    AssignFunction(cRearPTO);
    EnableAssignOrUnassign(cRearPTO, 0);    
    HighlightOperatorEnableButtonIfNecessary();
  }
}

on sysvar sysvar::Functions::RearPTO::svUnassignFct
{
  if (@this == 0)
  {
    Iso11783IL_TIMUnassignFunction(cRearPTO);  
    EnableAssignOrUnassign(cRearPTO, 1);
    EnableControls_RearPTO(0);
  }
}

on sysvar sysvar::Functions::RearPTO::svReleaseControl
{
  if (@this == 1)
  {
    Iso11783IL_TIMFunctionRequest(cRearPTO, cReleasedControlRequestingOperator);   
  }
  else
  {
    Iso11783IL_TIMFunctionRequest(cRearPTO, cReadyToControl);   
  }
}

on sysvar sysvar::Functions::RearPTO::svSpeed
{
  int result;
  
  result = SetPTOSpeed(cRearPTO, @this);
  if(result != 0)    
    writeLineEx(cWriteTargetCaplPage, cWriteSeverityError, "%s: Failed to set Rear PTO to %f 1/min", sClientName, @this);
}

on sysvar sysvar::Functions::RearPTO::svEngagement
{
  if(Iso11783IL_TIMFunctionRequest(cRearPTO, 0xFB00 ) != 0)
  {
    writeLineEx(cWriteTargetCaplPage, cWriteSeverityError, "%s: Failed to set Rear PTO to 0xFB00 (PTO on, Speed clockwise set by TIM Server)", sClientName);
  }
}

on sysvar sysvar::Functions::RearPTO::svEngagementCCW
{
  if(Iso11783IL_TIMFunctionRequest(cRearPTO, 0x0 ) != 0)
  {
    writeLineEx(cWriteTargetCaplPage, cWriteSeverityError, "%s: Failed to set Rear PTO to 0x0 (PTO on, Speed counter-clockwise set by TIM Server)", sClientName);
  }
}

on sysvar sysvar::Functions::RearPTO::svDisengagement
{
  if(Iso11783IL_TIMFunctionRequest(cRearPTO, 0x7D80 ) != 0)
  {
    writeLineEx(cWriteTargetCaplPage, cWriteSeverityError, "%s: Failed to set Rear PTO to 0x7D80 (PTO off)", sClientName);
  }
}


