  @RequiredFacilities::RearPTO::svDisengagement = 1;
  @RequiredFacilities::RearPTO::svEngagementCounterClockwise = 1;
  @RequiredFacilities::RearPTO::svEngagementClockwise = 1;
  @RequiredFacilities::RearPTO::svSpeedCounterClockwise = 1;
  @RequiredFacilities::RearPTO::svSpeedClockwise = 1;
  @RequiredFacilities::FrontHitch::svMotion = 1;
  @RequiredFacilities::FrontHitch::svPosition = 1;
  @RequiredFacilities::RearHitch::svMotion = 1;
  @RequiredFacilities::RearHitch::svPosition = 1;
