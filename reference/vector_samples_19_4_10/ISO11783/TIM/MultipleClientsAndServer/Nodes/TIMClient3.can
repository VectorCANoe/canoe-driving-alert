int SetCurrentAuxValveFlow(int funcId, double auxValveFlow)
{
  int result;
  word rawValue;
  
  rawValue = _round(((auxValveFlow + 128.512) * 250.0));
  result = Iso11783IL_TIMFunctionRequest(funcId, rawValue );
  
  return result;
}


