int SetPTOSpeed(int funcId, double physSpeed)
{
  int result;
  word rawValue;
  
  rawValue = (physSpeed + 4016.0) * 8;
  result = Iso11783IL_TIMFunctionRequest(funcId, rawValue );
  
  return result;
}


