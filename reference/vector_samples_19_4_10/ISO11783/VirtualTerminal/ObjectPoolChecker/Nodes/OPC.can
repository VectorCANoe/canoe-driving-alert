    SendGraphicsContextCmd( 10, @OPC::CmdGcDrawRecangleWidth, @OPC::CmdGcDrawRecangleHeight );
  }
}

//
// Send Graphics Context command 'Draw Text' to the VT
//
on sysvar OPC::CmdGcDrawText
{
  int  i;
  word length;
  char buf[25];
  pg VT21 vt21 = {dlc = 18};

  if (@this == 1) 
  {
    vt21.sa = OPC.NmStationAddress;
    vt21.da = gVTAddress;
    
    sysGetVariableString( sysvar::OPC::CmdGcDrawTextValue, buf, elcount(buf) );  

    length = strlen( buf );
    vt21.dlc = 6 + length;
    
    vt21.byte(0) = VT21.VTFunctionECUtoVT::GraphicsContextCommand;
    vt21.byte(1) = @OPC::CmdGcObjectID & 0xff;
    vt21.byte(2) = (@OPC::CmdGcObjectID >> 8) & 0xff;
    vt21.byte(3) = 13;
    vt21.byte(4) = @OPC::CmdGcDrawTextTransparent;
    vt21.byte(5) = length;

    for( i = 0; i < length; i++ ) 
    {
      vt21.byte(i+6) = buf[i];
    }
    
    output( vt21 );
  }
}

//
// Send Graphics Context command 'Draw VT Object' to the VT
//
on sysvar OPC::CmdGcDrawVTObject
{
  if (@this == 1) 
  {
    SendGraphicsContextCmd( 18, @OPC::CmdGcDrawVTObjectValue, 0xFFFF );
  }
}

//
// Draw a wide character text into the graphics context object 
//
on sysvar OPC::CmdGcDrawWideCharText
{
  int  i;
  word length;
  pg VT21 vt21 = {dlc = 18};

  vt21.sa = OPC.NmStationAddress;
  vt21.da = gVTAddress;

  if (@this == 1) 
  {
    length = 14;
    vt21.byte(0) = VT21.VTFunctionECUtoVT::GraphicsContextCommand;
    vt21.byte(1) = @OPC::CmdGcObjectID & 0xff;
    vt21.byte(2) = (@OPC::CmdGcObjectID >> 8) & 0xff;
    vt21.byte(3) = 13;
    vt21.byte(4) = @OPC::CmdGcDrawTextTransparent;
    vt21.byte(5) = length;
    // BOM
    vt21.byte(6) = 0xff;
    vt21.byte(7) = 0xfe;
    // Unicode text
    vt21.byte(8)  = 'U';
    vt21.byte(9)  = 0x00;
    vt21.byte(10) = 'N';
    vt21.byte(11) = 0x00;
    vt21.byte(12) = '\n';
    vt21.byte(13) = 0x00;
    vt21.byte(14) = 'I';
    vt21.byte(15) = 0x00;
    vt21.byte(16) = 'C';
    vt21.byte(17) = 0x00;

    output( vt21 );
  }
}

