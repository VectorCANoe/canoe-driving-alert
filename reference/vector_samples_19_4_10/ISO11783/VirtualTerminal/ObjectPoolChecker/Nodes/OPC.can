//
// Send Graphics Context command 'Draw Polygon' to the VT
//
on sysvar OPC::CmdGcDrawPolygon
{
  if (@this == 1) 
  {  
    pg VT21 vt21 = {dlc = 21};
    vt21.sa = OPC.NmStationAddress;
    vt21.da = gVTAddress;

    vt21.byte(0)  = VT21.VTFunctionECUtoVT::GraphicsContextCommand;
    vt21.byte(1)  = @OPC::CmdGcObjectID & 0xff;
    vt21.byte(2)  = (@OPC::CmdGcObjectID >> 8) & 0xff;
    vt21.byte(3)  = 12;
    vt21.byte(4)  = 4; // num of points 
    vt21.byte(5)  =  @OPC::CmdGcDrawPolygonX1       & 0xff;
    vt21.byte(6)  = (@OPC::CmdGcDrawPolygonX1 >> 8) & 0xff;
    vt21.byte(7)  =  @OPC::CmdGcDrawPolygonY1       & 0xff;
    vt21.byte(8)  = (@OPC::CmdGcDrawPolygonY1 >> 8) & 0xff;
    vt21.byte(9)  =  @OPC::CmdGcDrawPolygonX2       & 0xff;
    vt21.byte(10) = (@OPC::CmdGcDrawPolygonX2 >> 8) & 0xff;
    vt21.byte(11) =  @OPC::CmdGcDrawPolygonY2       & 0xff;
    vt21.byte(12) = (@OPC::CmdGcDrawPolygonY2 >> 8) & 0xff;
    vt21.byte(13) =  @OPC::CmdGcDrawPolygonX3       & 0xff;
    vt21.byte(14) = (@OPC::CmdGcDrawPolygonX3 >> 8) & 0xff;
    vt21.byte(15) =  @OPC::CmdGcDrawPolygonY3       & 0xff;
    vt21.byte(16) = (@OPC::CmdGcDrawPolygonY3 >> 8) & 0xff;
    vt21.byte(17) =  @OPC::CmdGcDrawPolygonX4       & 0xff;
    vt21.byte(18) = (@OPC::CmdGcDrawPolygonX4 >> 8) & 0xff;
    vt21.byte(19) =  @OPC::CmdGcDrawPolygonY4       & 0xff;
    vt21.byte(20) = (@OPC::CmdGcDrawPolygonY4 >> 8) & 0xff;

    output( vt21 );
  }
}

//
// Send Graphics Context command 'Draw Rectangle' to the VT
//
on sysvar OPC::CmdGcDrawRecangle
{
