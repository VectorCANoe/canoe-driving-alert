    );
  }
}

//
// Increase/decrease timer value for sending modified attribute values to the Vt
// 
on sysvar OPC::CmdChangeAttributeValueCycle
{
  if (@OPC::CmdChangeAttributeValueEnblCyc > 0) 
  {
    cancelTimer( gChangeAttrValueTimer );
    gChangeAttrValueTime = @this;
    if (gChangeAttrValueTime > 0) 
    {
      setTimer( gChangeAttrValueTimer, gChangeAttrValueTime * gChangeAttrValueTimeFact );
    }
  }
}

on timer gChangeAttrValueTimer
{
  int value;
  if (@OPC::CmdChangeAttributeValueCycle > 0) 
  {
    value = @OPC::CmdChangeAttributeValue;
    if (value < @OPC::CmdChangeAttributeValueMax) 
    {
      value++;
    }
    else {
      value = @OPC::CmdChangeAttributeValueMin; 
    }
    @OPC::CmdChangeAttributeValue = value; 

    CmdChangeAttribute();

    setTimer( gChangeAttrValueTimer, gChangeAttrValueTime * gChangeAttrValueTimeFact);
  }
}

//
// Enables/disables cyclically increment of the attribute value
// which is sent via command 'Change attribute' to the VT
//
on sysvar OPC::CmdChangeAttributeValueEnblCyc
{
  cancelTimer( gChangeAttrValueTimer ); 
  if (@this > 0) 
  {
    gChangeAttrValueTime = @OPC::CmdChangeAttributeValueCycle;
    if (gChangeAttrValueTime > 0) 
    {
      setTimer( gChangeAttrValueTimer, gChangeAttrValueTime * gChangeAttrValueTimeFact );
    }  
  }
}

//
// Increment attribute value and send it via command 'Change attribute' to the VT
//
on sysvar OPC::CmdChangeAttributeValueNext
{
  int value;

  if (@this == 1) 
  {
    value = @OPC::CmdChangeAttributeValue;
    if (value < @OPC::CmdChangeAttributeValueMax) 
    {
      value++;
    }
    else 
    {
      value = @OPC::CmdChangeAttributeValueMin; 
    }
    @OPC::CmdChangeAttributeValue = value; 

    CmdChangeAttribute();
  }
}

//
// Decrement attribute value and send it via command 'Change attribute' to the VT
//
on sysvar OPC::CmdChangeAttributeValuePrev
{
  int value;
  if (@this == 1) 
  {
    value = @OPC::CmdChangeAttributeValue;
    if (value > @OPC::CmdChangeAttributeValueMin) 
    {
      value--;
    }
    else 
    {
      value = @OPC::CmdChangeAttributeValueMax; 
    }
    @OPC::CmdChangeAttributeValue = value; 
    
    CmdChangeAttribute();
  }
}

//
// Send command 'Change Polygon Point' to the VT
//
on sysvar OPC::CmdChangePolygonPoint
{
  if (@this == 1) 
  {
    ResetVtData();
    gVT21.VTFunctionECUtoVT        = VT21.VTFunctionECUtoVT::ChangePolygonPoint;
    gVT21.PolygonObjectToChangeID  = @OPC::CmdChangePolygonPointId;
    gVT21.IndexOfThePointToReplace = @OPC::CmdChangePolygonPointIndex;
    gVT21.NewValueX                = @OPC::CmdChangePolygonPointX;
    gVT21.NewValueY                = @OPC::CmdChangePolygonPointY;
    output( gVT21 );
  }
}

//
// Send command 'Change Polygon Scale' to the VT
//
on sysvar OPC::CmdChangePoylgonScale
{
  if (@this == 1) 
  {
    ResetVtData();
    gVT21.VTFunctionECUtoVT       = VT21.VTFunctionECUtoVT::ChangePolygonScale;
    gVT21.PolygonObjectToScaleID  = @OPC::CmdChangePoylgonScaleId;
    gVT21.NewWidthAttribute       = @OPC::CmdChangePoylgonScaleWidth;
    gVT21.NewHeigthAttribute      = @OPC::CmdChangePoylgonScaleHeight;
    output( gVT21 );
  }
}

