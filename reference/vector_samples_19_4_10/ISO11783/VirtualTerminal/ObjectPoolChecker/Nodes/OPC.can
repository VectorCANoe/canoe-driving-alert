    gVT21.VTFunctionECUtoVT = VT21.VTFunctionECUtoVT::GetFontVersion;
    gVT21.dlc = 8;
    output( gVT21 );
  }
}

on sysvar OPC::ExportLoadedObjectPool
{
  if (@this == 1) 
  {
    char filePath[256];
    long result;

    sysGetVariableString(sysvar::OPC::FilenameExport, filePath, elcount(filePath));    
    result = Iso11783IL_OPSave(filePath);
    switch (result)
    {
      case 0:  writeEx(1, 1, "\n<%s> Object Pool is exported to file '%s'", gECULabel, filePath); break;
      default: writeEx(1, 2, "\n<%s> Failed to export Object Pool (error %i", gECULabel, result); break;
    } 
  }
}

void CmdChangeAttribute()
{
  byte floatValue[4];
  long rawValue;

  if (@OPC::CmdChangeAttributeUseFloat > 0)
  {
    Float64ToInt32( @OPC::CmdChangeAttributeValue, floatValue );
    rawValue =  (floatValue[3]<<24) | (floatValue[2]<<16) | (floatValue[1]<<8) | floatValue[0];
  }
  else
  {
    rawValue = @OPC::CmdChangeAttributeValue;
  }

  Iso11783IL_OPSetAttribute( @OPC::CmdChangeAttributeID, @OPC::CmdChangeAttributeAID, rawValue );

}

long Iso11783IL_OPOnKeyActivation( dword objectID, dword parentID, dword keyCode, dword activation )
{
  write("Iso11783IL_OPOnKeyActivation");
  return 0;
}


