on sysvar OPC::CmdShowWorkingSet
{
  byte buffer[8];
  long copiedBytes;
  sysvarData * sv;
  
  if (@this == 1) 
  {
    ResetVtData();
    gVT21.VTFunctionECUtoVT = VT21.VTFunctionECUtoVT::ShowWorkingSet;
    gVT21.dlc = 9;
    gVT21.qword(1)     = @OPC::CmdShowWorkingSetNAME;
    output( gVT21 );
  }
}

on sysvar OPC::CmdProprietaryCommand
{
  if (@this == 1) 
  {
    byte number;
      
    ResetVtData();
    number = @OPC::CmdProprietaryCommandNumber;
    if (number > 15)
    {
      writeEx(1, 2, "\nPlease enter a value between 0 and 15 to send a proprietary command"); 
      return;
    }
    gVT21.VTFunctionECUtoVT = 96 + @OPC::CmdProprietaryCommandNumber;
    output( gVT21 );
  }
}

