//
// Send Graphics Context command 'Pan and Zoom Viewport' to the VT
//
on sysvar OPC::CmdGcPanAndZoomViewport
{
  int  i;
  word length;
  float zoom;
  byte zoomValue[4];
  pg VT21 vt21 = {dlc = 12};

  vt21.sa = OPC.NmStationAddress;
  vt21.da = gVTAddress;
  
  if (@this == 1) {

    Float64ToInt32( @OPC::CmdGcZoomViewportValue, zoomValue );

    vt21.byte(0)  = VT21.VTFunctionECUtoVT::GraphicsContextCommand;
    vt21.byte(1)  =  @OPC::CmdGcObjectID       & 0xff;
    vt21.byte(2)  = (@OPC::CmdGcObjectID >> 8) & 0xff;
    vt21.byte(3)  = 16;
    vt21.byte(4)  =  @OPC::CmdGcPanViewportX       & 0xff;
    vt21.byte(5)  = (@OPC::CmdGcPanViewportX >> 8) & 0xff;
    vt21.byte(6)  =  @OPC::CmdGcPanViewportY       & 0xff;
    vt21.byte(7)  = (@OPC::CmdGcPanViewportY >> 8) & 0xff;
    vt21.byte(8)  =  zoomValue[0];
    vt21.byte(9)  =  zoomValue[1];
    vt21.byte(10) =  zoomValue[2];
    vt21.byte(11) =  zoomValue[3];

    output( vt21 );
  }
}

