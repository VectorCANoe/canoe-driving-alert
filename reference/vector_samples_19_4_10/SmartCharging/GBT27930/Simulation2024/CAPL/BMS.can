void UpdateK5K6StatusText()
{
  If(@sysvar::GBT27930::BMS::ContactorStatus_K5K6 == sysvar::GBT27930::BMS::ContactorStatus_K5K6::Close)
  {
   SetControlVisibility(gPanelName, "txt_K5K6Opened", 0);
   SetControlVisibility(gPanelName, "txt_K5K6Closed", 1);
  }
  else If(@sysvar::GBT27930::BMS::ContactorStatus_K5K6  == sysvar::GBT27930::BMS::ContactorStatus_K5K6::Open)
  {
   SetControlVisibility(gPanelName, "txt_K5K6Opened", 1);
   SetControlVisibility(gPanelName, "txt_K5K6Closed", 0);
  }
}

