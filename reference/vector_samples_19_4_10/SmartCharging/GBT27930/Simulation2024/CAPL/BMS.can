   $BMS.GBT27930_2_2024.VehicleBatteryBasicInformation.MaxVoltageMinParallelBatteryUnit.phys = @sysvar::GBT27930::BMS::ChargingDischarging::MaxVoltageMinParallelBatteryUnit;
   $BMS.GBT27930_2_2024.VehicleBatteryBasicInformation.MinVoltageMinParallelBatteryUnit.phys = @sysvar::GBT27930::BMS::ChargingDischarging::MinVoltageMinParallelBatteryUnit;
}

