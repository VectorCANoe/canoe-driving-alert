   $BMS.GBT27930_2_2024.VehicleBidirectionalChargingBatteryInfo.BatteryMinTemperature.phys = @sysvar::GBT27930::BMS::ChargingDischarging::BatteryMinTemperature;
   $BMS.GBT27930_2_2024.VehicleBidirectionalChargingBatteryInfo.MaxVoltageMinParallelBatteryUnit.phys = @sysvar::GBT27930::BMS::ChargingDischarging::MaxVoltageMinParallelBatteryUnit;
   $BMS.GBT27930_2_2024.VehicleBidirectionalChargingBatteryInfo.MinVoltageMinParallelBatteryUnit.phys = @sysvar::GBT27930::BMS::ChargingDischarging::MinVoltageMinParallelBatteryUnit;
