{
  $BMS.GBT27930_2_2024.VehiclePause.PauseStatus = @sysvar::GBT27930::BMS::ChargingDischarging::PauseCharging;
}

void SendVehicleBidirectionalChargingInfo()
{
  double inputEnergy;
  double chargingTimeMinutes;
  chargingTimeMinutes = ((timeNow() / 100) - msStartOfChargingMS) / 60000.0; // timeNow returns simulation time in 10 microseconds (10e-5) -> /100 to get milliseconds
  inputEnergy = abs($BMS.GBT27930_2_2024.ChargerBidirectionalChargingInfo.OutputVoltage.phys * $BMS.GBT27930_2_2024.ChargerBidirectionalChargingInfo.ChargingOutputCurrent.phys / 1000 /*W -> kW*/) * (chargingTimeMinutes / 60); //kWh
  @sysvar::GBT27930::BMS::ChargingDischarging::SoC = @sysvar::GBT27930::BMS::ChargingDischarging::SoC + (inputEnergy * 100 / @sysvar::GBT27930::BMS::ChargingDischarging::TotalCapacity);
  if (@sysvar::GBT27930::BMS::ChargingDischarging::SoC > 100)
     @sysvar::GBT27930::BMS::ChargingDischarging::SoC = 100;
  
  if (@sysvar::GBT27930::BMS::ChargingDischarging::DrivingEnergyConsumption != 0)
  {
    $BMS.GBT27930_2_2024.VehicleBidirectionalChargingInfo.DrivingRange.phys = @sysvar::GBT27930::BMS::ChargingDischarging::TotalCapacity / @sysvar::GBT27930::BMS::ChargingDischarging::DrivingEnergyConsumption; 
  } 
  else 
  {
    $BMS.GBT27930_2_2024.VehicleBidirectionalChargingInfo.DrivingRange.phys = 0; 
    WriteLineEx(1,2,"BMS: DrivingRange is set to zero, as no DrivingEnergyConsumption is given");
  }
  $BMS.GBT27930_2_2024.VehicleBidirectionalChargingInfo.EstimatedTimeRemaining.phys = 0; // ToDo: Calculate est remaining charging time
  $BMS.GBT27930_2_2024.VehicleBidirectionalChargingInfo.SoC.phys = @sysvar::GBT27930::BMS::ChargingDischarging::SoC;
}

