{
  $BMS.GBT27930_2_2024.VehicleBidirectionalDynamicOutputCapability.ChangeInVehicleOutputCapacity = @sysvar::GBT27930::BMS::ChargingDischarging::ChangeInVehicleOuputCapacity;
  $BMS.GBT27930_2_2024.VehicleBidirectionalDynamicOutputCapability.MaxCurrent.phys = @sysvar::GBT27930::BMS::ChargingDischarging::MaxCurrent;
}

void SendVehicleChargingBasicInformation()
{
  double inputEnergy, remainingEnergy;
  double chargingTimeMinutes;
  chargingTimeMinutes = ((timeNow() / 100) - msStartOfChargingMS) / 60000.0; // timeNow returns simulation time in 10 microseconds (10e-5) -> /100 to get milliseconds
  inputEnergy = abs($BMS.GBT27930_2_2024.ChargerChargingBasicInformation.PresentVoltage.phys * $BMS.GBT27930_2_2024.ChargerChargingBasicInformation.PresentCurrent.phys / 1000 /*W -> kW*/) * (chargingTimeMinutes / 60); //kWh
  @sysvar::GBT27930::BMS::ChargingDischarging::SoC = inputEnergy * 100 / @sysvar::GBT27930::BMS::ChargingDischarging::TotalCapacity * 100;
  
  // remaining Energy until SoC = 100%
  remainingEnergy = @sysvar::GBT27930::BMS::ChargingDischarging::TotalCapacity * (1.0 - @sysvar::GBT27930::BMS::ChargingDischarging::SoC/100.0) - inputEnergy;
  
  $BMS.GBT27930_2_2024.VehicleChargingBasicInformation.SoC.phys = @sysvar::GBT27930::BMS::ChargingDischarging::SoC;
  if (HV_measure_DC_U() > 0 && HV_measure_DC_I() > 0)
  {
    // remaining time until SoC = 100%
    $BMS.GBT27930_2_2024.VehicleChargingBasicInformation.RemainingTime.phys = (remainingEnergy / abs(HV_measure_DC_U()) * abs(HV_measure_DC_I()) / 1000) * 60;
  } else {
    $BMS.GBT27930_2_2024.VehicleChargingBasicInformation.RemainingTime.phys = 0;
  }
}

void ReactToK3K4Disconnect()
{
  if(currentBmsPhase == kSchedulingPhase && @sysvar::GBT27930::BMS::CurrentBmsStatus == kStatus3)
  {
    cancelTimer(timer_Tout0_Bms);
    @sysvar::GBT27930::BMS::CurrentBmsStatus = kStatus4;
  }
}

