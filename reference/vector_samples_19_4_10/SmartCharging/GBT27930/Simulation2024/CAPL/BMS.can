}

void SendVehicleBidirectionalChargingRequest()
{
  $BMS.GBT27930_2_2024.VehicleBidirectionalChargingRequest.VoltageRequest.phys = @sysvar::GBT27930::BMS::ChargingDischarging::TargetVoltage;
  $BMS.GBT27930_2_2024.VehicleBidirectionalChargingRequest.CurrentRequest.phys =  @sysvar::GBT27930::BMS::ChargingDischarging::TargetCurrent;
