{
  long contactorStatusEncoding;
  if(@sysvar::GBT27930::Charger::ContactorStatus_K1K2 == @sysvar::GBT27930::Charger::ContactorStatus_K1K2::Open)
  {
    contactorStatusEncoding = _GBT27930::DataTypes::parContactorStatusType::OFF;
  }
  else if (@sysvar::GBT27930::Charger::ContactorStatus_K1K2 == @sysvar::GBT27930::Charger::ContactorStatus_K1K2::Close)
  {
    contactorStatusEncoding = _GBT27930::DataTypes::parContactorStatusType::ON;
  }
  else
  {
    contactorStatusEncoding = _GBT27930::DataTypes::parContactorStatusType::Untrusted;
  }

  $Charger.GBT27930_2_2024.ChargerDCSupplyCircuitContactorStatus.StatusK1 = contactorStatusEncoding;
  $Charger.GBT27930_2_2024.ChargerDCSupplyCircuitContactorStatus.StatusK2 = contactorStatusEncoding;
}

void SendEndMessageAndEnterEndModule(long endType, long endReason)
{
  // Cyclic messages that shall be stopped if 'end message' is sent or received
  if(currentChargerPhase == kPreChargingAndEnergyTransferPhase)
  {
    // PreCharge and EnergyTransfer
    cancelTimer(sendCyclicChargerBidirectionalOutputCapability);
    cancelTimer(sendCyclicChargerBidirectionalChargingInfo);  
  }
  
  cancelTimer(timer_Tout0_Charger);
  SendEndMessageWithoutChangingModule(endType, endReason);
  currentChargerPhase = kEndPhase;
  SendChargerPhaseRequest();
}

void SendEndMessageWithoutChangingModule(long endType, long endReason)
{
  $Charger.GBT27930_2_2024.ChargerEnd.EndType = endType;
  switch(endType)
  {
    case _GBT27930::DataTypes::parEndType::EndCharging:
      $Charger.GBT27930_2_2024.ChargerEnd.EndReason.EndCharging = endReason;
      break;
    case _GBT27930::DataTypes::parEndType::FunctionModuleInformationInteractionTimeout:
      $Charger.GBT27930_2_2024.ChargerEnd.EndReason.FunctionModuleInteractionTimeout = endReason;
      break;
    case _GBT27930::DataTypes::parEndType::FunctionModuleExecutionFailed:
      $Charger.GBT27930_2_2024.ChargerEnd.EndReason.FunctionModuleExecutionFail = endReason;
      break;
    case _GBT27930::DataTypes::parEndType::PhaseAcknowledgementFailed:
      $Charger.GBT27930_2_2024.ChargerEnd.EndReason.PhaseAcknowledgementFail = endReason;
      break;
    default:
      $Charger.GBT27930_2_2024.ChargerEnd.EndReason.UnknownEndType = endReason;
      break;
  } 
}

void StartAuthentication()
{
  writeLineEx(-3,1,"#### Charger: Enter Authentication ####");
  switch (@sysvar::GBT27930::Charger::Authentication::PreferedAuthenticationMethod)
  {
    case sysvar::GBT27930::Charger::Authentication::PreferedAuthenticationMethod::EVIN:
      StartEVINAuthentication();
      break;
    case sysvar::GBT27930::Charger::Authentication::PreferedAuthenticationMethod::Cloud:
      StartCloudAuthentication();
      break;
    case sysvar::GBT27930::Charger::Authentication::PreferedAuthenticationMethod::Scan:
    default:
      StartScanAuthentication();
      break;
  }
}

void StartScanAuthentication()
{
  @sysvar::GBT27930::Charger::Authentication::AuthenticationType = @sysvar::GBT27930::Charger::Authentication::AuthenticationType::Scan; 
  StartTimerIfNotRunning(timer_Tout0_Charger, @sysvar::GBT27930::Charger::Timeouts::Tout0_Authentication); // 10 minutes
  // Send charger authentication parameters with "not completed"
  @sysvar::GBT27930::Charger::Authentication::AuthenticationStatus = 0x00;
  SendScanAuthenticationParameter();
  StartTimerIfNotRunning(sendCyclicChargerAuthenticationParameterMessage, cChargerAuthenticationParameterCycleTimeMs); // T1 = 250 ms, which is the cylce time of the URM 
  @sysvar::GBT27930::Charger::CurrentChargerStatus = kStatus1;
  StartTimerIfNotRunning(timer_SimulateAuthentication_Charger, cChargerAuthenticationSimulationTimeMs); 
}

void StartEVINAuthentication()
{
  @sysvar::GBT27930::Charger::Authentication::AuthenticationType = @sysvar::GBT27930::Charger::Authentication::AuthenticationType::EVIN;
  StartTimerIfNotRunning(timer_Tout0_Charger, @sysvar::GBT27930::Charger::Timeouts::Tout0_Authentication); // 10 minutes
  @sysvar::GBT27930::Charger::CurrentChargerStatus = kStatus1;
}

void StartCloudAuthentication()
{
  @sysvar::GBT27930::Charger::Authentication::AuthenticationType = @sysvar::GBT27930::Charger::Authentication::AuthenticationType::Cloud; 
  StartTimerIfNotRunning(timer_Tout0_Charger, @sysvar::GBT27930::Charger::Timeouts::Tout0_Authentication); // 10 minutes
  @sysvar::GBT27930::Charger::CurrentChargerStatus = kStatus1;
}

void PerformEVINAuthentication()
{
  // Set Auth status 
  if (@sysvar::GBT27930::Charger::Authentication::TriggerReAuthentication == 1)
  {
    @sysvar::GBT27930::Charger::Authentication::AuthenticationStatus = 0x00;
    $Charger.GBT27930_2_2024.ChargerEVINAuthenticationResult.AuthenticationResult = 0x00;
  } else {
    @sysvar::GBT27930::Charger::Authentication::AuthenticationStatus = 0xAA;
    $Charger.GBT27930_2_2024.ChargerEVINAuthenticationResult.AuthenticationResult = 0xAA;
  }
  // Check Auth status
  if (@sysvar::GBT27930::Charger::Authentication::AuthenticationStatus == 0xAA) 
  { // EVIN is valid
    $Charger.GBT27930_2_2024.ChargerEVINAuthenticationResult.SuccessfulAuthenticationFDC = 2; 
    SendChargerPhaseRequest();
    @sysvar::GBT27930::Charger::CurrentChargerStatus = kStatus3;
  } else { // EVIN is invalid
    $Charger.GBT27930_2_2024.ChargerEVINAuthenticationResult.SuccessfulAuthenticationFDC = 0;
    @sysvar::GBT27930::Charger::CurrentChargerStatus = kStatus2;
  }
}

void ReactToOpenK1K2DuringEndPhase()
{
  cancelTimer(timer_Tout1_Charger);
  $Charger.GBT27930_2_2024.ChargerAllowsAdhesionDetection.AllowAdhesionDetection = _GBT27930::DataTypes::parEnableType::Allowed;
  setTimerCyclic(sendCyclicChargerAllowsAdhesionDetectionMessage, cChargerAuthenticationParameterCycleTimeMs);
  setTimer(timer_Tout2_Charger, @sysvar::GBT27930::Charger::Timeouts::Tout2_EndPhase_VehicleAdhesionDetectionReceived);
  @sysvar::GBT27930::Charger::CurrentChargerStatus = kStatus2;
}

word CompareWithTolerance(double testValue, double targetValue, double tolerance)
{
  if (testValue > targetValue - tolerance && testValue < targetValue + tolerance)
  {
    return 1;
  }
  return 0;
}

/////////////////////////////////////////////////////////////////////////////////////
/*-----------------------------------Presentation----------------------------------*/
/////////////////////////////////////////////////////////////////////////////////////

void SetChargingStationPicturesVisibility(int Mode)
{
  If(Mode == Ready)
  {
   SetControlVisibility(gPanelName, "pictureChargingStationReady", 1);
   SetControlVisibility(gPanelName, "pictureChargingStationCharging", 0);
   SetControlVisibility(gPanelName, "pictureChargingStationError", 0);
  }
  else If(Mode == Charging)
  {
   SetControlVisibility(gPanelName, "pictureChargingStationReady", 0);
   SetControlVisibility(gPanelName, "pictureChargingStationCharging", 1);
   SetControlVisibility(gPanelName, "pictureChargingStationError", 0);
  }
  else If(Mode == Error)
  {
   SetControlVisibility(gPanelName, "pictureChargingStationReady", 0);
   SetControlVisibility(gPanelName, "pictureChargingStationCharging", 0);
   SetControlVisibility(gPanelName, "pictureChargingStationError", 1);
  }
}

void UpdateElectronicLockText()
{
  If(@sysvar::GBT27930::Charger::ElectronicLockStatus == sysvar::GBT27930::Charger::ElectronicLockStatus::Unlocked)
  {
   SetControlVisibility(gPanelName, "txt_ElectronicLockUnlocked", 1);
   SetControlVisibility(gPanelName, "txt_ElectronicLockLocked", 0);
   SetControlVisibility(gPanelName, "txt_ElectronicLockUntrusted", 0);
   SetControlVisibility(gPanelName, "pictureElectronicLockUnlocked", 1);
   SetControlVisibility(gPanelName, "pictureElectronicLockLocked", 0);
  }
  else If(@sysvar::GBT27930::Charger::ElectronicLockStatus  == sysvar::GBT27930::Charger::ElectronicLockStatus::Locked)
  {
   SetControlVisibility(gPanelName, "txt_ElectronicLockUnlocked", 0);
   SetControlVisibility(gPanelName, "txt_ElectronicLockLocked", 1);
   SetControlVisibility(gPanelName, "txt_ElectronicLockUntrusted", 0);
   SetControlVisibility(gPanelName, "pictureElectronicLockUnlocked", 0);
   SetControlVisibility(gPanelName, "pictureElectronicLockLocked", 1);
  }
  else If(@sysvar::GBT27930::Charger::ElectronicLockStatus == sysvar::GBT27930::Charger::ElectronicLockStatus::Untrusted)
  {
   SetControlVisibility(gPanelName, "txt_ElectronicLockUnlocked", 0);
   SetControlVisibility(gPanelName, "txt_ElectronicLockLocked", 0);
   SetControlVisibility(gPanelName, "txt_ElectronicLockUntrusted", 1);
   SetControlVisibility(gPanelName, "pictureElectronicLockUnlocked", 0);
   SetControlVisibility(gPanelName, "pictureElectronicLockLocked", 0);
  }
}

void UpdateK1K2StatusText()
{
  If(@sysvar::GBT27930::Charger::ContactorStatus_K1K2 == sysvar::GBT27930::Charger::ContactorStatus_K1K2::Close)
  {
   SetControlVisibility(gPanelName, "txt_K1K2Opened", 0);
   SetControlVisibility(gPanelName, "txt_K1K2Closed", 1);
  }
  else If(@sysvar::GBT27930::Charger::ContactorStatus_K1K2  == sysvar::GBT27930::Charger::ContactorStatus_K1K2::Open)
  {
   SetControlVisibility(gPanelName, "txt_K1K2Opened", 1);
   SetControlVisibility(gPanelName, "txt_K1K2Closed", 0);
  }
}

/////////////////////////////////////////////////////////////////////////////////////
/*-----------------------------------Key Inputs------------------------------------*/
/////////////////////////////////////////////////////////////////////////////////////

on key 'n'
{
  @sysvar::GBT27930::Charger::ElectronicLockStatus = 0xFF;
}
