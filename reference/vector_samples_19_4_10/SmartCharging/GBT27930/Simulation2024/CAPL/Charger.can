void UpdateChargerDetectionValueIfNeeded()
{
  if(sentChargerDetectionInformationCounter >= 2)
  {
    sentChargerDetectionInformationCounter = 0;
    // Transition values in order through states "WaitingForDetection" > "DetectionInProgress" > "DetectionSuccessful"
    if(@sysvar::GBT27930::Charger::Messages::ChargerDetectionInformation::ShortCircuitDetectionStatus <= @sysvar::GBT27930::Charger::Messages::ChargerDetectionInformation::ShortCircuitDetectionStatus::DetectionInProgress)
    {
      @sysvar::GBT27930::Charger::Messages::ChargerDetectionInformation::ShortCircuitDetectionStatus++;
      writeLineEx(1,1,"Charger: Update ChargerDetectionInformation.ShortCircuitDetectionStatus to state %d.", @sysvar::GBT27930::Charger::Messages::ChargerDetectionInformation::ShortCircuitDetectionStatus);
    }
    else if(@sysvar::GBT27930::Charger::Messages::ChargerDetectionInformation::InsulationDetectionStatus <= @sysvar::GBT27930::Charger::Messages::ChargerDetectionInformation::InsulationDetectionStatus::DetectionInProgress)
    {
      @sysvar::GBT27930::Charger::Messages::ChargerDetectionInformation::InsulationDetectionStatus++;
      writeLineEx(1,1,"Charger: Update ChargerDetectionInformation.InsulationDetectionStatus to state %d.", @sysvar::GBT27930::Charger::Messages::ChargerDetectionInformation::InsulationDetectionStatus);
    }
    else if(@sysvar::GBT27930::Charger::Messages::ChargerDetectionInformation::AdhesionDetectionStatus <= @sysvar::GBT27930::Charger::Messages::ChargerDetectionInformation::AdhesionDetectionStatus::DetectionInProgress)
    {
      @sysvar::GBT27930::Charger::Messages::ChargerDetectionInformation::AdhesionDetectionStatus++;
      writeLineEx(1,1,"Charger: Update ChargerDetectionInformation.AdhesionDetectionStatus to state %d.", @sysvar::GBT27930::Charger::Messages::ChargerDetectionInformation::AdhesionDetectionStatus);      
    }
    else if(@sysvar::GBT27930::Charger::Messages::ChargerDetectionInformation::DischargeStatus <= @sysvar::GBT27930::Charger::Messages::ChargerDetectionInformation::DischargeStatus::DischargingInProgress)
    {
      @sysvar::GBT27930::Charger::Messages::ChargerDetectionInformation::DischargeStatus++;
      writeLineEx(1,1,"Charger: Update ChargerDetectionInformation.DischargeStatus to state %d.", @sysvar::GBT27930::Charger::Messages::ChargerDetectionInformation::DischargeStatus);
    }
  }
  else
  {
    sentChargerDetectionInformationCounter++;
  }
}

