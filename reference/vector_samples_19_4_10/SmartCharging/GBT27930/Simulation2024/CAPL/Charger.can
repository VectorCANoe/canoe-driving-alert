  $Charger.GBT27930_2_2024.ChargerSupportFunction.Authentication.FDCSupport3 = 0x01;

  $Charger.GBT27930_2_2024.ChargerSupportFunction.Booking.FDCSupport1 = 0x01;

  $Charger.GBT27930_2_2024.ChargerSupportFunction.OutputCircuitDetection.FDCSupport1 = 0x01;

  $Charger.GBT27930_2_2024.ChargerSupportFunction.PowerSupplyMode.FDCSupport1 = 0x01;

  // both modules for precharging FDC1 and FDC2 are per default supported
  $Charger.GBT27930_2_2024.ChargerSupportFunction.PreChargingAndEnergyTransmission.FDCSupport1 = 0x01;
  $Charger.GBT27930_2_2024.ChargerSupportFunction.PreChargingAndEnergyTransmission.FDCSupport2 = 0x01;

  $Charger.GBT27930_2_2024.ChargerSupportFunction.EndMessage.FDCSupport1 = 0x01;
}

void SendChargerPhaseRequest()
{
  switch(currentChargerPhase)
  {
    case kInitial:
    case kVersionNegotiation:
      writeLineEx(-3,1,"Logic Error: There is no PhaseAcknowledge before the function module FunctionNegotiaton");
      break;
    case kFunctionNegotiationPhase:
      $Charger.GBT27930_2_2024.ChargerPhaseRequest.Phase = _GBT27930::DataTypes::PhaseTypeEncoding::parameter_configuration_charging_mode;
      break;
    case kParameterConfigurationPhase:
      if (skipAuthentication && skipScheduling) {$Charger.GBT27930_2_2024.ChargerPhaseRequest.Phase = _GBT27930::DataTypes::PhaseTypeEncoding::output_circuit_detection;}
      else if (skipAuthentication) {$Charger.GBT27930_2_2024.ChargerPhaseRequest.Phase = _GBT27930::DataTypes::PhaseTypeEncoding::scheduling_vehicle_defined_start_time;}
      else 
      {
        switch (@sysvar::GBT27930::Charger::Authentication::PreferedAuthenticationMethod)
        {
          case sysvar::GBT27930::Charger::Authentication::PreferedAuthenticationMethod::Scan:
            $Charger.GBT27930_2_2024.ChargerPhaseRequest.Phase = _GBT27930::DataTypes::PhaseTypeEncoding::authentication_scan_code_swipe_card;
            break;
          case sysvar::GBT27930::Charger::Authentication::PreferedAuthenticationMethod::EVIN:
            $Charger.GBT27930_2_2024.ChargerPhaseRequest.Phase = _GBT27930::DataTypes::PhaseTypeEncoding::authentication_scan_evin_authentication;
            break;
          case sysvar::GBT27930::Charger::Authentication::PreferedAuthenticationMethod::Cloud:
            $Charger.GBT27930_2_2024.ChargerPhaseRequest.Phase = _GBT27930::DataTypes::PhaseTypeEncoding::authentication_scan_cloud_authentication;
            break;
        }
      }
      break;
    case kAuthenticationPhase:
      if (skipScheduling)
      {
        $Charger.GBT27930_2_2024.ChargerPhaseRequest.Phase = _GBT27930::DataTypes::PhaseTypeEncoding::output_circuit_detection;
      }
      else
      {
        $Charger.GBT27930_2_2024.ChargerPhaseRequest.Phase = _GBT27930::DataTypes::PhaseTypeEncoding::scheduling_vehicle_defined_start_time;
      }
      break;
    case kSchedulingPhase:
      $Charger.GBT27930_2_2024.ChargerPhaseRequest.Phase = _GBT27930::DataTypes::PhaseTypeEncoding::output_circuit_detection;
      break;
    case kOutputCircuitDetectionPhase:
      if (skipPowerSupply)
      {
        $Charger.GBT27930_2_2024.ChargerPhaseRequest.Phase = _GBT27930::DataTypes::PhaseTypeEncoding::precharge_and_energy_transfer_charging;
      } else {
        $Charger.GBT27930_2_2024.ChargerPhaseRequest.Phase = _GBT27930::DataTypes::PhaseTypeEncoding::power_supply_mode;
      }
      break;
    case kPowerSupplyModePhase:
      $Charger.GBT27930_2_2024.ChargerPhaseRequest.Phase = _GBT27930::DataTypes::PhaseTypeEncoding::precharge_and_energy_transfer_charging;
      break;
    case kPreChargingAndEnergyTransferPhase:
      $Charger.GBT27930_2_2024.ChargerPhaseRequest.Phase = _GBT27930::DataTypes::PhaseTypeEncoding::end_message;
      break;
    case kEndPhase:
      // this is only triggerd when the Charging process is abnormal
      $Charger.GBT27930_2_2024.ChargerPhaseRequest.Phase = _GBT27930::DataTypes::PhaseTypeEncoding::end_message;
      isAbnormalEnd = 1;
      break;
    default:
      $Charger.GBT27930_2_2024.ChargerPhaseRequest;
      break;
  }
}

