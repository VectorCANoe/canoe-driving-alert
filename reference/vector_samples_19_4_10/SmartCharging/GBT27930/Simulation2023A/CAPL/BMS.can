/////////////////////////////////////////////////////////////////////////////////////
/*-----------------------------------Presentation----------------------------------*/
/////////////////////////////////////////////////////////////////////////////////////

void ResetAllGroups()
{
  setDefaultControlColors("BMS", "groupBHM");
  setDefaultControlColors("BMS", "groupBRM");
  setDefaultControlColors("BMS", "groupBCP");
  setDefaultControlColors("BMS", "groupBRO");
  setDefaultControlColors("BMS", "groupBCL");
  setDefaultControlColors("BMS", "groupBCS");
  setDefaultControlColors("BMS", "groupBSM");
  setDefaultControlColors("BMS", "groupBST");
  setDefaultControlColors("BMS", "groupBSD");
}

on timer tmrUpdatePanel
{
  long clrInactive, clrActive, clrChanging, clrBackActive;
  clrInactive = MakeRGB(0,0,0);
  clrActive = MakeRGB(0, 128, 0);
  clrChanging = MakeRGB(128, 0, 0);
  clrBackActive = MakeRGB(224, 224, 255);
  
  if(lastBmsStatus != currentBmsStatus)
  {
    switch(currentBmsStatus)
    {
      case 3: //Sending of BHM
        setControlForeColor("BMS", "groupBHM"   , clrActive);
        setControlBackColor("BMS", "groupBHM"   , clrBackActive);
        break;
        
      case 4: //Sending of BHM; delayed start of BRM is initiated
        setControlForeColor("BMS", "groupBHM"   , clrChanging);
        setControlBackColor("BMS", "groupBHM"   , clrBackActive);
        break;
        
      case 5: //Sending of BRM 
        setDefaultControlColors("BMS", "groupBHM");

        setControlForeColor("BMS", "groupBRM"   , clrActive);
        setControlBackColor("BMS", "groupBRM"   , clrBackActive);
        break;

      case 6: //Sending of BRM; delayed start of BCP is initiated
        setControlForeColor("BMS", "groupBRM"   , clrChanging);
        setControlBackColor("BMS", "groupBRM"   , clrBackActive);
        break;
        
        
      case 7: //Sending of BCP
        setDefaultControlColors("BMS", "groupBRM");

        setControlForeColor("BMS", "groupBCP"   , clrActive);
        setControlBackColor("BMS", "groupBCP"   , clrBackActive);
        break;

      case 8: //Sending of BCP; delayed start of BRO (Not ready) is initiated
        setControlForeColor("BMS", "groupBCP"   , clrChanging);
        setControlBackColor("BMS", "groupBCP"   , clrBackActive);
        break;
        
      case 9: //Sending of BRO (Not Ready for charging); delayed start of BRO (Ready for charging) is initiated
        setDefaultControlColors("BMS", "groupBCP");

        setControlForeColor("BMS", "groupBCP"   , clrActive);
        setControlBackColor("BMS", "groupBCP"   , clrBackActive);
        CHA_open_close_K5K6(CLOSE); //T12
        break;

      case 10: //Sending of BRO(Ready for charging)
        setControlForeColor("BMS", "groupBRO"   , clrActive);
        setControlBackColor("BMS", "groupBRO"   , clrBackActive);
        break;
        
      case 11: //Sending of BRO (Ready for charging); delayed start of BCL is initiated
        setControlForeColor("BMS", "groupBRO"   , clrChanging);
        setControlBackColor("BMS", "groupBRO"   , clrBackActive);
        break;
        
      case 30: //Sending of BCL
        setDefaultControlColors("BMS", "groupBRO");

        setControlForeColor("BMS", "groupBCL"   , clrActive);
        setControlBackColor("BMS", "groupBCL"   , clrBackActive);
        break;        
        
      case 31: //Sending of BCL; delayed start of BCS is initiated
        setDefaultControlColors("BMS", "groupBRO");

        setControlForeColor("BMS", "groupBCL"   , clrActive);
        setControlBackColor("BMS", "groupBCL"   , clrBackActive);
        break;        
        
      case 12: //Sending of BCL und BCS
      case 13: //Sending of BCL und BCS; delayed start of BSM is initiated
        setDefaultControlColors("BMS", "groupBRO");

        setControlForeColor("BMS", "groupBCL"   , clrActive);
        setControlBackColor("BMS", "groupBCL"   , clrBackActive);
        setControlForeColor("BMS", "groupBCS"   , clrActive);
        setControlBackColor("BMS", "groupBCS"   , clrBackActive);
        break;

      case 14: //Sending of BCL, BCS and BSM
        setControlForeColor("BMS", "groupBCL"   , clrActive);
        setControlBackColor("BMS", "groupBCL"   , clrBackActive);
        setControlForeColor("BMS", "groupBCS"   , clrActive);
        setControlBackColor("BMS", "groupBCS"   , clrBackActive);
        setControlForeColor("BMS", "groupBSM"   , clrActive);
        setControlBackColor("BMS", "groupBSM"   , clrBackActive);
        break;

      case 15: //Sending of BCL, BCS and BSM; delayed start of BST is initiated
        setControlForeColor("BMS", "groupBCL"   , clrChanging);
        setControlBackColor("BMS", "groupBCL"   , clrBackActive);
        setControlForeColor("BMS", "groupBCS"   , clrChanging);
        setControlBackColor("BMS", "groupBCS"   , clrBackActive);
        setControlForeColor("BMS", "groupBSM"   , clrChanging);
        setControlBackColor("BMS", "groupBSM"   , clrBackActive);
        break;
        
      case 16: //Sending of BST
        setDefaultControlColors("BMS", "groupBCL");
        setDefaultControlColors("BMS", "groupBCS");
        setDefaultControlColors("BMS", "groupBSM");

        setControlForeColor("BMS", "groupBST"   , clrActive);
        setControlBackColor("BMS", "groupBST"   , clrBackActive);
        StartTimerReadyToOpen_K5_K6(300);
        break;
        
      case 17: //Sending of BST; delayed start of BSD is initiated
        setDefaultControlColors("BMS", "groupBCL");
        setDefaultControlColors("BMS", "groupBCS");
        setDefaultControlColors("BMS", "groupBSM");

        setControlForeColor("BMS", "groupBST"   , clrChanging);
        setControlBackColor("BMS", "groupBST"   , clrBackActive);
        StartTimerReadyToOpen_K5_K6(10000);
        break;
        
      case 18: //Sending of BSD; delayed stop of BSD is initiated 
        setDefaultControlColors("BMS", "groupBCL");
        setDefaultControlColors("BMS", "groupBCS");
        setDefaultControlColors("BMS", "groupBSM");
        setDefaultControlColors("BMS", "groupBST");

        setControlForeColor("BMS", "groupBSD"   , clrActive);
        setControlBackColor("BMS", "groupBSD"   , clrBackActive);
        break;

      case 19: //End of charging
        setDefaultControlColors("BMS", "groupBSD");
        break;
        
      case 50: //Sending of CEM
        ResetAllGroups();
        setControlForeColor("BMS", "groupBEM"   , clrActive);
        setControlBackColor("BMS", "groupBEM"   , clrBackActive);
        break;

    }
    lastBmsStatus = currentBmsStatus;
  }  
  setTimer(tmrUpdatePanel, 100);
}

