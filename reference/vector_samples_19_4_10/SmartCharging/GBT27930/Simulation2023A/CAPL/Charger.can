  $Charger.CategoryA.CTS.TimeSyncInformation.Minute.phys = @sysvar::GBT27930::Charger::CTS::svTimeSyncInformationMinute;
  $Charger.CategoryA.CTS.TimeSyncInformation.Hour.phys = @sysvar::GBT27930::Charger::CTS::svTimeSyncInformationHour;
  $Charger.CategoryA.CTS.TimeSyncInformation.Day.phys = @sysvar::GBT27930::Charger::CTS::svTimeSyncInformationDay;
  $Charger.CategoryA.CTS.TimeSyncInformation.Month.phys = @sysvar::GBT27930::Charger::CTS::svTimeSyncInformationMonth;
  $Charger.CategoryA.CTS.TimeSyncInformation.Year.phys = @sysvar::GBT27930::Charger::CTS::svTimeSyncInformationYear;
}

void SendCML()
{
  $Charger.CategoryA.CML.MaxChargingCurrent.phys = @sysvar::GBT27930::Charger::CML::svMaxOutputCurrent;
  $Charger.CategoryA.CML.MinChargingCurrent.phys = @sysvar::GBT27930::Charger::CML::svMinOutputCurrent;
  $Charger.CategoryA.CML.MaxChargingVoltage.phys = @sysvar::GBT27930::Charger::CML::svMaxOutputVoltage;
  $Charger.CategoryA.CML.MinChargingVoltage.phys = @sysvar::GBT27930::Charger::CML::svMinOutputVoltage;
}

void SendCRO()
{
  $Charger.CategoryA.CRO.ChargerReadyForCharging = @sysvar::GBT27930::Charger::CRO::svReadyForCharging;
}

void SendCST()
{
  $Charger.CategoryA.CST.ConditionReached = @sysvar::GBT27930::Charger::CST::svConditionReached;
  $Charger.CategoryA.CST.ManualSuspension = @sysvar::GBT27930::Charger::CST::svManualSuspension;
  $Charger.CategoryA.CST.FaultSuspension = @sysvar::GBT27930::Charger::CST::svFaultSuspension;
  $Charger.CategoryA.CST.BmsActivelySuspends = @sysvar::GBT27930::Charger::CST::svBmsActivelySuspends;
  $Charger.CategoryA.CST.ChargerOverTemp = @sysvar::GBT27930::Charger::CST::svChargerOverTemp;
  $Charger.CategoryA.CST.ChargingConnectorFault = @sysvar::GBT27930::Charger::CST::svChargingConnectorFault;
  $Charger.CategoryA.CST.ChargerInternalOverTemp = @sysvar::GBT27930::Charger::CST::svChargerInternalOverTemp;
  $Charger.CategoryA.CST.CannotSupplyRequiredPower = @sysvar::GBT27930::Charger::CST::svCannotSupplyRequiredPower;
  $Charger.CategoryA.CST.EmergencyStop = @sysvar::GBT27930::Charger::CST::svEmergencyStop;
  $Charger.CategoryA.CST.OtherFault = @sysvar::GBT27930::Charger::CST::svOtherFault;
  $Charger.CategoryA.CST.SelfCheckFault = @sysvar::GBT27930::Charger::CST::svSelfCheckFault;
  $Charger.CategoryA.CST.PreChargeFault = @sysvar::GBT27930::Charger::CST::svPreChargeFault;
  $Charger.CategoryA.CST.CurrentMismatchError = @sysvar::GBT27930::Charger::CST::svCurrentMismatchError;
  $Charger.CategoryA.CST.AbnormalVoltageError = @sysvar::GBT27930::Charger::CST::svAbnormalVoltageError;
  $Charger.CategoryA.CST.ChargingParametersMismatchError = @sysvar::GBT27930::Charger::CST::svChargingParametersMismatchError;
}

void SendCRM()
{
  char buf[4];
  dword textAsDWord;

  sysGetVariableString(sysvar::GBT27930::Charger::svChargerLocation, buf, elcount(buf));
  $Charger.CategoryA.CRM.ChargerLocation = buf;
  $Charger.CategoryA.CRM.ChargerNumber = @sysvar::GBT27930::Charger::CRM::svChargerNumber;
  $Charger.CategoryA.CRM.BMS_RecognitionResult = @sysvar::GBT27930::Charger::CRM::svBMSRecognitionResult;
}

void SendCEM()
{
  $Charger.CategoryA.CEM.Timeout_BRM = @sysvar::GBT27930::Charger::CEM::svTimeout_BRM;
  $Charger.CategoryA.CEM.Timeout_BCP = @sysvar::GBT27930::Charger::CEM::svTimeout_BCP;
  $Charger.CategoryA.CEM.Timeout_BRO = @sysvar::GBT27930::Charger::CEM::svTimeout_BRO;
  $Charger.CategoryA.CEM.Timeout_BCS = @sysvar::GBT27930::Charger::CEM::svTimeout_BCS;
  $Charger.CategoryA.CEM.Timeout_BCL = @sysvar::GBT27930::Charger::CEM::svTimeout_BCL;
  $Charger.CategoryA.CEM.Timeout_BST = @sysvar::GBT27930::Charger::CEM::svTimeout_BST;
  $Charger.CategoryA.CEM.Timeout_BSD = @sysvar::GBT27930::Charger::CEM::svTimeout_BSD;
  $Charger.CategoryA.CEM.Timeout_BSM = @sysvar::GBT27930::Charger::CEM::svTimeout_BSM;
}

/////////////////////////////////////////////////////////////////////////////////////
/*-----------------------------------Presentation----------------------------------*/
/////////////////////////////////////////////////////////////////////////////////////

void ResetAllGroups()
{
  setDefaultControlColors(gPanelName, "groupCHM");
  setDefaultControlColors(gPanelName, "groupCRM");
  setDefaultControlColors(gPanelName, "groupCML");
  setDefaultControlColors(gPanelName, "groupCTS");
  setDefaultControlColors(gPanelName, "groupCRO");
  setDefaultControlColors(gPanelName, "groupCCS");
  setDefaultControlColors(gPanelName, "groupCST");
  setDefaultControlColors(gPanelName, "groupCEM");
  setDefaultControlColors(gPanelName, "groupCSD");
}

on timer tmrUpdatePanel
{
  long clrInactive, clrActive, clrChanging, clrBackActive;
  clrInactive = MakeRGB(0,0,0);
  clrActive = MakeRGB(0, 128, 0);
  clrChanging = MakeRGB(128, 0, 0);
  clrBackActive = MakeRGB(224, 224, 255);
  
  if(lastChargerStatus != currentChargerStatus)
  {
    switch(currentChargerStatus)
    {
      case 1: //Sending of CHM
        setControlForeColor(gPanelName, "groupCHM"   , clrActive);
        setControlBackColor(gPanelName, "groupCHM"   , clrBackActive);        
        break;
        
      case 2: //Sending of CHM; delayed start of CRM (BMS is not recognized) is initiated
        setControlForeColor(gPanelName, "groupCHM"   , clrChanging);
        setControlBackColor(gPanelName, "groupCHM"   , clrBackActive);
        break;
        
      case 3: //Sending of CRM (BMS is not recognized)
        setDefaultControlColors(gPanelName, "groupCHM");

        setControlForeColor(gPanelName, "groupCRM"   , clrActive);
        setControlBackColor(gPanelName, "groupCRM"   , clrBackActive);
        
        break;

      case 4: //Sending of CRM (BMS is not recognized); delayed start of CRM (BMS is recognized) is initiated
      case 5: //Sending of CRM (BMS is recognized)
        break;

      case 6: //Sending of CRM (BMS is recognized); delayed start of CML is initiated
        setControlForeColor(gPanelName, "groupCRM"   , clrChanging);
        setControlBackColor(gPanelName, "groupCRM"   , clrBackActive);
        break;
        
      case 7: //Sending of CML
        setDefaultControlColors(gPanelName, "groupCRM");

        setControlForeColor(gPanelName, "groupCML"   , clrActive);
        setControlBackColor(gPanelName, "groupCML"   , clrBackActive);
        setControlForeColor(gPanelName, "groupCTS"   , clrActive);
        setControlBackColor(gPanelName, "groupCTS"   , clrBackActive);
        break;

      case 8: //Sending of CML; delayed start of CRO (Not ready for charging) is initiated
        setControlForeColor(gPanelName, "groupCML"   , clrChanging);
        setControlBackColor(gPanelName, "groupCML"   , clrBackActive);
        setControlForeColor(gPanelName, "groupCTS"   , clrChanging);
        setControlBackColor(gPanelName, "groupCTS"   , clrBackActive);
        break;
        
      case 9: //Sending of CRO (Not ready for charging); delayed start of CRO (Ready for charging) is initiated
        setDefaultControlColors(gPanelName, "groupCML");
        setDefaultControlColors(gPanelName, "groupCTS");

        setControlForeColor(gPanelName, "groupCRO"   , clrActive);
        setControlBackColor(gPanelName, "groupCRO"   , clrBackActive);
        break;
        
      case 10: //Sending of CRO (Ready for charging)
        break;
        
      case 11: //Sending of CRO (Ready for charging); delayed start of CCS is initiated
        setControlForeColor(gPanelName, "groupCRO"   , clrChanging);
        setControlBackColor(gPanelName, "groupCRO"   , clrBackActive);
        break;

      case 12: //Sending of CCS
        setDefaultControlColors(gPanelName, "groupCRO");
        
        setControlForeColor(gPanelName, "groupCCS"   , clrActive);
        setControlBackColor(gPanelName, "groupCCS"   , clrBackActive);
        break;

      case 13: //Sending of CCS; delayed start of CST is initiated
        setControlForeColor(gPanelName, "groupCCS"   , clrChanging);
        setControlBackColor(gPanelName, "groupCCS"   , clrBackActive);
        break;
        
      case 14: //Sending of CST
        setDefaultControlColors(gPanelName, "groupCCS");

        setControlForeColor(gPanelName, "groupCST"   , clrActive);
        setControlBackColor(gPanelName, "groupCST"   , clrBackActive);
        StartTimerReadyToOpen_K1_K2(100);
        break;
        
      case 15: //Sending of CST; delayed start of CSD is initiated
        setControlForeColor(gPanelName, "groupCST"   , clrChanging);
        setControlBackColor(gPanelName, "groupCST"   , clrBackActive);
        StartTimerReadyToOpen_K1_K2(100);
        break;
        
      case 16: //Sending of CSD; delayed stop of CSD is initiated 
        setDefaultControlColors(gPanelName, "groupCST");

        setControlForeColor(gPanelName, "groupCSD"   , clrActive);
        setControlBackColor(gPanelName, "groupCSD"   , clrBackActive);
        break;

      case 17: //End of charging
        setDefaultControlColors(gPanelName, "groupCSD");
        HV_source_reset();
        if(CHA_measure_voltage_CP1() >= 4.1 || CHA_measure_voltage_CP1() <= 3.9) //~4V
          StartTimerReadyToOpen_K1_K2(50);
        else
          StartTimerReadyToOpen_K1_K2(100);
        CHA_open_close_K3K4(OPEN);
        break;
        
      case 50: //Sending of CEM
        ResetAllGroups();
        setControlForeColor(gPanelName, "groupCEM"   , clrActive);
        setControlBackColor(gPanelName, "groupCEM"   , clrBackActive);
        break;
    }
    lastChargerStatus = currentChargerStatus;
  }  
  setTimer(tmrUpdatePanel, 100);
}

void SetChargerPanelColor(int measurementState)
{
  long foreColor;
  long backColor;
  // measurementState == Running - default state
  foreColor = MakeRGB(0, 0, 0);
  backColor = MakeRGB(255, 255, 255);
  
  if(measurementState == Stop)
  {
    foreColor = MakeRGB(112, 112, 112);
    backColor = MakeRGB(224, 224, 224);
  }
  setControlForeColor(gPanelName, "editK3K4toChm"        , foreColor);
  setControlForeColor(gPanelName, "editCrmNotRecognized" , foreColor);
  setControlForeColor(gPanelName, "editCrmRecognized"    , foreColor);
  setControlForeColor(gPanelName, "editCmlCts"           , foreColor);
  setControlForeColor(gPanelName, "editCroReady"         , foreColor);
  setControlForeColor(gPanelName, "editCroNotReady"      , foreColor);
  setControlForeColor(gPanelName, "editCcs"              , foreColor);
  setControlForeColor(gPanelName, "editCst"              , foreColor);
  setControlForeColor(gPanelName, "editCsd"              , foreColor);
  setControlForeColor(gPanelName, "editEnd"              , foreColor);
  setControlForeColor(gPanelName, "editMissBcp"          , foreColor);
  setControlForeColor(gPanelName, "editMissBroNotReady"  , foreColor);
  setControlForeColor(gPanelName, "editMissBroReady"     , foreColor);
  setControlForeColor(gPanelName, "editMissBcl"          , foreColor);
  setControlForeColor(gPanelName, "editMissBcs"          , foreColor);
  setControlForeColor(gPanelName, "editMissBst"          , foreColor);
  setControlForeColor(gPanelName, "editMissBrm"          , foreColor);
  setControlForeColor(gPanelName, "editMissBsd"          , foreColor);
  
  
  setControlBackColor(gPanelName, "editK3K4toChm"        , backColor);
  setControlBackColor(gPanelName, "editCrmNotRecognized" , backColor);
  setControlBackColor(gPanelName, "editCrmRecognized"    , backColor);
  setControlBackColor(gPanelName, "editCmlCts"           , backColor);
  setControlBackColor(gPanelName, "editCroReady"         , backColor);
  setControlBackColor(gPanelName, "editCroNotReady"      , backColor);
  setControlBackColor(gPanelName, "editCcs"              , backColor);
  setControlBackColor(gPanelName, "editCst"              , backColor);
  setControlBackColor(gPanelName, "editCsd"              , backColor);
  setControlBackColor(gPanelName, "editEnd"              , backColor);
  setControlBackColor(gPanelName, "editMissBcp"          , backColor);
  setControlBackColor(gPanelName, "editMissBroNotReady"  , backColor);
  setControlBackColor(gPanelName, "editMissBroReady"     , backColor);
  setControlBackColor(gPanelName, "editMissBcl"          , backColor);
  setControlBackColor(gPanelName, "editMissBcs"          , backColor);
  setControlBackColor(gPanelName, "editMissBst"          , backColor);
  setControlBackColor(gPanelName, "editMissBrm"          , backColor);
  setControlBackColor(gPanelName, "editMissBsd"          , backColor);
}

void SetChargingStationPicturesVisibility(enum eMode Mode)
{  
  If(Mode == Ready)
  {
   SetControlVisibility(gPanelName, "pictureChargingStationReady", 1);
   SetControlVisibility(gPanelName, "pictureChargingStationCharging", 0);
   SetControlVisibility(gPanelName, "pictureChargingStationError", 0);
  }
  else If(Mode == Charging)
  {
   SetControlVisibility(gPanelName, "pictureChargingStationReady", 0);
   SetControlVisibility(gPanelName, "pictureChargingStationCharging", 1);
   SetControlVisibility(gPanelName, "pictureChargingStationError", 0);
  }
  else If(Mode == Error)
  {
   SetControlVisibility(gPanelName, "pictureChargingStationReady", 0);
   SetControlVisibility(gPanelName, "pictureChargingStationCharging", 0);
   SetControlVisibility(gPanelName, "pictureChargingStationError", 1);
  }
}

/////////////////////////////////////////////////////////////////////////////////////
/*-----------------------------------Key Inputs------------------------------------*/
/////////////////////////////////////////////////////////////////////////////////////

on key 'n'
{
  if(@GBT27930::svStart == 0)
  {
    @GBT27930::svStart = 1;
  }
  else
  {
    @GBT27930::svStart = 0;
  }
}
