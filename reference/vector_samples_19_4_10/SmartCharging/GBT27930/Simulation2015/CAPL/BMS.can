  cableStatus = unknown;
  setControlForeColor("BMS", "btnStoreSettings", MakeRGB(0, 128, 0));
  color = MakeRGB(0, 0, 0);
  //Delay
  setControlForeColor("BMS", "editChmToBhm"               , color);
  setControlForeColor("BMS", "editCrmNotRecognizedToBrm"  , color);
  setControlForeColor("BMS", "editCrmRecognizedToBcp"     , color);
  setControlForeColor("BMS", "editCmlToBroNotReady"       , color);
  setControlForeColor("BMS", "editBroNotReadyToBroReady"  , color);
  setControlForeColor("BMS", "editCroReadyToBcl"          , color);
  setControlForeColor("BMS", "editBclToBcs"               , color);
  setControlForeColor("BMS", "editCcsToBsm"               , color);
  setControlForeColor("BMS", "editCstToBsd"               , color);
  setControlForeColor("BMS", "editCstToBst"               , color);
  setControlForeColor("BMS", "editBstToBsd"               , color);
  setControlForeColor("BMS", "editBsdToEnd"               , color);
  //Missing
  setControlForeColor("BMS", "editMissChm"              , color);
  setControlForeColor("BMS", "editMissCrmNotRecognized" , color);
  setControlForeColor("BMS", "editMissCrmRecognized"    , color);
  setControlForeColor("BMS", "editMissCml"              , color);
  setControlForeColor("BMS", "editMissCroNotReady"      , color);
  setControlForeColor("BMS", "editMissCroReady"         , color);
  setControlForeColor("BMS", "editMissCcs"              , color);
  setControlForeColor("BMS", "editMissCst"              , color);
  setControlForeColor("BMS", "editMissCsd"              , color);
  color = MakeRGB(255, 255, 255);
  //Delay
  setControlBackColor("BMS", "editChmToBhm"        , color);
  setControlBackColor("BMS", "editCrmNotRecognizedToBrm"        , color);
  setControlBackColor("BMS", "editCrmRecognizedToBcp"        , color);
  setControlBackColor("BMS", "editCmlToBroNotReady", color);
  setControlBackColor("BMS", "editBroNotReadyToBroReady"   , color);
  setControlBackColor("BMS", "editCroReadyToBcl"     , color);
  setControlBackColor("BMS", "editBclToBcs"        , color);
  setControlBackColor("BMS", "editCcsToBsm"        , color);
  setControlBackColor("BMS", "editCstToBsd"        , color);
  setControlBackColor("BMS", "editCstToBst"        , color);
  setControlBackColor("BMS", "editBstToBsd"        , color);
  setControlBackColor("BMS", "editBsdToEnd"        , color);
  //Missing
  setControlBackColor("BMS", "editMissChm"              , color);
  setControlBackColor("BMS", "editMissCrmNotRecognized" , color);
  setControlBackColor("BMS", "editMissCrmRecognized"    , color);
  setControlBackColor("BMS", "editMissCml"              , color);
  setControlBackColor("BMS", "editMissCroNotReady"      , color);
  setControlBackColor("BMS", "editMissCroReady"         , color);
  setControlBackColor("BMS", "editMissCcs"              , color);
  setControlBackColor("BMS", "editMissCst"              , color);
  setControlBackColor("BMS", "editMissCsd"              , color);
}

