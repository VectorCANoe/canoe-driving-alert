/*@!Encoding:1252*/

variables
{
  enum Connector
  {
    OPEN = 0,
    CLOSE = 1
  };   
  const float cRes_R1 = 1000.0;
  const float cRes_R2 = 1000.0;
  const float cRes_R3 = 1000.0;
  const float cAux_voltage = 12.0;
  
  msTimer tTimeoutReadyToOpen_K1_K2;
  msTimer tCurrentMonitoring;
}

on sysvar_update sysvar::VTS::EVSE_VT2004_Ch3_CC1::CurVoltage
{
  @sysvar::GBT27930::Control::voltage_CP1 = @sysvar::VTS::EVSE_VT2004_Ch3_CC1::CurVoltage;
}

on timer tCurrentMonitoring
{
  if(_CheckCanBeOpened_K1_K2_() == 1)
  {
    HV_open_close_K1K2(OPEN);
    cancelTimer(tTimeoutReadyToOpen_K1_K2);
    writeLineEx(-3, 3, "Current < 5A measured, opening K1_K2 now");
  }
  
  if(isTimerActive(tTimeoutReadyToOpen_K1_K2))
    tCurrentMonitoring.set(5); //Check again in 5ms
}

on timer tTimeoutReadyToOpen_K1_K2
{
  writeLineEx(-3, 3, "Current value >= 5A measured (value: %f), K1_K2 could not be opened within timeout. Opening now", HV_measure_DC_I());
  HV_open_close_K1K2(OPEN);
}

long _CheckCanBeOpened_K1_K2_()
{
  if(HV_measure_DC_I() < 5.0)
    return 1;
  
  return 0;
}

export void StartTimerReadyToOpen_K1_K2(long timeoutMs)
{
  if(_CheckCanBeOpened_K1_K2_() == 1)
  {
    HV_open_close_K1K2(OPEN);
    writeLineEx(-3, 3, "K1_K2 can be opened immediately");
  }
  else
  {
    if(!isTimerActive(tTimeoutReadyToOpen_K1_K2))
      setTimer(tTimeoutReadyToOpen_K1_K2, timeoutMs);
    setTimer(tCurrentMonitoring, 5);
  }
}

//--------------------------------------------- functions of the GBT HW interface ----------------------------------------------------------------------
//Connects to the bus bar to provide 12 V; connects R1 to BMS via CC1
export void Connect_CC1()
{
  @sysvar::VTS::EVSE_VT2004_Ch3_CC1::RelayOrgSensor = 0;
  @sysvar::VTS::EVSE_VT2004_Ch3_CC1::RelayShortCircuit = 0;
  @sysvar::VTS::EVSE_VT2004_Ch3_CC1::RelayBusBar1A = 1;
  @sysvar::VTS::EVSE_VT2004_Ch3_CC1::RelayBusBar1B = 0;
  @sysvar::VTS::EVSE_VT2004_Ch3_CC1::RelayBusBar2A = 0;
  @sysvar::VTS::EVSE_VT2004_Ch3_CC1::RelayBusBar2B = 0;
  sysvar::VTS::EVSE_VT2004_Ch3_CC1.SetStimulationMode(eVTSStimulationModeResistanceGreater);
  @sysvar::VTS::EVSE_VT2004_Ch3_CC1::Resistor = 1000;
  
  @sysvar::VTS::EVSE_VT2004_Ch4_CC1_::RelayOrgSensor = 0;
  @sysvar::VTS::EVSE_VT2004_Ch4_CC1_::RelayShortCircuit = 0;
  @sysvar::VTS::EVSE_VT2004_Ch4_CC1_::RelayBusBar1A = 0;
  @sysvar::VTS::EVSE_VT2004_Ch4_CC1_::RelayBusBar1B = 0;
  @sysvar::VTS::EVSE_VT2004_Ch4_CC1_::RelayBusBar2A = 0;
  @sysvar::VTS::EVSE_VT2004_Ch4_CC1_::RelayBusBar2B = 1;
  sysvar::VTS::EVSE_VT2004_Ch4_CC1_.SetStimulationMode(eVTSStimulationModeResistanceGreater);
  @sysvar::VTS::EVSE_VT2004_Ch4_CC1_::Resistor = 1000;
//  writeEx(-3,3, "Test system: Connect_CC1 called");
}


//Disconnects from the bus bar (no voltage at check point 1)
export void Disconnect_CC1()
{
  @sysvar::VTS::EVSE_VT2004_Ch3_CC1::RelayOrgSensor = 0;
  @sysvar::VTS::EVSE_VT2004_Ch3_CC1::RelayShortCircuit = 0;
  @sysvar::VTS::EVSE_VT2004_Ch3_CC1::RelayBusBar1A = 0;
  @sysvar::VTS::EVSE_VT2004_Ch3_CC1::RelayBusBar1B = 0;
  @sysvar::VTS::EVSE_VT2004_Ch3_CC1::RelayBusBar2A = 0;
  @sysvar::VTS::EVSE_VT2004_Ch3_CC1::RelayBusBar2B = 0;
  
  @sysvar::VTS::EVSE_VT2004_Ch4_CC1_::RelayOrgSensor = 0;
  @sysvar::VTS::EVSE_VT2004_Ch4_CC1_::RelayShortCircuit = 0;
  @sysvar::VTS::EVSE_VT2004_Ch4_CC1_::RelayBusBar1A = 0;
  @sysvar::VTS::EVSE_VT2004_Ch4_CC1_::RelayBusBar1B = 0;
  @sysvar::VTS::EVSE_VT2004_Ch4_CC1_::RelayBusBar2A = 0;
  @sysvar::VTS::EVSE_VT2004_Ch4_CC1_::RelayBusBar2B = 0; 
}

export void Connect_CC2()
{
  @sysvar::VTS::EVSE_VT2004_Ch1_CC2::RelayOrgSensor = 0;
  @sysvar::VTS::EVSE_VT2004_Ch1_CC2::RelayShortCircuit = 0;
  @sysvar::VTS::EVSE_VT2004_Ch1_CC2::RelayBusBar1A = 0;
  @sysvar::VTS::EVSE_VT2004_Ch1_CC2::RelayBusBar1B = 0;
  @sysvar::VTS::EVSE_VT2004_Ch1_CC2::RelayBusBar2A = 0;
  @sysvar::VTS::EVSE_VT2004_Ch1_CC2::RelayBusBar2B = 1;
  sysvar::VTS::EVSE_VT2004_Ch1_CC2.SetStimulationMode(eVTSStimulationModeResistanceGreater);
  @sysvar::VTS::EVSE_VT2004_Ch1_CC2::Resistor = 1000;
//  writeEx(-3,3, "Test system: Connect_CC2 called");
}


//Disconnects from the bus bar (no voltage at check point 1)
export void Disconnect_CC2()
{
  @sysvar::VTS::EVSE_VT2004_Ch1_CC2::RelayOrgSensor = 0;
  @sysvar::VTS::EVSE_VT2004_Ch1_CC2::RelayShortCircuit = 0;
  @sysvar::VTS::EVSE_VT2004_Ch1_CC2::RelayBusBar1A = 0;
  @sysvar::VTS::EVSE_VT2004_Ch1_CC2::RelayBusBar1B = 0;
