export void CHA_open_close_S(int openClose)
{
  @sysvar::VTS::EVSE_VT2004_Ch4_CC1_::RelayOrgSensor = 0;
  @sysvar::VTS::EVSE_VT2004_Ch4_CC1_::RelayShortCircuit = 0;
  @sysvar::VTS::EVSE_VT2004_Ch4_CC1_::RelayBusBar1A = 0;
  @sysvar::VTS::EVSE_VT2004_Ch4_CC1_::RelayBusBar1B = 0;
  @sysvar::VTS::EVSE_VT2004_Ch4_CC1_::RelayBusBar2A = 0;

  if (openClose == CLOSE)
    @sysvar::VTS::EVSE_VT2004_Ch4_CC1_::RelayBusBar2B = 1;
  else if (openClose == OPEN)
    @sysvar::VTS::EVSE_VT2004_Ch4_CC1_::RelayBusBar2B = 0;

//  writeEx(-3,3, "Test system: CHA_open_close_S called, openClose %d", openClose);
}

