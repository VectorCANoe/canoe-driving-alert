export void CHA_set_voltage_CP1(double voltage)
{
  if(isSimulated())
    @sysvar::GBT27930::Control::voltage_CP1 = voltage;
  //else
    //voltage is currently taken from VT power supply and cannot be changed
} 

export double CHA_measure_voltage_CP1()
{
  return @sysvar::GBT27930::Control::voltage_CP1;
}

export void CHA_set_resistance_R1(double resistance)
{
  if(resistance < 1)
    sysvar::VTS::EVSE_VT2004_Ch3_CC1.SetStimulationMode(eVTSStimulationModeNone);
  else
    sysvar::VTS::EVSE_VT2004_Ch3_CC1.SetStimulationMode(eVTSStimulationModeResistanceGreater);
  
  @sysvar::VTS::EVSE_VT2004_Ch3_CC1::Resistor = resistance;
//  writeEx(-3,3, "Test system: CHA_set_resistance_R1 called");
}

export void CHA_set_resistance_R2(double resistance)
{
  if(resistance < 1)
    sysvar::VTS::EVSE_VT2004_Ch4_CC1_.SetStimulationMode(eVTSStimulationModeNone);
  else
    sysvar::VTS::EVSE_VT2004_Ch4_CC1_.SetStimulationMode(eVTSStimulationModeResistanceGreater);
  
  @sysvar::VTS::EVSE_VT2004_Ch4_CC1_::Resistor = resistance;
//  writeEx(-3,3, "Test system: CHA_set_resistance_R2 called");
}

export void CHA_set_resistance_R3(double resistance)
{
  if(resistance < 1)
    sysvar::VTS::EVSE_VT2004_Ch1_CC2.SetStimulationMode(eVTSStimulationModeNone);
  else
    sysvar::VTS::EVSE_VT2004_Ch1_CC2.SetStimulationMode(eVTSStimulationModeResistanceGreater);
  
  @sysvar::VTS::EVSE_VT2004_Ch1_CC2::Resistor = resistance;
//  writeEx(-3,3, "Test system: CHA_set_resistance_R3 called");
}
 
export void disconnect_resistances()
{
  sysvar::VTS::EVSE_VT2004_Ch1_CC2.SetStimulationMode(eVTSStimulationModeNone);
  sysvar::VTS::EVSE_VT2004_Ch2.SetStimulationMode(eVTSStimulationModeNone);
  sysvar::VTS::EVSE_VT2004_Ch3_CC1.SetStimulationMode(eVTSStimulationModeNone);
  sysvar::VTS::EVSE_VT2004_Ch4_CC1_.SetStimulationMode(eVTSStimulationModeNone);
}

