void FUNC_Get_EVACChargeLoopValues()
{
  if ($EV.ISO20.AC_ChargeLoop_Response.CLResControlModeElementId == 0)
  {
    if($EV.ISO20.AC_ChargeLoop_Response.CLResControlMode.Dynamic_AC_CLResControlMode.EVSEPresentActivePower.IsValid)
      @sysvar::EV_Sim::SysEV_PresentPower = $EV.ISO20.AC_ChargeLoop_Response.CLResControlMode.Dynamic_AC_CLResControlMode.EVSEPresentActivePower.Value;
    
    if($EV.ISO20.AC_ChargeLoop_Response.CLResControlMode.Dynamic_AC_CLResControlMode.EVSEPresentActivePower_L2.IsValid)
      @sysvar::EV_Sim::SysEV_PresentPower_L2 = $EV.ISO20.AC_ChargeLoop_Response.CLResControlMode.Dynamic_AC_CLResControlMode.EVSEPresentActivePower_L2.Value;
    
    if($EV.ISO20.AC_ChargeLoop_Response.CLResControlMode.Dynamic_AC_CLResControlMode.EVSEPresentActivePower_L3.IsValid)
      @sysvar::EV_Sim::SysEV_PresentPower_L3 = $EV.ISO20.AC_ChargeLoop_Response.CLResControlMode.Dynamic_AC_CLResControlMode.EVSEPresentActivePower_L3.Value;
  }
  
  if ($EV.ISO20.AC_ChargeLoop_Response.CLResControlModeElementId == 1)
  {
    if($EV.ISO20.AC_ChargeLoop_Response.CLResControlMode.BPT_Dynamic_AC_CLResControlMode.EVSEPresentActivePower.IsValid)
      @sysvar::EV_Sim::SysEV_PresentPower = $EV.ISO20.AC_ChargeLoop_Response.CLResControlMode.BPT_Dynamic_AC_CLResControlMode.EVSEPresentActivePower.Value;
    
    if($EV.ISO20.AC_ChargeLoop_Response.CLResControlMode.BPT_Dynamic_AC_CLResControlMode.EVSEPresentActivePower_L2.IsValid)
      @sysvar::EV_Sim::SysEV_PresentPower_L2 = $EV.ISO20.AC_ChargeLoop_Response.CLResControlMode.BPT_Dynamic_AC_CLResControlMode.EVSEPresentActivePower_L2.Value;
    
    if($EV.ISO20.AC_ChargeLoop_Response.CLResControlMode.BPT_Dynamic_AC_CLResControlMode.EVSEPresentActivePower_L3.IsValid)
      @sysvar::EV_Sim::SysEV_PresentPower_L3 = $EV.ISO20.AC_ChargeLoop_Response.CLResControlMode.BPT_Dynamic_AC_CLResControlMode.EVSEPresentActivePower_L3.Value;
  }
}

void FUNC_EnableSchemaControls( int enabled)
{
  enableControl(gPanelName, "sw_BPT", enabled);
  enableControl(gPanelName, "sw_ACDC", enabled);
  enableControl(gPanelName, "sw_Dynamic", enabled);
  enableControl(gPanelName, "sw_Scheduled", enabled);
}

void FUNC_CheckEV_TargetCurrent_Visibility()
{
  if(@sysvar::EV_Sim::Control::SysEV_ControlModeDynamic == @sysvar::EV_Sim::Control::SysEV_ControlModeDynamic::Scheduled)
  {
    SetControlVisibility(gPanelName, "upDown_DCTargetCurrent", 1);
    SetControlVisibility(gPanelName, "lbl_DCTargetCurrent", 1);
  }
  else
  {
    SetControlVisibility(gPanelName, "upDown_DCTargetCurrent", 0);
    SetControlVisibility(gPanelName, "lbl_DCTargetCurrent", 0);
  }
}

ValidateProtocolPanel(int lastRxMessageId)
{
  if (0 <= @sysvar::Common::SysProtocolBar)
  {
    // show/hide result labels
    if (3 <= @sysvar::Common::SysProtocolBar)
    {          
      // update response code label
      snprintf(labelNameOK, 50, "TResult%iOK", @sysvar::Common::SysProtocolBar); 
      snprintf(labelNameNOK, 50, "TResult%iNOK", @sysvar::Common::SysProtocolBar);
      
      // check if a FAIL was already written, then do not overwrite
      if (@sysvar::Common::SysProtocolBarStatus[@sysvar::Common::SysProtocolBar] != 0)
      { 
        if(
            (lastRxMessageId == _CCS::DataTypes::SupportedAppProtocolRes && CheckSAPResponseCode(lastRxMessageId) == 0) || //Check response code for SAP response
            (lastRxMessageId != _CCS::DataTypes::SupportedAppProtocolRes && CheckResponseCode(lastRxMessageId) == 0)       //Check response code for other messages
          )
        {
          // Responscde = OK
          setControlVisibility(gProtocolPanelName, labelNameNOK, 0);
          setControlVisibility(gProtocolPanelName, labelNameOK, 1);     
  
          @sysvar::Common::SysProtocolBarStatus[@sysvar::Common::SysProtocolBar] = 1;
        }
        else 
        {
          // Responscde = Failed
          setControlVisibility(gProtocolPanelName, labelNameOK, 0);
          setControlVisibility(gProtocolPanelName, labelNameNOK, 1);       
          
          @sysvar::Common::SysProtocolBarStatus[@sysvar::Common::SysProtocolBar] = 0;
        }   
      }
    }
  }
}

int CheckResponseCode(int lastRxMessageId)
{
  if ((GetResponseCode(lastRxMessageId) == _CCS::DataTypes::ISO20ResponseCodeType::OK)
       || (GetResponseCode(lastRxMessageId) == _CCS::DataTypes::ISO20ResponseCodeType::OK_CertificateExpiresSoon)
       || (GetResponseCode(lastRxMessageId) == _CCS::DataTypes::ISO20ResponseCodeType::OK_NewSessionEstablished)
       || (GetResponseCode(lastRxMessageId) == _CCS::DataTypes::ISO20ResponseCodeType::OK_OldSessionJoined)
       || (GetResponseCode(lastRxMessageId) == _CCS::DataTypes::ISO20ResponseCodeType::OK_PowerToleranceConfirmed))
  {
    return 0;
  }
  
  return 1;  
}

int CheckSAPResponseCode(int lastRxMessageId)
{
  if (GetResponseCode(lastRxMessageId) != _CCS::DataTypes::SAPResponseCodeType::FAILED_NoNegotiation)
  {
    return 0;
  }
  
  return 1;  
}

int GetResponseCode(int lastEVRxMessageId)
{  
  int responseCode = 0;
  
  switch (lastEVRxMessageId)
  {
    case _CCS::DataTypes::SupportedAppProtocolRes: 
      responseCode = $EV.SAP.SupportedAppProtocol_Response.ResponseCode;
      break;
      
    case _CCS::DataTypes::SessionSetupRes:
      responseCode = $EV.ISO20.SessionSetup_Response.ResponseCode;
      break;
      
    case _CCS::DataTypes::AuthorizationSetupRes: 
      responseCode = $EV.ISO20.AuthorizationSetup_Response.ResponseCode;
      break;
      
    case _CCS::DataTypes::AuthorizationRes:
      responseCode = $EV.ISO20.Authorization_Response.ResponseCode;
      break; 
      
    case _CCS::DataTypes::ServiceDiscoveryRes:    
      responseCode = $EV.ISO20.ServiceDiscovery_Response.ResponseCode;
      break;
      
    case _CCS::DataTypes::ServiceDetailRes:
      responseCode = $EV.ISO20.ServiceDetail_Response.ResponseCode;
      break;
      
    case _CCS::DataTypes::ServiceSelectionRes:
      responseCode = $EV.ISO20.ServiceSelection_Response.ResponseCode;
      break;
      
    //Not supported yet
    case _CCS::DataTypes::CertificateInstallationRes:      
      //responseCode = $EV.ISO20.CertificateInstallation_Response.ResponseCode;
      break;     
     
    case _CCS::DataTypes::ACChargeParameterDiscoveryRes:
      responseCode = $EV.ISO20.AC_ChargeParameterDiscovery_Response.ResponseCode;
      break;
      
    case _CCS::DataTypes::DCChargeParameterDiscoveryRes:
      responseCode = $EV.ISO20.DC_ChargeParameterDiscovery_Response.ResponseCode;
      break;
      
    case _CCS::DataTypes::ScheduleExchangeRes:
      responseCode = $EV.ISO20.ScheduleExchange_Response.ResponseCode;
      break;
      
    case _CCS::DataTypes::DCCableCheckRes:
      responseCode = $EV.ISO20.DC_CableCheck_Response.ResponseCode;
      break;
      
    case _CCS::DataTypes::DCPreChargeRes:
      responseCode = $EV.ISO20.DC_PreCharge_Response.ResponseCode;
      break;    
      
    //Not supported yet
    case _CCS::DataTypes::MeteringConfirmationRes:
      //responseCode = $EV.ISO20.MeteringConfirmation_Response.ResponseCode;
      break;        
              
    case _CCS::DataTypes::PowerDeliveryRes:   
      responseCode = $EV.ISO20.PowerDelivery_Response.ResponseCode;
      break;
      
    case _CCS::DataTypes::ACChargeLoopRes:
      responseCode = $EV.ISO20.AC_ChargeLoop_Response.ResponseCode;
      break;
      
    case _CCS::DataTypes::DCChargeLoopRes:
      responseCode = $EV.ISO20.DC_ChargeLoop_Response.ResponseCode;
      break;
      
    case _CCS::DataTypes::DCWeldingDetectionRes:    
      responseCode = $EV.ISO20.DC_WeldingDetection_Response.ResponseCode;
      break;
      
    case _CCS::DataTypes::SessionStopRes:
      responseCode = $EV.ISO20.SessionStop_Response.ResponseCode;
      break;    

    default:
      /* Button was pressed during SLAC. Next message with ResponseCode is SupportedAppProtocol */
      responseCode = $EV.SAP.SupportedAppProtocol_Response.ResponseCode;
      break;
  }
  
  return responseCode;
}

void FUNC_CheckEV_BPT_Visibility()
{
  if ((@Common::SysUserBPTMode == sysvar::Common::SysUserBPTMode::BPT) && ( @sysvar::EV_Sim::Control::SysEV_ControlModeDynamic == sysvar::EV_Sim::Control::SysEV_ControlModeDynamic::Scheduled))
  {
    /* EV decides when to charge or discharge */  
    SetControlVisibility(gEVPanelName, gCanvasDisableChargeDischarge, 0);
  }
  else
  {
    /* No BPT or EVSE decides when to charge or discharge */
    SetControlVisibility(gEVPanelName, gCanvasDisableChargeDischarge, 1);
  }
}

on key 'n'
{
  if(isSimulationRunning == 0)
  {
    @sysvar::EV_Sim::Control::SysEV_Connected = 1;
    isSimulationRunning = 1;
  }
  else
  {
    @sysvar::EV_Sim::Control::SysEV_Connected = 0;
    isSimulationRunning = 0;
  }
}