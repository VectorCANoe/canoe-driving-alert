      case _CCS::DataTypes::EVSENotificationType::ScheduleRenegotiation:
        sysSetVariableString(sysvar::EVSE_Sim::SysEVSE_DCStatusCode, "ScheduleRenegotiation"); break;
        
      case _CCS::DataTypes::EVSENotificationType::ServiceRenegotiation:
        sysSetVariableString(sysvar::EVSE_Sim::SysEVSE_DCStatusCode, "ServiceRenegotiation"); break;
        
      case _CCS::DataTypes::EVSENotificationType::MeteringConfirmation:
        sysSetVariableString(sysvar::EVSE_Sim::SysEVSE_DCStatusCode, "MeteringConfirmation"); break;     
      
      default:
