  if(IsEVSERolePassive())
    return;
  
  FUNC_Set_EVSEACLimits_ChargeParameterDiscoveryRes(); 
}

on value_update EVSE.ISO20.AC_DER_ChargeParameterDiscovery_Request
{
  if(IsEVSERolePassive())
    return;
  
  FUNC_Set_EVSEACDERLimits_ChargeParameterDiscoveryRes();
}

on fct_called EVSE.OnLastTransmittedMessageIdChanged 
{
  if ($EVSE.OnLastTransmittedMessageIdChanged.LatestCall.lastTxMessageId == _CCS::DataTypes::MessageIdType::ACDERChargeParameterDiscoveryRes)
  {
    EVSE.ISO20.EnableAutoBodyFill.Call(1); // re-enable auto body fill set in ChargeParameterDiscovery_Request
    AutoFill_body = 1;
  }
}

on value_update EVSE.ScheduleRenegotiation.DC_ChargeParameterDiscovery_Request
{
  FUNC_Set_EVSEDCLimits_ScheduleRenegotiationChargeParameterDiscoveryRes(); 
}

on value_update EVSE.ScheduleRenegotiation.AC_ChargeParameterDiscovery_Request
{
  FUNC_Set_EVSEACLimits_ScheduleRenegotiationChargeParameterDiscoveryRes(); 
}

on value_update EVSE.ISO20.ScheduleExchange_Request
{
  if(IsEVSERolePassive())
    return;
  
  FUNC_Set_ScheduleExchangeRes();

  if($EVSE.ISO20.ScheduleExchange_Request.SEReqControlModeElementId == _CCS::DataTypes::parISO20SEReqMode::Dynamic_SEReq)
    @sysvar::EVSE_Sim::SysEVSE_SelectedControlMode = @sysvar::EVSE_Sim::SysEVSE_SelectedControlMode::Dynamic;
  // Scheduled Mode
  else
  {
    @sysvar::EVSE_Sim::SysEVSE_SelectedControlMode = @sysvar::EVSE_Sim::SysEVSE_SelectedControlMode::Scheduled;
  }
}

on value_update EVSE.ScheduleRenegotiation.ScheduleExchange_Request
{
  if($EVSE.ScheduleRenegotiation.ScheduleExchange_Request.SEReqControlModeElementId == _CCS::DataTypes::parISO20SEReqMode::Dynamic_SEReq)
    @sysvar::EVSE_Sim::SysEVSE_SelectedControlMode = @sysvar::EVSE_Sim::SysEVSE_SelectedControlMode::Dynamic;
  else
    @sysvar::EVSE_Sim::SysEVSE_SelectedControlMode = @sysvar::EVSE_Sim::SysEVSE_SelectedControlMode::Scheduled;
  
  if (EVSESRProcessingLoopCounter < ProcessingLoopRepetitions)
  {
    EVSESRProcessingLoopCounter++; 
  }
  else
  {
    EVSESRProcessingLoopCounter = 0;
    EVSE.ScheduleRenegotiation.FinishProcessing.Call();
  }
}

on value_update EVSE.ISO20.ScheduleExchange_Response
{
  if (EVSEProcessingLoopCounter < ProcessingLoopRepetitions)
  {
    EVSEProcessingLoopCounter++; 
  }
  else
  {
    EVSEProcessingLoopCounter = 0;
    EVSE.ISO20.FinishProcessing.Call();
  }
  gCntCableCheck = 0; // Reset for potentially incremented counter
}

on value_update EVSE.ISO20.DC_CableCheck_Request
{
  gCntCableCheck++;
  
  if((HV_measure_DC_U_VeriVolt() < 10) && (gCntCableCheck == 1))
  {
    HV_source_set_output(1); // Close switches of DC power supply
    HV_source_set_I_DC(cPreChargeMinimumCurrent);
    HV_source_set_U_DC(@EVSE_Sim::SysEVSE_MaxVoltage);
  }
  else if(gCntCableCheck == 1)
  {
    WriteLineEx(0, 3, "EVSE: Voltage on cable > 10V. EV contactors appear to be closed.");
    return;
  }
}

on value_update EVSE.ISO20.DC_CableCheck_Response
{
  if(isSimulated())
  {
    if (EVSEProcessingLoopCounter < ProcessingLoopRepetitions)
    {
      EVSEProcessingLoopCounter++;
    }
    else
    {
      EVSEProcessingLoopCounter = 0;
      EVSE.ISO20.FinishProcessing.Call();
    }
  }
  else
  {
    stack long isoState = HV_get_isolation_state(1, 0, 0);
    if(isoState == 1) // valid
    {
      HV_source_set_U_DC(0);
      EVSE.ISO20.FinishProcessing.Call(); // Set EVSE Processing to Finished
    }
    else if(isoState == 2) // fault
    {
      HV_source_set_I_DC(0);
      HV_source_set_U_DC(0);
      HV_source_set_output(0); // Open switches of DC power supply
      
      WriteLineEx(0, 3, "EVSE: Fault result of cable check insulation test.");
      
      @EVSE_Sim::Control::SysEVSE_ReturnFailed = 1;
      EVSE.ISO20.FinishProcessing.Call(); // Set EVSE Processing to Finished
    }
    else // ongoing
    {
      EVSEProcessingLoopCounter++; // Set EVSE Processing to OnGoing
    }
  }
}

on value_update EVSE.ISO20.DC_PreCharge_Request
{
  float evTargetVoltage;
  if(IsEVSERolePassive())
    return;
  
  /* Set requested voltage from EV */
  evTargetVoltage = getValueConsideringExponent($EVSE.ISO20.DC_PreCharge_Request.EVTargetVoltage.Value,$EVSE.ISO20.DC_PreCharge_Request.EVTargetVoltage.Exponent);
  HV_source_set_U_DC(evTargetVoltage < @EVSE_Sim::SysEVSE_MaxVoltage ? evTargetVoltage : @EVSE_Sim::SysEVSE_MaxVoltage);
  HV_source_set_I_DC(cPreChargeMinimumCurrent);
  FUNC_Set_PreChargeRes();
}

on value_update EVSE.ISO20.PowerDelivery_Request
{
  if ($EVSE.ISO20.PowerDelivery_Request.ChargeProgress == _CCS::DataTypes::parChargeProgressType::`Stop
            || $EVSE.ISO20.PowerDelivery_Request.ChargeProgress == _CCS::DataTypes::parChargeProgressType::Standby)
  {
    HV_reduce_VoltageAndCurrent();
  }
}

on value_update EVSE.ISO20.AC_ChargeLoop_Response
{
  if(IsEVSERolePassive())
    return;
  
  FUNC_Set_EVSE_ACChargeLoopValues();
}

on value_update EVSE.ISO20.DC_ChargeLoop_Request
{
  if(IsEVSERolePassive())
    return;
  
  //Mark EVSEStatus as a missing optional element
  ($EVSE.ISO20.DC_ChargeLoop_Response.EVSEStatus).SetInvalid();
  FUNC_Get_EVSE_DCChargeLoopValues();
  
  if( $this.CLReqControlModeElementId == 2 ){
    HV_source_set_U_DC(getValueConsideringExponent($this.CLReqControlMode.Scheduled_DC_CLReqControlMode.EVTargetVoltage.Value, $this.CLReqControlMode.Scheduled_DC_CLReqControlMode.EVTargetVoltage.Exponent));
    HV_source_set_I_DC(getValueConsideringExponent($this.CLReqControlMode.Scheduled_DC_CLReqControlMode.EVTargetCurrent.Value, $this.CLReqControlMode.Scheduled_DC_CLReqControlMode.EVTargetCurrent.Exponent));
  }
  else if($this.CLReqControlModeElementId == 3){
    HV_source_set_U_DC(getValueConsideringExponent($this.CLReqControlMode.BPT_Scheduled_DC_CLReqControlMode.EVTargetVoltage.Value, $this.CLReqControlMode.BPT_Scheduled_DC_CLReqControlMode.EVTargetVoltage.Exponent));
    HV_source_set_I_DC(getValueConsideringExponent($this.CLReqControlMode.BPT_Scheduled_DC_CLReqControlMode.EVTargetCurrent.Value, $this.CLReqControlMode.BPT_Scheduled_DC_CLReqControlMode.EVTargetCurrent.Exponent));
  }
  else{ //Dynamic
    HV_source_set_U_DC(@EVSE_Sim::SysEVSE_PresentVoltage);
    HV_source_set_I_DC(@EVSE_Sim::SysEVSE_PresentCurrent);
  }
}

on value_update EVSE.ISO20.AC_ChargeLoop_Request
{
  if(IsEVSERolePassive())
    return;
  
  FUNC_Get_EVSE_ACChargeLoopValues();
}

on value_update EVSE.ISO20.AC_DER_ChargeLoop_Request
{
  if(IsEVSERolePassive())
    return;
  FUNC_Get_EVSE_ACDERChargeLoopValues();
}

on value_update EVSE.ISO20.DC_ChargeLoop_Response
{
  if(IsEVSERolePassive())
    return;
  
  FUNC_Set_EVSE_DCChargeLoopValues();
}

on value_update EVSE.ISO20.DC_WeldingDetection_Request
{
  HV_reduce_VoltageAndCurrent();
  setTimer(tOpenContactors, cOpenContactorsDelay);  
  HV_source_perform_welding();
}

on value_update EVSE.ISO20.SessionStop_Request
{
  HV_reduce_VoltageAndCurrent();
  setTimer(tOpenContactors, cOpenContactorsDelay);  
  gSessionStopReqCounter++;
}

on value_update EVSE.ISO20.SessionStop_Response
{
  SetChargingStationPicturesVisibility(Ready); 
}

/**********************************************************************************************************************
 *  ON DATA
 *********************************************************************************************************************/
on value_update EVSE.CurrentLinkStatus
{
  if ($EVSE.CurrentLinkStatus == _CCS::DataTypes::Connected)
  {
    @sysvar::EVSE_Sim::SysEVSE_LinkStatus = 1;
  }
  else if ($EVSE.CurrentLinkStatus == _CCS::DataTypes::ReadyToJoin)
  {
    @sysvar::EVSE_Sim::SysEVSE_LinkStatus = 2;
  }
  else
  {
    @sysvar::EVSE_Sim::SysEVSE_LinkStatus = 0;
  }
}

on value_update EVSE.ExpectedCPState
{
  if ($this ==  _CCS::DataTypes::CPStateType::State_B)
   SetChargingStationPicturesVisibility(Charging);
}

on value_update EVSE.Reporting.CCSError
{
  if($EVSE.Reporting.CCSError.LastReceivedMessage.IsValid){
     if(!IsSideStreamMessageReceived())
       SetChargingStationPicturesVisibility(Error);
    }
}

on value_update EVSE.Reporting.EXIError
{
  SetChargingStationPicturesVisibility(Error);
}

/**********************************************************************************************************************
 *  HELPER FUNCTIONS
 *********************************************************************************************************************/
void FUNC_Set_DepartureTimeDefaults()
{
  const int DepartureTimeDefault = 900; //15 min

  $CCS::Simulation::EVSE.ISO20.ScheduleExchange_Response.SEResControlMode.Dynamic_SEResControlMode.DepartureTime =  DepartureTimeDefault;

  $CCS::Simulation::EVSE.ISO20.DC_ChargeLoop_Response.CLResControlMode.Dynamic_DC_CLResControlMode.DepartureTime =  DepartureTimeDefault;
  $CCS::Simulation::EVSE.ISO20.DC_ChargeLoop_Response.CLResControlMode.BPT_Dynamic_DC_CLResControlMode.DepartureTime =  DepartureTimeDefault;
  
  $CCS::Simulation::EVSE.ISO20.AC_ChargeLoop_Response.CLResControlMode.Dynamic_AC_CLResControlMode.DepartureTime =  DepartureTimeDefault;
  $CCS::Simulation::EVSE.ISO20.AC_ChargeLoop_Response.CLResControlMode.BPT_Dynamic_AC_CLResControlMode.DepartureTime =  DepartureTimeDefault;
}

void FUNC_Set_EVSEChargingMode()
{
  if (@sysvar::Common::SysUserChargingMode == sysvar::Common::SysUserChargingMode::AC) 
  {
    /* AC */
    if (@sysvar::Common::SysUserBPTMode == sysvar::Common::SysUserBPTMode::No_BPT) 
    {
      /* No BPT */
      if(@Common::SysUserACDERMode == 1){
        setAttribute(CCS::Simulation::EVSE, CCSBinding::EnergyTransferService, CCSBinding::AC_DER);  
      }
      else{
        setAttribute(CCS::Simulation::EVSE, CCSBinding::EnergyTransferService, CCSBinding::AC);
      }
    }
    else
    {
      /* BPT */
      setAttribute(CCS::Simulation::EVSE, CCSBinding::EnergyTransferService, CCSBinding::AC_BPT);
    }
  }
  else 
  {
    /* DC */
    if (@sysvar::Common::SysUserBPTMode == sysvar::Common::SysUserBPTMode::No_BPT)
    {
      /* No BPT */
      setAttribute(CCS::Simulation::EVSE, CCSBinding::EnergyTransferService, CCSBinding::DC);  
    }
    else
    {
      /* BPT */
      setAttribute(CCS::Simulation::EVSE, CCSBinding::EnergyTransferService, CCSBinding::DC_BPT);
    }
  }  
}

void FUNC_Set_EVSEDCLimits_ScheduleRenegotiationChargeParameterDiscoveryRes()
{
  /* EVSEMaximumChargePower */
  $EVSE.ScheduleRenegotiation.DC_ChargeParameterDiscovery_Response.CPDResEnergyTransferMode.DC_CPDResEnergyTransferMode.EVSEMaximumChargePower.Value = @sysvar::EVSE_Sim::SysEVSE_MaxPowerDC;
  $EVSE.ScheduleRenegotiation.DC_ChargeParameterDiscovery_Response.CPDResEnergyTransferMode.DC_CPDResEnergyTransferMode.EVSEMaximumChargePower.Exponent = 3; //Unit: kW
  $EVSE.ScheduleRenegotiation.DC_ChargeParameterDiscovery_Response.CPDResEnergyTransferMode.BPT_DC_CPDResEnergyTransferMode.EVSEMaximumChargePower.Value = @sysvar::EVSE_Sim::SysEVSE_MaxPowerDC;
  $EVSE.ScheduleRenegotiation.DC_ChargeParameterDiscovery_Response.CPDResEnergyTransferMode.BPT_DC_CPDResEnergyTransferMode.EVSEMaximumChargePower.Exponent = 3; //Unit: kW
  
  /* EVSEMinimumChargePower */
  $EVSE.ScheduleRenegotiation.DC_ChargeParameterDiscovery_Response.CPDResEnergyTransferMode.DC_CPDResEnergyTransferMode.EVSEMinimumChargePower.Value = @sysvar::EVSE_Sim::SysEVSE_MinPowerDC;
  $EVSE.ScheduleRenegotiation.DC_ChargeParameterDiscovery_Response.CPDResEnergyTransferMode.DC_CPDResEnergyTransferMode.EVSEMinimumChargePower.Exponent = 3; //Unit: kW
  $EVSE.ScheduleRenegotiation.DC_ChargeParameterDiscovery_Response.CPDResEnergyTransferMode.BPT_DC_CPDResEnergyTransferMode.EVSEMinimumChargePower.Value = @sysvar::EVSE_Sim::SysEVSE_MinPowerDC;
  $EVSE.ScheduleRenegotiation.DC_ChargeParameterDiscovery_Response.CPDResEnergyTransferMode.BPT_DC_CPDResEnergyTransferMode.EVSEMinimumChargePower.Exponent = 3; //Unit: kW
  
  /* EVSEMaximumChargeCurrent */
  $EVSE.ScheduleRenegotiation.DC_ChargeParameterDiscovery_Response.CPDResEnergyTransferMode.DC_CPDResEnergyTransferMode.EVSEMaximumChargeCurrent.Value = @sysvar::EVSE_Sim::SysEVSE_MaxCurrent;
  $EVSE.ScheduleRenegotiation.DC_ChargeParameterDiscovery_Response.CPDResEnergyTransferMode.DC_CPDResEnergyTransferMode.EVSEMaximumChargeCurrent.Exponent = 0;
  $EVSE.ScheduleRenegotiation.DC_ChargeParameterDiscovery_Response.CPDResEnergyTransferMode.BPT_DC_CPDResEnergyTransferMode.EVSEMaximumChargeCurrent.Value = @sysvar::EVSE_Sim::SysEVSE_MaxCurrent;
  $EVSE.ScheduleRenegotiation.DC_ChargeParameterDiscovery_Response.CPDResEnergyTransferMode.BPT_DC_CPDResEnergyTransferMode.EVSEMaximumChargeCurrent.Exponent = 0;
  
  /* EVSEMaximumVoltage */
  $EVSE.ScheduleRenegotiation.DC_ChargeParameterDiscovery_Response.CPDResEnergyTransferMode.DC_CPDResEnergyTransferMode.EVSEMaximumVoltage.Value = @sysvar::EVSE_Sim::SysEVSE_MaxVoltage;
  $EVSE.ScheduleRenegotiation.DC_ChargeParameterDiscovery_Response.CPDResEnergyTransferMode.DC_CPDResEnergyTransferMode.EVSEMaximumVoltage.Exponent = 0;
  $EVSE.ScheduleRenegotiation.DC_ChargeParameterDiscovery_Response.CPDResEnergyTransferMode.BPT_DC_CPDResEnergyTransferMode.EVSEMaximumVoltage.Value = @sysvar::EVSE_Sim::SysEVSE_MaxVoltage;
  $EVSE.ScheduleRenegotiation.DC_ChargeParameterDiscovery_Response.CPDResEnergyTransferMode.BPT_DC_CPDResEnergyTransferMode.EVSEMaximumVoltage.Exponent = 0;
  
  /* EVSEMinimumVoltage */
  $EVSE.ScheduleRenegotiation.DC_ChargeParameterDiscovery_Response.CPDResEnergyTransferMode.DC_CPDResEnergyTransferMode.EVSEMinimumVoltage.Value = @sysvar::EVSE_Sim::SysEVSE_MinVoltage;
  $EVSE.ScheduleRenegotiation.DC_ChargeParameterDiscovery_Response.CPDResEnergyTransferMode.DC_CPDResEnergyTransferMode.EVSEMinimumVoltage.Exponent = 0;
  $EVSE.ScheduleRenegotiation.DC_ChargeParameterDiscovery_Response.CPDResEnergyTransferMode.BPT_DC_CPDResEnergyTransferMode.EVSEMinimumVoltage.Value = @sysvar::EVSE_Sim::SysEVSE_MinVoltage;
  $EVSE.ScheduleRenegotiation.DC_ChargeParameterDiscovery_Response.CPDResEnergyTransferMode.BPT_DC_CPDResEnergyTransferMode.EVSEMinimumVoltage.Exponent = 0;
  
  /* EVSEMaximumDischargePower */
  $EVSE.ScheduleRenegotiation.DC_ChargeParameterDiscovery_Response.CPDResEnergyTransferMode.BPT_DC_CPDResEnergyTransferMode.EVSEMaximumDischargePower.Value = - abs(@sysvar::EVSE_Sim::SysEVSE_MaxPowerDC);
  $EVSE.ScheduleRenegotiation.DC_ChargeParameterDiscovery_Response.CPDResEnergyTransferMode.BPT_DC_CPDResEnergyTransferMode.EVSEMaximumDischargePower.Exponent = 3; //Unit: kW
  
  /* EVSEMinimumDischargePower */
  $EVSE.ScheduleRenegotiation.DC_ChargeParameterDiscovery_Response.CPDResEnergyTransferMode.BPT_DC_CPDResEnergyTransferMode.EVSEMinimumDischargePower.Value =  - abs(@sysvar::EVSE_Sim::SysEVSE_MinPowerDC);
  $EVSE.ScheduleRenegotiation.DC_ChargeParameterDiscovery_Response.CPDResEnergyTransferMode.BPT_DC_CPDResEnergyTransferMode.EVSEMinimumDischargePower.Exponent = 3; //Unit: kW
  
  /* EVSEMaximumDischargeCurrent */
  $EVSE.ScheduleRenegotiation.DC_ChargeParameterDiscovery_Response.CPDResEnergyTransferMode.BPT_DC_CPDResEnergyTransferMode.EVSEMaximumDischargeCurrent.Value =  - abs(@sysvar::EVSE_Sim::SysEVSE_MaxCurrent);
  $EVSE.ScheduleRenegotiation.DC_ChargeParameterDiscovery_Response.CPDResEnergyTransferMode.BPT_DC_CPDResEnergyTransferMode.EVSEMaximumDischargeCurrent.Exponent = 0;
}

