void FUNC_Set_EVSE_ACChargeLoopValues()
{
  if($EVSE.ISO20.AC_ChargeLoop_Response.EVSEStatus.IsValid)
  {
    switch ($EVSE.ISO20.AC_ChargeLoop_Response.EVSEStatus.EVSENotification)
    {
      case _CCS::DataTypes::EVSENotificationType::Pause:
        sysSetVariableString(sysvar::EVSE_Sim::SysEVSE_DCStatusCode, "Pause"); break;
        
      case _CCS::DataTypes::EVSENotificationType::ExitStandby:
         sysSetVariableString(sysvar::EVSE_Sim::SysEVSE_DCStatusCode, "ExitStandby"); break;
        
      case _CCS::DataTypes::EVSENotificationType::Terminate:
        sysSetVariableString(sysvar::EVSE_Sim::SysEVSE_DCStatusCode, "Terminate"); break;
        
      case _CCS::DataTypes::EVSENotificationType::ScheduleRenegotiation:
        sysSetVariableString(sysvar::EVSE_Sim::SysEVSE_DCStatusCode, "ScheduleRenegotiation"); break;
        
      case _CCS::DataTypes::EVSENotificationType::ServiceRenegotiation:
        sysSetVariableString(sysvar::EVSE_Sim::SysEVSE_DCStatusCode, "ServiceRenegotiation"); break;
        
      case _CCS::DataTypes::EVSENotificationType::MeteringConfirmation:
        sysSetVariableString(sysvar::EVSE_Sim::SysEVSE_DCStatusCode, "MeteringConfirmation"); break;     
      
      default:
        sysSetVariableString(sysvar::EVSE_Sim::SysEVSE_DCStatusCode, "unknown StatusCode"); 
    }
  }
}

void FUNC_Set_EVSE_DCChargeLoopValues()
{
  if ($EVSE.ISO20.DC_ChargeLoop_Response.EVSEStatus.IsValid)
  {
    switch ($EVSE.ISO20.DC_ChargeLoop_Response.EVSEStatus.EVSENotification)
    {
      case _CCS::DataTypes::EVSENotificationType::Pause:
