    }
  }
}

void FUNC_EVSE_PrepareCommunication()
{
  FUNC_Set_Attributes();
     
  // Start Simulation
  FUNC_Set_ChargeDischargeValues();
  EVSE.StartSimulation.Call();
  PP_EVSE_set_resistance(getPPResistance());
  @sysvar::EVSE_Sim::SysEVSE_SimState = 0;
  strncpy(evseConnections, "", 256);
  SysSetVariableString(sysvar::EVSE_Sim::SysEVSE_Connections, evseConnections); 
}

void WriteHex(char outText[], byte data[])
{
  WriteHex(outText, data, elcount(data), "", 0);
}

void WriteHex(char outText[], byte data[], int length)
{
  WriteHex(outText, data, length, "", length);
}

void WriteHexMacId(char outText[], byte data[])
{
  if (elcount(data) < 6)
    return;
  
  WriteHex(outText, data, 6, ":", 1);
}

void WriteHexIPv6(char outText[], byte data[])
{
  if (elcount(data) < 16) return;
  
  WriteHex(outText, data, 16, ":", 2);
}

void WriteHex(char outText[], byte data[], int dataLength, char sep[], int sepEveryXChars)
{
  int i, sepCnt;
  
  if (dataLength <= 0) return;
  if (elcount(outText) <= 0) return;
  
  sepCnt = (sepEveryXChars < 1 ? 1 : sepEveryXChars);
    
  // Clear string
  snprintf(outText, 1, "");
  
  for (i=0; i< dataLength; i++)
  {
    // Append Byte as Hex
    snprintf(outText, elcount(outText), "%s%02X", outText, data[i]); 
    
    // Append Separator
    if (i < dataLength-1)
    {
      if (((i+1)%sepCnt) == 0)
      {
        snprintf(outText, elcount(outText), "%s%s", outText, sep);
      }
    }
  }       
}

void FUNC_Set_ChargeDischargeValues()
{
  int leadingSign;
  leadingSign = 1;
  
  //If BPT enabled (ChargeDischarge button shown) and Discharge selected
  if((@sysvar::Common::SysUserBPTMode == sysvar::Common::SysUserBPTMode::BPT) 
    && (@sysvar::EVSE_Sim::Control::SysEVSE_ChargeDischarge == @sysvar::EVSE_Sim::Control::SysEVSE_ChargeDischarge::Discharge))
  {
    leadingSign = -1;
  }
  
  //Make sure that the correct leading sign is used
  if ((@sysvar::Common::SysUserChargingMode == sysvar::Common::SysUserChargingMode::AC)) 
  {
    /* AC_BPT */
    @sysvar::EVSE_Sim::SysEVSE_PresentPower = abs(@sysvar::EVSE_Sim::SysEVSE_PresentPower) * leadingSign;
    @sysvar::EVSE_Sim::SysEVSE_PresentPower_L2 = abs(@sysvar::EVSE_Sim::SysEVSE_PresentPower_L2) * leadingSign;
    @sysvar::EVSE_Sim::SysEVSE_PresentPower_L3 = abs(@sysvar::EVSE_Sim::SysEVSE_PresentPower_L3) * leadingSign;    
  }
  
  if ((@sysvar::Common::SysUserChargingMode == sysvar::Common::SysUserChargingMode::DC)) 
  {   
    /* DC_BPT */
    double current;     
    current = HV_measure_DC_I();
    HV_source_set_I_DC( abs(current) * leadingSign );    
  } 
}

void FUNC_Set_Attributes()
{
  reReadSharedAttributes();
  
  // Set Processing    
  if (@sysvar::Common::SysUseProcessing == 1){
    setAttribute(CCS::Simulation::EVSE, CCSBinding::ProcessingLooping, CCSBinding::Enabled); 
    SetControlForeColor(gPanelName, "TProcessing",  MakeRGB(0, 0, 255)); 
  }
  else{
    setAttribute(CCS::Simulation::EVSE, CCSBinding::ProcessingLooping, CCSBinding::Disabled); 
  }
}

void SetChargingStationPicturesVisibility(int Mode)
{
  If(Mode == Ready)
  {
   SetControlVisibility(gPanelName, "pictureChargingStationReady", 1);
   SetControlVisibility(gPanelName, "pictureChargingStationCharging", 0);
   SetControlVisibility(gPanelName, "pictureChargingStationError", 0);
  }
  else If(Mode == Charging)
  {
   SetControlVisibility(gPanelName, "pictureChargingStationReady", 0);
   SetControlVisibility(gPanelName, "pictureChargingStationCharging", 1);
   SetControlVisibility(gPanelName, "pictureChargingStationError", 0);
  }
  else If(Mode == Error)
  {
   SetControlVisibility(gPanelName, "pictureChargingStationReady", 0);
   SetControlVisibility(gPanelName, "pictureChargingStationCharging", 0);
   SetControlVisibility(gPanelName, "pictureChargingStationError", 1);
  }
}

int IsSideStreamMessageReceived()
{
 if(($EVSE.Reporting.CCSError.LastReceivedMessage == SRACChargeParameterDiscoveryReq)||
 ($EVSE.Reporting.CCSError.LastReceivedMessage == SRDCChargeParameterDiscoveryReq)||
 ($EVSE.Reporting.CCSError.LastReceivedMessage == SRScheduleExchangeReq)||
 ($EVSE.Reporting.CCSError.LastReceivedMessage == SRPowerDeliveryReq)||
 ($EVSE.Reporting.CCSError.LastReceivedMessage == MeteringConfirmationReq))
  return 1;
 
  return 0;
}

on value_update EVSE.StimDutyCycle
{
  CP_EVSE_set_Dutycycle($EVSE.StimDutyCycle);
}

on value_update EVSE.StimCPState
{
  switch ($EVSE.StimCPState)
  {
    case _CCS::DataTypes::CPStateType::State_A:
      CP_EVSE_set_Voltage(12);
      SetChargingStationPicturesVisibility(Ready);     
      break;
    case _CCS::DataTypes::CPStateType::State_B:
      SetChargingStationPicturesVisibility(Charging);
      break;
    case _CCS::DataTypes::CPStateType::State_E:
      CP_EVSE_set_Voltage(0);
      CP_EVSE_set_Dutycycle(100);
      break;
    case _CCS::DataTypes::CPStateType::State_F:
      CP_EVSE_set_Voltage(-12);
      CP_EVSE_set_Dutycycle(0);
      break;
    default:
      // Output.WriteLine("EVSE: 'OnStimCPStateChanged' called wih invalid value!");
      // other states not supported (set by EV)
      break;
  }
}

/**********************************************************************************************************************
 *  HV control
 *********************************************************************************************************************/

on timer tActionsAfterContactorOpen
{
  HV_ActionsAfterContactorOpen();
}

on timer tOpenContactors
{
  if(abs(HV_measure_DC_I()) > 5)
  {
    HV_reduce_VoltageAndCurrent();
    setTimer(tOpenContactors, cOpenContactorsDelay);
  }
  else
  {
    HV_OpenContactors();
    setTimer(tActionsAfterContactorOpen, cActionsAfterContactorOpenDelay);
  }
}

void HV_reduce_VoltageAndCurrent()
{
  if(abs(HV_measure_DC_I()) > 5)
    HV_source_set_I_DC(cPreChargeMinimumCurrent);
  HV_source_set_U_DC(HV_measure_DC_U_VeriVolt());
}

void HV_OpenContactors()
{
  HV_source_set_output(0); // Open switches of DC power supply
}

void HV_ActionsAfterContactorOpen()
{
  HV_source_set_I_DC(0);
  HV_source_set_U_DC(0);
  
  ST_Reset();
}

double getValueConsideringExponent(int value, int exponent)
{
  return (value * _pow(10, exponent)); 
}