/// <CharINInterfaceDC>
double HV_measure_DC_U()
{
  double presentVoltage;
  if($EV.OnLastReceivedMessageIdChanged.LatestCall.lastRxMessageId == _CCS::DataTypes::MessageIdType::DCChargeLoopRes)
    presentVoltage = ($EV.ISO20.DC_ChargeLoop_Response.EVSEPresentVoltage.Value * _pow(10, $EV.ISO20.DC_ChargeLoop_Response.EVSEPresentVoltage.Exponent));
  else
    presentVoltage = ($EV.ISO20.DC_PreCharge_Response.EVSEPresentVoltage.Value * _pow(10, $EV.ISO20.DC_PreCharge_Response.EVSEPresentVoltage.Exponent));
  
  return presentVoltage;
}

