on sysvar VTS::VT_EV::MeasVoltageHigh
{
  $CCS::Simulation::EV.MeasVoltageHigh = @this;
}

on sysvar VTS::VT_EV::MeasDutyCycle
{
  $CCS::Simulation::EV.MeasDutyCycle = @this;
}

/// <CharINInterface>
void ST_Init()
{
  WriteLineEx(-3, 1, "EV: 'ST_Init' called");

  @sysvar::VTS::VT_EV::Relay_K1 = 1;
  @sysvar::VTS::VT_EV::Relay_K2 = 0;
  @sysvar::VTS::VT_EV::Relay_K3 = 0;
  @sysvar::VTS::VT_EV::Relay_K4 = 0;
  @sysvar::VTS::VT_EV::Relay_K5 = 0;
  @sysvar::VTS::VT_EV::Relay_K6 = 0;
  @sysvar::VTS::VT_EV::Relay_K7 = 0;
  @sysvar::VTS::VT_EV::Relay_K8 = 0;
  @sysvar::VTS::VT_EV::Relay_K9 = 1;
  @sysvar::VTS::VT_EV::Relay_K10 = 0;
  @sysvar::VTS::VT_EV::Relay_K11 = 1;
  @sysvar::VTS::VT_EV::Relay_K12 = 0;
  @sysvar::VTS::VT_EV::Relay_K13 = 0;
  @sysvar::VTS::VT_EV::Relay_K14 = 0;
  @sysvar::VTS::VT_EV::Relay_K15 = 0;
  @sysvar::VTS::VT_EV::Relay_K16 = 0;
  @sysvar::VTS::VT_EV::Relay_K17 = 0;
  @sysvar::VTS::VT_EV::Relay_K18 = 0;
  @sysvar::VTS::VT_EV::Relay_K19 = 0;
  @sysvar::VTS::VT_EV::Relay_K20 = 0;
  @sysvar::VTS::VT_EV::Relay_K21 = 0;
  @sysvar::VTS::VT_EV::Relay_K22 = 0;
  @sysvar::VTS::VT_EV::Relay_K23 = 1;
  @sysvar::VTS::VT_EV::Relay_K24 = 1;
  @sysvar::VTS::VT_EV::Relay_K25 = 0;
  @sysvar::VTS::VT_EV::Relay_K26 = 0;
  @sysvar::VTS::VT_EV::Relay_K27 = 0;
  @sysvar::VTS::VT_EV::Relay_K28 = 1;
  @sysvar::VTS::VT_EV::Relay_K29 = 0;
  @sysvar::VTS::VT_EV::Relay_K31 = 0;
  @sysvar::VTS::VT_EV::Relay_K32 = 0;
  @sysvar::VTS::VT_EV::Relay_K33 = 0;
  @sysvar::VTS::VT_EV::Relay_K34 = 0;
  @sysvar::VTS::VT_EV::Relay_K35 = 0;
  @sysvar::VTS::VT_EV::Relay_K36 = 0;
  @sysvar::VTS::VT_EV::Relay_K37 = 0;

  @sysvar::VTS::VT_EV::StimVoltageHigh = 0;
  @sysvar::VTS::VT_EV::StimVoltageLow = 0;
  @sysvar::VTS::VT_EV::StimFrequency = 0;
  @sysvar::VTS::VT_EV::StimDutyCycle = 0;
}

/// <CharINInterface>
void ST_Reset()
{
  ST_Init();
  CP_EV_set_open_circuit(0);
}

/// <CharINInterface>
void CP_EV_set_open_circuit(long closed)
{
  if (closed > 0)
  {
    @sysvar::VTS::VT_EV::Relay_K26 = 1;
    @sysvar::VTS::VT_EV::Relay_K27 = 1;
    @sysvar::VTS::VT_EV::Relay_K1 = 1;
  }
  else
  {
    @sysvar::VTS::VT_EV::Relay_K26 = 0;
    @sysvar::VTS::VT_EV::Relay_K27 = 0;
    @sysvar::VTS::VT_EV::Relay_K1 = 0;
  }
}

/// <CP_PP>
void PP_EV_set_open_circuit(long closed)
{
  if(closed > 0)
  {
    @sysvar::VTS::VT_EV::Relay_K1 = 1;
    @sysvar::VTS::VT_EV::Relay_K52 = 1; //close to apply 5V
  }
  else
  {
    @sysvar::VTS::VT_EV::Relay_K1 = 0;
    @sysvar::VTS::VT_EV::Relay_K52 = 0;
  }
}

/// <CP_PP>
void SetCPStateB()
{
 @sysvar::VTS::VT_EV::Relay_K9 = 1;
 @sysvar::VTS::VT_EV::Relay_K11 = 1;
 @sysvar::VTS::VT_EV::Relay_K14 = 0;
 @sysvar::VTS::VT_EV::Relay_K15 = 0;
 @sysvar::VTS::VT_EV::Relay_K16 = 0;
 @sysvar::VTS::VT_EV::Relay_K19 = 0;
}

/// <CP_PP>
void SetCPStateC()
{
 @sysvar::VTS::VT_EV::Relay_K9 = 1;
 @sysvar::VTS::VT_EV::Relay_K11 = 1;
 @sysvar::VTS::VT_EV::Relay_K14 = 1;
 @sysvar::VTS::VT_EV::Relay_K15 = 0;
 @sysvar::VTS::VT_EV::Relay_K16 = 0;
 @sysvar::VTS::VT_EV::Relay_K19 = 1;
}

/// <CP_PP>
void SetCPStateD()
{
 @sysvar::VTS::VT_EV::Relay_K9 = 1;
 @sysvar::VTS::VT_EV::Relay_K11 = 1;
 @sysvar::VTS::VT_EV::Relay_K14 = 1;
 @sysvar::VTS::VT_EV::Relay_K15 = 1;
 @sysvar::VTS::VT_EV::Relay_K16 = 1;
 @sysvar::VTS::VT_EV::Relay_K19 = 0;
}

on value_update EV.StimCPState
{
  switch ($EV.StimCPState)
  {
    case _CCS::DataTypes::CPStateType::State_B:
      SetCPStateB();
      break;
    case _CCS::DataTypes::CPStateType::State_C:
      SetCPStateC();
      break;
    case _CCS::DataTypes::CPStateType::State_D:
      SetCPStateD();
      break;
    default:
      // other states not allowed (set by EVSE)
      break;
  }
}

/// <CP_PP>
double CP_EV_get_Voltage_positive()
{
  return $CCS::Simulation::EV.MeasVoltageHigh;
}

/// <CP_PP>
double CP_EV_get_DutyCycle()
{
  return $CCS::Simulation::EV.MeasDutyCycle;
}

/// <CP_PP>
double CP_EV_get_Frequency()
{ 
  if(isSimulated())
    return 0;
  else
    return @sysvar::VTS::VT_EV::MeasFrequency;  
}

