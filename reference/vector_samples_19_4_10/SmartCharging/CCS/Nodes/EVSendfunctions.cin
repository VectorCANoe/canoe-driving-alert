/*@!Encoding:1252*/
includes
{
  //Already included in EVsimDO.can, but might be needed if this file is used on its own
  //#include "EVCommonFunctions.cin"
  //#include "CharIn_HW_Interface_EV.cin"
  #include "StateUtilities.cin"
}

variables
{
  
}

on prestart 
{
  @Test::SysTestApplyControlMode = 0;
}

on sysVar Test::SysTestApplyControlMode
{
  if (@this == 1)
  {
    reReadAttributes();
    EV.StartSimulation.Call();    
  }
  else
  {
    EV.ResetSimulation.Call(); // PEV needs to close the connection in order to start again
  }
}

on value_update EV.SLAC.CM_SLAC_MATCH_CNF
{
  if(IsEVRolePassive())
  {
    EV.StopSimulation.Call();
    EV.SetAdHocSendingEnabled.Call(1);
    SendCmSetKeyReq();
  }
}

void SendCmSetKeyReq()
{
  int i;
  for(i = 0; i < $EV.SLAC.CM_SLAC_MATCH_CNF.NMK.length; i++)
  {     
    $EV.SLAC.CM_SET_KEY_REQ.NMK[i] = $EV.SLAC.CM_SLAC_MATCH_CNF.NMK[i];   
  }
  for(i = 0; i < $EV.SLAC.CM_SLAC_MATCH_CNF.NID.length; i++)
  {     
    $EV.SLAC.CM_SET_KEY_REQ.NID[i] = $EV.SLAC.CM_SLAC_MATCH_CNF.NID[i];   
  }
}

on sysVar Test::SysSendSECCDiscoveryReq
{
  if (@this == 1 && IsEVRolePassive())
  {
    if(@sysVar::Common::SysTLSEnabled == @Common::SysTLSEnabled::TLSDisabled)
      $EV.SDP.SECC_Discovery_Request.SecurityType = 0x10;
    else
      $EV.SDP.SECC_Discovery_Request.SecurityType = 0x00;
  }
}

on sysVar Test::SysSendSupportedAppProtocolReq
{
  if (@this == 1 && IsEVRolePassive())
  {
    if (IsSchemaISO_20_Selected())
    {
      if(@sysvar::Common::SysUserChargingMode == sysvar::Common::SysUserChargingMode::AC)
      {
        if(@sysvar::Common::SysUserACDERMode == 0)
          $EV.SAP.SupportedAppProtocol_Request.AppProtocols[0].ProtocolNamespace = "urn:iso:std:iso:15118:-20:AC";
        else
          $EV.SAP.SupportedAppProtocol_Request.AppProtocols[0].ProtocolNamespace = "urn:iso:std:iso:15118:-20:AC-DER";
      }
      else
      {
        $EV.SAP.SupportedAppProtocol_Request.AppProtocols[0].ProtocolNamespace = "urn:iso:std:iso:15118:-20:DC";
      }
    }

    if (IsSchemaISO_2_Selected())
    {
        $EV.SAP.SupportedAppProtocol_Request.AppProtocols[0].ProtocolNamespace = "urn:iso:15118:2:2013:MsgDef";
        $EV.SAP.SupportedAppProtocol_Request.AppProtocols[0].SchemaID = 2;
        $EV.SAP.SupportedAppProtocol_Request.AppProtocols[0].VersionNumberMajor = 2;
    }
  }
}

on sysVar Test::SysSendSessionSetupReq
{  
  if (@this == 1 && IsEVRolePassive())
  {   
    if (IsSchemaISO_20_Selected())
    {
      $EV.ISO20.SessionSetup_Request.EVCCID = $EV.ISO20.SessionSetup_Request.EVCCID;
    }
    if (IsSchemaISO_2_Selected())
    {
      $EV.ISO2.SessionSetup_Request;
    }
  }
}

