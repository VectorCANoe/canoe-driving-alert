on sysVar Test::SysSendChargeParDiscoveryReq
{
  if (@this == 1 && IsEVRolePassive())
  {
    if (IsSchemaISO_20_Selected())
    {
      if (@sysvar::Common::SysUserChargingMode == 0 /* AC */)
        if(@sysvar::Common::SysUserACDERMode == 0)
          FUNC_Set_EVACLimits_ChargeParameterDiscoveryReq();
        else
          FUNC_Set_EVDERACLimits_ChargeParameterDiscoveryReq();
      else if (@sysvar::Common::SysUserChargingMode == 1 /* DC */)
        FUNC_Set_EVDCLimits_ChargeParameterDiscoveryReq();
    }
    if (IsSchemaISO_2_Selected())
    {
      $EV.ISO2.ChargeParameterDiscovery_Request;
    }
  }
}

