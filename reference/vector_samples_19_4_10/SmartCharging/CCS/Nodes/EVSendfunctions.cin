on sysVar Test::SysSendAuthorizationReq
{  
  if (@this == 1 && IsEVRolePassive())
  {
    if (IsSchemaISO_20_Selected())
    {
      if(@Common::SysUserAuthorizationMode == @Common::SysUserAuthorizationMode::PnC)
      {
        int i;
        for(i = 0; i < 16; i++)
        {
          $EV.ISO20.Authorization_Request.AReqAuthorizationMode.PnC_AReqAuthorizationMode.GenChallenge[i] = $EV.ISO20.AuthorizationSetup_Response.ASResAuthorizationMode.PnC_ASResAuthorizationMode.GenChallenge[i];
        }
      }
      $EV.ISO20.Authorization_Request.Header.TimeStamp = $EV.ISO20.Authorization_Request.Header.TimeStamp;
    }
    if (IsSchemaISO_2_Selected())
    {
      $EV.ISO2.Authorization_Request;
    }
  }
}

