void FUNC_Get_EVSE_DCChargeLoopValues()
{  
  $EVSE.ISO20.DC_ChargeLoop_Response.EVSEPresentCurrent.Value = HV_measure_DC_I();
  $EVSE.ISO20.DC_ChargeLoop_Response.EVSEPresentCurrent.Exponent = 0;
  
  $EVSE.ISO20.DC_ChargeLoop_Response.EVSEPresentVoltage.Value = HV_measure_DC_U();
  $EVSE.ISO20.DC_ChargeLoop_Response.EVSEPresentVoltage.Exponent = 0;
  
  if($EVSE.ISO20.DC_ChargeLoop_Request.DisplayParameters.IsValid)
  {
    if($EVSE.ISO20.DC_ChargeLoop_Request.DisplayParameters.MinimumSOC.IsValid)
    {
      $EVSE.ISO20.DC_ChargeLoop_Response.CLResControlMode.BPT_Dynamic_DC_CLResControlMode.MinimumSOC = $EVSE.ISO20.DC_ChargeLoop_Request.DisplayParameters.MinimumSOC;
      $EVSE.ISO20.DC_ChargeLoop_Response.CLResControlMode.Dynamic_DC_CLResControlMode.MinimumSOC = $EVSE.ISO20.DC_ChargeLoop_Request.DisplayParameters.MinimumSOC;
    }
    else
    {
      $EVSE.ISO20.DC_ChargeLoop_Response.CLResControlMode.BPT_Dynamic_DC_CLResControlMode.MinimumSOC.SetInvalid();
      $EVSE.ISO20.DC_ChargeLoop_Response.CLResControlMode.Dynamic_DC_CLResControlMode.MinimumSOC.SetInvalid();
    }
     
    if($EVSE.ISO20.DC_ChargeLoop_Request.DisplayParameters.TargetSOC.IsValid)
    {
      $EVSE.ISO20.DC_ChargeLoop_Response.CLResControlMode.BPT_Dynamic_DC_CLResControlMode.TargetSOC = $EVSE.ISO20.DC_ChargeLoop_Request.DisplayParameters.TargetSOC;
      $EVSE.ISO20.DC_ChargeLoop_Response.CLResControlMode.Dynamic_DC_CLResControlMode.TargetSOC = $EVSE.ISO20.DC_ChargeLoop_Request.DisplayParameters.TargetSOC;
    }    
    else
    {
      $EVSE.ISO20.DC_ChargeLoop_Response.CLResControlMode.BPT_Dynamic_DC_CLResControlMode.TargetSOC.SetInvalid();
      $EVSE.ISO20.DC_ChargeLoop_Response.CLResControlMode.Dynamic_DC_CLResControlMode.TargetSOC.SetInvalid();
    }
  }
  else
  {
    $EVSE.ISO20.DC_ChargeLoop_Response.CLResControlMode.BPT_Dynamic_DC_CLResControlMode.MinimumSOC.SetInvalid();
    $EVSE.ISO20.DC_ChargeLoop_Response.CLResControlMode.Dynamic_DC_CLResControlMode.MinimumSOC.SetInvalid();
    $EVSE.ISO20.DC_ChargeLoop_Response.CLResControlMode.BPT_Dynamic_DC_CLResControlMode.TargetSOC.SetInvalid();
    $EVSE.ISO20.DC_ChargeLoop_Response.CLResControlMode.Dynamic_DC_CLResControlMode.TargetSOC.SetInvalid();
  }
  
  //EVSEMinimumChargePower
  $EVSE.ISO20.DC_ChargeLoop_Response.CLResControlMode.BPT_Dynamic_DC_CLResControlMode.EVSEMinimumChargePower.Value = @sysvar::EVSE_Sim::SysEVSE_MinPowerDC;
  $EVSE.ISO20.DC_ChargeLoop_Response.CLResControlMode.BPT_Dynamic_DC_CLResControlMode.EVSEMinimumChargePower.Exponent = 3; //Unit: kW
  $EVSE.ISO20.DC_ChargeLoop_Response.CLResControlMode.Dynamic_DC_CLResControlMode.EVSEMinimumChargePower.Value = @sysvar::EVSE_Sim::SysEVSE_MinPowerDC;
  $EVSE.ISO20.DC_ChargeLoop_Response.CLResControlMode.Dynamic_DC_CLResControlMode.EVSEMinimumChargePower.Exponent = 3; //Unit: kW
  $EVSE.ISO20.DC_ChargeLoop_Response.CLResControlMode.BPT_Scheduled_DC_CLResControlMode.EVSEMinimumChargePower.Value = @sysvar::EVSE_Sim::SysEVSE_MinPowerDC;
  $EVSE.ISO20.DC_ChargeLoop_Response.CLResControlMode.BPT_Scheduled_DC_CLResControlMode.EVSEMinimumChargePower.Exponent = 3; //Unit: kW
  $EVSE.ISO20.DC_ChargeLoop_Response.CLResControlMode.Scheduled_DC_CLResControlMode.EVSEMinimumChargePower.Value = @sysvar::EVSE_Sim::SysEVSE_MinPowerDC;
  $EVSE.ISO20.DC_ChargeLoop_Response.CLResControlMode.Scheduled_DC_CLResControlMode.EVSEMinimumChargePower.Exponent = 3; //Unit: kW
  
  //EVSEMaximumChargePower
  $EVSE.ISO20.DC_ChargeLoop_Response.CLResControlMode.BPT_Dynamic_DC_CLResControlMode.EVSEMaximumChargePower.Value = @sysvar::EVSE_Sim::SysEVSE_MaxPowerDC;
  $EVSE.ISO20.DC_ChargeLoop_Response.CLResControlMode.BPT_Dynamic_DC_CLResControlMode.EVSEMaximumChargePower.Exponent = 3; //Unit: kW
  $EVSE.ISO20.DC_ChargeLoop_Response.CLResControlMode.Dynamic_DC_CLResControlMode.EVSEMaximumChargePower.Value = @sysvar::EVSE_Sim::SysEVSE_MaxPowerDC;
  $EVSE.ISO20.DC_ChargeLoop_Response.CLResControlMode.Dynamic_DC_CLResControlMode.EVSEMaximumChargePower.Exponent = 3; //Unit: kW
  $EVSE.ISO20.DC_ChargeLoop_Response.CLResControlMode.BPT_Scheduled_DC_CLResControlMode.EVSEMaximumChargePower.Value = @sysvar::EVSE_Sim::SysEVSE_MaxPowerDC;
  $EVSE.ISO20.DC_ChargeLoop_Response.CLResControlMode.BPT_Scheduled_DC_CLResControlMode.EVSEMaximumChargePower.Exponent = 3; //Unit: kW
  $EVSE.ISO20.DC_ChargeLoop_Response.CLResControlMode.Scheduled_DC_CLResControlMode.EVSEMaximumChargePower.Value = @sysvar::EVSE_Sim::SysEVSE_MaxPowerDC;
  $EVSE.ISO20.DC_ChargeLoop_Response.CLResControlMode.Scheduled_DC_CLResControlMode.EVSEMaximumChargePower.Exponent = 3; //Unit: kW
  
  //EVSEMaximumVoltage
  $EVSE.ISO20.DC_ChargeLoop_Response.CLResControlMode.BPT_Dynamic_DC_CLResControlMode.EVSEMaximumVoltage.Value = @sysvar::EVSE_Sim::SysEVSE_MaxVoltage;
  $EVSE.ISO20.DC_ChargeLoop_Response.CLResControlMode.BPT_Dynamic_DC_CLResControlMode.EVSEMaximumVoltage.Exponent = 0;
  $EVSE.ISO20.DC_ChargeLoop_Response.CLResControlMode.Dynamic_DC_CLResControlMode.EVSEMaximumVoltage.Value = @sysvar::EVSE_Sim::SysEVSE_MaxVoltage;
  $EVSE.ISO20.DC_ChargeLoop_Response.CLResControlMode.Dynamic_DC_CLResControlMode.EVSEMaximumVoltage.Exponent = 0;
  $EVSE.ISO20.DC_ChargeLoop_Response.CLResControlMode.BPT_Scheduled_DC_CLResControlMode.EVSEMaximumVoltage.Value = @sysvar::EVSE_Sim::SysEVSE_MaxVoltage;
  $EVSE.ISO20.DC_ChargeLoop_Response.CLResControlMode.BPT_Scheduled_DC_CLResControlMode.EVSEMaximumVoltage.Exponent = 0;
  $EVSE.ISO20.DC_ChargeLoop_Response.CLResControlMode.Scheduled_DC_CLResControlMode.EVSEMaximumVoltage.Value = @sysvar::EVSE_Sim::SysEVSE_MaxVoltage;
  $EVSE.ISO20.DC_ChargeLoop_Response.CLResControlMode.Scheduled_DC_CLResControlMode.EVSEMaximumVoltage.Exponent = 0;
  
  //EVSEMaximumChargeCurrent
  $EVSE.ISO20.DC_ChargeLoop_Response.CLResControlMode.BPT_Dynamic_DC_CLResControlMode.EVSEMaximumChargeCurrent.Value = @sysvar::EVSE_Sim::SysEVSE_MaxCurrent;
  $EVSE.ISO20.DC_ChargeLoop_Response.CLResControlMode.BPT_Dynamic_DC_CLResControlMode.EVSEMaximumChargeCurrent.Exponent = 0;
  $EVSE.ISO20.DC_ChargeLoop_Response.CLResControlMode.Dynamic_DC_CLResControlMode.EVSEMaximumChargeCurrent.Value = @sysvar::EVSE_Sim::SysEVSE_MaxCurrent;
  $EVSE.ISO20.DC_ChargeLoop_Response.CLResControlMode.Dynamic_DC_CLResControlMode.EVSEMaximumChargeCurrent.Exponent = 0;
  $EVSE.ISO20.DC_ChargeLoop_Response.CLResControlMode.BPT_Scheduled_DC_CLResControlMode.EVSEMaximumChargeCurrent.Value = @sysvar::EVSE_Sim::SysEVSE_MaxCurrent;
  $EVSE.ISO20.DC_ChargeLoop_Response.CLResControlMode.BPT_Scheduled_DC_CLResControlMode.EVSEMaximumChargeCurrent.Exponent = 0;
  $EVSE.ISO20.DC_ChargeLoop_Response.CLResControlMode.Scheduled_DC_CLResControlMode.EVSEMaximumChargeCurrent.Value = @sysvar::EVSE_Sim::SysEVSE_MaxCurrent;
  $EVSE.ISO20.DC_ChargeLoop_Response.CLResControlMode.Scheduled_DC_CLResControlMode.EVSEMaximumChargeCurrent.Exponent = 0;
  
  //EVSEMaximumDischargePower
  $EVSE.ISO20.DC_ChargeLoop_Response.CLResControlMode.BPT_Dynamic_DC_CLResControlMode.EVSEMaximumDischargePower.Value = - abs(@sysvar::EVSE_Sim::SysEVSE_MaxPowerDC);
  $EVSE.ISO20.DC_ChargeLoop_Response.CLResControlMode.BPT_Dynamic_DC_CLResControlMode.EVSEMaximumDischargePower.Exponent = 3; //Unit: kW
  $EVSE.ISO20.DC_ChargeLoop_Response.CLResControlMode.BPT_Scheduled_DC_CLResControlMode.EVSEMaximumDischargePower.Value = - abs(@sysvar::EVSE_Sim::SysEVSE_MaxPowerDC);
  $EVSE.ISO20.DC_ChargeLoop_Response.CLResControlMode.BPT_Scheduled_DC_CLResControlMode.EVSEMaximumDischargePower.Exponent = 3; //Unit: kW
  
  //EVSEMinimumDischargePower
  $EVSE.ISO20.DC_ChargeLoop_Response.CLResControlMode.BPT_Dynamic_DC_CLResControlMode.EVSEMinimumDischargePower.Value = - abs(@sysvar::EVSE_Sim::SysEVSE_MinPowerDC);
  $EVSE.ISO20.DC_ChargeLoop_Response.CLResControlMode.BPT_Dynamic_DC_CLResControlMode.EVSEMinimumDischargePower.Exponent = 3; //Unit: kW
  $EVSE.ISO20.DC_ChargeLoop_Response.CLResControlMode.BPT_Scheduled_DC_CLResControlMode.EVSEMinimumDischargePower.Value = - abs(@sysvar::EVSE_Sim::SysEVSE_MinPowerDC);
  $EVSE.ISO20.DC_ChargeLoop_Response.CLResControlMode.BPT_Scheduled_DC_CLResControlMode.EVSEMinimumDischargePower.Exponent = 3; //Unit: kW
  
  //EVSEMaximumDischargeCurrent
  $EVSE.ISO20.DC_ChargeLoop_Response.CLResControlMode.BPT_Dynamic_DC_CLResControlMode.EVSEMaximumDischargeCurrent.Value = - abs(@sysvar::EVSE_Sim::SysEVSE_MaxCurrent);
  $EVSE.ISO20.DC_ChargeLoop_Response.CLResControlMode.BPT_Dynamic_DC_CLResControlMode.EVSEMaximumDischargeCurrent.Exponent = 0;
  $EVSE.ISO20.DC_ChargeLoop_Response.CLResControlMode.BPT_Scheduled_DC_CLResControlMode.EVSEMaximumDischargeCurrent.Value = - abs(@sysvar::EVSE_Sim::SysEVSE_MaxCurrent);
  $EVSE.ISO20.DC_ChargeLoop_Response.CLResControlMode.BPT_Scheduled_DC_CLResControlMode.EVSEMaximumDischargeCurrent.Exponent = 0;
  
  //EVSEMinimumVoltage
  $EVSE.ISO20.DC_ChargeLoop_Response.CLResControlMode.BPT_Dynamic_DC_CLResControlMode.EVSEMinimumVoltage.Value = @sysvar::EVSE_Sim::SysEVSE_MinVoltage;
  $EVSE.ISO20.DC_ChargeLoop_Response.CLResControlMode.BPT_Dynamic_DC_CLResControlMode.EVSEMinimumVoltage.Exponent = 0;
  $EVSE.ISO20.DC_ChargeLoop_Response.CLResControlMode.BPT_Scheduled_DC_CLResControlMode.EVSEMinimumVoltage.Value = @sysvar::EVSE_Sim::SysEVSE_MinVoltage;
  $EVSE.ISO20.DC_ChargeLoop_Response.CLResControlMode.BPT_Scheduled_DC_CLResControlMode.EVSEMinimumVoltage.Exponent = 0;
}