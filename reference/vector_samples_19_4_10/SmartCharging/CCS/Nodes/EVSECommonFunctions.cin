void FUNC_Get_EVSE_ACChargeLoopValues()
{    
  if($EVSE.ISO20.AC_ChargeLoop_Request.DisplayParameters.IsValid)
  {
    if($EVSE.ISO20.AC_ChargeLoop_Request.DisplayParameters.MinimumSOC.IsValid)
    {
      $EVSE.ISO20.AC_ChargeLoop_Response.CLResControlMode.BPT_Dynamic_AC_CLResControlMode.MinimumSOC = $EVSE.ISO20.AC_ChargeLoop_Request.DisplayParameters.MinimumSOC;
      $EVSE.ISO20.AC_ChargeLoop_Response.CLResControlMode.Dynamic_AC_CLResControlMode.MinimumSOC = $EVSE.ISO20.AC_ChargeLoop_Request.DisplayParameters.MinimumSOC;
    }
    else
    {
      $EVSE.ISO20.AC_ChargeLoop_Response.CLResControlMode.BPT_Dynamic_AC_CLResControlMode.MinimumSOC.SetInvalid();
      $EVSE.ISO20.AC_ChargeLoop_Response.CLResControlMode.Dynamic_AC_CLResControlMode.MinimumSOC.SetInvalid();
    }
     
    if($EVSE.ISO20.DC_ChargeLoop_Request.DisplayParameters.TargetSOC.IsValid)
    {
      $EVSE.ISO20.AC_ChargeLoop_Response.CLResControlMode.BPT_Dynamic_AC_CLResControlMode.TargetSOC = $EVSE.ISO20.AC_ChargeLoop_Request.DisplayParameters.TargetSOC;
      $EVSE.ISO20.AC_ChargeLoop_Response.CLResControlMode.Dynamic_AC_CLResControlMode.TargetSOC = $EVSE.ISO20.AC_ChargeLoop_Request.DisplayParameters.TargetSOC;
    }   
    else
    {
      $EVSE.ISO20.AC_ChargeLoop_Response.CLResControlMode.BPT_Dynamic_AC_CLResControlMode.TargetSOC.SetInvalid();
      $EVSE.ISO20.AC_ChargeLoop_Response.CLResControlMode.Dynamic_AC_CLResControlMode.TargetSOC.SetInvalid();
    }
  }
  else
  {
    $EVSE.ISO20.AC_ChargeLoop_Response.CLResControlMode.BPT_Dynamic_AC_CLResControlMode.MinimumSOC.SetInvalid();
    $EVSE.ISO20.AC_ChargeLoop_Response.CLResControlMode.Dynamic_AC_CLResControlMode.MinimumSOC.SetInvalid();
