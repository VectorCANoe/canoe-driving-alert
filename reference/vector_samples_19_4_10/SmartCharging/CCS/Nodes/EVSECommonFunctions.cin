    $EVSE.ISO20.AC_DER_ChargeLoop_Response.CLResControlMode.DER_Scheduled_AC_CLResControlMode.DERControl.ActivePowerSupport.LimitMaxDischargePower.PowerMonitoringMustTripCurve.xUnit = _CCS::DataTypes::CurveDataPointsUnitType::W;
    $EVSE.ISO20.AC_DER_ChargeLoop_Response.CLResControlMode.DER_Scheduled_AC_CLResControlMode.DERControl.ActivePowerSupport.LimitMaxDischargePower.PowerMonitoringMustTripCurve.yUnit = _CCS::DataTypes::CurveDataPointsUnitType::W;
    $EVSE.ISO20.AC_DER_ChargeLoop_Response.CLResControlMode.DER_Scheduled_AC_CLResControlMode.DERControl.ActivePowerSupport.LimitMaxDischargePower.PowerMonitoringMustTripCurve.CurveDataPoints.CurveDataPoint.Length = 3;
    $EVSE.ISO20.AC_DER_ChargeLoop_Response.CLResControlMode.DER_Scheduled_AC_CLResControlMode.DERControl.ActivePowerSupport.LimitMaxDischargePower.PowerMonitoringMustTripCurve.CurveDataPoints.CurveDataPoint[0].x.Exponent = 1;
    $EVSE.ISO20.AC_DER_ChargeLoop_Response.CLResControlMode.DER_Scheduled_AC_CLResControlMode.DERControl.ActivePowerSupport.LimitMaxDischargePower.PowerMonitoringMustTripCurve.CurveDataPoints.CurveDataPoint[0].x.Value = 2;
    $EVSE.ISO20.AC_DER_ChargeLoop_Response.CLResControlMode.DER_Scheduled_AC_CLResControlMode.DERControl.ActivePowerSupport.LimitMaxDischargePower.PowerMonitoringMustTripCurve.CurveDataPoints.CurveDataPoint[0].y.Exponent = 1;
    $EVSE.ISO20.AC_DER_ChargeLoop_Response.CLResControlMode.DER_Scheduled_AC_CLResControlMode.DERControl.ActivePowerSupport.LimitMaxDischargePower.PowerMonitoringMustTripCurve.CurveDataPoints.CurveDataPoint[0].y.Value = 2;
    $EVSE.ISO20.AC_DER_ChargeLoop_Response.CLResControlMode.DER_Scheduled_AC_CLResControlMode.DERControl.ActivePowerSupport.LimitMaxDischargePower.PowerMonitoringMustTripCurve.CurveDataPoints.CurveDataPoint[1].x.Exponent = 1;
    $EVSE.ISO20.AC_DER_ChargeLoop_Response.CLResControlMode.DER_Scheduled_AC_CLResControlMode.DERControl.ActivePowerSupport.LimitMaxDischargePower.PowerMonitoringMustTripCurve.CurveDataPoints.CurveDataPoint[1].x.Value = 2;
    $EVSE.ISO20.AC_DER_ChargeLoop_Response.CLResControlMode.DER_Scheduled_AC_CLResControlMode.DERControl.ActivePowerSupport.LimitMaxDischargePower.PowerMonitoringMustTripCurve.CurveDataPoints.CurveDataPoint[1].y.Exponent = 1;
    $EVSE.ISO20.AC_DER_ChargeLoop_Response.CLResControlMode.DER_Scheduled_AC_CLResControlMode.DERControl.ActivePowerSupport.LimitMaxDischargePower.PowerMonitoringMustTripCurve.CurveDataPoints.CurveDataPoint[1].y.Value = 2;
    $EVSE.ISO20.AC_DER_ChargeLoop_Response.CLResControlMode.DER_Scheduled_AC_CLResControlMode.DERControl.ActivePowerSupport.LimitMaxDischargePower.PowerMonitoringMustTripCurve.CurveDataPoints.CurveDataPoint[2].x.Exponent = 1;
    $EVSE.ISO20.AC_DER_ChargeLoop_Response.CLResControlMode.DER_Scheduled_AC_CLResControlMode.DERControl.ActivePowerSupport.LimitMaxDischargePower.PowerMonitoringMustTripCurve.CurveDataPoints.CurveDataPoint[2].x.Value = 2;
