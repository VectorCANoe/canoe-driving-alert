void FUNC_Set_EVSEACDERLimits_ChargeParameterDiscoveryRes()
{
  EVSE.ISO20.EnableAutoBodyFill.Call(0);
  AutoFill_body = 0;
  
  if((@Common::SysUserACDERMode == 0) && (@Common::SysUserBPTMode == 0))
    UseACElement();
  else if(@Common::SysUserBPTMode == 1)
    UseACBPTElement();
  else
    UseACDERElement();
}

void UseACElement()
{
  /* EVSEMaximumChargePower */
  $EVSE.ISO20.AC_DER_ChargeParameterDiscovery_Response.CPDResEnergyTransferMode.AC_CPDResEnergyTransferMode.EVSEMaximumChargePower.Value = @sysvar::EVSE_Sim::SysEVSE_MaxPowerAC;
  $EVSE.ISO20.AC_DER_ChargeParameterDiscovery_Response.CPDResEnergyTransferMode.AC_CPDResEnergyTransferMode.EVSEMaximumChargePower.Exponent = 3; //Unit: kW
}

void UseACBPTElement()
{
  /* EVSEMaximumChargePower */
