    $EVSE.ISO20.AC_DER_ChargeLoop_Response.CLResControlMode.DER_Scheduled_AC_CLResControlMode.DERControl.ActivePowerSupport.LimitMaxDischargePower.PowerMonitoringMustTripCurve.CurveDataPoints.CurveDataPoint[2].y.Value = 2;
    $EVSE.ISO20.AC_DER_ChargeLoop_Response.CLResControlMode.DER_Scheduled_AC_CLResControlMode.DERControl.ActivePowerSupport.LimitMaxDischargePower.PowerMonitoringMustTripCurve.LockInValue = _CCS::DataTypes::LockValueUnitType::W;
    $EVSE.ISO20.AC_DER_ChargeLoop_Response.CLResControlMode.DER_Scheduled_AC_CLResControlMode.DERControl.ActivePowerSupport.LimitMaxDischargePower.PowerMonitoringMustTripCurve.LockOutValue = _CCS::DataTypes::LockValueUnitType::W;
    $EVSE.ISO20.AC_DER_ChargeLoop_Response.CLResControlMode.DER_Scheduled_AC_CLResControlMode.DERControl.ActivePowerSupport.LimitMaxDischargePower.PowerMonitoringMustTripCurve.OpenLoopResponseTime.Exponent = 2;
