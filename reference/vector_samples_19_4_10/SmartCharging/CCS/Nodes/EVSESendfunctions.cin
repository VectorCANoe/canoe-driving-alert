on sysVar Test::SysSendChargeParDiscoveryRes
{
  if (@this == 1 && IsEVSERolePassive())
  {
    if (IsSchemaISO_20_Selected())
    {
      if (@sysvar::Common::SysUserChargingMode == 0 /* AC */)
      {
        if(@sysvar::Common::SysUserACDERMode == 0)
          FUNC_Set_EVSEACLimits_ChargeParameterDiscoveryRes();
        else
          FUNC_Set_EVSEACDERLimits_ChargeParameterDiscoveryRes();
      }
      else if (@sysvar::Common::SysUserChargingMode == 1 /* DC */)
        FUNC_Set_EVSEDCLimits_ChargeParameterDiscoveryRes();
    }
    if (IsSchemaISO_2_Selected())
    {
      $EVSE.ISO2.ChargeParameterDiscovery_Response;
    }
  }
}

