/*@!Encoding:1252*/
includes
{
  //Already included in EVSEsimDO.can, but might be needed if this file is used on its own
  //#include "EVSECommonFunctions.cin"
  //#include "CharIn_HW_Interface_EVSE.cin"
  #include "StateUtilities.cin"
}

variables
{
}

on prestart 
{
  @Test::SysTestApplyControlMode = 0;
}

on sysVar Test::SysTestApplyControlMode
{
  if (@this == 1)
  {
    reReadSharedAttributes();    
    EVSE.StartSimulation.Call();
    CP_EVSE_set_open_circuit(1);
    PP_EVSE_set_open_circuit(1);
  }
  else
  {
    // PEVSE needs to close the connection in order to start again
    Reset_EVSE_Values();
  }
}

on value_update EVSE.SDP.SECC_Discovery_Request
{
  if(IsEVSERolePassive())
  {
    EVSE.StopSimulation.Call();
    EVSE.SetAdHocSendingEnabled.Call(1);
  }
}

on sysVar Test::SysSendSECCDiscoveryRes
{
  if (@this == 1 && IsEVSERolePassive())
  {
    if(@sysVar::Common::SysTLSEnabled == @Common::SysTLSEnabled::TLSDisabled)
      $EVSE.SDP.SECC_Discovery_Response.SecurityType = 0x10;
    else
      $EVSE.SDP.SECC_Discovery_Response.SecurityType = 0x00;
  }
}

on sysVar Test::SysSendSupportedAppProtocolRes
{
  if (@this == 1 && IsEVSERolePassive())
  {
    if (IsSchemaISO_20_Selected())
    {
      $EVSE.SAP.SupportedAppProtocol_Response.ResponseCode = $EVSE.SAP.SupportedAppProtocol_Response.ResponseCode;
    }
    if (IsSchemaISO_2_Selected())
    {
      $EVSE.SAP.SupportedAppProtocol_Response.ResponseCode = $EVSE.SAP.SupportedAppProtocol_Response.ResponseCode;
      $EVSE.SAP.SupportedAppProtocol_Response.SchemaID = 2;
    }
  }
}

on sysVar Test::SysSendSessionSetupRes
{  
  if (@this == 1 && IsEVSERolePassive())
  {
    if (IsSchemaISO_20_Selected())
    {
      $EVSE.ISO20.SessionSetup_Response.ResponseCode = $EVSE.ISO20.SessionSetup_Response.ResponseCode;
    }
    if (IsSchemaISO_2_Selected())
    {
      $EVSE.ISO2.SessionSetup_Response.ResponseCode = $EVSE.ISO2.SessionSetup_Response.ResponseCode;
    }
  }
}

on sysVar Test::SysSendAuthorizationSetupRes
{  
  if (@this == 1 && IsEVSERolePassive())
  {
    if(@Common::SysUserAuthorizationMode == @Common::SysUserAuthorizationMode::PnC)
    {
      int i;
      // ensure PnC element is active and add a default value
      $CCS::Simulation::EVSE.ISO20.AuthorizationSetup_Response.ASResAuthorizationModeElementId = _CCS::DataTypes::parISO20ASResAuthorizationMode::PnC_ASRes;
      $CCS::Simulation::EVSE.ISO20.AuthorizationSetup_Response.ASResAuthorizationMode.PnC_ASResAuthorizationMode.SupportedProviders.ProviderID.Length = 1;
      $CCS::Simulation::EVSE.ISO20.AuthorizationSetup_Response.ASResAuthorizationMode.PnC_ASResAuthorizationMode.SupportedProviders.ProviderID[0] = "Vector";
      for(i = 0; i < 16; i++)
      {
        $EVSE.ISO20.AuthorizationSetup_Response.ASResAuthorizationMode.PnC_ASResAuthorizationMode.GenChallenge[i] = i+1;
      }
    }
    $EVSE.ISO20.AuthorizationSetup_Response.ResponseCode = $EVSE.ISO20.AuthorizationSetup_Response.ResponseCode;
  }
}

on sysVar Test::SysSendServiceDiscoveryRes
{
  if (@this == 1 && IsEVSERolePassive())
  {
    if (IsSchemaISO_20_Selected())
    {
      if(@sysvar::Common::SysUserChargingMode == sysvar::Common::SysUserChargingMode::AC)
      {
        /* AC_BPT */
        $EVSE.ISO20.ServiceDiscovery_Response.EnergyTransferServiceList.Service[0].ServiceID = _CCS::DataTypes::ServiceIDEncoding::AC_BPT;
      }
      else
      {
        /* DC_BPT */
        $EVSE.ISO20.ServiceDiscovery_Response.EnergyTransferServiceList.Service[0].ServiceID = _CCS::DataTypes::ServiceIDEncoding::DC_BPT;
      }
    }

    if (IsSchemaISO_2_Selected())
    {
      $EVSE.ISO2.ServiceDiscovery_Response;
    }
  }
}

on sysVar Test::SysSendServiceDetailRes
{
  if (@this == 1 && IsEVSERolePassive())
  {
    if (IsSchemaISO_20_Selected())
    {
      if ($EVSE.ISO20.ServiceDetail_Request.ServiceID == 6)
        FUNC_Set_ServiceDetailRes();
      else
      {
        // Definition of required service ID (shall be equal to the if query
        $EVSE.ISO20.ServiceDetail_Response.ServiceID = $EVSE.ISO20.ServiceDetail_Request.ServiceID;
      }
    }
    if (IsSchemaISO_2_Selected())
    {
      $EVSE.ISO2.ServiceDetail_Response;
    }
  }
}

