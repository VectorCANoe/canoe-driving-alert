    $EVSE.ISO20.ScheduleExchange_Response.ResponseCode = $EVSE.ISO20.ScheduleExchange_Response.ResponseCode;
    if(@Common::SysUserAuthorizationMode == @Common::SysUserAuthorizationMode::PnC)
    {
      $CCS::Simulation::EVSE.ISO20.ScheduleExchange_Response.SEResControlMode.Dynamic_SEResControlMode.PriceSchedule.AbsolutePriceSchedule.TimeAnchor = 60;  
    }      
