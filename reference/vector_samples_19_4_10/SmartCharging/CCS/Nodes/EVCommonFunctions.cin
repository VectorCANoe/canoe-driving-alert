/*@!Encoding:1252*/
variables
{
  int isPassive = 0;
  
  const SystemPageOfWriteWindow = 0;
  const Warning = 2;
  int gSessionStopResCounter = 0;
  int matchingParameterSetID_BPT = -1;
  int AutoFill_body = 0;
  const long cBatteryCapacityInWh = 80000;
  const float cTargetSOC = 80.0;
  const float cMinimumSOC = 20.0;
  const int cRationalNumberMaxValue = 32767; // sint16 MaxValue
}

on sysvar Common::SysTLSEnabled
{
  setTLSAttribute();
}

on sysvar Common::SysUserAuthorizationMode
{
  setAuthorizationMode(); 
}

int IsEVRolePassive()
{
  if((@sysVar::Test::SysTestControlledEntity != 1) && (@Test::SysTestApplyControlMode == 1))
    return 1;
  
  return 0;
}

void ResetVariables()
{
  gSessionStopResCounter = 0;
  matchingParameterSetID_BPT = -1;
  EVProcessingLoopCounter = 0;
  EVSRProcessingLoopCounter = 0;
}

reReadAttributes()
{
  setControlMode();
  setTLSAttribute();
  setAuthorizationMode();
  setCertHandlingAttribute();
}

setControlMode()
{
  if (@sysvar::EV_Sim::Control::SysEV_ControlModeDynamic == @sysvar::EV_Sim::Control::SysEV_ControlModeDynamic::Dynamic){
    setAttribute(CCS::Simulation::EV, CCSBinding::EV::ControlMode, CCSBinding::Dynamic);
  }
  else
  {
    setAttribute(CCS::Simulation::EV, CCSBinding::EV::ControlMode, CCSBinding::Scheduled);
  }
}

setAuthorizationMode()
{
  if (@sysvar::Common::SysUserAuthorizationMode == sysvar::Common::SysUserAuthorizationMode::EIM){
    setAttribute(CCS::Simulation::EV, CCSBinding::EV::AuthorizationMode, 0);
  }
  else{
    setAttribute(CCS::Simulation::EV, CCSBinding::EV::AuthorizationMode, 1); //PnC
  }
}

setTLSAttribute()
{
  if (@sysVar::Common::SysTLSEnabled == @sysvar::Common::SysTLSEnabled::TLSEnabled){
    setAttribute(CCS::Simulation::EV, CCSBinding::TLS, CCSBinding::TLSEnabled); 
  }
  else{
    setAttribute(CCS::Simulation::EV, CCSBinding::TLS, CCSBinding::TLSDisabled); 
  }
}

setCertHandlingAttribute()
{
  if (@sysvar::EV_Sim::Control::SysEV_CertificateInstallation == 1){
    setAttribute(CCS::Simulation::EV, CCSBinding::EV::CertificateHandling, CCSBinding::Installation);
  }
  else{
    setAttribute(CCS::Simulation::EV, CCSBinding::EV::CertificateHandling, CCSBinding::None);
  }
}

int GetCorrespondingMessageControlModeForSelectedControlMode()
{
  if (@sysvar::EV_Sim::Control::SysEV_ControlModeDynamic == @sysvar::EV_Sim::Control::SysEV_ControlModeDynamic::Dynamic){
    return _CCS::DataTypes::ControlModeType::Dynamic;
  }
  else{
    return _CCS::DataTypes::ControlModeType::Scheduled;
  }
}

int GetCorrespondingMessageServiceIDForSelectedChargingMode_Downgraded()
{
  return _GetCorrespondingMessageServiceIDForSelectedChargingMode(@sysvar::Common::SysUserChargingMode, @sysvar::Common::SysUserBPTMode::No_BPT);
}

int GetCorrespondingMessageServiceIDForSelectedChargingMode()
{
  return _GetCorrespondingMessageServiceIDForSelectedChargingMode(@sysvar::Common::SysUserChargingMode, @sysvar::Common::SysUserBPTMode);
}

int _GetCorrespondingMessageServiceIDForSelectedChargingMode(int chargingMode, int bptMode)
{
  if (chargingMode == sysvar::Common::SysUserChargingMode::AC) 
  {
    /* AC */
    if (bptMode == sysvar::Common::SysUserBPTMode::No_BPT)
    {
      /* NO BPT */
      if(@Common::SysUserACDERMode == 1)
        /* AC_DER */
        return _CCS::DataTypes::ServiceIDType::AC_DER; 
      else
        return _CCS::DataTypes::ServiceIDType::AC;
    }
    else
    {
      /* BPT */
      return _CCS::DataTypes::ServiceIDType::AC_BPT;
    }
  }
  else 
  {
    /* DC */
    if (bptMode == sysvar::Common::SysUserBPTMode::No_BPT)
    {
      /* No BPT */
      return _CCS::DataTypes::ServiceIDType::DC;
    }
    else
    {
      /* BPT */
      return _CCS::DataTypes::ServiceIDType::DC_BPT;
    }
  }
}

on fct_called EV.OnPreSendMessageIdChanged
{
  if(this.txMessageId == _CCS::DataTypes::MessageIdType::ServiceSelectionReq)
  {
    // Disable AutoBodyFill for manual definition of the selected parameter set and EnergyTransferService
    if (AutoFill_body == 1)
    {
      EV.EnableAutoBodyFill.Call(0);
      AutoFill_body = 0;
    }
  }
}

ServiceSelection()
{
  int it;
  int selectedControlMode;
  int selectedServiceID;
  int selectedServiceIDDowngraded;
  
  selectedControlMode = GetCorrespondingMessageControlModeForSelectedControlMode();
  selectedServiceID = GetCorrespondingMessageServiceIDForSelectedChargingMode();
  selectedServiceIDDowngraded = GetCorrespondingMessageServiceIDForSelectedChargingMode_Downgraded();

  if ($EV.ISO20.ServiceDetail_Response.ServiceID == selectedServiceID 
        || $EV.ISO20.ServiceDetail_Response.ServiceID == selectedServiceIDDowngraded)
  {
    switch($EV.ISO20.ServiceDetail_Response.ServiceID)
    {
      case 1: //AC
        {
          if(matchingParameterSetID_BPT < 0) // Only overwrite if matching BPT has not been found (yet)
          {
            for(it = 0; it <= $EV.ISO20.ServiceDetail_Response.ServiceParameterList.ParameterSet.length; it++)
            {
              if($EV.ISO20.ServiceDetail_Response.ServiceParameterList.ParameterSet[it].Parameter.AC.ControlMode == selectedControlMode) 
              {
                $EV.ISO20.ServiceSelection_Request.SelectedEnergyTransferService.ServiceID = $EV.ISO20.ServiceDetail_Response.ServiceID;
                $EV.ISO20.ServiceSelection_Request.SelectedEnergyTransferService.ParameterSetID = $EV.ISO20.ServiceDetail_Response.ServiceParameterList.ParameterSet[it].ParameterSetID;
                break;
              }
            }
          }
        }
        break;
      case 2: //DC
        {
          if(matchingParameterSetID_BPT < 0) // Only overwrite if matching BPT has not been found (yet)
          {
            for(it = 0; it < $EV.ISO20.ServiceDetail_Response.ServiceParameterList.ParameterSet.length; it++)
            {
              if($EV.ISO20.ServiceDetail_Response.ServiceParameterList.ParameterSet[it].Parameter.DC.ControlMode == selectedControlMode) 
              {
                $EV.ISO20.ServiceSelection_Request.SelectedEnergyTransferService.ServiceID = $EV.ISO20.ServiceDetail_Response.ServiceID;
                $EV.ISO20.ServiceSelection_Request.SelectedEnergyTransferService.ParameterSetID = $EV.ISO20.ServiceDetail_Response.ServiceParameterList.ParameterSet[it].ParameterSetID;
                break;
              }
            }
          }
        }
        break;
      case 5: //AC_BPT
        {
          for(it = 0; it < $EV.ISO20.ServiceDetail_Response.ServiceParameterList.ParameterSet.length; it++)
          {
            if($EV.ISO20.ServiceDetail_Response.ServiceParameterList.ParameterSet[it].Parameter.AC_BPT.ControlMode == selectedControlMode) 
            {
              $EV.ISO20.ServiceSelection_Request.SelectedEnergyTransferService.ServiceID = $EV.ISO20.ServiceDetail_Response.ServiceID;
              $EV.ISO20.ServiceSelection_Request.SelectedEnergyTransferService.ParameterSetID = $EV.ISO20.ServiceDetail_Response.ServiceParameterList.ParameterSet[it].ParameterSetID;
              matchingParameterSetID_BPT = $EV.ISO20.ServiceDetail_Response.ServiceParameterList.ParameterSet[it].ParameterSetID;
              break;
            }
          }
        }
        break;
      case 6: //DC_BPT
        {
          for(it = 0; it < $EV.ISO20.ServiceDetail_Response.ServiceParameterList.ParameterSet.length; it++)
          {
            if($EV.ISO20.ServiceDetail_Response.ServiceParameterList.ParameterSet[it].Parameter.DC_BPT.ControlMode == selectedControlMode)
            {
              $EV.ISO20.ServiceSelection_Request.SelectedEnergyTransferService.ServiceID = $EV.ISO20.ServiceDetail_Response.ServiceID;
              $EV.ISO20.ServiceSelection_Request.SelectedEnergyTransferService.ParameterSetID = $EV.ISO20.ServiceDetail_Response.ServiceParameterList.ParameterSet[it].ParameterSetID;
              break;
            }
          }
        }
        break;
      case 10: //AC_DER
        {
          for(it = 0; it < $EV.ISO20.ServiceDetail_Response.ServiceParameterList.ParameterSet.length; it++)
          {
            if($EV.ISO20.ServiceDetail_Response.ServiceParameterList.ParameterSet[it].Parameter.AC_DER.ControlMode == selectedControlMode)
            {
              $EV.ISO20.ServiceSelection_Request.SelectedEnergyTransferService.ServiceID = $EV.ISO20.ServiceDetail_Response.ServiceID;
              $EV.ISO20.ServiceSelection_Request.SelectedEnergyTransferService.ParameterSetID = $EV.ISO20.ServiceDetail_Response.ServiceParameterList.ParameterSet[it].ParameterSetID;
              matchingParameterSetID_BPT = $EV.ISO20.ServiceDetail_Response.ServiceParameterList.ParameterSet[it].ParameterSetID;
              break;
            }
          }
        }
        break;
      default:// no charge mode
        {
          writeLineEx(SystemPageOfWriteWindow , Warning,"EV: No matching ParameterSetID was found. The default ParameterSetID value is used in the ServiceSelectionReq.");
        }
        break;
    }
  }
}

void FUNC_Set_EVDCLimits_ChargeParameterDiscoveryReq()
{  
  /* EVMaximumChargePower */
  $EV.ISO20.DC_ChargeParameterDiscovery_Request.CPDReqEnergyTransferMode.DC_CPDReqEnergyTransferMode.EVMaximumChargePower.Value = @sysvar::EV_Sim::SysEV_MaxPowerDC;
  $EV.ISO20.DC_ChargeParameterDiscovery_Request.CPDReqEnergyTransferMode.DC_CPDReqEnergyTransferMode.EVMaximumChargePower.Exponent = 3; //Unit: kW
  $EV.ISO20.DC_ChargeParameterDiscovery_Request.CPDReqEnergyTransferMode.BPT_DC_CPDReqEnergyTransferMode.EVMaximumChargePower.Value = @sysvar::EV_Sim::SysEV_MaxPowerDC;
  $EV.ISO20.DC_ChargeParameterDiscovery_Request.CPDReqEnergyTransferMode.BPT_DC_CPDReqEnergyTransferMode.EVMaximumChargePower.Exponent = 3; //Unit: kW
  
  /* EVMaximumVoltage */
  $EV.ISO20.DC_ChargeParameterDiscovery_Request.CPDReqEnergyTransferMode.DC_CPDReqEnergyTransferMode.EVMaximumVoltage.Value = @sysvar::EV_Sim::SysEV_MaxVoltage;
  $EV.ISO20.DC_ChargeParameterDiscovery_Request.CPDReqEnergyTransferMode.DC_CPDReqEnergyTransferMode.EVMaximumVoltage.Exponent = 0;
  $EV.ISO20.DC_ChargeParameterDiscovery_Request.CPDReqEnergyTransferMode.BPT_DC_CPDReqEnergyTransferMode.EVMaximumVoltage.Value= @sysvar::EV_Sim::SysEV_MaxVoltage;
  $EV.ISO20.DC_ChargeParameterDiscovery_Request.CPDReqEnergyTransferMode.BPT_DC_CPDReqEnergyTransferMode.EVMaximumVoltage.Exponent = 0;
  
  /* EVMaximumChargeCurrent */
  $EV.ISO20.DC_ChargeParameterDiscovery_Request.CPDReqEnergyTransferMode.DC_CPDReqEnergyTransferMode.EVMaximumChargeCurrent.Value = @sysvar::EV_Sim::SysEV_MaxCurrent;
  $EV.ISO20.DC_ChargeParameterDiscovery_Request.CPDReqEnergyTransferMode.DC_CPDReqEnergyTransferMode.EVMaximumChargeCurrent.Exponent = 0;
  $EV.ISO20.DC_ChargeParameterDiscovery_Request.CPDReqEnergyTransferMode.BPT_DC_CPDReqEnergyTransferMode.EVMaximumChargeCurrent.Value = @sysvar::EV_Sim::SysEV_MaxCurrent;
  $EV.ISO20.DC_ChargeParameterDiscovery_Request.CPDReqEnergyTransferMode.BPT_DC_CPDReqEnergyTransferMode.EVMaximumChargeCurrent.Exponent = 0;
  
  /* EVMinimumChargeCurrent */
  $EV.ISO20.DC_ChargeParameterDiscovery_Request.CPDReqEnergyTransferMode.DC_CPDReqEnergyTransferMode.EVMinimumChargeCurrent.Value = @sysvar::EV_Sim::SysEV_MinCurrent;
  $EV.ISO20.DC_ChargeParameterDiscovery_Request.CPDReqEnergyTransferMode.DC_CPDReqEnergyTransferMode.EVMinimumChargeCurrent.Exponent = 0;
  $EV.ISO20.DC_ChargeParameterDiscovery_Request.CPDReqEnergyTransferMode.BPT_DC_CPDReqEnergyTransferMode.EVMinimumChargeCurrent.Value = @sysvar::EV_Sim::SysEV_MinCurrent;
  $EV.ISO20.DC_ChargeParameterDiscovery_Request.CPDReqEnergyTransferMode.BPT_DC_CPDReqEnergyTransferMode.EVMinimumChargeCurrent.Exponent = 0;
  
  /* EVMaximumDischargePower */
  $EV.ISO20.DC_ChargeParameterDiscovery_Request.CPDReqEnergyTransferMode.BPT_DC_CPDReqEnergyTransferMode.EVMaximumDischargePower.Value = - abs(@sysvar::EV_Sim::SysEV_MaxPowerDC);
  $EV.ISO20.DC_ChargeParameterDiscovery_Request.CPDReqEnergyTransferMode.BPT_DC_CPDReqEnergyTransferMode.EVMaximumDischargePower.Exponent = 3; //Unit: kW

  /* EVMaximumDischargeCurrent */
  $EV.ISO20.DC_ChargeParameterDiscovery_Request.CPDReqEnergyTransferMode.BPT_DC_CPDReqEnergyTransferMode.EVMaximumDischargeCurrent.Value = - abs(@sysvar::EV_Sim::SysEV_MaxCurrent);
  $EV.ISO20.DC_ChargeParameterDiscovery_Request.CPDReqEnergyTransferMode.BPT_DC_CPDReqEnergyTransferMode.EVMaximumDischargeCurrent.Exponent = 0;  
  
  /* EVMinimumDischargeCurrent */
  $EV.ISO20.DC_ChargeParameterDiscovery_Request.CPDReqEnergyTransferMode.BPT_DC_CPDReqEnergyTransferMode.EVMinimumDischargeCurrent.Value = - abs(@sysvar::EV_Sim::SysEV_MinCurrent);
  $EV.ISO20.DC_ChargeParameterDiscovery_Request.CPDReqEnergyTransferMode.BPT_DC_CPDReqEnergyTransferMode.EVMinimumDischargeCurrent.Exponent = 0;
}

