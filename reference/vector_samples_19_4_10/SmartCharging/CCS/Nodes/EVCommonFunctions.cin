void FUNC_Set_EVDCLimits_ChargeLoopReq()
{
  /* EVMaximumVoltage */
  $EV.ISO20.DC_ChargeLoop_Request.CLReqControlMode.Dynamic_DC_CLReqControlMode.EVMaximumVoltage.Value = @sysvar::EV_Sim::SysEV_MaxVoltage;
  $EV.ISO20.DC_ChargeLoop_Request.CLReqControlMode.Dynamic_DC_CLReqControlMode.EVMaximumVoltage.Exponent = 0;
  $EV.ISO20.DC_ChargeLoop_Request.CLReqControlMode.BPT_Dynamic_DC_CLReqControlMode.EVMaximumVoltage.Value = @sysvar::EV_Sim::SysEV_MaxVoltage;
  $EV.ISO20.DC_ChargeLoop_Request.CLReqControlMode.BPT_Dynamic_DC_CLReqControlMode.EVMaximumVoltage.Exponent = 0;
  $EV.ISO20.DC_ChargeLoop_Request.CLReqControlMode.Scheduled_DC_CLReqControlMode.EVMaximumVoltage.Value = @sysvar::EV_Sim::SysEV_MaxVoltage;
  $EV.ISO20.DC_ChargeLoop_Request.CLReqControlMode.Scheduled_DC_CLReqControlMode.EVMaximumVoltage.Exponent = 0;
  $EV.ISO20.DC_ChargeLoop_Request.CLReqControlMode.BPT_Scheduled_DC_CLReqControlMode.EVMaximumVoltage.Value = @sysvar::EV_Sim::SysEV_MaxVoltage;
  $EV.ISO20.DC_ChargeLoop_Request.CLReqControlMode.BPT_Scheduled_DC_CLReqControlMode.EVMaximumVoltage.Exponent = 0;
  
  /* EVMaximumChargePower */
  $EV.ISO20.DC_ChargeLoop_Request.CLReqControlMode.Scheduled_DC_CLReqControlMode.EVMaximumChargePower.Value = @sysvar::EV_Sim::SysEV_MaxPowerDC;
  $EV.ISO20.DC_ChargeLoop_Request.CLReqControlMode.Scheduled_DC_CLReqControlMode.EVMaximumChargePower.Exponent = 3; //Unit: kW  
  $EV.ISO20.DC_ChargeLoop_Request.CLReqControlMode.BPT_Scheduled_DC_CLReqControlMode.EVMaximumChargePower.Value = @sysvar::EV_Sim::SysEV_MaxPowerDC;
  $EV.ISO20.DC_ChargeLoop_Request.CLReqControlMode.BPT_Scheduled_DC_CLReqControlMode.EVMaximumChargePower.Exponent = 3; //Unit: kW
  $EV.ISO20.DC_ChargeLoop_Request.CLReqControlMode.Dynamic_DC_CLReqControlMode.EVMaximumChargePower.Value = @sysvar::EV_Sim::SysEV_MaxPowerDC;
  $EV.ISO20.DC_ChargeLoop_Request.CLReqControlMode.Dynamic_DC_CLReqControlMode.EVMaximumChargePower.Exponent = 3; //Unit: kW
  $EV.ISO20.DC_ChargeLoop_Request.CLReqControlMode.BPT_Dynamic_DC_CLReqControlMode.EVMaximumChargePower.Value = @sysvar::EV_Sim::SysEV_MaxPowerDC;
  $EV.ISO20.DC_ChargeLoop_Request.CLReqControlMode.BPT_Dynamic_DC_CLReqControlMode.EVMaximumChargePower.Exponent = 3; //Unit: kW

  /* EVMaximumChargeCurrent */
  $EV.ISO20.DC_ChargeLoop_Request.CLReqControlMode.Scheduled_DC_CLReqControlMode.EVMaximumChargeCurrent.Value = @sysvar::EV_Sim::SysEV_MaxCurrent;
  $EV.ISO20.DC_ChargeLoop_Request.CLReqControlMode.Scheduled_DC_CLReqControlMode.EVMaximumChargeCurrent.Exponent = 0;
  $EV.ISO20.DC_ChargeLoop_Request.CLReqControlMode.BPT_Scheduled_DC_CLReqControlMode.EVMaximumChargeCurrent.Value = @sysvar::EV_Sim::SysEV_MaxCurrent;
  $EV.ISO20.DC_ChargeLoop_Request.CLReqControlMode.BPT_Scheduled_DC_CLReqControlMode.EVMaximumChargeCurrent.Exponent = 0;
  $EV.ISO20.DC_ChargeLoop_Request.CLReqControlMode.Dynamic_DC_CLReqControlMode.EVMaximumChargeCurrent.Value = @sysvar::EV_Sim::SysEV_MaxCurrent;
  $EV.ISO20.DC_ChargeLoop_Request.CLReqControlMode.Dynamic_DC_CLReqControlMode.EVMaximumChargeCurrent.Exponent = 0;
  $EV.ISO20.DC_ChargeLoop_Request.CLReqControlMode.BPT_Dynamic_DC_CLReqControlMode.EVMaximumChargeCurrent.Value = @sysvar::EV_Sim::SysEV_MaxCurrent;
  $EV.ISO20.DC_ChargeLoop_Request.CLReqControlMode.BPT_Dynamic_DC_CLReqControlMode.EVMaximumChargeCurrent.Exponent = 0;
  
  /* EVMaximumDischargePower */
  $EV.ISO20.DC_ChargeLoop_Request.CLReqControlMode.BPT_Scheduled_DC_CLReqControlMode.EVMaximumDischargePower.Value = - abs(@sysvar::EV_Sim::SysEV_MaxPowerDC);
  $EV.ISO20.DC_ChargeLoop_Request.CLReqControlMode.BPT_Scheduled_DC_CLReqControlMode.EVMaximumDischargePower.Exponent = 3; //Unit: kW
  $EV.ISO20.DC_ChargeLoop_Request.CLReqControlMode.BPT_Dynamic_DC_CLReqControlMode.EVMaximumDischargePower.Value = - abs(@sysvar::EV_Sim::SysEV_MaxPowerDC);
  $EV.ISO20.DC_ChargeLoop_Request.CLReqControlMode.BPT_Dynamic_DC_CLReqControlMode.EVMaximumDischargePower.Exponent = 3; //Unit: kW
  
  /* EVMaximumDischargeCurrent */
  $EV.ISO20.DC_ChargeLoop_Request.CLReqControlMode.BPT_Scheduled_DC_CLReqControlMode.EVMaximumDischargeCurrent.Value = - abs(@sysvar::EV_Sim::SysEV_MaxCurrent);
  $EV.ISO20.DC_ChargeLoop_Request.CLReqControlMode.BPT_Scheduled_DC_CLReqControlMode.EVMaximumDischargeCurrent.Exponent = 0;
  $EV.ISO20.DC_ChargeLoop_Request.CLReqControlMode.BPT_Dynamic_DC_CLReqControlMode.EVMaximumDischargeCurrent.Value = - abs(@sysvar::EV_Sim::SysEV_MaxCurrent);
  $EV.ISO20.DC_ChargeLoop_Request.CLReqControlMode.BPT_Dynamic_DC_CLReqControlMode.EVMaximumDischargeCurrent.Exponent = 0;
}


void FUNC_Set_EVDCChargeLoopValues()
{
  stack word TargetSOC = $EV.ISO20.DC_ChargeLoop_Request.DisplayParameters.TargetSOC;
  stack word PresentSOC = @sysvar::EV_Sim::SysEV_BatteryState;
  
  $EV.ISO20.DC_ChargeLoop_Request.EVPresentVoltage.Value = HV_measure_DC_U();  
  $EV.ISO20.DC_ChargeLoop_Request.EVPresentVoltage.Exponent = 0;
  
  if (@sysvar::EV_Sim::Control::SysEV_ControlModeDynamic == @sysvar::EV_Sim::Control::SysEV_ControlModeDynamic::Dynamic)
  {
    if (@sysvar::Common::SysUserBPTMode == sysvar::Common::SysUserBPTMode::BPT) 
    { 
      stack word EVMaximumEnergyRequest;
      $EV.ISO20.DC_ChargeLoop_Request.CLReqControlModeElementId = 1; /* 1 for BPT_Dynamic_DC_CLReqControlMode */
      EVMaximumEnergyRequest = $EV.ISO20.DC_ChargeLoop_Request.CLReqControlMode.BPT_Dynamic_DC_CLReqControlMode.EVMaximumEnergyRequest.Value;
      $EV.ISO20.DC_ChargeLoop_Request.CLReqControlMode.BPT_Dynamic_DC_CLReqControlMode.EVTargetEnergyRequest.Value = EVMaximumEnergyRequest * (TargetSOC - PresentSOC)/100;
    }
    else
    {
      stack word EVMaximumEnergyRequest;
      $EV.ISO20.DC_ChargeLoop_Request.CLReqControlModeElementId = 0; /* 0 for Dynamic_DC_CLReqControlMode */
      EVMaximumEnergyRequest = $EV.ISO20.DC_ChargeLoop_Request.CLReqControlMode.Dynamic_DC_CLReqControlMode.EVMaximumEnergyRequest.Value;
      $EV.ISO20.DC_ChargeLoop_Request.CLReqControlMode.Dynamic_DC_CLReqControlMode.EVTargetEnergyRequest.Value = EVMaximumEnergyRequest * (TargetSOC - PresentSOC)/100;
    }
  }
  else
  {
    if (@sysvar::Common::SysUserBPTMode == sysvar::Common::SysUserBPTMode::BPT) 
    {
      $EV.ISO20.DC_ChargeLoop_Request.CLReqControlModeElementId = 3; /* 3 for BPT_Scheduled_DC_CLReqControlMode */
      if($EV.ISO20.DC_ChargeLoop_Request.CLReqControlMode.BPT_Scheduled_DC_CLReqControlMode.EVMaximumEnergyRequest.IsValid){
        stack word EVMaximumEnergyRequest = $EV.ISO20.DC_ChargeLoop_Request.CLReqControlMode.BPT_Scheduled_DC_CLReqControlMode.EVMaximumEnergyRequest.Value;
        $EV.ISO20.DC_ChargeLoop_Request.CLReqControlMode.BPT_Scheduled_DC_CLReqControlMode.EVTargetEnergyRequest.Value = EVMaximumEnergyRequest * (TargetSOC - PresentSOC)/100;
      }
      $EV.ISO20.DC_ChargeLoop_Request.CLReqControlModeElementId = 3; /* 3 for BPT_Scheduled_DC_CLReqControlMode */
      if (@sysvar::EV_Sim::Control::SysEV_ChargeDischarge == sysvar::EV_Sim::Control::SysEV_ChargeDischarge::Charge)
        $EV.ISO20.DC_ChargeLoop_Request.CLReqControlMode.BPT_Scheduled_DC_CLReqControlMode.EVTargetCurrent.Value = @sysvar::EV_Sim::SysEV_TargetCurrent;
      else
        $EV.ISO20.DC_ChargeLoop_Request.CLReqControlMode.BPT_Scheduled_DC_CLReqControlMode.EVTargetCurrent.Value = - abs(@sysvar::EV_Sim::SysEV_TargetCurrent);
      $EV.ISO20.DC_ChargeLoop_Request.CLReqControlMode.BPT_Scheduled_DC_CLReqControlMode.EVTargetCurrent.Exponent = 0;
      $EV.ISO20.DC_ChargeLoop_Request.CLReqControlMode.BPT_Scheduled_DC_CLReqControlMode.EVTargetVoltage.Value = @sysvar::EV_Sim::SysEV_TargetVoltage;
      $EV.ISO20.DC_ChargeLoop_Request.CLReqControlMode.BPT_Scheduled_DC_CLReqControlMode.EVTargetVoltage.Exponent = 0;
    }
    else
    {
      $EV.ISO20.DC_ChargeLoop_Request.CLReqControlModeElementId = 2; /* 2 for Scheduled_DC_CLReqControlMode */
      if($EV.ISO20.DC_ChargeLoop_Request.CLReqControlMode.Scheduled_DC_CLReqControlMode.EVMaximumEnergyRequest.isValid){
        stack word EVMaximumEnergyRequest = $EV.ISO20.DC_ChargeLoop_Request.CLReqControlMode.Scheduled_DC_CLReqControlMode.EVMaximumEnergyRequest.Value;
        $EV.ISO20.DC_ChargeLoop_Request.CLReqControlMode.Scheduled_DC_CLReqControlMode.EVTargetEnergyRequest.Value = EVMaximumEnergyRequest * (TargetSOC - PresentSOC)/100;
      }
      $EV.ISO20.DC_ChargeLoop_Request.CLReqControlModeElementId = 2; /* 2 for Scheduled_DC_CLReqControlMode */
      $EV.ISO20.DC_ChargeLoop_Request.CLReqControlMode.Scheduled_DC_CLReqControlMode.EVTargetCurrent.Value = @sysvar::EV_Sim::SysEV_TargetCurrent;
      $EV.ISO20.DC_ChargeLoop_Request.CLReqControlMode.Scheduled_DC_CLReqControlMode.EVTargetCurrent.Exponent = 0;
      $EV.ISO20.DC_ChargeLoop_Request.CLReqControlMode.Scheduled_DC_CLReqControlMode.EVTargetVoltage.Value = @sysvar::EV_Sim::SysEV_TargetVoltage;
      $EV.ISO20.DC_ChargeLoop_Request.CLReqControlMode.Scheduled_DC_CLReqControlMode.EVTargetVoltage.Exponent = 0;
    }
  }
}

