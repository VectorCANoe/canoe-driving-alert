  $EV.ISO20.AC_ChargeLoop_Request.CLReqControlMode.Dynamic_AC_CLReqControlMode.EVMinimumChargePower_L2.Value = @sysvar::EV_Sim::SysEV_MinPowerAC;
  $EV.ISO20.AC_ChargeLoop_Request.CLReqControlMode.Dynamic_AC_CLReqControlMode.EVMinimumChargePower_L2.Exponent = 3; //Unit: kW
  $EV.ISO20.AC_ChargeLoop_Request.CLReqControlMode.Dynamic_AC_CLReqControlMode.EVMinimumChargePower_L3.Value = @sysvar::EV_Sim::SysEV_MinPowerAC;
  $EV.ISO20.AC_ChargeLoop_Request.CLReqControlMode.Dynamic_AC_CLReqControlMode.EVMinimumChargePower_L3.Exponent = 3; //Unit: kW
  
  $EV.ISO20.AC_ChargeLoop_Request.CLReqControlMode.BPT_Dynamic_AC_CLReqControlMode.EVMinimumChargePower.Value = @sysvar::EV_Sim::SysEV_MinPowerAC;
  $EV.ISO20.AC_ChargeLoop_Request.CLReqControlMode.BPT_Dynamic_AC_CLReqControlMode.EVMinimumChargePower.Exponent = 3; //Unit: kW
  $EV.ISO20.AC_ChargeLoop_Request.CLReqControlMode.BPT_Dynamic_AC_CLReqControlMode.EVMinimumChargePower_L2.Value = @sysvar::EV_Sim::SysEV_MinPowerAC;
  $EV.ISO20.AC_ChargeLoop_Request.CLReqControlMode.BPT_Dynamic_AC_CLReqControlMode.EVMinimumChargePower_L2.Exponent = 3; //Unit: kW
  $EV.ISO20.AC_ChargeLoop_Request.CLReqControlMode.BPT_Dynamic_AC_CLReqControlMode.EVMinimumChargePower_L3.Value = @sysvar::EV_Sim::SysEV_MinPowerAC;
  $EV.ISO20.AC_ChargeLoop_Request.CLReqControlMode.BPT_Dynamic_AC_CLReqControlMode.EVMinimumChargePower_L3.Exponent = 3; //Unit: kW
  
  /* EVMaximumDischargePower */                                                 
  $EV.ISO20.AC_ChargeLoop_Request.CLReqControlMode.BPT_Scheduled_AC_CLReqControlMode.EVMaximumDischargePower.Value = - abs(@sysvar::EV_Sim::SysEV_MaxPowerAC);
  $EV.ISO20.AC_ChargeLoop_Request.CLReqControlMode.BPT_Scheduled_AC_CLReqControlMode.EVMaximumDischargePower.Exponent = 3; //Unit: kW
  $EV.ISO20.AC_ChargeLoop_Request.CLReqControlMode.BPT_Scheduled_AC_CLReqControlMode.EVMaximumDischargePower_L2.Value = - abs(@sysvar::EV_Sim::SysEV_MaxPowerAC);
