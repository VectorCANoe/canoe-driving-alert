  $EV.ISO20.AC_ChargeLoop_Request.CLReqControlMode.BPT_Scheduled_AC_CLReqControlMode.EVMinimumDischargePower_L2.Exponent = 3; //Unit: kW
  $EV.ISO20.AC_ChargeLoop_Request.CLReqControlMode.BPT_Scheduled_AC_CLReqControlMode.EVMinimumDischargePower_L3.Value = - abs(@sysvar::EV_Sim::SysEV_MinPowerAC);
  $EV.ISO20.AC_ChargeLoop_Request.CLReqControlMode.BPT_Scheduled_AC_CLReqControlMode.EVMinimumDischargePower_L3.Exponent = 3; //Unit: kW
  
  $EV.ISO20.AC_ChargeLoop_Request.CLReqControlMode.BPT_Dynamic_AC_CLReqControlMode.EVMinimumDischargePower.Value = - abs(@sysvar::EV_Sim::SysEV_MinPowerAC);
