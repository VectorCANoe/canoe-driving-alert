  $EV.ISO20.AC_ChargeLoop_Request.CLReqControlMode.Dynamic_AC_CLReqControlMode.EVMaximumChargePower_L3.Value = @sysvar::EV_Sim::SysEV_MaxPowerAC;
  $EV.ISO20.AC_ChargeLoop_Request.CLReqControlMode.Dynamic_AC_CLReqControlMode.EVMaximumChargePower_L3.Exponent = 3; //Unit: kW
  
  $EV.ISO20.AC_ChargeLoop_Request.CLReqControlMode.BPT_Dynamic_AC_CLReqControlMode.EVMaximumChargePower.Value = @sysvar::EV_Sim::SysEV_MaxPowerAC;
  $EV.ISO20.AC_ChargeLoop_Request.CLReqControlMode.BPT_Dynamic_AC_CLReqControlMode.EVMaximumChargePower.Exponent = 3; //Unit: kW
  $EV.ISO20.AC_ChargeLoop_Request.CLReqControlMode.BPT_Dynamic_AC_CLReqControlMode.EVMaximumChargePower_L2.Value = @sysvar::EV_Sim::SysEV_MaxPowerAC;
  $EV.ISO20.AC_ChargeLoop_Request.CLReqControlMode.BPT_Dynamic_AC_CLReqControlMode.EVMaximumChargePower_L2.Exponent = 3; //Unit: kW
  $EV.ISO20.AC_ChargeLoop_Request.CLReqControlMode.BPT_Dynamic_AC_CLReqControlMode.EVMaximumChargePower_L3.Value = @sysvar::EV_Sim::SysEV_MaxPowerAC;
  $EV.ISO20.AC_ChargeLoop_Request.CLReqControlMode.BPT_Dynamic_AC_CLReqControlMode.EVMaximumChargePower_L3.Exponent = 3; //Unit: kW
  
  /* EVMinimumChargePower */
  $EV.ISO20.AC_ChargeLoop_Request.CLReqControlMode.Dynamic_AC_CLReqControlMode.EVMinimumChargePower.Value = @sysvar::EV_Sim::SysEV_MinPowerAC;
