int HV_ContactorsState()
{
  if(HV_get_DC_Plus_relay() == 1 ||
     HV_get_DC_Minus_relay() == 1 ||
     HV_get_AC_relay_L1() == 1 ||
     HV_get_AC_relay_L2() == 1 ||
     HV_get_AC_relay_L3() == 1 ||
     HV_get_AC_relay_N() == 1)
    return 1;
  else
    return 0;
}

