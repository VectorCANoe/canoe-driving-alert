/// <CP_PP>
export double CP_EV_get_Frequency()
{ 
  return @sysvar::VTS::VT_EV::MeasFrequency;
  
  return 0;
}

/// <CP_PP>
export void CP_EV_set_Open_Circuit(long closed)
{
  if (closed > 0)
  {
    @sysvar::VTS::VT_EV::Relay_K26 = 1;
    @sysvar::VTS::VT_EV::Relay_K27 = 1;
    
    inletLockedState = 1;
  }
  else
  {
    @sysvar::VTS::VT_EV::Relay_K26 = 0;
    @sysvar::VTS::VT_EV::Relay_K27 = 0;
    
    inletLockedState = 0;
  }
  OnLockedStatusChanged(inletLockedState);
}

/// <CP_PP>
export int CP_EV_get_Open_Circuit()
{
  if(@sysvar::VTS::VT_EV::Relay_K26 == 1 || @sysvar::VTS::VT_EV::Relay_K27 == 1)
    return 1;
  else
    return 0;
}

/// <CP_PP>
void PP_EV_set_open_circuit(long closed)
{
  if(closed > 0)
  {
    @sysvar::VTS::VT_EV::Relay_K1 = 1;
    @sysvar::VTS::VT_EV::Relay_K52 = 1; //close to apply 5V
  }
  else
  {
    @sysvar::VTS::VT_EV::Relay_K1 = 0;
    @sysvar::VTS::VT_EV::Relay_K52 = 0;
  }
}

