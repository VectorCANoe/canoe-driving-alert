Mute_ISO()
{
  muteISO = 1;
  return;
}

UnMute_ISO()
{
  muteISO = 0;
  return;
}

int GetISOMonitoringMuted()
{
  return muteISO;
}

LockConnector()
{
  inletLocked = 1;
}

UnlockConnector()
{
  inletLocked = 0;
}

int GetConnectorLockState()
{
  return inletLocked;
}