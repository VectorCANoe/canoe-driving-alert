  @sysvar::VTS::VT_EVSE::Relay_K20 = 0;
  @sysvar::VTS::VT_EVSE::Relay_K21 = 0;
  @sysvar::VTS::VT_EVSE::Relay_K22 = 0;
  @sysvar::VTS::VT_EVSE::Relay_K23 = 0;
  @sysvar::VTS::VT_EVSE::Relay_K24 = 0;
  @sysvar::VTS::VT_EVSE::Relay_K25 = 0;
  @sysvar::VTS::VT_EVSE::Relay_K26 = 0;
  @sysvar::VTS::VT_EVSE::Relay_K27 = 1; //Set bypass for voltage measurement Vs3
  @sysvar::VTS::VT_EVSE::Relay_K28 = 0;
  @sysvar::VTS::VT_EVSE::Relay_K29 = 1; //Set bypass for voltage measurement Vs3
  @sysvar::VTS::VT_EVSE::Relay_K31 = 0;
