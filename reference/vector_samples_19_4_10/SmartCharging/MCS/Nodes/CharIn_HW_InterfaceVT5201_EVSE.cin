  @sysvar::VTS::VT_EVSE::StimConstVoltage = 5; //Set required voltage for CE functionality
  
  @sysvar::VTS::VT_EVSE::StimVoltageHigh = 0; //Disable PWM
  @sysvar::VTS::VT_EVSE::StimVoltageLow = 0; //Disable PWM
