  @sysvar::VTS::VT_EVSE::Relay_K36 = 0;
  @sysvar::VTS::VT_EVSE::Relay_K37 = 0;
  @sysvar::VTS::VT_EVSE::Relay_K38 = 0;
  @sysvar::VTS::VT_EVSE::Relay_K39 = 0;
  @sysvar::VTS::VT_EVSE::Relay_K40 = 0;
  @sysvar::VTS::VT_EVSE::Relay_K41 = 0;
