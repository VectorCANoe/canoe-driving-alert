export long HV_source_set_I_DC(double current)
{
  return 0;
}

export long HV_source_set_U_DC(double voltage)
{
  if(voltage > 10)  //sink voltage
    voltage -= 10;
  
  return 0;
}

//function will receive positive voltage value within PreCharge and CurrentDemand
export long HV_source_set_U_DC_PreCharge(double voltage)
{
  return 0;
}

/// <CharINInterfaceDC>
double HV_measure_DC_U()
{
  if(@sysvar::EV_Sim::SysEV_State > 18)
    return ($EV.ISO20.DC_ChargeLoop_Response.EVSEPresentVoltage.Value * _pow(10, $EV.ISO20.DC_ChargeLoop_Response.EVSEPresentVoltage.Exponent));
  else
    return ($EV.ISO20.DC_PreCharge_Response.EVSEPresentVoltage.Value * _pow(10, $EV.ISO20.DC_PreCharge_Response.EVSEPresentVoltage.Exponent));
}

/// <CharINInterfaceDC>
export double HV_measure_DC_U_VeriVolt()
{
  return HV_measure_DC_U();
}

/// <CharINInterfaceDC>
 double HV_measure_DC_I()
{
  return ($EV.ISO20.DC_ChargeLoop_Response.EVSEPresentCurrent.Value * _pow(10, $EV.ISO20.DC_ChargeLoop_Response.EVSEPresentCurrent.Exponent));
}

/// <CharInInterface>
int GetLockState()
{
  return 0;
}

Mute_ISO()
{
  muteISO = 1;
  return;
}

UnMute_ISO()
{
  muteISO = 0;
  return;
}

int GetISOMonitoringMuted()
{
  return muteISO;
}

UnlockConnector()
{
  inletLocked = 0;
}

LockConnector()
{
  inletLocked = 1;
}

int GetConnectorLockState()
{
  return inletLocked;
}