/// <ServiceDetail>
_ServiceDetail_PrepareResponseContent_DC_List()
{
  // Short or enlarge ParameterSet length if necessary
  $EVSE.ISO20.ServiceDetail_Response.ServiceParameterList.ParameterSet.Length = 3;
  
  /* Entry[0] ParameterSet 1: Extended, Scheduled, ProvidedByEVCC, NoPricing*/
  _ServiceDetail_PrepareResponseContent_DC_Parameter(0, 1, _CCS::DataTypes::DCConnectorType::Extended
                                                         , _CCS::DataTypes::ControlModeType::Scheduled
                                                         , _CCS::DataTypes::MobilityNeedsModeType::ProvidedByEVCC       
                                                         , _CCS::DataTypes::PricingType::NoPricing); 
  /* Entry[1] ParameterSet 2: Extended, Dynamic, ProvidedByEVCC, NoPricing*/
  _ServiceDetail_PrepareResponseContent_DC_Parameter(1, 2, _CCS::DataTypes::DCConnectorType::Extended
                                                         , _CCS::DataTypes::ControlModeType::Dynamic
                                                         , _CCS::DataTypes::MobilityNeedsModeType::ProvidedByEVCC
                                                         , _CCS::DataTypes::PricingType::NoPricing); 
  /* Entry[2] ParameterSet 3: Extended, Dynamic, ProvidedBySECCAllowed, NoPricing*/
  _ServiceDetail_PrepareResponseContent_DC_Parameter(2, 3, _CCS::DataTypes::DCConnectorType::Extended
                                                         , _CCS::DataTypes::ControlModeType::Dynamic
                                                         , _CCS::DataTypes::MobilityNeedsModeType::ProvidedBySECCAllowed
                                                         , _CCS::DataTypes::PricingType::NoPricing); 
}

/// <ServiceDetail>
_ServiceDetail_PrepareResponseContent_DC_Parameter( long paramIndex
                                                  , long paramSetID
                                                  , enum _CCS::DataTypes::DCConnectorType       connector
                                                  , enum _CCS::DataTypes::ControlModeType       controlMode
                                                  , enum _CCS::DataTypes::MobilityNeedsModeType mobilityNeedsMode
                                                  , enum _CCS::DataTypes::PricingType           pricing )
{
  $EVSE.ISO20.ServiceDetail_Response.ServiceParameterList.ParameterSet[paramIndex].ParameterSetID = paramSetID;
  $EVSE.ISO20.ServiceDetail_Response.ServiceParameterList.ParameterSet[paramIndex].UnionDiscriminator = 2; // DC
  $EVSE.ISO20.ServiceDetail_Response.ServiceParameterList.ParameterSet[paramIndex].Parameter.DC.Connector = connector;
  $EVSE.ISO20.ServiceDetail_Response.ServiceParameterList.ParameterSet[paramIndex].Parameter.DC.ControlMode = controlMode;
  $EVSE.ISO20.ServiceDetail_Response.ServiceParameterList.ParameterSet[paramIndex].Parameter.DC.MobilityNeedsMode = mobilityNeedsMode;
  $EVSE.ISO20.ServiceDetail_Response.ServiceParameterList.ParameterSet[paramIndex].Parameter.DC.Pricing = pricing;  
}







