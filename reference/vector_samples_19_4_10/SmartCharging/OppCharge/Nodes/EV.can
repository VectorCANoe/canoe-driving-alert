}

SCC_RestartInd( byte sessionID[] )
{
  WriteLineEx(writeTab, 1, "EV: Restarting protocol, retries left: %d", SCC_GetRetriesLeft());
}

SCC_LinkStatusChangeInd( dword oldStatus, dword newStatus)
{
  // Note: this indication is only received when polling is enabled
  WriteLineEx(writeTab, 1, "EV: Link status changed from %i to %i", oldStatus, newStatus);
  @sysVar::EV_Sim::SysEV_LinkStatus = newStatus;
}

// generic host indication for all supported PLCs
void SCC_Generic_VS_HostMessage_Ind( byte sourceMacAddess[], dword hostMessage )
{
  // Device is ready to communicate on power line but may not be a member of an AVLN yet. 
  const byte PLC_READY_TO_JOIN_AVLN = 0x01;
  // Device is ready to communicate on power line but may not be a member of an AVLN yet. 
  const byte PLC_AVLN_JOINED = 0x02;
  // Device is disconnected from  an AVLN and there are no peers available. 
  const byte PLC_AVLN_DISCONNECTED = 0x03;  
  
  if (hostMessage == PLC_AVLN_JOINED)
  {
    @sysVar::EV_Sim::SysEV_LinkStatus = 1;
    SCC_SLAC_SetLinkStatus(1);
    cancelTimer(tSECCDiscoveryMaxDelay);
  }
  else
  {
    @sysVar::EV_Sim::SysEV_LinkStatus = 0;
    SCC_SLAC_SetLinkStatus(0);
  } 
  
  WriteLineEx(writeTab, 1, "EV: Link status changed to %i", @sysVar::EV_Sim::SysEV_LinkStatus);
}


SCC_SLACFinishedInd( dword result)
{
  float resultBuffer[16];
  long  resultCount = 0;
  int i;
  
  if (result)
    WriteLineEx(writeTab, 1, "EV: SLAC finished, result : OK");
  else
    WriteLineEx(writeTab, 1, "EV: SLAC finished, result : FAILED");
  
  if (result)
  {
    // Get and print attenuation values
    SCC_SLAC_GetAttenResults(resultBuffer, resultCount);
    
    if (resultCount > 0)
      WriteLineEx(writeTab, 1, "EV: %i EVSEs found, results sorted by attenuation are:", resultCount);
    else
      WriteLineEx(writeTab, 2, "EV: No EVSEs found");
    
    for (i = 0; i< resultCount; ++i)
    {
      WriteLineEx(writeTab, 1, "EVSE %i: %f db", i+1, resultBuffer[i]);
    }
  }
  
  if (result)   // SLAC finished successfully
  {
    if (isSimulated())
    {
      SCC_SLAC_SetLinkStatus(1);
      @sysVar::EV_Sim::SysEV_LinkStatus = SCC_SLAC_GetLinkStatus(); 
      WriteLineEx(writeTab, 1, "EV: Set simulated link status = 1");
    }
    else
    {
      setTimer(tSECCDiscoveryMaxDelay, cSECCDiscoveryMaxDelay);
      WriteLineEx(writeTab, 1, "EV: Waiting for link status from chip = 1");
    }
    
    isReconnectAfterReset = 0;
  }
}

SCC_StateTransitionInd( byte sessionId[], dword oldState, dword newState)
{
  SCC_GetStateName(newState, strBuffer1, 100);
  
  WriteLineEx(writeTab, 1, "EV: Entering state \"%s\"", strBuffer1);
  
  // Map state machine's state to protocol bar
  // Note: For the definition of the state IDs, see appendix section of the manual
  
  // Special handling for charge loop init
  if ( (newState == 8 && oldState < 8)
    || (newState == 10 && oldState == 101)
    || (newState == 100 && oldState == 7))
  {
    @sysVar::EV_Sim::SysEV_State = 7; 
    return;
  }
  
  switch (newState)
  {
    case 0:
      // Nothing
      @sysVar::EV_Sim::SysEV_State = 0; break;
    case 1:
      // Session Setup
      @sysVar::EV_Sim::SysEV_State = 2; break;
    case 2:
    case 3:
      // Service Discovery
      @sysVar::EV_Sim::SysEV_State = 3; break;
    case 4:
      // Service Payment Sel
      @sysVar::EV_Sim::SysEV_State = 4; break;
    case 5:
    case 6:
    case 16:
    case 17:
      // Payment / Authorization
      @sysVar::EV_Sim::SysEV_State = 5; break;
    case 7:
      // Charge Par Discovery / Renegotiation
      @sysVar::EV_Sim::SysEV_State = 6; break;
    case 11:
    case 12:
    case 101:
      // Charge Loop Init
      @sysVar::EV_Sim::SysEV_State = 7; break;
    case 9:
    case 10:
    case 13:
    case 102:
    case 103:
      // Charge Loop
      chargeLoopEntered = 1;
      @sysVar::EV_Sim::SysEV_State = 8; break;
    case 14:
    case 15:
    case 104:
      // Stop Charging
      @sysVar::EV_Sim::SysEV_State = 9; break;   
  }
}

SCC_TCPConnectInd( dword socket, long isSender)
{
  if (isSender)
    WriteLineEx(writeTab, 1, "EV: TCP connection established on socket %i", socket);
  else    // cannot happen here
    WriteLineEx(writeTab, 1, "EV: TCP client connected to socket %i", socket);
}

SCC_TCPShutdownInd( dword socket, long isSender)
{
  if (isSender)
    WriteLineEx(writeTab, 1, "EV: TCP connection on socket %i closed", socket);
  else
    WriteLineEx(writeTab, 1, "EV: TCP connection on socket %i was closed by remote station", socket);
}

SCC_InvalidMessageInd( long MessageType, long ErrorCode)
{
  @Sysvar::Test::SysErrorIndEV = 1;
  setTimer(tInvalidMessage, 3000);  
  
  if (ErrorCode == 0)    
    WriteLineEx(writeTab, 1, "EV: Invalid message received - wrong version number or format!");
  else if (ErrorCode == 1)
    WriteLineEx(writeTab, 1, "EV: Invalid message received - unknown payload type!");
  else if (ErrorCode == 2)
    WriteLineEx(writeTab, 1, "EV: Invalid message received - invalid payload length!");
  else if (ErrorCode == 3)
    WriteLineEx(writeTab, 1, "EV: Invalid message received - decoding error");
}  

SCC_SignaturePreSendInd( byte sessionID[], dword messageId, byte signature[], dword& signatureLength)
{ 
  WriteLineEx(writeTab, 1, "EV: Signature of length %i created for Message ID = %d", signatureLength, messageId);
}

SCC_SignatureVerificationInd( dword messageID, dword result)
{
  setControlVisibility(gPanelName, "Verification", 1);
  setTimer(tVerification, 1000);
}

SCC_CertChainVerificationInd( byte SessionId[], char chainName[], dword Result )
{  
  int i;
  char certName[255];
  dword errorCode;
  
  if (Result > 0)
  {
    WriteLineEx(writeTab, 1 /* info */, "%s verified, result: OK", chainName);
  }
  else
  { 
    WriteLineEx(writeTab, 2 /* warning */, "%s verified, result: FAILED", chainName);
    
    for (i = 0; i < SCC_GetCertChainVerificationErrorCount(); ++i)
    {
      SCC_GetCertChainVerificationError(i, certName, errorCode);      
      WriteLineEx(writeTab, 2 /* warning */, "  Error %i was found in certificate %s", errorCode, certName );
    }
  }
}

SCC_ConnectionTimeoutInd( byte sessionId[] )
{  
  WriteLineEx(writeTab, 2, "EV connection timeout");
}

SCC_V2G_EVCC_Msg_TimeoutInd( byte RunId[], dword MessageID)
