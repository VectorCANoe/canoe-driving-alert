variables
{
  dword writeTab;  // Sink identifier
  
  int   iTemp1, iTemp2;
  long  lTemp;
  float fTemp;
  
  char strBuffer1[100];
  
  char gPanelName[32] = "Vehicle";
  
  int certificateServiceRequested = 0;    // 1 = installation, 2 = update
  int serviceDetailRequests = 0;
  
  char gProtocolPanelName[9] = "Protocol";
  char DCStatusCode[32];

  int isPowerOn = 0;
  int chargeLoopEntered = 0;
  int isDCMode = 0;
  int isPassiveMode = 0;
  int reNegotiationRequested = 0;
  int reNegotiationRunning = 0;
  int isReconnectAfterReset = 0;
  
  msTimer tMessageTx;
  msTimer tInvalidMessage;
  msTimer tVerification;
  msTimer tProcessingTime;
  msTimer tStartSimulationDelay; //Start Simulation Delay after Plug-In
  
  msTimer tSECCDiscoveryMaxDelay;  
  
  const int cSECCDiscoveryMaxDelay = 5000;
    
  int processing = 0;
  int processingFinished = 0;
  
  // VT access  
  int MSGreaction = 0;
  int nextStateChange_IECrelevant = 0;
}

on sysvar EV_Sim::Control::SysEV_Connected
{
  if (@this == 1)
  {
    // Set TLS state - request TLS only for ISO15118 when the "TLS" option is checked
    if ((@sysVar::Common::SysTLSEnabled) && @sysVar::EV_Sim::Control::SysEV_Schema != DIN70121)
    {
      SCC_SetTLSEnabled(1);
    }
    else
    {
      SCC_SetTLSEnabled(0);
    }
    
    setTimer(tStartSimulationDelay, 1500); // Instead of SCC_StartSimulation() immediately;
    
    @sysVar::EV_Sim::SysEV_State = 0;    
    @sysVar::EV_Sim::SysEV_Error = 0;
    
    SCC_SLAC_SetLinkStatus(0);
    @sysVar::EV_Sim::SysEV_LinkStatus = 0;      
    
    if (@sysvar::EV_Sim::Control::SysEV_CertificateInstallation)
    {
      certificateServiceRequested = 1;
      @sysVar::EV_Sim::Control::SysEV_CertificateUpdate = 0;
    }  
    else if (@sysvar::EV_Sim::Control::SysEV_CertificateUpdate)
    {
      certificateServiceRequested = 2;
      @sysVar::EV_Sim::Control::SysEV_CertificateInstallation = 0;      
    }
    
    CP_EV_SetCPStateB();
    CP_EV_set_Open_Circuit(1);
    PP_EV_set_open_circuit(1);
  }
  else
  {
    CP_EV_set_Open_Circuit(0);
    HV_set_AC_relays(0);
    PP_EV_set_open_circuit(0);
    
    SCC_StopSimulation();
  
    @sysVar::EV_Sim::Control::SysEV_CertificateInstallation = 0;
    @sysVar::EV_Sim::Control::SysEV_CertificateUpdate = 0;    
    @sysVar::EV_Sim::SysEV_LinkStatus = 2;
    
    certificateServiceRequested = 0;
  }
  
  EnableSchemaControls(!@this);
  
  @sysVar::EV_Sim::Control::SysEV_WaitResume = 0;
    
  ReadEVStatus();
  UpdateSimState();
  
  // VT access
  @sysvar::EV_Sim::VT_Access::SysEV_S2close = 0;
}

on sysvar EV_Sim::Control::SysEV_Reset
{
  if (@this == 0)
    return;
  
  SCC_SimulationReset();
  InitSimulation();
 
  @sysVar::EV_Sim::Control::SysEV_WaitResume = 0;
  @sysVar::EV_Sim::Control::SysEV_Connected = 0;
  @sysVar::EV_Sim::Control::SysEV_CertificateInstallation = 0;
  @sysVar::EV_Sim::Control::SysEV_CertificateUpdate = 0;
  
  isReconnectAfterReset = 1;
}

on sysvar EV_Sim::Control::SysEV_Stop
{
  if (@this == 1)
  {
    // Shutdown and send "Pause"
    SCC_Shutdown(1);
    ReactOnEVStop();
  }
}

on sysvar EV_Sim::Control::SysEV_Renegotiate
{
  if (@this == 1)
  {    
    SCC_StartRenegotiation();
    reNegotiationRequested = 1;
  }
}

on sysvar EV_Sim::Control::SysEV_CertificateInstallation
{
  if (@this == 1)
  {
    certificateServiceRequested = 1;
    @sysVar::EV_Sim::Control::SysEV_CertificateUpdate = 0;
  }
}

on sysvar EV_Sim::Control::SysEV_CertificateUpdate 
{
  if (@this == 1)
  {
    certificateServiceRequested = 2;
    @sysVar::EV_Sim::Control::SysEV_CertificateInstallation = 0;
  }
}

on start
{
  writeTab = WriteCreate("SCC EV");    // same name as tab created by nodelayer

  EnableSchemaControls(!@sysvar::EV_Sim::Control::SysEV_Connected);
  SetCertificateControlsVisible(@sysvar::EV_Sim::Control::SysEV_PnCEnabled);
  
  @sysVar::EV_Sim::SysEV_Error = 0;
  @sysvar::Test::SysErrorIndEV = 0;
  
  InitSimulation();
  PrintEthernetSettings("EV");  
  AdaptPanelToSchema();

  iTemp1 = sysGetVariableInt(sysvar::EV_Sim::Control::SysEV_Connected);
  
  if (iTemp1 == 1)
    SCC_StartSimulation(); 
  else
    SCC_StopSimulation();
  
  ST_Init();
  CP_EV_set_Open_Circuit(0);
  HV_set_AC_relays(0);
  HV_source_set_output(0);
  PP_EV_set_open_circuit(0);
}

void InitSimulation()
{ 
  @sysVar::EV_Sim::Control::SysEV_Schema = 1;
  UpdateSelectedSchema();    
  ApplyMessageDelay();
  UpdateSimState();
}

on preStart
{
  if (@sysVar::Common::SysVerboseWrite)
    SCC_SetVerbosity(5);
  else
    SCC_SetVerbosity(2);

  @sysVar::EV_Sim::Control::SysEV_WaitResume = 0;
  
  UpdateSimState();
}

on sysvar EV_Sim::Control::SysEV_ClearBattery
{
  SCC_SetBatteryState(0.0);
  @sysVar::EV_Sim::SysEV_BatteryState = 0.0;
}

on sysVar Common::SysUserChargingMode
{
  SetChargingModeAndPaymentOption();
}

on sysvar EV_Sim::Control::SysEV_PnCEnabled
{
  SetChargingModeAndPaymentOption();  
  SetCertificateControlsVisible(@this);
}

void SCC_MessageRxInd(byte SessionID[], dword MessageID)
{
  char responseCodeString[50];
  SCC_GetResponseCodeString(responseCodeString);
  sysSetVariableString(sysvar::Common::LastReceivedResponseCode, responseCodeString);
  
  SetLastMessageID(MessageID);
}

void SCC_MessageTxInd( byte SessionID[], dword MessageId, long Error)
{
  /*
  WriteLineEx(writeTab, 0, "EV: Message Tx: Session Id = %0X%0X%0X%0X%0X%0X%0X%0X, result = %i",
    SessionID[0], SessionID[1], SessionID[2], SessionID[3], SessionID[4], SessionID[5], SessionID[6], SessionID[7],
    error
  );
  */
  
  // VT Access
  // IEC61851 Synchronization (only relevant for AC charging, because for DC we react to the response)
  //-------------------------------------------------------------------------------------------------------
  if (MSGreaction) 
  {
    // AC charging and no ReNegotiation
    if (@sysvar::Common::SysUserChargingMode == 0 /* AC */ & @sysvar::EV_Sim::Control::SysEV_Renegotiate == 0)
    {
      // entering charge loop --> close S2
      if (!isPowerOn)
        @sysvar::EV_Sim::VT_Access::SysEV_S2close = 1;
    }
  }
  MSGreaction = 0;
  
  //----------------------------------------------------------------------------------------------
  
  if(@Common::SysUserChargingMode == @Common::SysUserChargingMode::AC)
  {
    if(SCC_GetChargeProgress() == 1 /*Start*/)
      CP_EV_SetCPStateC();
    else if(SCC_GetChargeProgress() == 0 /*Stop*/)
      CP_EV_SetCPStateB();
  }
  else //dc charging
  {
    if(MessageId == CableCheckReq)
      CP_EV_SetCPStateC(); //[V2G2-912] change and wait for cp state c or d before sending cable check request
  }
  
  if((MessageId == PreChargeReq) || (MessageId == CurrentDemandReq))
  {
    HV_source_set_U_DC(@EV_Sim::SysEV_TargetVoltage);
    HV_source_set_I_DC(@EV_Sim::SysEV_TargetCurrent);
  }
  
  if(MessageId == WeldingDetectionReq)
    HV_source_perform_welding();
  
  if(MessageId == PowerDeliveryReq)
    @sysvar::Common::ChargeProgress = SCC_GetChargeProgress();
  
  if(MessageId == PowerDeliveryReq && SCC_GetChargeProgress() == 0 /*Stop*/ || MessageId == SessionStopReq)
    HV_source_set_output(0);
  
  if(MessageId == CmSLACParamReq && isSimulated())
    SCC_SLAC_SetLinkStatus(0);  //avoid link status problem within restart
  
  @sysvar::EV_Sim::SysEV_MessageTx = 1;
  setTimer(tMessageTx, 150);
  
  if (Error > 0)
    WriteLineEx(writeTab, 2, "EV: Message sending of type %0x failed: %i", MessageId, Error); 
}



on timer tStartSimulationDelay
{
  SCC_StartSimulation();
  UpdateSimState();
}
on timer tMessageTx
{  
  @sysvar::EV_Sim::SysEV_MessageTx = 0;
}

on timer tInvalidMessage
{  
  @Sysvar::Test::SysErrorIndEV = 0;
}

on timer tVerification
{
  setControlVisibility(gPanelName, "Verification", 0);
}

on timer tSECCDiscoveryMaxDelay
{ 
  SCC_SLAC_SetLinkStatus(1);
  @sysVar::EV_Sim::SysEV_LinkStatus = SCC_SLAC_GetLinkStatus(); 
}

on timer tProcessingTime
{ 
  processingFinished = 1;
}

