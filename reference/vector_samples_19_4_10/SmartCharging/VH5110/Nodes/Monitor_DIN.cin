// PowerDelivery
on any_monitored_value_change _CCS::DataTypes::IMonitoredChargePoint.DIN.PowerDelivery_Request
{
  if($this.value.ReadyToChargeState == 1)
    sysSetVariableString(sysvar::Common::ChargeState, "Start");
  else if($this.value.ReadyToChargeState == 0)
    sysSetVariableString(sysvar::Common::ChargeState, "Stop");  
  
  UpdateProgressBar(PowerDeliveryReq);
}

on any_monitored_value_change _CCS::DataTypes::IMonitoredVehicle.DIN.PowerDelivery_Response
{
  if($this.value.ResponseCode == 0)
    sysSetVariableString(sysvar::Common::ResponseCode, "OK");
  else
    sysSetVariableString(sysvar::Common::ResponseCode, "NOK");
  
  UpdateProgressBar(PowerDeliveryRes);
}

