/*@!Encoding:1252*/
includes
{
}

// Session Setup
on any_monitored_value_change _CCS::DataTypes::IMonitoredChargePoint.DIN.SessionSetup_Request
{
  UpdateProgressBar(SessionSetupReq);
}

on any_monitored_value_change _CCS::DataTypes::IMonitoredVehicle.DIN.SessionSetup_Response
{  
  if($this.value.ResponseCode <= 2)
    sysSetVariableString(sysvar::Common::ResponseCode, "OK");
  else
    sysSetVariableString(sysvar::Common::ResponseCode, "NOK");
  
  UpdateProgressBar(SessionSetupRes);
}


