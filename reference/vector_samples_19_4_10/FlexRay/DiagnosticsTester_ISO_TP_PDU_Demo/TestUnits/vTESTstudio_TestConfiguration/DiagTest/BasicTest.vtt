      <function_definition navid="da2e1ef5-0d25-4af0-aa32-c301e2eea1df">
        <name>ComputeKeyFromSeed</name>
        <parameters />
        <variables />
        <caplinline>
          <title />
          <code>byte  gSeedArray[2];
int   gSeedArraySize      = 2;
int   gSecurityLevel      = 0x20;
char  gVariant[200]       = "";
char  gOption[200]        = "";
byte  gKeyArray[2];
int   gMaxKeyArraySize    = 2;  
DWORD gActualSize         = 0; 
int ret;

@DiagTestUnit::GeneratedKey = 0;
gSeedArray[0] = (@DiagTestUnit::SecuritySeed &gt;&gt; 8) &amp; 0xff;
gSeedArray[1] =  @DiagTestUnit::SecuritySeed       &amp; 0xff;
ret=diagGenerateKeyFromSeed("ECM", gSeedArray, 2, 1, gVariant, gOption, gKeyArray, gMaxKeyArraySize, gActualSize);
if(ret == 0)
{ 
    /* write key value into system variable */  
    @DiagTestUnit::GeneratedKey = gKeyArray[0] &lt;&lt; 8;       // High Byte 
    @DiagTestUnit::GeneratedKey = @DiagTestUnit::GeneratedKey | gKeyArray[1];   // Low  Byte 
    @DiagTestUnit::GeneratedKey = @DiagTestUnit::GeneratedKey &amp; 0x0000FFFF;
}</code>
        </caplinline>
      </function_definition>
