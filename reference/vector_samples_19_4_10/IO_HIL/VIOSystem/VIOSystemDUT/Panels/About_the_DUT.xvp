      <Property Name="Size">317, 40</Property>
      <Property Name="Location">32, 197</Property>
      <Property Name="BackColor">HighlightText</Property>
      <Property Name="Text">A counter whose speed can be controlled by an analog voltage.
- Input voltage range 1..10 V
- Counter speed range 2..20 Hz</Property>
    </Object>
    <Object Type="Vector.CANalyzer.Panels.Design.StaticTextControl, Vector.CANalyzer.Panels.CommonControls, Version=18.0.150.0, Culture=neutral, PublicKeyToken=null" Name="StaticTextControl21" ControlName="Static Text 18">
      <Property Name="Name">StaticTextControl21</Property>
      <Property Name="Size">419, 65</Property>
      <Property Name="Location">32, 105</Property>
      <Property Name="BackColor">HighlightText</Property>
      <Property Name="Text">A TFT display indicates the status of the configuration:
- Red traffic light: CANoe is stopped, please start CANoe.
- Yellow  traffic light: CANoe is started but the DUT is still in idle state. 
   (To start the DUT, please press the 'DUT Start' button.)
- Green  traffic light: CANoe is started and so is the DUT.
</Property>
    </Object>
