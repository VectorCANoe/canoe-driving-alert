    <Object Type="Vector.CANalyzer.Panels.Design.StaticTextControl, Vector.CANalyzer.Panels.CommonControls, Version=18.0.150.0, Culture=neutral, PublicKeyToken=null" Name="StaticTextControl11" ControlName="Static Text 8">
      <Property Name="Name">StaticTextControl11</Property>
      <Property Name="Size">314, 52</Property>
      <Property Name="Location">32, 571</Property>
      <Property Name="BackColor">HighlightText</Property>
      <Property Name="Text">A distance sensor that is controlled by the Arduino on the DUT.
It delivers a signal runtime that is calculated into a distance.
The formula is 
dist = (signal runtime in us)/2 * 0.03432 cm/us</Property>
    </Object>
    <Object Type="Vector.CANalyzer.Panels.Design.StaticTextControl, Vector.CANalyzer.Panels.CommonControls, Version=18.0.150.0, Culture=neutral, PublicKeyToken=null" Name="StaticTextControl8" ControlName="Static Text 5">
