      <Property Name="BackColor">HighlightText</Property>
      <Property Name="Font">Microsoft Sans Serif, 8.25pt, style=Bold</Property>
      <Property Name="Text">PWM Dimmable LED</Property>
    </Object>
    <Object Type="Vector.CANalyzer.Panels.Design.StaticTextControl, Vector.CANalyzer.Panels.CommonControls, Version=18.0.150.0, Culture=neutral, PublicKeyToken=null" Name="StaticTextControl28" ControlName="Static Text 25">
      <Property Name="Name">StaticTextControl28</Property>
      <Property Name="Size">432, 40</Property>
      <Property Name="Location">32, 335</Property>
      <Property Name="BackColor">HighlightText</Property>
      <Property Name="Text">An LED that is dimmed by applying PWM duty cycles coming from the VIO System.
- A slider on the DUT generates an analog voltage that is sent to a VIO1008 input.
- A PWM duty cycle is calculated by the DUT and the result is sent to the LED.
</Property>
    </Object>
    <Object Type="Vector.CANalyzer.Panels.Design.StaticTextControl, Vector.CANalyzer.Panels.CommonControls, Version=18.0.150.0, Culture=neutral, PublicKeyToken=null" Name="StaticTextControl25" ControlName="Static Text 22">
      <Property Name="Name">StaticTextControl25</Property>
      <Property Name="Size">132, 15</Property>
      <Property Name="Location">22, 253</Property>
      <Property Name="BackColor">HighlightText</Property>
      <Property Name="Font">Microsoft Sans Serif, 8.25pt, style=Bold</Property>
      <Property Name="Text">Analog Dimmable LED</Property>
    </Object>
    <Object Type="Vector.CANalyzer.Panels.Design.StaticTextControl, Vector.CANalyzer.Panels.CommonControls, Version=18.0.150.0, Culture=neutral, PublicKeyToken=null" Name="StaticTextControl26" ControlName="Static Text 23">
      <Property Name="Name">StaticTextControl26</Property>
      <Property Name="Size">403, 40</Property>
      <Property Name="Location">32, 269</Property>
      <Property Name="BackColor">HighlightText</Property>
      <Property Name="Text">An LED that is dimmed directly by a voltage coming from the VIO System.
- The LED's voltage is controlled by the slider within the CANoe dashboard.
- The LED's current is measured by the VIO System (VIO1804).</Property>
    </Object>
    <Object Type="Vector.CANalyzer.Panels.Design.StaticTextControl, Vector.CANalyzer.Panels.CommonControls, Version=18.0.150.0, Culture=neutral, PublicKeyToken=null" Name="StaticTextControl23" ControlName="Static Text 20">
