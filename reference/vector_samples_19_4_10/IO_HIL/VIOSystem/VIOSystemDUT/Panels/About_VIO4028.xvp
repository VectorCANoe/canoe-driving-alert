      <Property Name="Font">Microsoft Sans Serif, 8.25pt, style=Bold</Property>
      <Property Name="Text">Signal connections</Property>
    </Object>
    <Object Type="Vector.CANalyzer.Panels.Design.StaticTextControl, Vector.CANalyzer.Panels.CommonControls, Version=17.3.40.0, Culture=neutral, PublicKeyToken=null" Name="StaticTextControl1" Children="Controls" ControlName="Static Text">
      <Property Name="Name">StaticTextControl1</Property>
      <Property Name="Size">399, 156</Property>
      <Property Name="Location">17, 58</Property>
      <Property Name="BackColor">HighlightText</Property>
      <Property Name="Text">Outputs:
Channel 01 generates the signal 'CANoe Running'.
Channel 02 generates the signal 'DUT Running'.
Channel 16 generates the PWM output to control the speed of the fan on the DUT.

Inputs:
Channel 03 detects the start button signal.
Channel 05 measures the PWM signal of the 'PWM Dimmable LED'.
Channel 06 measures bit0 of the counter to calculate the frequency. 
Channels 09..12 measure the counter bits of the 4-bit counter.
Channel 14 measures the distance signal (PWM coded: 1cm = 1%)
Channel 15 measures the rpms of the PWM controlled fan on the DUT.
</Property>
    </Object>
    <Property Name="Name">Panel</Property>
    <Property Name="Size">1000, 622</Property>
    <Property Name="BackColor">HighlightText</Property>
  </Object>
