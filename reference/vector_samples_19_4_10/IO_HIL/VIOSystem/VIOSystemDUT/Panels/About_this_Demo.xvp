    <Object Type="Vector.CANalyzer.Panels.Design.StaticTextControl, Vector.CANalyzer.Panels.CommonControls, Version=18.0.150.0, Culture=neutral, PublicKeyToken=null" Name="StaticTextControl2" ControlName="Static Text">
      <Property Name="Name">StaticTextControl2</Property>
      <Property Name="Size">467, 65</Property>
      <Property Name="Location">490, 55</Property>
      <Property Name="BackColor">White</Property>
      <Property Name="Text">The System Variable Names used in this config were chosen to ease code readability.
Instead of dealing with variables like 'VIO4028_Pos2/Channel 1/Out'
the signal was named 'CANoeRunning_Ch01' with a meaning that is much more obvious.

Any System Variable Name is possible as long as it starts with a letter (not a number).</Property>
    </Object>
