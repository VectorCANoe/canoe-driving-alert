    <Object Type="Vector.CANalyzer.Panels.Design.StaticTextControl, Vector.CANalyzer.Panels.CommonControls, Version=18.0.150.0, Culture=neutral, PublicKeyToken=null" Name="StaticTextControl8" ControlName="Static Text">
      <Property Name="Name">StaticTextControl8</Property>
      <Property Name="Size">320, 65</Property>
      <Property Name="Location">20, 510</Property>
      <Property Name="BackColor">White</Property>
      <Property Name="Text">A detailed description of this sample configuration can be found 
via the Help panel within the Help tab.

If you have a real VIO system at your disposal 
you can also take a look at the 'VIO System DUT' config.</Property>
    </Object>
    <Object Type="Vector.CANalyzer.Panels.Design.StaticTextControl, Vector.CANalyzer.Panels.CommonControls, Version=18.0.150.0, Culture=neutral, PublicKeyToken=null" Name="StaticTextControl7" ControlName="Static Text">
      <Property Name="Name">StaticTextControl7</Property>
      <Property Name="Size">505, 65</Property>
      <Property Name="Location">490, 490</Property>
      <Property Name="BackColor">White</Property>
      <Property Name="Text">These names are also used in this config. The only thing changed is the name of the root namespace. 
Instead of 'VIO' it is called 'VIO_simulated' to make clear that this is only a simulation.

Left: Struct 'VIO_simulated' with alias names.
Right: Struct 'VIO' with real I/O names.</Property>
    </Object>
    <Object Type="Vector.CANalyzer.Panels.Design.StaticTextControl, Vector.CANalyzer.Panels.CommonControls, Version=18.0.150.0, Culture=neutral, PublicKeyToken=null" Name="StaticTextControl6" ControlName="Static Text">
      <Property Name="Name">StaticTextControl6</Property>
      <Property Name="Size">113, 15</Property>
      <Property Name="Location">20, 490</Property>
      <Property Name="BackColor">White</Property>
      <Property Name="Font">Microsoft Sans Serif, 8.25pt, style=Bold</Property>
      <Property Name="Text">Further information</Property>
    </Object>
    <Object Type="Vector.CANalyzer.Panels.Design.StaticTextControl, Vector.CANalyzer.Panels.CommonControls, Version=18.0.150.0, Culture=neutral, PublicKeyToken=null" Name="StaticTextControl2" ControlName="Static Text">
      <Property Name="Name">StaticTextControl2</Property>
      <Property Name="Size">457, 52</Property>
      <Property Name="Location">490, 55</Property>
      <Property Name="BackColor">White</Property>
      <Property Name="Text">The namespaces used in this config were chosen to resemble the naming conventions 
of the real VIO System. The following image shows how the mapping of VIO data  to 
CANoe system variables would look like when connecting real VIO hardware.
In addition, the use of alias names (used to ease code readability) is shown.</Property>
    </Object>
    <Object Type="Vector.CANalyzer.Panels.Design.StaticTextControl, Vector.CANalyzer.Panels.CommonControls, Version=18.0.150.0, Culture=neutral, PublicKeyToken=null" Name="StaticTextControl5" ControlName="Static Text">
