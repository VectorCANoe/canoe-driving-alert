    <Object Type="Vector.CANalyzer.Panels.Design.StaticTextControl, Vector.CANalyzer.Panels.CommonControls, Version=18.0.150.0, Culture=neutral, PublicKeyToken=null" Name="StaticTextControl1" ControlName="Static Text">
      <Property Name="Name">StaticTextControl1</Property>
      <Property Name="Size">401, 65</Property>
      <Property Name="Location">20, 55</Property>
      <Property Name="BackColor">HighlightText</Property>
      <Property Name="Text">This config presents a typical use case of the VIO System in which 
the different VIO I/O cards (VIO1008, VIO1804, VIO2004, VIO4028) 
are used to stimulate and analyze an electronic circuit.

The following image shows how such a test system would look like in reality:</Property>
