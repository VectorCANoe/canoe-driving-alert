    <Object Type="Vector.CANalyzer.Panels.Design.StaticTextControl, Vector.CANalyzer.Panels.CommonControls, Version=17.3.40.0, Culture=neutral, PublicKeyToken=null" Name="StaticTextControl11" Children="Controls" ControlName="Static Text 8">
      <Property Name="Name">StaticTextControl11</Property>
      <Property Name="Size">439, 26</Property>
      <Property Name="Location">20, 499</Property>
      <Property Name="BackColor">HighlightText</Property>
      <Property Name="Text">To start, this test triggers the CANoe Start/Stop button and then the DUT Start/Stop button.
It checks whether the signals CANoeRunning and DutRunning are set correctly.</Property>
    </Object>
    <Object Type="Vector.CANalyzer.Panels.Design.StaticTextControl, Vector.CANalyzer.Panels.CommonControls, Version=17.3.40.0, Culture=neutral, PublicKeyToken=null" Name="StaticTextControl12" Children="Controls" ControlName="Static Text 9">
