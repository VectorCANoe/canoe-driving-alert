    </Object>
    <Object Type="Vector.CANalyzer.Panels.Design.StaticTextControl, Vector.CANalyzer.Panels.CommonControls, Version=17.3.40.0, Culture=neutral, PublicKeyToken=null" Name="StaticTextControl13" Children="Controls" ControlName="Static Text 10">
      <Property Name="Name">StaticTextControl13</Property>
      <Property Name="Size">381, 52</Property>
      <Property Name="Location">20, 740</Property>
      <Property Name="BackColor">HighlightText</Property>
      <Property Name="Text">To run a set of tests, simply click on the red triangle in the uppermost menu bar.
You will see the tests being executed sequentially.
A success is shown by a white hook on green, a failure by a white cross on red.
With the rightmost button, a test report can be opened.</Property>
    </Object>
