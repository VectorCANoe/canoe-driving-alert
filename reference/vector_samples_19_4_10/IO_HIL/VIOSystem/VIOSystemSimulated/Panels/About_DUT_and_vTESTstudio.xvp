<?xml version="1.0"?>
<Panel Type="Vector.CANalyzer.Panels.PanelSerializer, Vector.CANalyzer.Panels.Serializer, Version=17.3.40.0, Culture=neutral, PublicKeyToken=null">
  <Object Type="Vector.CANalyzer.Panels.Runtime.Panel, Vector.CANalyzer.Panels.Common, Version=17.3.40.0, Culture=neutral, PublicKeyToken=null" Name="Panel" Children="Controls" ControlName="About the DUT and the vTESTstudio in this sample configuration">
    <Object Type="Vector.CANalyzer.Panels.Design.StaticTextControl, Vector.CANalyzer.Panels.CommonControls, Version=17.3.40.0, Culture=neutral, PublicKeyToken=null" Name="StaticTextControl27" Children="Controls" ControlName="Static Text 24">
      <Property Name="Name">StaticTextControl27</Property>
      <Property Name="Size">123, 13</Property>
      <Property Name="Location">15, 292</Property>
      <Property Name="BackColor">HighlightText</Property>
      <Property Name="Font">Microsoft Sans Serif, 8.25pt, style=Bold</Property>
      <Property Name="Text">PWM Dimmable LED</Property>
    </Object>
    <Object Type="Vector.CANalyzer.Panels.Design.StaticTextControl, Vector.CANalyzer.Panels.CommonControls, Version=17.3.40.0, Culture=neutral, PublicKeyToken=null" Name="StaticTextControl28" Children="Controls" ControlName="Static Text 25">
      <Property Name="Name">StaticTextControl28</Property>
      <Property Name="Size">521, 52</Property>
      <Property Name="Location">22, 311</Property>
      <Property Name="BackColor">HighlightText</Property>
      <Property Name="Text">An LED that is dimmed by applying PWM duty cycles coming from the VIO System.
- A slider within the DUT panel generates an analog voltage that is sent to a VIO1008 input.
- A PWM duty cycle is calculated by the DUT and the result is sent to the LED via the VIO4028 PWM output.
- The duty cycle to brightness characteristics is taken from a value table as no real LED exists here.</Property>
    </Object>
    <Object Type="Vector.CANalyzer.Panels.Design.StaticTextControl, Vector.CANalyzer.Panels.CommonControls, Version=17.3.40.0, Culture=neutral, PublicKeyToken=null" Name="StaticTextControl25" Children="Controls" ControlName="Static Text 22">
      <Property Name="Name">StaticTextControl25</Property>
      <Property Name="Size">132, 13</Property>
      <Property Name="Location">20, 215</Property>
      <Property Name="BackColor">HighlightText</Property>
      <Property Name="Font">Microsoft Sans Serif, 8.25pt, style=Bold</Property>
      <Property Name="Text">Analog Dimmable LED</Property>
    </Object>
    <Object Type="Vector.CANalyzer.Panels.Design.StaticTextControl, Vector.CANalyzer.Panels.CommonControls, Version=17.3.40.0, Culture=neutral, PublicKeyToken=null" Name="StaticTextControl26" Children="Controls" ControlName="Static Text 23">
      <Property Name="Name">StaticTextControl26</Property>
      <Property Name="Size">401, 52</Property>
      <Property Name="Location">22, 234</Property>
      <Property Name="BackColor">HighlightText</Property>
      <Property Name="Text">An LED that is dimmed directly by a voltage coming from the VIO System (VIO2004).
- The LED's voltage is controlled by the slider within the CANoe dashboard.
- The LED's current is measured by the VIO System (VIO1804).
- The current is taken from a value table as no real LED exists here.</Property>
    </Object>
    <Object Type="Vector.CANalyzer.Panels.Design.StaticTextControl, Vector.CANalyzer.Panels.CommonControls, Version=17.3.40.0, Culture=neutral, PublicKeyToken=null" Name="StaticTextControl23" Children="Controls" ControlName="Static Text 20">
      <Property Name="Name">StaticTextControl23</Property>
      <Property Name="Size">80, 13</Property>
      <Property Name="Location">18, 151</Property>
      <Property Name="BackColor">HighlightText</Property>
      <Property Name="Font">Microsoft Sans Serif, 8.25pt, style=Bold</Property>
      <Property Name="Text">4-bit Counter</Property>
    </Object>
    <Object Type="Vector.CANalyzer.Panels.Design.StaticTextControl, Vector.CANalyzer.Panels.CommonControls, Version=17.3.40.0, Culture=neutral, PublicKeyToken=null" Name="StaticTextControl24" Children="Controls" ControlName="Static Text 21">
      <Property Name="Name">StaticTextControl24</Property>
      <Property Name="Size">445, 39</Property>
      <Property Name="Location">20, 170</Property>
      <Property Name="BackColor">HighlightText</Property>
      <Property Name="Text">A counter whose speed can be controlled by an analog voltage coming from the VIO System.
- Input voltage range 1..10 V
- Counter speed range 2..20 Hz</Property>
    </Object>
    <Object Type="Vector.CANalyzer.Panels.Design.StaticTextControl, Vector.CANalyzer.Panels.CommonControls, Version=17.3.40.0, Culture=neutral, PublicKeyToken=null" Name="StaticTextControl21" Children="Controls" ControlName="Static Text 18">
      <Property Name="Name">StaticTextControl21</Property>
      <Property Name="Size">548, 52</Property>
      <Property Name="Location">20, 93</Property>
      <Property Name="BackColor">HighlightText</Property>
      <Property Name="Text">A 3-LED 'traffic light' that indicates the status of the test system including CANoe.
- RED: CANoe is stopped, please press the 'CANoe Start' button within the CANoe panel.
- YELLOW: CANoe is started but the DUT is still in idle state. To start the DUT, please press the 'DUT Start' button.
- GREEN: CANoe is started and so is the DUT. The counter starts and the LEDs can be dimmed.</Property>
    </Object>
    <Object Type="Vector.CANalyzer.Panels.Design.StaticTextControl, Vector.CANalyzer.Panels.CommonControls, Version=17.3.40.0, Culture=neutral, PublicKeyToken=null" Name="StaticTextControl22" Children="Controls" ControlName="Static Text 19">
      <Property Name="Name">StaticTextControl22</Property>
      <Property Name="Size">73, 13</Property>
      <Property Name="Location">20, 74</Property>
      <Property Name="BackColor">HighlightText</Property>
      <Property Name="Font">Microsoft Sans Serif, 8.25pt, style=Bold</Property>
      <Property Name="Text">DUT Status</Property>
    </Object>
