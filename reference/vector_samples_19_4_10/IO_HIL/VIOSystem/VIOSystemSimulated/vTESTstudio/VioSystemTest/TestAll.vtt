          <statecheck>
            <title />
            <expected>
              <compare>
                <value>
                  <dbobject>SysVar_BEGIN_OF_OBJECT|1|LedAnalogCurrent|VIO_simulated::VIO1804In::Ch01|-1|0|END_OF_OBJECT_SysVar|</dbobject>
