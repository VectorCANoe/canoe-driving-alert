<UserControl x:Class="Demo.Wpf.NavigationInfo.NavigationInfoControlView"
             x:ClassModifier="internal"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:interfaces="clr-namespace:Demo.Wpf.NavigationInfo.Interfaces"
             xmlns:converters="clr-namespace:Demo.Wpf.Helper.Converters"
             d:DataContext="{d:DesignInstance Type=interfaces:INavigationInfoControlViewModel, IsDesignTimeCreatable=True}"
             mc:Ignorable="d">

    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <UserControl.Visibility>
        <Binding Path="IsVisible" Converter="{StaticResource BooleanToVisibilityConverter}"/>
    </UserControl.Visibility>

    <Border BorderBrush="Black" BorderThickness="1" Background="{Binding BackgroundColor}">
        <StackPanel Margin="7">
            <TextBlock Text="Destination:" 
                       Foreground="{Binding TextColor}"/>
            <TextBox Text="{Binding Destination}" 
                     Margin="0,5" 
                     Width="280"
                     Foreground="{Binding TextColor}"/>
            <TextBlock Text="Distance:" 
                       Foreground="{Binding TextColor}"/>
            <TextBox Text="{Binding Distance}" 
                     Margin="0,5" 
                     Foreground="{Binding TextColor}"/>
            <Button Content="Send" 
                    Margin="0,5,0,0" 
                    Padding="20,5" 
                    HorizontalAlignment="Right" 
                    Command="{Binding SendCommand}"
                    IsEnabled="{Binding IsEnabled}"/>
        </StackPanel>
    </Border>
</UserControl>
