    <UserControl.Visibility>
        <Binding Path="IsVisible" Converter="{StaticResource BooleanToVisibilityConverter}"/> 
    </UserControl.Visibility>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="{Binding Distance, Converter={StaticResource DistanceToGridLengthConverter}}"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="{Binding ReserveSpace, Converter={StaticResource DistanceToGridLengthConverter}}"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="8*"/>
            <RowDefinition Height="17*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Image x:Name="CarA"
               Grid.Column="0" 
               Grid.Row="0" 
               Grid.RowSpan="3"
               Source="{StaticResource AdasCar}"
               Margin="0,0,0,0"/>
        <Border Grid.Column="1"
                Grid.Row="2"
                Background="Black"/>
        <StackPanel x:Name="CarB"
                    Grid.Row="1" 
                    Grid.Column="2" 
                    Grid.RowSpan="2" 
                    Orientation="Horizontal">
            <Image Source="{StaticResource Car}"
                   MouseDown="UIElement_OnMouseDown"
                   MouseUp="UIElement_OnMouseUp"
                   MouseMove="UIElement_OnMouseMove"/>
            <TextBlock Text="{Binding DisplayDistance}"
                       Foreground="{Binding TextColor}"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Top"
                       FontSize="12"
                       MinWidth="35"
                       TextAlignment="Right"
                       Margin="5,0,0,0"/>
        </StackPanel>
    </Grid>
</UserControl>
