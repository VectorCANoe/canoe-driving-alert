export testcase quality_control_after_three_intact_pcbs()
{
  char thirdLast[10];
  char secondLast[10];
  char last[10];

  disable_control_panel();

  sysSetVariableLong(sysvar::QualityControl::ButtonQualityControl, 1);

  testWaitForTimeout(5500);

  sysSetVariableLong(sysvar::QualityControl::ButtonQualityControl, 0);

  sysGetVariableString(sysvar::QualityControl::ConditionThridLastPCB, thirdLast, elcount(thirdLast));
  sysGetVariableString(sysvar::QualityControl::ConditionSecondLastPCB, secondLast, elcount(secondLast));
  sysGetVariableString(sysvar::QualityControl::ConditionLastPCB, last, elcount(last));

  if (mbstrncmp(thirdLast, "intact", 10) == 0 && mbstrncmp(secondLast, "intact", 10) == 0 && mbstrncmp(last, "intact", 10) == 0)
  {
    testStepPass("Quality Control after three intact PCBs was correct");
  }
  else
  {
    testStepFail("Error in Quality Control after three intact PCBs!");
  } 
}

