export testcase quality_control_mixed() 
{
  char thirdLast[10];
  char secondLast[10];
  char last[10];

  disable_control_panel();

  sysSetVariableLong(sysvar::QualityControl::ButtonQualityControl, 1);

  testWaitForTimeout(5500);

  sysSetVariableLong(sysvar::QualityControl::ButtonQualityControl, 0);

  sysGetVariableString(sysvar::QualityControl::ConditionThridLastPCB, thirdLast, elcount(thirdLast));
  sysGetVariableString(sysvar::QualityControl::ConditionSecondLastPCB, secondLast, elcount(secondLast));
  sysGetVariableString(sysvar::QualityControl::ConditionLastPCB, last, elcount(last));

  setControlVisibility("ControlPanel", "Text_NormalMode", 1);
  setControlVisibility("ControlPanel", "Text_Manipulation", 1);
  setControlVisibility("ControlPanel", "Text_RemoteAccess", 1);
  setControlVisibility("ControlPanel", "Button_PlaceIntactPCB", 1); 
  setControlVisibility("ControlPanel", "Button_PlaceDefectPCB", 1);
  setControlVisibility("ControlPanel", "Button_StartConveyor", 1); 
  setControlVisibility("ControlPanel", "Button_DisconnectS1", 1);
  setControlVisibility("ControlPanel", "Button_DisconnectS2", 1);
  setControlVisibility("ControlPanel", "Button_RepairS1", 1);
  setControlVisibility("ControlPanel", "Button_RepairS2", 1);  
  setControlVisibility("ControlPanel", "Button_QualityControl", 1);

  if (mbstrncmp(thirdLast, "defect", 10) == 0 && mbstrncmp(secondLast, "defect", 10) == 0 && mbstrncmp(last, "intact", 10) == 0)
  {
    testStepPass("Quality Control mixed was correct");
  }
  else
  {
    testStepFail("Error in Quality Control for mixed!");
  } 
}

export testcase disconnect_and_repair_sensors()
{
  int systemStateCorrectCount = 0;

  disable_control_panel();

  if (sysGetVariableLong(sysvar::General::SystemState) == IDLE) systemStateCorrectCount++;
  
  sysSetVariableLong(sysvar::Sensors::S1Disconnected, 1);
  testWaitForTimeout(2500);
  sysSetVariableLong(sysvar::Sensors::S1Disconnected, 0);
  if (sysGetVariableLong(sysvar::General::SystemState) == SENSOR_DEFECT_INFO) systemStateCorrectCount++;

  sysSetVariableLong(sysvar::Sensors::S2Disconnected, 1);
  testWaitForTimeout(1500);
  sysSetVariableLong(sysvar::Sensors::S2Disconnected, 0);
  if (sysGetVariableLong(sysvar::General::SystemState) == STOPPED) systemStateCorrectCount++;

  sysSetVariableLong(sysvar::Sensors::RepairS1, 1);
  testWaitForTimeout(2500);
  sysSetVariableLong(sysvar::Sensors::RepairS1, 0);
  if (sysGetVariableLong(sysvar::General::SystemState) == SENSOR_DEFECT_INFO) systemStateCorrectCount++;

  sysSetVariableLong(sysvar::Sensors::RepairS2, 1);
  testWaitForTimeout(1500);
  sysSetVariableLong(sysvar::Sensors::RepairS2, 0);
  if (sysGetVariableLong(sysvar::General::SystemState) == IDLE) systemStateCorrectCount++;      

  if (systemStateCorrectCount == 5)
  {
    testStepPass("Disconnect and Repair Sensors was correct");
  }
  else
  {
    testStepFail("Error disconnecting and repairing Sensors!");
  } 

}

