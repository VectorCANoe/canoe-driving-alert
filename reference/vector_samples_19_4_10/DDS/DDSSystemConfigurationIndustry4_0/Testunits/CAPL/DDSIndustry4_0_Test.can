void disable_control_panel()
{
  setControlVisibility("ControlPanel", "Text_NormalMode", 0);
  setControlVisibility("ControlPanel", "Text_Manipulation", 0);
  setControlVisibility("ControlPanel", "Text_RemoteAccess", 0);
  setControlVisibility("ControlPanel", "Button_PlaceIntactPCB", 0); 
  setControlVisibility("ControlPanel", "Button_PlaceDefectPCB", 0);
  setControlVisibility("ControlPanel", "Button_StartConveyor", 0); 
  setControlVisibility("ControlPanel", "Button_DisconnectS1", 0);
  setControlVisibility("ControlPanel", "Button_DisconnectS2", 0);
  setControlVisibility("ControlPanel", "Button_RepairS1", 0);
  setControlVisibility("ControlPanel", "Button_RepairS2", 0);  
  setControlVisibility("ControlPanel", "Button_QualityControl", 0);
}

void enable_control_panel()
{
  setControlVisibility("ControlPanel", "Text_NormalMode", 1);
  setControlVisibility("ControlPanel", "Text_Manipulation", 1);
  setControlVisibility("ControlPanel", "Text_RemoteAccess", 1);
  setControlVisibility("ControlPanel", "Button_PlaceIntactPCB", 1); 
  setControlVisibility("ControlPanel", "Button_PlaceDefectPCB", 1);
  setControlVisibility("ControlPanel", "Button_StartConveyor", 1); 
  setControlVisibility("ControlPanel", "Button_DisconnectS1", 1);
  setControlVisibility("ControlPanel", "Button_DisconnectS2", 1);
  setControlVisibility("ControlPanel", "Button_RepairS1", 1);
  setControlVisibility("ControlPanel", "Button_RepairS2", 1);  
  setControlVisibility("ControlPanel", "Button_QualityControl", 1);
}

export testcase process_three_intact_pcbs()
{
  int i;
  int currentPCBIntactCount;
  int countOfPCBs = 3;

  currentPCBIntactCount = $SystemSimulation::evaluationParticipant.receivedData.pcbIntactCount;

  disable_control_panel();      

  for (i=0; i<countOfPCBs; i++)
  {
    sysSetVariableLong(sysvar::General::PCBIntactButton, 1);
    testWaitForTimeout(350);
    sysSetVariableLong(sysvar::General::StartSystem, 1);

    testWaitForTimeout(13000);

    sysSetVariableLong(sysvar::General::PCBIntactButton, 0);
    sysSetVariableLong(sysvar::General::StartSystem, 0);
  }  

  if ($SystemSimulation::evaluationParticipant.receivedData.pcbIntactCount == currentPCBIntactCount + countOfPCBs)
  {
    testStepPass("Three intact PCBs processed as expected");
  }
  else
  {
    testStepFail("Error while processing three intact PCBs!");
  } 
}

