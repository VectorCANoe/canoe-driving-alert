////////////////////////////////////////////////////////
//
// Functions
//
////////////////////////////////////////////////////////

/*
 * Check if TPRI message is sent and if it contains expected pressure
 *
 * tireLocation - Location of the tire
 * diff         - Pressure difference which is used to calculate the current reference pressure 
*/
void WaitForTPRIAndCheckPressure(int tireLocation, float diff)
{
  pg TPRI rxTPRI;
  float expectedPressure, actualPressure;

  // wait for TPRI response
  switch(TestWaitForJ1939PG( TPRI.pgn, TirePressureController.NmStationAddress, GlobalAddress, 1250 )) 
  {
    case 0: // timeout
      snprintf( textBuffer, elCount(textBuffer), "Message TPRI (tire location 0x%X) is missing (timeout).", tireLocation );
      TestStepFail( textBuffer ); 
      return;
    case 1: // ok: message has occurred
      TestGetWaitJ1939PGData( rxTPRI );
      break;
    default: // failed
      snprintf( textBuffer, elCount(textBuffer), "Message TPRI (tire location 0x%X) is missing (WaitForMessage: General error occurred).", tireLocation );
      TestStepFail( textBuffer ); 
      return;
  }
  
  if (rxTPRI.TireLocation != tireLocation) 
  {
    snprintf( textBuffer, elCount(textBuffer), "Wrong TPRI.TireLocation received 0x%X, but must be 0x%X. ", rxTPRI.TireLocation, tireLocation );
    TestStepFail( textBuffer );
  }
  else 
  {
    switch (tireLocation)
    {
      case 0x00:
        expectedPressure = @TPMS::FrontLeftPressure + diff;
        actualPressure   = rxTPRI.ReferenceTirePress_00.phys;
        break;
      case 0x01:
        expectedPressure = @TPMS::FrontRightPressure + diff;
        actualPressure   = rxTPRI.ReferenceTirePress_01.phys;
        break;
      case 0x10:
        expectedPressure = @TPMS::Rear1LeftPressure + diff;
        actualPressure   = rxTPRI.ReferenceTirePress_10.phys;
        break;
      case 0x11:
        expectedPressure = @TPMS::Rear1RightPressure + diff;
        actualPressure   = rxTPRI.ReferenceTirePress_11.phys;
        break;
      case 0x20:
        expectedPressure = @TPMS::Rear2LeftPressure + diff;
        actualPressure   = rxTPRI.ReferenceTirePress_20.phys;
        break;
      case 021:
        expectedPressure = @TPMS::Rear2RightPressure + diff;
        actualPressure   = rxTPRI.ReferenceTirePress_21.phys;
        break;
      default:
        break;
    }
 
    if (expectedPressure != actualPressure) 
    {
      snprintf( textBuffer, elCount(textBuffer), "Wrong TPRI.ReferenceTirePress (tire location 0x%X) received %f, but must be %f. ", tireLocation, rxTPRI.ReferenceTirePress_21.phys, @TPMS::Rear2RightPressure + diff );
      TestStepFail( textBuffer );
    } 
    else
    {
      snprintf( textBuffer, elCount(textBuffer), "Message TPRI (tire location 0x%X) received.", tireLocation );
      TestStepPass( textBuffer ); 
    }
  }
}

/*
 * Check if TIRE1 message is sent and if it contains expected pressure
 *
 * tireLocation - Location of the tire
 */
void WaitForTIRE1AndCheckPressure(int tireLocation)
{
  pg TIRE1 rxTIRE;
  float expectedPressure, actualPressure;
  
  // wait for TIRE response
  switch(TestWaitForJ1939PG( TIRE1.pgn, TirePressureController.NmStationAddress, GlobalAddress, 1250 )) 
  {
    case 0: // timeout
      snprintf( textBuffer, elCount(textBuffer), "Message TIRE1 (tire location 0x%X) is missing (timeout).", tireLocation );
      TestStepFail( textBuffer ); 
      return;
    case 1: // ok: message has occurred
      TestGetWaitJ1939PGData( rxTIRE );
      break;
    default: // failed
      snprintf( textBuffer, elCount(textBuffer), "Message TIRE1  (tire location 0x%X) is missing (WaitForMessage: General error occurred).", tireLocation );
      TestStepFail( textBuffer ); 
      return;
  }

  // check TIRE response
  if (rxTIRE.TireLocation != tireLocation) 
  {
    snprintf( textBuffer, elCount(textBuffer), "Wrong TIRE.TireLocation received 0x%X, but must be 0x%X. ", rxTIRE.TireLocation, tireLocation );
    TestStepFail( textBuffer );
  }
  else
  {
    switch (tireLocation)
    {
      case 0x00:
        expectedPressure = @TPMS::FrontLeftPressure;
        actualPressure   = rxTIRE.TirePress_00.phys;
        break;
      case 0x01:
        expectedPressure = @TPMS::FrontRightPressure;
        actualPressure   = rxTIRE.TirePress_01.phys;
        break;
      case 0x10:
        expectedPressure = @TPMS::Rear1LeftPressure;
        actualPressure   = rxTIRE.TirePress_10.phys;
        break;
      case 0x11:
        expectedPressure = @TPMS::Rear1RightPressure;
        actualPressure   = rxTIRE.TirePress_11.phys;
        break;
      case 0x20:
        expectedPressure = @TPMS::Rear2LeftPressure;
        actualPressure   = rxTIRE.TirePress_01.phys;
        break;
      case 021:
        expectedPressure = @TPMS::Rear2RightPressure;
        actualPressure   = rxTIRE.TirePress_21.phys;
        break;
      default:
        break;
    }
    
    if (expectedPressure != actualPressure) 
    {
      snprintf( textBuffer, elCount(textBuffer), "Wrong TIRE.TirePress received %f (must be %f).", actualPressure, expectedPressure );
      TestStepFail( textBuffer );
    }
    
    snprintf( textBuffer, elCount(textBuffer), "Response for TIRE 0x%X received.", tireLocation );
    TestStepPass( textBuffer ); 
  }
}

/*
* Check if TPRI message is sent and if it contains expected pressure
*
* tireLocation - Location of the tire
*/
void WaitForTPRI(int tireLocation)
{
  pg TPRI rxTPRI;

  // wait for TPRI response
  switch(TestWaitForJ1939PG( TPRI.pgn, TirePressureController.NmStationAddress, GlobalAddress, 1250 )) 
  {
    case 0: // timeout
      snprintf( textBuffer, elCount(textBuffer), "Message TPRI (tire location 0x%X) is missing (timeout).", tireLocation );
      TestStepFail( textBuffer ); 
      return;
    case 1: // ok: message has occurred
      TestGetWaitJ1939PGData( rxTPRI );
      break;
    default: // failed
      snprintf( textBuffer, elCount(textBuffer), "Message TPRI (tire location 0x%X) is missing (WaitForMessage: General error occurred).", tireLocation );
      TestStepFail( textBuffer ); 
      return;
  }
  
  if (rxTPRI.TireLocation != tireLocation) 
  {
    snprintf( textBuffer, elCount(textBuffer), "Wrong TPRI.TireLocation received 0x%X, but must be 0x%X. ", rxTPRI.TireLocation, tireLocation );
    TestStepFail( textBuffer );
  }
  else
  {
    snprintf( textBuffer, elCount(textBuffer), "Message TPRI (tire location 0x%X) received.", tireLocation );
    TestStepPass( textBuffer ); 
  }
}

/*
 * Wait for DM1 message
 */
int TpmsWaitForDM1( BYTE tpmsAddr, DWORD spn, WORD fmi, BYTE led )
{
  dword dtc;
  pg DM01 dm1;

  // wait for the response
  switch(TestWaitForJ1939PG( DM01.pgn, tpmsAddr, GlobalAddress, 2000 )) 
  {
    case 0: // timeout 
      TestStepFail( "Timeout, DM1 response not received."); 
      return -1;
    case 1: // ok: message has occurred 
      TestGetWaitJ1939PGData( dm1 );

      switch(led) 
      {
        case 1:
          if (dm1.ProtectLampStatus != 1) 
          {
            TestStepFail( "Protecion Lamp is off." );
            return -2;
          }
          break;
        case 2:
          if (dm1.RedStopLampState != 1) 
          {
            TestStepFail( "Ret stop Lamp is off." );
            return -2;
          }
          break;
        case 3:
          if (dm1.AmberWarningLampStatus != 1) 
          {
            TestStepFail( "Amber warning Lamp is off." );
            return -2;
          }
          break;
        case 4:
          if (dm1.MalfunctionIndicatorLampStatus != 1) 
          {
            TestStepFail( "Malfunction indicator lamp off." );
            return -2;
          }
          break;
        }

      J1939GetDTC(dm1, spn, fmi, 0xFFFF, dtc);
      if (J1939GetSpnFromDTC(dtc) != spn)
      {
        snprintf( textBuffer, elCount(textBuffer), "SPN is %d but must be %d. ", J1939GetSpnFromDTC(dtc), spn );
        TestStepFail( textBuffer );
        return -3;
      }
      
      if (J1939GetFmiFromDTC(dtc) != fmi) 
      {
        snprintf( textBuffer, elCount(textBuffer), "FMI is %d but must be %d. ", J1939GetFmiFromDTC(dtc), fmi );
        TestStepFail( textBuffer );
        return -4;
      }
      return 0;
    default: // Failed 
      TestStepFail( "WaitForMessage: General error occurred. ");
      return -5;
  }
}
