    <Object Type="Vector.CANalyzer.Panels.Design.StaticTextControl, Vector.CANalyzer.Panels.CommonControls, Version=18.0.150.0, Culture=neutral, PublicKeyToken=null" Name="StaticTextControl4" ControlName="Static Text 2">
      <Property Name="Name">StaticTextControl4</Property>
      <Property Name="Size">329, 40</Property>
      <Property Name="Location">57, 144</Property>
      <Property Name="BackColor">White</Property>
      <Property Name="Text">The J1939 Interaction Layer is assigned to the node 'EMS'. The
J1939 IL is completely configured with the database, no CAPL
programming is needed.</Property>
    </Object>
    <Object Type="Vector.CANalyzer.Panels.Design.StaticTextControl, Vector.CANalyzer.Panels.CommonControls, Version=18.0.150.0, Culture=neutral, PublicKeyToken=null" Name="StaticTextControl11" ControlName="Static Text 2">
      <Property Name="Name">StaticTextControl11</Property>
      <Property Name="Size">326, 91</Property>
      <Property Name="Location">841, 60</Property>
      <Property Name="BackColor">White</Property>
      <Property Name="Text">The behaviour of the node is defined in the DBC below topic
"Network nodes" by means of 
  -node attributes (e.g. for the J1939 device name)
  -Tx message list (parameter groups which are supported
    for transmission)
  -message attributes (starting with "GenMsg…")
  -signal attributes (starting with "GenSig…")
</Property>
    </Object>
    <Object Type="Vector.CANalyzer.Panels.Design.StaticTextControl, Vector.CANalyzer.Panels.CommonControls, Version=18.0.150.0, Culture=neutral, PublicKeyToken=null" Name="StaticTextControl10" ControlName="Static Text 2">
