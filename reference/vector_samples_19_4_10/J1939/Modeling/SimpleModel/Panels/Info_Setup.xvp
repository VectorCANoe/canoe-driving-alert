    <Object Type="Vector.CANalyzer.Panels.Design.StaticTextControl, Vector.CANalyzer.Panels.CommonControls, Version=18.0.150.0, Culture=neutral, PublicKeyToken=null" Name="StaticTextControl7" ControlName="Static Text 2">
      <Property Name="Name">StaticTextControl7</Property>
      <Property Name="Size">314, 52</Property>
      <Property Name="Location">461, 47</Property>
      <Property Name="BackColor">White</Property>
      <Property Name="Text">When the measurement is started, CANoe switches to the 
desktop 'Measurement'. Use the context menu of 
the desktop tab to configure this behaviour!

</Property>
    </Object>
    <Object Type="Vector.CANalyzer.Panels.Design.StaticTextControl, Vector.CANalyzer.Panels.CommonControls, Version=18.0.150.0, Culture=neutral, PublicKeyToken=null" Name="StaticTextControl6" ControlName="Static Text 2">
      <Property Name="Name">StaticTextControl6</Property>
      <Property Name="Size">315, 27</Property>
      <Property Name="Location">841, 28</Property>
      <Property Name="BackColor">White</Property>
      <Property Name="Text">&gt; Click on the CANdb++ Editor button (      ) on the ribbon tap 'Tool' 
    to open the assigned database.
</Property>
    </Object>
    <Object Type="Vector.CANalyzer.Panels.Design.StaticTextControl, Vector.CANalyzer.Panels.CommonControls, Version=18.0.150.0, Culture=neutral, PublicKeyToken=null" Name="StaticTextControl5" ControlName="Static Text 2">
      <Property Name="Name">StaticTextControl5</Property>
      <Property Name="Size">333, 78</Property>
      <Property Name="Location">57, 60</Property>
      <Property Name="BackColor">White</Property>
      <Property Name="Text">The network contains a single node 'EMS', which can transmit
the following parameter groups:
  -EEC1 with signal EndSpeed is transmitted cyclically
  -ET1 with signal CoolantTemp is transmitted on change
   and on request
  -ACL, ACKM, TPCM, TPDT which are needed in a J1939 network</Property>
    </Object>
