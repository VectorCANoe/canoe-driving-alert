        </caplfunction>
        <value_valid>
          <title />
          <checkid />
          <compare>
            <dbobject>DBSignal_BEGIN_OF_OBJECT|1|NodeOrFrameData_BEGIN_OF_OBJECT|1|1|CAN|1|Aftertreatment|EAS|END_OF_OBJECT_NodeOrFrameData|FrameData_BEGIN_OF_OBJECT|1|61|255|0|0|PROB_2_EAS|-1728118467|False|END_OF_OBJECT_FrameData|ReductionFluidTankLevel|7|END_OF_OBJECT_|</dbobject>
            <range>
              <fromto>
                <from>
                  <const>10</const>
                </from>
                <to>
                  <const>100</const>
                </to>
              </fromto>
            </range>
          </compare>
        </value_valid>
        <caplfunction>
          <title />
          <name>CheckReactionOfEmptyFluidTank</name>
        </caplfunction>
        <caplfunction>
          <title />
          <name>SetAcceleratorPosition</name>
          <param>
            <type>dword</type>
            <value>
              <const>0</const>
            </value>
          </param>
        </caplfunction>
      </tc>
