      <tc>
        <title>Check cycle time violation</title>
        <tcid>60437df3-39c7-49d1-808c-fe09253c7e9b</tcid>
        <description>The test checks, if the cycle time for the tested PGs is in range</description>
        <cycletime_rel>
          <title />
          <checkid />
          <object>
            <j1939_pg>
              <dbobject>DBFrameOrPDU_BEGIN_OF_OBJECT|2|NodeOrFrameData_BEGIN_OF_OBJECT|1|1|CAN|1|Aftertreatment|EAS|END_OF_OBJECT_NodeOrFrameData|FrameData_BEGIN_OF_OBJECT|1|61|255|0|0|PROB_1_EAS|-1728118723|False|END_OF_OBJECT_FrameData|4|0|END_OF_OBJECT_|</dbobject>
