    <tf navid="e40f5fd2-8a52-418c-95d2-1427bcc50f68">
      <title>Functionality tests</title>
      <tc>
        <title>Check fluid tank level range violation</title>
        <tcid>1943e45a-34ea-425c-9b9c-b699ba7b78c4</tcid>
        <value_valid>
          <title />
          <checkid />
          <compare>
            <dbobject>DBSignal_BEGIN_OF_OBJECT|1|NodeOrFrameData_BEGIN_OF_OBJECT|1|1|CAN|1|Aftertreatment|EAS|END_OF_OBJECT_NodeOrFrameData|FrameData_BEGIN_OF_OBJECT|1|61|255|0|0|PROB_2_EAS|-1728118467|False|END_OF_OBJECT_FrameData|ReductionFluidTankLevel|7|END_OF_OBJECT_|</dbobject>
            <range>
              <fromto>
                <from>
                  <const>10</const>
                </from>
                <to>
                  <const>100</const>
                </to>
              </fromto>
            </range>
          </compare>
        </value_valid>
        <stimulate_ramp>
          <title />
          <dbobject>SysVar_BEGIN_OF_OBJECT|1|Accelerator|EMS|-1|0|END_OF_OBJECT_SysVar|</dbobject>
          <time_up>
            <value>
              <const>5</const>
            </value>
            <unit>s</unit>
          </time_up>
          <time_high>
            <value>
              <const>3</const>
            </value>
            <unit>s</unit>
          </time_high>
          <time_down>
            <value>
              <const>5</const>
            </value>
            <unit>s</unit>
          </time_down>
          <time_low>
            <value>
              <const>2</const>
            </value>
            <unit>s</unit>
          </time_low>
          <duration>
            <value>
              <const>15</const>
            </value>
            <unit>s</unit>
          </duration>
          <cycle_time>
            <value>
              <const>100</const>
            </value>
            <unit>ms</unit>
          </cycle_time>
          <wait_until_finished>
            <bool>true</bool>
          </wait_until_finished>
        </stimulate_ramp>
      </tc>
      <tc>
        <title>Check reaction of empty fluid tank</title>
        <tcid>a49244bd-d68d-4190-b7a4-0b93c27f8f35</tcid>
        <caplfunction>
          <title />
          <name>SetAcceleratorPosition</name>
