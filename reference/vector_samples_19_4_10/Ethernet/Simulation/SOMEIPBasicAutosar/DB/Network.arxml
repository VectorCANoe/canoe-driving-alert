                  <INTERFACE-VERSION>1</INTERFACE-VERSION>
                </SOMEIP-TRANSFORMATION-DESCRIPTION>
              </TRANSFORMATION-DESCRIPTIONS>
              <TRANSFORMER-CLASS>SERIALIZER</TRANSFORMER-CLASS>
              <VERSION>1</VERSION>
