    <AR-PACKAGE>
      <SHORT-NAME>CompuMethod</SHORT-NAME>
      <ELEMENTS>
        <COMPU-METHOD>
          <!-- /CompuMethod/DistanceCM -->
          <SHORT-NAME>DistanceCM</SHORT-NAME>
          <CATEGORY>LINEAR</CATEGORY>
          <UNIT-REF DEST='UNIT'>/Unit/DistanceUnit</UNIT-REF>
          <COMPU-INTERNAL-TO-PHYS>
            <COMPU-SCALES>
              <COMPU-SCALE>
                <COMPU-RATIONAL-COEFFS>
                  <COMPU-NUMERATOR>
                    <V>-1000</V>
                    <V>0.01</V>
                  </COMPU-NUMERATOR>
                </COMPU-RATIONAL-COEFFS>
              </COMPU-SCALE>
              <COMPU-SCALE>
                <LOWER-LIMIT INTERVAL-TYPE='CLOSED'>4294967295</LOWER-LIMIT>
                <UPPER-LIMIT INTERVAL-TYPE='CLOSED'>4294967295</UPPER-LIMIT>
                <COMPU-CONST>
                  <VT>NoDistance</VT>
                </COMPU-CONST>
              </COMPU-SCALE>
            </COMPU-SCALES>
          </COMPU-INTERNAL-TO-PHYS>
        </COMPU-METHOD>
        <COMPU-METHOD>
          <!-- /CompuMethod/ReliabilityCM -->
          <SHORT-NAME>ReliabilityCM</SHORT-NAME>
          <CATEGORY>LINEAR</CATEGORY>
          <UNIT-REF DEST='UNIT'>/Unit/ReliabilityUnit</UNIT-REF>
