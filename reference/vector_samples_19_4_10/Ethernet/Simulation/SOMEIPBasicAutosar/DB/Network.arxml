                <UPPER-LIMIT INTERVAL-TYPE='CLOSED'>3</UPPER-LIMIT>
                <COMPU-CONST>
                  <VT>NoPassingZoneEndSign</VT>
                </COMPU-CONST>
              </COMPU-SCALE>
              <COMPU-SCALE>
                <LOWER-LIMIT INTERVAL-TYPE='CLOSED'>4</LOWER-LIMIT>
                <UPPER-LIMIT INTERVAL-TYPE='CLOSED'>4</UPPER-LIMIT>
                <COMPU-CONST>
                  <VT>HazardSign</VT>
                </COMPU-CONST>
              </COMPU-SCALE>
              <COMPU-SCALE>
                <LOWER-LIMIT INTERVAL-TYPE='CLOSED'>5</LOWER-LIMIT>
                <UPPER-LIMIT INTERVAL-TYPE='CLOSED'>5</UPPER-LIMIT>
                <COMPU-CONST>
                  <VT>HazardEndSign</VT>
                </COMPU-CONST>
              </COMPU-SCALE>
              <COMPU-SCALE>
                <LOWER-LIMIT INTERVAL-TYPE='CLOSED'>6</LOWER-LIMIT>
                <UPPER-LIMIT INTERVAL-TYPE='CLOSED'>6</UPPER-LIMIT>
                <COMPU-CONST>
                  <VT>RoadworkSign</VT>
                </COMPU-CONST>
              </COMPU-SCALE>
              <COMPU-SCALE>
                <LOWER-LIMIT INTERVAL-TYPE='CLOSED'>7</LOWER-LIMIT>
                <UPPER-LIMIT INTERVAL-TYPE='CLOSED'>7</UPPER-LIMIT>
                <COMPU-CONST>
                  <VT>RoadworkEndSign</VT>
                </COMPU-CONST>
              </COMPU-SCALE>
              <COMPU-SCALE>
                <LOWER-LIMIT INTERVAL-TYPE='CLOSED'>30</LOWER-LIMIT>
                <UPPER-LIMIT INTERVAL-TYPE='CLOSED'>30</UPPER-LIMIT>
                <COMPU-CONST>
                  <VT>SpeedLimit30Sign</VT>
                </COMPU-CONST>
              </COMPU-SCALE>
              <COMPU-SCALE>
                <LOWER-LIMIT INTERVAL-TYPE='CLOSED'>40</LOWER-LIMIT>
                <UPPER-LIMIT INTERVAL-TYPE='CLOSED'>40</UPPER-LIMIT>
                <COMPU-CONST>
