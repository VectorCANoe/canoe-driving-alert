{
   snprintf(gTempStr, elcount(gTempStr), formatstr, value1, value2, value3);
   writeDbgLvlPrefix(DbgLvl, gTempStr);
}

void writeDbgLvlPrefix(word DbgLvl, char formatstr[], long value1, long value2, long value3, long value4)
{
   snprintf(gTempStr, elcount(gTempStr), formatstr, value1, value2, value3, value4);
   writeDbgLvlPrefix(DbgLvl, gTempStr);
