void HandleMethodRequest_echoUINT8Array(DWORD methodHandle, DWORD messageHandle, DWORD messageResponseHandle,
  DWORD minExpectedNumberOfElements, char argumentNameReq[], char argumentNameRes[])
{
  dword numberOfElements, errorCode;
  dword arg;
  char reqBuffer[64], resBuffer[64];
  int i;

  if(GetMethodArgumentDWord(messageHandle, argumentNameReq, numberOfElements, errorCode)==kFalse)
  {
    SomeIpSetReturnCode(messageResponseHandle, errorCode);
    return;
  }

  if(numberOfElements<minExpectedNumberOfElements)
  {
    SomeIpSetReturnCode(messageResponseHandle, sysvar::TC8_ETS::ETS_MethodResult::MALFORMED_MESSAGE);
    return;
  }
  
  for(i=0; i<numberOfElements; ++i)
  {
    snprintf(reqBuffer, elCount(reqBuffer), "%s[%d]", argumentNameReq, i);
    snprintf(resBuffer, elCount(resBuffer), "%s[%d]", argumentNameRes, i);
    if(GetMethodArgumentDWord(messageHandle,   reqBuffer, arg, errorCode)==kFalse ||
       SetMethodArgumentDWord(messageResponseHandle, resBuffer, arg, errorCode)==kFalse)
    {
      SomeIpSetReturnCode(messageResponseHandle, errorCode);
      return;
    }
  }
}
