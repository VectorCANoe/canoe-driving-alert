// Functions required for field TestFieldUINT8Array

/// <DefaultSetter>
long setFieldToDefault_TestFieldUINT8Array()
{
  dword i, errorCode;
  char buffer[32];
  memcpy(gTestFieldUINT8Array, gTestFieldUINT8Array_default);
  if(SetMethodArgumentDWord(gFieldHandle_TestFieldUINT8Array, "", gTestFieldUINT8Array.length, errorCode)!=kTrue)
    return kFalse;
  
  for(i=0; i<gTestFieldUINT8Array.length; i++)
  {
    snprintf(buffer, elcount(buffer), "[%d]", i);
    if(SetMethodArgumentDWord(gFieldHandle_TestFieldUINT8Array, buffer, gTestFieldUINT8Array.values[i], errorCode)!=kTrue)
      return kFalse;
  }
  SomeIpCommitField(gFieldHandle_TestFieldUINT8Array);
  return SomeIpGetLastError()==0;
}

/// <FieldFunctions>
void OnService_ETS_FieldResponse_get_TestFieldUINT8Array(dword methodCallHandle, dword messageHandle, dword messageResponseHandle)
{
  dword i, errorCode;
  char buffer[32];
  if(SetMethodArgumentDWord(messageResponseHandle, "", gTestFieldUINT8Array.length, errorCode)!=kTrue)
  {
    SomeIpSetReturnCode(messageResponseHandle, errorCode);
    return;
  }

  for(i=0; i<gTestFieldUINT8Array.length; i++)
  {
    snprintf(buffer, elcount(buffer), "[%d]", i);
    if(SetMethodArgumentDWord(messageResponseHandle, buffer, gTestFieldUINT8Array.values[i], errorCode)!=kTrue)
    {
      SomeIpSetReturnCode(messageResponseHandle, errorCode);
      return;
    }
  }
}

/// <FieldFunctions>
void OnService_ETS_FieldResponse_set_TestFieldUINT8Array(dword methodCallHandle, dword messageHandle, dword messageResponseHandle)
{
  dword i, errorCode;
  char buffer[32];
  gTestFieldUINT8Array.length = SomeIpGetValueDWord(messageHandle, "");
  if(SetMethodArgumentDWord(messageResponseHandle, "", gTestFieldUINT8Array.length, errorCode)!=kTrue)
  {
    SomeIpSetReturnCode(messageResponseHandle, errorCode);
    return;
  }
  
  for(i=0; i<gTestFieldUINT8Array.length; i++)
  {
    snprintf(buffer, elcount(buffer), "[%d]", i);
    gTestFieldUINT8Array.values[i] = SomeIpGetValueDWord(messageHandle, buffer);
    if(SetMethodArgumentDWord(messageResponseHandle, buffer, gTestFieldUINT8Array.values[i], errorCode)!=kTrue)
    {
      SomeIpSetReturnCode(messageResponseHandle, errorCode);
      return;
    }
  }
}

//  ETS Service prepare event callbacks

/// <EventFunctions>
void OnService_ETS_PrepareEvent_TestEventUINT8(dword dwEventH, dword dwMsgH)
{
  dword errorCode;
  SetMethodArgumentDWord(dwMsgH, gEventArgumentName_TestEventUINT8_arg1, gTestEventUINT8, errorCode);
}

/// <EventFunctions>
void OnService_ETS_PrepareEvent_TestEventUINT8Array(dword eventHandle, dword messageHandle)
{
  dword i, errorCode;
  char buffer[32];
  if(SetMethodArgumentDWord(messageHandle, gEventArgumentName_TestEventUINT8Array_arg1, gTestEventUINT8Array.length, errorCode))
  {
    for(i=0; i<gTestEventUINT8Array.length; i++)
    {
      snprintf(buffer, elcount(buffer), "%s[%d]", gEventArgumentName_TestEventUINT8Array_arg1, i);
      if(SetMethodArgumentDWord(messageHandle, buffer, gTestEventUINT8Array.values[i], errorCode)!=kTrue)
        return;
    }
  }
}

