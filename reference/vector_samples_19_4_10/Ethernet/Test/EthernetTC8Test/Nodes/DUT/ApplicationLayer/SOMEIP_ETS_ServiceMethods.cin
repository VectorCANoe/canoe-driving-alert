void OnService_ETS_PrepareEvent_TestEventUINT8Reliable(dword dwEventH, dword dwMsgH)
{
  dword errorCode;
  SetMethodArgumentDWord(dwMsgH, gEventArgumentName_TestEventUINT8Reliable_arg1, gTestEventUINT8Reliable, errorCode);
}

/// <EventFunctions>
void OnService_ETS_PrepareEvent_TestEventUINT8Multicast(dword dwEventH, dword dwMsgH)
{
  dword errorCode;
  SetMethodArgumentDWord(dwMsgH, gEventArgumentName_TestEventUINT8Multicast_arg1, gTestEventUINT8Multicast, errorCode);
}

// ETS Service methods -------------------------

/// <ServiceMethods>
void OnService_ETS_MethodRequest_echoBitfields(DWORD methodHandle, DWORD messageHandle, DWORD responseMessageHandle)
{
  dword arg1, arg2, arg3, errorCode;
  if(GetMethodArgumentDWord(messageHandle, gMethodArgumentName_echoBitfields_REQ_bitfield8, arg1, errorCode)!=kTrue  ||
     GetMethodArgumentDWord(messageHandle, gMethodArgumentName_echoBitfields_REQ_bitfield16, arg2, errorCode)!=kTrue ||
     GetMethodArgumentDWord(messageHandle, gMethodArgumentName_echoBitfields_REQ_bitfield32, arg3, errorCode)!=kTrue ||
     SetMethodArgumentDWord(responseMessageHandle, gMethodArgumentName_echoBitfields_RES_bitfield8, reverseBits(arg1, 8), errorCode)!=kTrue   ||
     SetMethodArgumentDWord(responseMessageHandle, gMethodArgumentName_echoBitfields_RES_bitfield16, reverseBits(arg2, 16), errorCode)!=kTrue ||
     SetMethodArgumentDWord(responseMessageHandle, gMethodArgumentName_echoBitfields_RES_bitfield32, reverseBits(arg3, 32), errorCode)!=kTrue )
  {
    SomeIpSetReturnCode(responseMessageHandle, errorCode);
  }
}

/// <ServiceMethods>
void OnService_ETS_MethodRequest_checkByteOrder(DWORD methodHandle, DWORD messageHandle, DWORD responseMessageHandle)
{
  dword arg1, arg2, errorCode;
  
  if(GetMethodArgumentDWord(messageHandle, gMethodArgumentName_checkByteOrder_REQ_arg1, arg1, errorCode)==kFalse ||
     GetMethodArgumentDWord(messageHandle, gMethodArgumentName_checkByteOrder_REQ_arg2, arg2, errorCode)==kFalse ||
     SetMethodArgumentDWord(responseMessageHandle, gMethodArgumentName_checkByteOrder_RES_arg1, arg1+arg2, errorCode)==kFalse)
  {
    SomeIpSetReturnCode(responseMessageHandle, errorCode);
  }
}

/// <ServiceMethods>
void OnService_ETS_MethodRequest_echoCommonDatatypes(DWORD methodHandle, DWORD messageHandle, DWORD responseMessageHandle)
{
  dword errorCode;
  struct _echoCommonDatatypesArgs args;
  if(GetMethodArgumentDWord(messageHandle,      gMethodArgumentName_echoCommonDatatypes_REQ_ARG1_BOOLEAN, args.booleanArg, errorCode)!=kTrue ||
     GetMethodArgumentDWord(messageHandle,      gMethodArgumentName_echoCommonDatatypes_REQ_ARG2_UINT8,   args.unsignedArgs[0], errorCode)!=kTrue ||
     GetMethodArgumentDWord(messageHandle,      gMethodArgumentName_echoCommonDatatypes_REQ_ARG3_UINT16,  args.unsignedArgs[1], errorCode)!=kTrue ||
     GetMethodArgumentDWord(messageHandle,      gMethodArgumentName_echoCommonDatatypes_REQ_ARG4_UINT32,  args.unsignedArgs[2], errorCode)!=kTrue ||
     GetMethodArgumentLong(messageHandle,       gMethodArgumentName_echoCommonDatatypes_REQ_ARG5_INT8,    args.signedArgs[0], errorCode)!=kTrue ||
     GetMethodArgumentLong(messageHandle,       gMethodArgumentName_echoCommonDatatypes_REQ_ARG6_INT16,   args.signedArgs[1], errorCode)!=kTrue ||
     GetMethodArgumentLong(messageHandle,       gMethodArgumentName_echoCommonDatatypes_REQ_ARG7_INT32,   args.signedArgs[2], errorCode)!=kTrue ||
     GetMethodArgumentFloat(messageHandle,      gMethodArgumentName_echoCommonDatatypes_REQ_ARG8_FLOAT32, args.float32Arg, errorCode)!=kTrue  ||
     GetMethodArgumentFloat(messageHandle,      gMethodArgumentName_echoCommonDatatypes_REQ_ARG9_FLOAT64, args.float64Arg, errorCode)!=kTrue  ||
     SetMethodArgumentDWord(responseMessageHandle, gMethodArgumentName_echoCommonDatatypes_RES_ARG9_BOOLEAN, args.booleanArg, errorCode)!=kTrue ||
     SetMethodArgumentDWord(responseMessageHandle, gMethodArgumentName_echoCommonDatatypes_RES_ARG8_UINT8,   args.unsignedArgs[0], errorCode)!=kTrue ||
     SetMethodArgumentDWord(responseMessageHandle, gMethodArgumentName_echoCommonDatatypes_RES_ARG7_UINT16,  args.unsignedArgs[1], errorCode)!=kTrue ||
     SetMethodArgumentDWord(responseMessageHandle, gMethodArgumentName_echoCommonDatatypes_RES_ARG6_UINT32,  args.unsignedArgs[2], errorCode)!=kTrue ||
     SetMethodArgumentLong(responseMessageHandle,  gMethodArgumentName_echoCommonDatatypes_RES_ARG5_INT8,    args.signedArgs[0], errorCode)!=kTrue ||
     SetMethodArgumentLong(responseMessageHandle,  gMethodArgumentName_echoCommonDatatypes_RES_ARG4_INT16,   args.signedArgs[1], errorCode)!=kTrue ||
     SetMethodArgumentLong(responseMessageHandle,  gMethodArgumentName_echoCommonDatatypes_RES_ARG3_INT32,   args.signedArgs[2], errorCode)!=kTrue ||
     SetMethodArgumentFloat(responseMessageHandle, gMethodArgumentName_echoCommonDatatypes_RES_ARG2_FLOAT32, args.float32Arg, errorCode)!=kTrue ||
     SetMethodArgumentFloat(responseMessageHandle, gMethodArgumentName_echoCommonDatatypes_RES_ARG1_FLOAT64, args.float64Arg, errorCode)!=kTrue)
  {
    SomeIpSetReturnCode(responseMessageHandle, errorCode);
  }    
}

/// <ServiceMethods>
void OnService_ETS_MethodRequest_echoENUM(DWORD methodHandle, DWORD messageHandle, DWORD responseMessageHandle)
{
  dword arg, errorCode;
  if(GetMethodArgumentDWord(messageHandle,   gMethodArgumentName_echoENUM_REQ_enumValue, arg, errorCode)!=kTrue ||
