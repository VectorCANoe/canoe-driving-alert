{
  dword errorCode;
  char buffer[256];
  buffer[0] = '\0';

  if(GetMethodArgumentStringUTF16(messageHandle, gMethodArgumentName_echoUTF16FIXED_REQ_UTF16String, elcount(buffer), buffer, errorCode)!=kTrue)
