variables
{
  // These IDs are predefined in the TC8 specification
  const dword EVENT_ID_TestEventUINT8          = 0x8001;
  const dword EVENT_ID_TestEventUINT8Array     = 0x8002;
  const dword EVENT_ID_TestEventUINT8Reliable  = 0x8003;
  const dword EVENT_ID_TestEventUINT8Multicast = 0x800B;

  const dword EVENTGROUP_ID_EvgAll            = 0x0002;
  const dword EVENTGROUP_ID_EvgUnreliableOnly = 0x0005;
  const dword EVENTGROUP_ID_EvgMulticast      = 0x0006;

  const dword FIELD_ID_InterfaceVersion       = 0x8005;
  const dword FIELD_ID_TestFieldUINT8         = 0x8006;
  const dword FIELD_ID_TestFieldUINT8Array    = 0x8007;
  const dword FIELD_ID_TestFieldUINT8Reliable = 0x8008;
 
  dword gCsiHandleUDP=0, gCsiHandleTCP=0, gClientServiceAepHandleUDP=0, gClientServiceAepHandleTCP=0;
    
  dword gCegHandle1UDP=0, gCegHandle1TCP=0;
  dword gCegHandle2UDP=0, gCegHandle2TCP=0;
  dword gCegHandle3UDP=0, gCegHandle3TCP=0;

  dword gCreatedConsumedServiceInstance[long];
  
  enum SomeIpTransportProtokol
  {
    TP_TCP = 6,
    TP_UDP = 17
  };
  
  enum SomeIpReturnCode
  {
    SOMEIP_RC_NOT_OK = 1,
    SOMEIP_RC_MALFORMED_MESSAGE = 9
  };
  
  struct _InterfaceVersion
  {
    byte  majorVersion;
    dword minorVersion;
  };

  struct _TestFieldUINT8Array
  {
    byte length;
    byte values[10];
  };

  struct _TestEventUINT8Array
  {
    byte length;
    byte values[10];
  };

  struct _InterfaceVersion gInterfaceVersion_default = { 12 , 2 };
  struct _InterfaceVersion gInterfaceVersion;

  const byte gTestEventUINT8_default = 25;
  byte gTestEventUINT8 = gTestEventUINT8_default;
  
  const byte gTestEventUINT8Multicast_default = 30;
  byte gTestEventUINT8Multicast = gTestEventUINT8Multicast_default;
  
  const byte gTestEventUINT8Reliable_default = 35;
  byte gTestEventUINT8Reliable = gTestEventUINT8Reliable_default;

  struct _TestEventUINT8Array gTestEventUINT8Array_default = { 10 , { 2, 3, 4, 5, 0, 7, 0, 9, 0, 11} };
  struct _TestEventUINT8Array gTestEventUINT8Array;

  byte gLastEventUINT8 = 0, gLastEventUINT8Reliable = 0, gLastEventUINT8Multicast = 0;

  byte gTestFieldUINT8_default = 4;
  byte gTestFieldUINT8;
  
  byte gTestFieldUINT8Reliable_default = 5;
  byte gTestFieldUINT8Reliable;

  struct _TestFieldUINT8Array gTestFieldUINT8Array_default = { 3 , { 1, 2, 3, 0, 0, 0, 0, 0, 0, 0} };
  struct _TestFieldUINT8Array gTestFieldUINT8Array;
 
  struct _echoCommonDatatypesArgs
  {
    dword  booleanArg;
    dword  unsignedArgs[3];
    long   signedArgs[3];
    float  float32Arg;
    float  float64Arg;
  };
  
  msTimer gClientServiceActivateTimer, gClientServiceDeactivateTimer, gSubscribeEventGroupTimer, gUnsubscribeEventGroupTimer,
    gSuspendInterfaceDelayTimer, gSuspendInterfaceDurationTimer;
    
  IP_Endpoint gClientServiceEndpoint;

  struct _debounceData
  {
    dword timeMs;
    dword counter;
  };
  
  msTimer gTriggerTestEventUINT8DelayTimer, gTriggerTestEventUINT8DebounceTimer;
  struct _debounceData gTriggerTestEventUINT8Debounce;
  
  msTimer gTriggerTestEventUINT8ArrayDelayTimer, gTriggerTestEventUINT8ArrayDebounceTimer;
  struct _debounceData gTriggerTestEventUINT8ArrayDebounce;

  msTimer gTriggerTestEventUINT8ReliableDelayTimer, gTriggerTestEventUINT8ReliableDebounceTimer;
  struct _debounceData gTriggerTestEventUINT8ReliableDebounce;

  msTimer gTriggerTestEventUINT8MulticastDelayTimer, gTriggerTestEventUINT8MulticastDebounceTimer;
  struct _debounceData gTriggerTestEventUINT8MulticastDebounce;
 
  enum Bool gIsClientServiceActive = kFalse;
  
  dword gSuspendInterfaceDurationSeconds;
}

void StopAllEventTimer()
{
  gTriggerTestEventUINT8DelayTimer.cancel();
  gTriggerTestEventUINT8DebounceTimer.cancel();
  gTriggerTestEventUINT8ArrayDelayTimer.cancel();
  gTriggerTestEventUINT8ArrayDebounceTimer.cancel();
  gTriggerTestEventUINT8ReliableDelayTimer.cancel();
  gTriggerTestEventUINT8ReliableDebounceTimer.cancel();
  gTriggerTestEventUINT8MulticastDelayTimer.cancel();
  gTriggerTestEventUINT8MulticastDebounceTimer.cancel();
}

/// <Helper functions>
void HandleTriggerTestEventDelayTimer(dword eventHandle, struct _debounceData debounce, msTimer debounceTimer)
{
  if(SomeIpTriggerEvent(eventHandle)!=0)
    ReportSomeIpError("Trigger event failed");
  
  if(debounce.counter>0)
    setTimer(debounceTimer, debounce.timeMs);
}

/// <Helper functions>
void HandleTriggerTestEventDebounceTimer(dword eventHandle, struct _debounceData debounce, msTimer debounceTimer)
{
  if(SomeIpTriggerEvent(eventHandle)!=0)
    ReportSomeIpError("Trigger event failed");
  
  --debounce.counter;
  if(debounce.counter>0)
    setTimer(debounceTimer, debounce.timeMs);
}

on timer gTriggerTestEventUINT8DelayTimer
{
  HandleTriggerTestEventDelayTimer(gEventHandle_TestEventUINT8, gTriggerTestEventUINT8Debounce, gTriggerTestEventUINT8DebounceTimer);
}

on timer gTriggerTestEventUINT8DebounceTimer
{
  HandleTriggerTestEventDebounceTimer(gEventHandle_TestEventUINT8, gTriggerTestEventUINT8Debounce, gTriggerTestEventUINT8DebounceTimer);
}

on timer gTriggerTestEventUINT8ArrayDelayTimer
{
  HandleTriggerTestEventDelayTimer(gEventHandle_TestEventUINT8Array, gTriggerTestEventUINT8ArrayDebounce, gTriggerTestEventUINT8ArrayDebounceTimer);
}

on timer gTriggerTestEventUINT8ArrayDebounceTimer
{
  HandleTriggerTestEventDebounceTimer(gEventHandle_TestEventUINT8Array, gTriggerTestEventUINT8ArrayDebounce, gTriggerTestEventUINT8ArrayDebounceTimer);
}

on timer gTriggerTestEventUINT8ReliableDelayTimer
{
  HandleTriggerTestEventDelayTimer(gEventHandle_TestEventUINT8Reliable, gTriggerTestEventUINT8ReliableDebounce, gTriggerTestEventUINT8ReliableDebounceTimer);
}

on timer gTriggerTestEventUINT8ReliableDebounceTimer
{
  HandleTriggerTestEventDebounceTimer(gEventHandle_TestEventUINT8Reliable, gTriggerTestEventUINT8ReliableDebounce, gTriggerTestEventUINT8ReliableDebounceTimer);
}

on timer gTriggerTestEventUINT8MulticastDelayTimer
{
  HandleTriggerTestEventDelayTimer(gEventHandle_TestEventUINT8Multicast, gTriggerTestEventUINT8MulticastDebounce, gTriggerTestEventUINT8MulticastDebounceTimer);
}

on timer gTriggerTestEventUINT8MulticastDebounceTimer
{
  HandleTriggerTestEventDebounceTimer(gEventHandle_TestEventUINT8Multicast, gTriggerTestEventUINT8MulticastDebounce, gTriggerTestEventUINT8MulticastDebounceTimer);
}

/// <ServiceMethods>
void OnService_ETS_MethodRequest_triggerEventUINT8(DWORD methodHandle, DWORD messageHandle)
{
  dword delaySeconds, durationSeconds, debounceTimeSeconds, errorCode;
  cancelTimer(gTriggerTestEventUINT8DelayTimer);
  cancelTimer(gTriggerTestEventUINT8DebounceTimer);
  if(GetMethodArgumentDWord(messageHandle, gMethodArgumentName_triggerEventUINT8_REQ_delay, delaySeconds, errorCode)==kTrue &&
     GetMethodArgumentDWord(messageHandle, gMethodArgumentName_triggerEventUINT8_REQ_duration, durationSeconds, errorCode)==kTrue &&
     GetMethodArgumentDWord(messageHandle, gMethodArgumentName_triggerEventUINT8_REQ_debounceTime, debounceTimeSeconds, errorCode)==kTrue)
  {
    gTriggerTestEventUINT8Debounce.counter = debounceTimeSeconds>0 ? durationSeconds/debounceTimeSeconds : 0;
    gTriggerTestEventUINT8Debounce.timeMs = debounceTimeSeconds*1000;
    setTimer(gTriggerTestEventUINT8DelayTimer, delaySeconds*1000);
  }
}

