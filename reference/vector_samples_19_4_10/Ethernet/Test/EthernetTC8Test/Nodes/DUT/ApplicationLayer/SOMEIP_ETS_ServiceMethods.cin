/// <ServiceMethods>
void OnService_ETS_MethodRequest_echoUINT8Array2Dim(DWORD methodHandle, DWORD messageHandle, DWORD responseMessageHandle)
{
  dword row, col, countRows, countCols, errorCode;
  char reqBuffer[64], resBuffer[64];
  dword value;

  if(GetMethodArgumentDWord(messageHandle, gMethodArgumentName_echoUINT8Array2Dim_REQ_UINT8Array, countRows, errorCode)!=kTrue)
  {
    SomeIpSetReturnCode(responseMessageHandle, errorCode);
    return;
  }
  
  for(row=0; row<countRows; ++row)
  {
    snprintf(reqBuffer, elCount(reqBuffer), "%s[%d]", gMethodArgumentName_echoUINT8Array2Dim_REQ_UINT8Array, row);
    if(GetMethodArgumentDWord(messageHandle, reqBuffer, countCols, errorCode)!=kTrue)
    {
      SomeIpSetReturnCode(responseMessageHandle, errorCode);
      return;
    }
    
    for(col=0; col<countCols; ++col)
    {
      snprintf(reqBuffer, elCount(reqBuffer), "%s[%d][%d]", gMethodArgumentName_echoUINT8Array2Dim_REQ_UINT8Array, row, col);
      snprintf(resBuffer, elCount(resBuffer), "%s[%d][%d]", gMethodArgumentName_echoUINT8Array2Dim_RES_UINT8Array, row, col);
      if(GetMethodArgumentDWord(messageHandle, reqBuffer, value, errorCode)!=kTrue ||
         SetMethodArgumentDWord(responseMessageHandle, resBuffer, value, errorCode)!=kTrue)
      {
        SomeIpSetReturnCode(responseMessageHandle, errorCode);
        return;
      }
    }
  }
}

/// <ServiceMethods>
void OnService_ETS_MethodRequest_echoUNION(DWORD methodHandle, DWORD messageHandle, DWORD responseMessageHandle)
{
  dword value, validIndex, errorCode;
  long sValue;
  float fValue;
  enum Bool success;
  success = kFalse;
  if(GetMethodArgumentDWord(messageHandle, gMethodArgumentName_echoUNION_REQ_unionElement, validIndex, errorCode))
  {
    switch(validIndex)
    {
      case 1:
        success = (enum Bool)
                  (GetMethodArgumentDWord(messageHandle, gMethodArgumentName_echoUNION_REQ_unionMember1, value, errorCode) &&
                   SetMethodArgumentDWord(responseMessageHandle, gMethodArgumentName_echoUNION_RES_unionMember1, value, errorCode));
        break;
      case 2:
        success = (enum Bool)
                  (GetMethodArgumentDWord(messageHandle, gMethodArgumentName_echoUNION_REQ_unionMember2, value, errorCode) &&
                   SetMethodArgumentDWord(responseMessageHandle, gMethodArgumentName_echoUNION_RES_unionMember2, value, errorCode));
        break;
      case 3:
        success = (enum Bool)
                  (GetMethodArgumentDWord(messageHandle, gMethodArgumentName_echoUNION_REQ_unionMember3, value, errorCode) &&
                   SetMethodArgumentDWord(responseMessageHandle, gMethodArgumentName_echoUNION_RES_unionMember3, value, errorCode));
        break;
      case 4:
        success = (enum Bool)
                  (GetMethodArgumentDWord(messageHandle, gMethodArgumentName_echoUNION_REQ_unionMember4, value, errorCode) &&
                   SetMethodArgumentDWord(responseMessageHandle, gMethodArgumentName_echoUNION_RES_unionMember4, value, errorCode));
        break;
      case 5:
        success = (enum Bool)
                  (GetMethodArgumentLong(messageHandle, gMethodArgumentName_echoUNION_REQ_unionMember5, sValue, errorCode) &&
                   SetMethodArgumentLong(responseMessageHandle, gMethodArgumentName_echoUNION_RES_unionMember5, sValue, errorCode));
        break;
      case 6:
        success = (enum Bool)
                  (GetMethodArgumentLong(messageHandle, gMethodArgumentName_echoUNION_REQ_unionMember6, sValue, errorCode) &&
                   SetMethodArgumentLong(responseMessageHandle, gMethodArgumentName_echoUNION_RES_unionMember6, sValue, errorCode));
        break;
      case 7:
        success = (enum Bool)
                  (GetMethodArgumentLong(messageHandle, gMethodArgumentName_echoUNION_REQ_unionMember7, sValue, errorCode) &&
                   SetMethodArgumentLong(responseMessageHandle, gMethodArgumentName_echoUNION_RES_unionMember7, sValue, errorCode));
        break;
      case 8:
        success = (enum Bool)
                  (GetMethodArgumentFloat(messageHandle, gMethodArgumentName_echoUNION_REQ_unionMember8, fValue, errorCode) &&
                   SetMethodArgumentFloat(responseMessageHandle, gMethodArgumentName_echoUNION_RES_unionMember8, fValue, errorCode));
        break;
    }
    if(success==kFalse)
      SomeIpSetReturnCode(responseMessageHandle, errorCode);
  }
  else
    SomeIpSetReturnCode(responseMessageHandle, errorCode);
}

