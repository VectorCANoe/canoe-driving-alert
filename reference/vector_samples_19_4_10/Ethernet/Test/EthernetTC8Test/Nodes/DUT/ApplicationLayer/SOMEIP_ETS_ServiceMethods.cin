/// <ServiceMethods>
void OnService_ETS_MethodRequest_clientServiceActivate(DWORD methodHandle, DWORD messageHandle)
{
  dword delaySeconds, errorCode;
  if(gIsClientServiceActive==kFalse &&
     GetMethodArgumentDWord(messageHandle, gMethodArgumentName_clientServiceActivate_REQ_arg1, delaySeconds, errorCode))
  {
    char buffer[64];
    sysGetVariableString(sysvar::Internal::DIface0Ip, buffer, elcount(buffer)); 
    if(gClientServiceEndpoint.ParseEndpointFromString(buffer)!=0)
      return;

    setTimer(gClientServiceActivateTimer, delaySeconds*1000);
  }
}

/// <ServiceMethods>
void OnService_ETS_MethodRequest_clientServiceDeactivate(DWORD methodHandle, DWORD messageHandle)
{
  dword delaySeconds, errorCode;
  if(isTimerActive(gClientServiceActivateTimer))
    cancelTimer(gClientServiceActivateTimer);
  if(gIsClientServiceActive==kTrue && 
    GetMethodArgumentDWord(messageHandle, gMethodArgumentName_clientServiceActivate_REQ_arg1, delaySeconds, errorCode))
  {
    setTimer(gClientServiceDeactivateTimer, delaySeconds*1000);
  }  
}

/// <ServiceMethods>
void OnService_ETS_MethodRequest_clientServiceSubscribeEventgroup(DWORD methodHandle, DWORD messageHandle)
{
  dword delaySeconds, durationSeconds, errorCode;
  long subscribeTimeMs;
  
  if(GetMethodArgumentDWord(messageHandle, gMethodArgumentName_clientServiceSubscribeEventgroup_REQ_delay, delaySeconds, errorCode)==kTrue &&
     GetMethodArgumentDWord(messageHandle, gMethodArgumentName_clientServiceSubscribeEventgroup_REQ_duration, durationSeconds, errorCode)==kTrue)
  {
    if(durationSeconds>0)
    {
      subscribeTimeMs = delaySeconds*1000;
      setTimer(gSubscribeEventGroupTimer, subscribeTimeMs);
      setTimer(gUnsubscribeEventGroupTimer, subscribeTimeMs + durationSeconds*1000);
    }
    else
    {
      write("ERROR: subscribe event group duration is zero");
    }
  }
  else
  {
    ReportSomeIpError("OnService_ETS_MethodRequest_clientServiceSubscribeEventgroup argument error");
  }
}

/// <ServiceMethods>
void OnService_ETS_MethodRequest_resetInterface(DWORD methodHandle, DWORD messageHandle)
{
  setDefaultValues();
}

/// <ServiceMethods>
void OnService_ETS_MethodRequest_suspendInterface(DWORD methodHandle, DWORD messageHandle)
{
  dword delaySeconds, errorCode;
  if(GetMethodArgumentDWord(messageHandle, gMethodArgumentName_suspendInterface_REQ_delay, delaySeconds, errorCode)==kTrue &&
     GetMethodArgumentDWord(messageHandle, gMethodArgumentName_suspendInterface_REQ_duration, gSuspendInterfaceDurationSeconds, errorCode)==kTrue)
  {
    setTimer(gSuspendInterfaceDelayTimer, delaySeconds*1000);
  }
  else
  {
    ReportSomeIpError("OnService_ETS_MethodRequest_clientServiceSubscribeEventgroup argument error");
  }
}

void CloseLocalApplicationEndPointsForETSClientService()
{
  if(gClientServiceAepHandleUDP)
    SomeIpCloseLocalApplicationEndpoint(gClientServiceAepHandleUDP);
  if(gClientServiceAepHandleTCP)
    SomeIpCloseLocalApplicationEndpoint(gClientServiceAepHandleTCP);
  
  gClientServiceAepHandleUDP = 0;
  gClientServiceAepHandleTCP = 0;
}

/// <Helper functions>
void OpenLocalApplicationEndPointsForETSClientService(IP_Endpoint endpoint)
{
  if(gClientServiceAepHandleUDP==0)
  {
    endpoint.SetToUdp();
    gClientServiceAepHandleUDP = ETSOpenLocalApplicationEndpoint(endpoint);
    if(gClientServiceAepHandleUDP==0)
    {
      ReportSomeIpError("Creation of UDP local application endpoint failed");
      return;
    }
  }
 
  if(gClientServiceAepHandleTCP==0)
  {
    endpoint.SetToTcp();
    gClientServiceAepHandleTCP = ETSOpenLocalApplicationEndpoint(endpoint);
    if(gClientServiceAepHandleTCP==0)
    {
      ReportSomeIpError("Creation of TCP local application endpoint failed");
      return;
    }
  }
}

/// <Helper functions>
enum Bool HandleSomeIpCreateEventConsumer(dword csiHandle, dword eventId, char eventCallbackPrefix[], CHAR onEventCallback[], dword & eventHandle)
{
  char callbackName[128];
  strncpy(callbackName, eventCallbackPrefix, elcount(callbackName));
  strncpy_off(callbackName, strlen(callbackName), onEventCallback, elcount(callbackName));
  
  eventHandle = SomeIpCreateEventConsumer(csiHandle, eventId, callbackName);
  if(eventHandle==0)
  {
    ReportSomeIpError("Creation of event consumer failed");
    write("Creation of event consumer failed. Callback name: %s", callbackName);
    return kFalse;
  }
  return kTrue;
}

/// <Helper functions>
enum Bool ActivateClientService(char eventCallbackPrefix[], IP_Endpoint endpoint)
{
  dword eventHandle;

  if(gCsiHandleUDP==0)
  {
    if(gClientServiceAepHandleUDP==0)
      OpenLocalApplicationEndPointsForETSClientService(endpoint);
    gCsiHandleUDP = ETS_SomeIpCreateConsumedServiceInstance(gClientServiceAepHandleUDP, @sysvar::TC8_ETS_Config::ETS_ServiceId, GetInstanceIdOfConsumedETS());
    if(gCsiHandleUDP==0)
    {
      write("#### ActivateClientService: Creating UDP CSI failed");
      return kFalse;
    }
  }

  if(gCsiHandleTCP==0)
  {
    if(gClientServiceAepHandleTCP==0)
      OpenLocalApplicationEndPointsForETSClientService(endpoint);
    gCsiHandleTCP = ETS_SomeIpCreateConsumedServiceInstance(gClientServiceAepHandleTCP, @sysvar::TC8_ETS_Config::ETS_ServiceId, GetInstanceIdOfConsumedETS());
    if(gCsiHandleTCP==0)
    {
      write("#### ActivateClientService: Creating TCP CSI failed");
      return kFalse;
    }
  }
 

  if(gCsiHandleTCP &&
     HandleSomeIpCreateEventConsumer(gCsiHandleTCP, EVENT_ID_TestEventUINT8Reliable, eventCallbackPrefix, "EventReceived_TestEventUINT8Reliable", eventHandle)==kFalse ||
     HandleSomeIpCreateEventConsumer(gCsiHandleTCP, EVENT_ID_TestEventUINT8, eventCallbackPrefix, "EventReceived_TestEventUINT8", eventHandle)==kFalse ||
     HandleSomeIpCreateEventConsumer(gCsiHandleTCP, EVENT_ID_TestEventUINT8Array, eventCallbackPrefix, "EventReceived_TestEventUINT8Array", eventHandle)==kFalse)
  {
      write("#### ActivateClientService: creating of tcp event consumer failed");
      return kFalse;
  }
  
  
  if(HandleSomeIpCreateEventConsumer(gCsiHandleUDP, EVENT_ID_TestEventUINT8, eventCallbackPrefix, "EventReceived_TestEventUINT8", eventHandle)==kFalse ||
     HandleSomeIpCreateEventConsumer(gCsiHandleUDP, EVENT_ID_TestEventUINT8Array, eventCallbackPrefix, "EventReceived_TestEventUINT8Array", eventHandle)==kFalse ||
     HandleSomeIpCreateEventConsumer(gCsiHandleUDP, EVENT_ID_TestEventUINT8Multicast, eventCallbackPrefix, "EventReceived_TestEventUINT8Multicast", eventHandle)==kFalse)
  {
      write("#### ActivateClientService: creating of udp event consumer failed");
      return kFalse;
  }
  
  
  gIsClientServiceActive = kTrue;
  return kTrue;
}

/// <Helper functions>
void DeactivateClientService()
{
  cancelTimer(gClientServiceActivateTimer);
  cancelTimer(gClientServiceDeactivateTimer);
  cancelTimer(gSubscribeEventGroupTimer);
  cancelTimer(gUnsubscribeEventGroupTimer);

  RemoveEventGroupConsumers(gCegHandle1UDP, gCegHandle1TCP);
  RemoveEventGroupConsumers(gCegHandle2UDP, gCegHandle2TCP);
  RemoveEventGroupConsumers(gCegHandle3UDP, gCegHandle3TCP);

  releaseAllCreatedCSIs();
 
  gIsClientServiceActive = kFalse;
}

on timer gClientServiceActivateTimer
{
  ActivateClientService("ETSClient_", gClientServiceEndpoint);
}

on timer gClientServiceDeactivateTimer
{
  DeactivateClientService();
  CloseLocalApplicationEndPointsForETSClientService();
}

on timer gSubscribeEventGroupTimer
{
  AddEventGroupConsumers(EVENTGROUP_ID_EvgAll, gCegHandle1UDP, gCegHandle1TCP);
  
  SubscribeEventGroup(EVENTGROUP_ID_EvgAll, gCegHandle1UDP, gCegHandle1TCP);
}

on timer gSuspendInterfaceDelayTimer
{
  SomeIpSDSetServiceStatus(gPsiUdp, 0);
  SomeIpSDSetServiceStatus(gPsiTcp, 0);
  setTimer(gSuspendInterfaceDurationTimer, gSuspendInterfaceDurationSeconds*1000);
}

on timer gSuspendInterfaceDurationTimer
{
  SomeIpSDSetServiceStatus(gPsiUdp, 1);
  SomeIpSDSetServiceStatus(gPsiTcp, 1);  
}

/// <Helper functions>
enum Bool SubscribeEventGroup(dword eventGroupId, dword & cegHandleUDP, dword & cegHandleTCP)
{
  long returnCode;
  
  if(gCsiHandleUDP==0 || gCsiHandleTCP==0)
  {
    write("ERROR: no consumer service instantiated");
    return kFalse;
  }

  returnCode = 0;
  if(eventGroupId==EVENTGROUP_ID_EvgAll)
    returnCode = SomeIpSDSubscribeEventgroup(cegHandleTCP, eventGroupId);

  if(returnCode==0)
    returnCode = SomeIpSDSubscribeEventgroup(cegHandleUDP, eventGroupId);

  return returnCode==0 ? kTrue : kFalse;
}

on timer gUnsubscribeEventGroupTimer
{
  RemoveEventGroupConsumers(gCegHandle1UDP, gCegHandle1TCP);
  RemoveEventGroupConsumers(gCegHandle2UDP, gCegHandle2TCP);
  RemoveEventGroupConsumers(gCegHandle3UDP, gCegHandle3TCP);
}

void AddEventGroupConsumers(int eventGroupId, dword & cegHandleUDP, dword & cegHandleTCP)
{
  if(eventGroupId==EVENTGROUP_ID_EvgAll)
  {
    cegHandleTCP = SomeIpAddConsumedEventGroup(gCsiHandleTCP, eventGroupId);
  }
  
  cegHandleUDP = SomeIpAddConsumedEventGroup(gCsiHandleUDP, eventGroupId);
}

void RemoveEventGroupConsumers(dword & cegHandleUDP, dword & cegHandleTCP)
{
  if(cegHandleTCP)
  {
    if(SomeIpRemoveConsumedEventGroup(cegHandleTCP)!=0)
    {
      ReportSomeIpError("Unsubscribe of TCP event group failed");
    }
    cegHandleTCP = 0;
  }

  if(cegHandleUDP && cegHandleUDP!=cegHandleTCP)
  {
    if(SomeIpRemoveConsumedEventGroup(cegHandleUDP)!=0)
    {
      ReportSomeIpError("Unsubscribe of UDP event group failed");
    }
    cegHandleUDP = 0;
  }
  cegHandleUDP = 0;
  cegHandleTCP = 0;
}

