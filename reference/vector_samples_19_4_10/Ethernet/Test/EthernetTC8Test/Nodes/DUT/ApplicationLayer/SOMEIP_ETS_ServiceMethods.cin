// Functions required for field InterfaceVersion

/// <DefaultSetter>
enum Bool setFieldToDefault_InterfaceVersion()
{
  dword errorCode;
  memcpy(gInterfaceVersion, gInterfaceVersion_default);
  return (enum Bool)
    (SetMethodArgumentLong(gFieldHandle_InterfaceVersion, gFieldname_InterfaceVersion_majorVersion, gInterfaceVersion.majorVersion, errorCode) &&
     SetMethodArgumentLong(gFieldHandle_InterfaceVersion, gFieldname_InterfaceVersion_minorVersion, gInterfaceVersion.minorVersion, errorCode) &&
     SomeIpCommitField(gFieldHandle_InterfaceVersion)==0);
}

/// <FieldFunctions>
void OnService_ETS_FieldResponse_get_InterfaceVersion(dword methodCallHandle, dword messageHandle, dword messageResponseHandle)
{
  dword errorCode;
  if(SetMethodArgumentInt64(messageResponseHandle, gFieldname_InterfaceVersion_majorVersion, gInterfaceVersion.majorVersion, errorCode)!=kTrue ||
     SetMethodArgumentInt64(messageResponseHandle, gFieldname_InterfaceVersion_minorVersion, gInterfaceVersion.minorVersion, errorCode)!=kTrue)
    SomeIpSetReturnCode(messageResponseHandle, errorCode);
}

/// <FieldFunctions>
void OnService_ETS_FieldResponse_set_InterfaceVersion(dword methodCallHandle, dword messageHandle, dword messageResponseHandle)
{
  dword errorCode;
  gInterfaceVersion.majorVersion = SomeIpGetValueDWord(messageHandle, gFieldname_InterfaceVersion_majorVersion);
  gInterfaceVersion.minorVersion = SomeIpGetValueDWord(messageHandle, gFieldname_InterfaceVersion_minorVersion);
  if(SetMethodArgumentInt64(messageResponseHandle, gFieldname_InterfaceVersion_majorVersion, gInterfaceVersion.majorVersion, errorCode)!=kTrue ||
     SetMethodArgumentInt64(messageResponseHandle, gFieldname_InterfaceVersion_minorVersion, gInterfaceVersion.minorVersion, errorCode)!=kTrue)
    SomeIpSetReturnCode(messageResponseHandle, errorCode);
}

