dword ETS_SomeIpCreateConsumedServiceInstance(dword aepHandle, dword serviceId, dword instanceId)
{
  dword csiHandle;
  csiHandle = SomeIpCreateConsumedServiceInstance(aepHandle, serviceId, instanceId);
  if(SomeIpGetLastError()!=0)
  {
    ReportSomeIpError("Creation of consumed service instance failed");
    return 0;
  }

  /****************** Unsubscribe these event groups because they might get "auto-subscribed" **********/
  if(gCreatedConsumedServiceInstance[csiHandle] != 1)
  {
    SomeIpSDDesubscribeEventGroup(SomeIpAddConsumedEventGroup(csiHandle, EVENTGROUP_ID_EvgAll));
    SomeIpSDDesubscribeEventGroup(SomeIpAddConsumedEventGroup(csiHandle, EVENTGROUP_ID_EvgUnreliableOnly));
    SomeIpSDDesubscribeEventGroup(SomeIpAddConsumedEventGroup(csiHandle, EVENTGROUP_ID_EvgMulticast));
  }
  /*****************************************************************************************************/

  gCreatedConsumedServiceInstance[csiHandle] = 1;

  return csiHandle;
}

void releaseAllCreatedCSIs()
{
  for(long csiKey: gCreatedConsumedServiceInstance)
  {
    SomeIpReleaseConsumedServiceInstance(csiKey);
  }
  gCreatedConsumedServiceInstance.clear();
  gCsiHandleTCP = gCsiHandleUDP = 0;
}