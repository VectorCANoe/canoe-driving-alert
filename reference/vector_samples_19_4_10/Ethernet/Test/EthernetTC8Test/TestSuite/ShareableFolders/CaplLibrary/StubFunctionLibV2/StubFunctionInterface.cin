/// <TcpStubFunctions>
/**
 * Data that will be received after the call of this SP will be forwarded to the test system.
 * @param expectedResult expected TCP error result.
 */
export testfunction Stub_TcpReceiveAndForward(enum TestabilityMessageResultIds expectedResult, word expectedDropCnt)
{
  char dropCnt[10];
  
  snprintf(dropCnt, elcount(dropCnt), "%u", expectedDropCnt);
  
  CallStubImplementation("Stub_TcpReceiveAndForward", Stub_TcpReceiveAndForwardImpl(expectedResult, dropCnt));
}

/// <TcpStubFunctions>
/**
 * This is not just a wrapper.
 * Checks the data that returns after Stub_TcpReceiveAndForward according to various parameters.
 * @param timeoutMilliseconds Listen timeout in milliseconds.
 * @param fullLen Compares with the full length of available data in bytes.
 * @param payload Compares with the payload that was received.
 */
export testfunction Stub_TcpReceiveAndForwardEvent(long timeoutMilliseconds, word fullLen, char payload[])
{
  char len[255];
  snprintf(len, elcount(len), "%d", fullLen);
  CallStubImplementation("Stub_TcpReceiveAndForwardEvent", Stub_TcpReceiveAndForwardEventImpl(timeoutMilliseconds, len, payload, kTrue, Success));
}

