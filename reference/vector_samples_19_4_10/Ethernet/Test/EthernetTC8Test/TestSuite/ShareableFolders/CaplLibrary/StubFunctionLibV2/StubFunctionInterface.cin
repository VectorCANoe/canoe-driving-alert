includes
{
  #include "StubFunctionImplementation.cin"
}

variables
{
  long            gSocketId[10]; // socket id. -1 if socket is not open
  enum TcpStateId gSocketState[10];
  word            gSocketPort[10]; //port of dut
  dword           gSequenceNumber[10];
  dword           gAcknowledgement[10];
  word            gConnectedPort[10]; //port of tester
  char            gConnectedIP[10][64];
}

enum StubFunctionResult CallStubImplementation(char functionName[], enum StubFunctionResult result)
{
  switch(result)
  {
    case kOk:             testStepPass(functionName); break;
    case kNotImplemented:
    {
      testStepInconclusive(functionName, "Function %s is not implemented", functionName );
      testCaseFail(); // workaround, until break on inconclusive is supported
    }
    break;
    default:              testStepFail(functionName); break;
  }  
  return result;
}

