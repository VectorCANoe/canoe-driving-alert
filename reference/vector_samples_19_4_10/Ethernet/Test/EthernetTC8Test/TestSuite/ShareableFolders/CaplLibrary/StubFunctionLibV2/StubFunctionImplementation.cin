float Stub_DhcpCalculateT1InMillisecondsUsedByDutImpl(dword leaseTimeSeconds)
{
  float renewFuzzTimeMilliseconds = 750;
  return 0.5 * leaseTimeSeconds * 1000.0 - renewFuzzTimeMilliseconds;
}

float Stub_DhcpCalculateT2InMillisecondsUsedByDutImpl(dword leaseTimeSeconds)
{
  float renewFuzzTimeMilliseconds = 0;
  return 0.875 * leaseTimeSeconds * 1000.0 - renewFuzzTimeMilliseconds;
}