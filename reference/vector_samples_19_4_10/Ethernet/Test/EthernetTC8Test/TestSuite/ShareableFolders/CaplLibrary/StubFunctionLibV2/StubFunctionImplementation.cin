/// <UdpStubFunctions>
enum StubFunctionResult Stub_UdpReceiveAndForwardEventImpl(long timeoutMilliseconds, char fullLen[], char srcPort[], char srcIpAddress[], char payload[], enum Bool expectedMessage)
{
  long result;
  enum TestabilityMessageResultIds stubResult;
  int i;
  
  result = TmpWaitForServicePrimitiveEvent(kInternalEventReceiveAndForward, timeoutMilliseconds);
  
  if(result != 1) // event did not occur ...
  {
    if(expectedMessage) // ... but was expected -> test step failed
    {
      testStepFail("Stub_UdpReceiveAndForward", "No UDP Receive and Forward Event was received");
      return kError;
    }
    else // ... and was not expected -> test step passed
    {
      testStepPass("Stub_UdpReceiveAndForward", "No UDP Receive and Forward Event was received (as expected)");
      return kOk;
    }
  }
  else if(expectedMessage == kFalse) // event did occur but was not expected -> test step failed
  {
    testStepFail("Stub_UdpReceiveAndForward", "UDP Receive and Forward Event was received unexpectedly");
    return kError;
  }
  
  stubResult = (enum TestabilityMessageResultIds)gInternalServicePrimitiveEventParameters.ReceiveAndForwardUdpEvent.resultId;
  
  if(stubResult == E_OK)
  {
    //Check if received data matches expected values  
    if(!Equals(fullLen, gInternalServicePrimitiveEventParameters.ReceiveAndForwardUdpEvent.fullLen, "Stub_UdpReceiveAndForward", "Receive and check UDP data on DUT failed. Full length mismatch."))
      return kError;
    
    if(!Equals(srcPort, gInternalServicePrimitiveEventParameters.ReceiveAndForwardUdpEvent.srcPort, "Stub_UdpReceiveAndForward", "Receive and check UDP data on DUT failed. Source Port mismatch."))
      return kError;
    
    if(!IpEquals(srcIpAddress
      , gInternalServicePrimitiveEventParameters.ReceiveAndForwardUdpEvent.srcIpAddress
      , gInternalServicePrimitiveEventParameters.ReceiveAndForwardUdpEvent.ipAddressByteLength
      ,"Stub_UdpReceiveAndForward"
      , "Receive and check UDP data on DUT failed. Source IP mismatch."))
      return kError;
    
    if(!Equals(payload
      , gInternalServicePrimitiveEventParameters.ReceiveAndForwardUdpEvent.payload
      , gInternalServicePrimitiveEventParameters.ReceiveAndForwardUdpEvent.payloadByteLength
      , "Stub_UdpReceiveAndForward"
      , "Receive and check UDP data on DUT failed. Payload mismatch."))
      return kError;
  }  
  
  return Convert(stubResult);
}

