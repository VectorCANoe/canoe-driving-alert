/// <TcpStubFunctions>
enum StubFunctionResult Stub_TcpConfigureSocketImpl(enum TcpParameterId paramId, word paramVal)
{
  byte data[2];
  int  dataLen;
  
  switch(paramId)
  {
    case 0:
    case 1:
    case 2:
    case 4:
    case 6:
    case 7:
      dataLen = 1;
      data[0] = paramVal & 0xFF;
      break;
    case 5:
    case 65534:
    case 65535:
      dataLen = 2;
      data[0] = paramVal >> 8 & 0xFF;
      data[1] = paramVal & 0xFF;
      break;
    default:
      testStepFail("Stub_TcpConfigureSocket", "Unexpected paramId.");
      return kError;
  }

  return Convert(SP_Tcp_ConfigureSocket(gSocketId[0], paramId, data, dataLen));
}

/// <TcpStubFunctions>
enum StubFunctionResult Stub_TcpConnectImpl(int socketId, char destIpAddr[], word destPort, enum TestabilityMessageResultIds expectedResult)
{
  enum TestabilityMessageResultIds stubResult;
  ip_Address dstIp;
  
  if( gSocketId[socketId] < 0)
  {
    testStepFail("Stub_TcpConnect", "Invalid socket ID, please create socket first.");
    return kError;
  }
  
  if(dstIp.ParseAddressFromString(destIpAddr) != 0)
  {
    testStepFail("Stub_TcpConnect", "Invalid input parameter destIpAddr: %s", destIpAddr);
    return kError;
  }

  stubResult = SP_Tcp_Connect(gSocketId[socketId], destPort, dstIp, expectedResult != Success);
  
  if(stubResult == E_OK)
  {
    gConnectedPort[socketId] = destPort;
    strncpy(gConnectedIP[socketId], destIpAddr, elcount(destIpAddr));
  }
  
  return Convert("SP_Tcp_Connect", stubResult, expectedResult);
}

/// <TcpStubFunctions>
enum StubFunctionResult Stub_TcpCreateAndBindImpl(word socketIndex, word port, enum Bool doBind)
{
  enum       TestabilityMessageResultIds stubResult;
  ip_Address ip;
  
  if(ip.ParseAddressFromString(syspar::DIface0Ip) != 0)
  {
    testStepFail("Stub_TcpCreateAndBind", "Invalid IP address: %s", syspar::DIface0Ip);
    return kError;
  }
  
  stubResult = SP_Tcp_CreateAndBind(doBind, port, ip);
  
  if(stubResult == E_OK)
  {    
    gSocketId[socketIndex]    = gInternalServicePrimitiveResponseParameters.CreateAndBindResponse.socketId;
    gSocketState[socketIndex] = TcpStateIdEstablished;
    gSocketPort[socketIndex]  = port;
  }
  
  return Convert(stubResult);
}

/// <TcpStubFunctions>
enum StubFunctionResult Stub_TcpListenAndAcceptImpl(word maxCon, int socketIndex)
{
  enum TestabilityMessageResultIds stubResult;
  int i;
  
  if( gSocketId[socketIndex] < 0)
  {
    testStepFail("Stub_TcpListenAndAccept", "Invalid socket ID, please create socket first.");
    return kError;
  }
  
  //Move listen socket information to the end of the array
  for(i = 9; i >= 0; i--)
  {
    if(gSocketId[i] < 0)
    {
      gSequenceNumber[i] = gSequenceNumber[socketIndex];
      gSequenceNumber[socketIndex] = 0;
      
      gAcknowledgement[i] = gAcknowledgement[socketIndex];
      gAcknowledgement[socketIndex] = 0;
      
      gSocketPort[i] = gSocketPort[socketIndex];
      gSocketPort[socketIndex] = 0;
      
      gSocketState[i] = gSocketState[socketIndex];
      gSocketState[socketIndex] = TcpStateIdInvalid;
      
      gConnectedPort[i] = gConnectedPort[socketIndex];
      gConnectedPort[socketIndex] = 0;
      
      strncpy(gConnectedIP[i], gConnectedIP[socketIndex], elcount(gConnectedIP[socketIndex]));
      strncpy(gConnectedIP[socketIndex], "0.0", elcount("0.0"));
      
      gSocketId[i] = gSocketId[socketIndex];
      gSocketId[socketIndex] = -1;
      break;
    }
  }
  
  return Convert(SP_Tcp_Listen_and_Accept(gSocketId[i], maxCon));
}

/// <TcpStubFunctions>
enum StubFunctionResult Stub_TcpListenAndAcceptEventImpl(long timeoutMilliseconds)
{
  long result;
  int i;  
  
  result = TmpWaitForServicePrimitiveEvent(kInternalEventListenAndAccept, timeoutMilliseconds);
  
  if(result != 1)
  {
    testStepFail("Stub_TcpListenAndAcceptEvent", "No TCP Listen and Accept Event received");
    return kError;
  }
  
  for(i = 0; i < 10; i++)
  {
    if(gSocketId[i] < 0)
    {
      gSocketId[i]    = gInternalServicePrimitiveEventParameters.ListenAndAcceptTcpEvent.newSocketId;
      gSocketState[i] = TcpStateIdEstablished;
      gSocketPort[i]  = gInternalServicePrimitiveEventParameters.ListenAndAcceptTcpEvent.port;
      break;
    }
  }
  
  return kOk;
}

/// <TcpStubFunctions>
enum StubFunctionResult Stub_TcpReceiveAndForwardImpl(enum TestabilityMessageResultIds expectedResult, char expectedDropCnt[])
{
  enum TestabilityMessageResultIds stubResult;
  
  if(gSocketId[0] < 0)
  {
    testStepFail("Stub_TcpReceiveAndForward", "Invalid socket ID, please create socket first.");
    return kError;
  }

  stubResult = SP_Tcp_ReceiveAndForward(gSocketId[0], 0xFFFF, 0xFFFF);  
  
  if(stubResult == expectedResult )
  {
    if(expectedResult != Success)
    {
      testStepPass("Stub_TcpReceiveAndForward", "Receive and check TCP data on DUT succeeded.");
    }
    else if(isWildcard(expectedDropCnt))
    {
      testStepPass("Stub_TcpReceiveAndForward", "Receive and forward TCP data on DUT succeeded.");
    }
    else if(atol(expectedDropCnt) == gInternalServicePrimitiveResponseParameters.ReceiveAndForwardResponse.dropCnt)
    {
      testStepPass("Stub_TcpReceiveAndForward", "Receive and check TCP data on DUT succeeded.");
    }
    else
    {
      testStepFail("Stub_TcpReceiveAndForward", "Receive and check TCP data on DUT failed.");
      return kError;
    }
  }
  
  return Convert("Stub_TcpReceiveAndForward", stubResult, expectedResult);
}

/// <TcpStubFunctions>
enum StubFunctionResult Stub_TcpReceiveAndForwardEventImpl(long timeoutMilliseconds, char fullLen[], char payload[], enum Bool expectedMessage, enum TestabilityMessageResultIds expectedResult)
{
  long result;
  enum TestabilityMessageResultIds stubResult;
  int i;
  
  result = TmpWaitForServicePrimitiveEvent(kInternalEventReceiveAndForward, timeoutMilliseconds);
  
  if(result != 1) // event did not occur ...
  {
    if(expectedMessage) // ... but was expected -> test step failed
    {
      testStepFail("Stub_TcpReceiveAndForward", "No TCP Receive and Forward Event was received");
      return kError;
    }
    else // ... and was not expected -> test step passed
    {
      testStepPass("Stub_TcpReceiveAndForward", "No TCP Receive and Forward Event was received (as expected)");
      return kOk;
    }
  }
  else if(expectedMessage == kFalse) // event did occur but was not expected -> test step failed
  {
    testStepFail("Stub_TcpReceiveAndForward", "TCP Receive and Forward Event was received unexpectedly");
    return kError;
  }
  
  stubResult = (enum TestabilityMessageResultIds)gInternalServicePrimitiveEventParameters.ReceiveAndForwardTcpEvent.resultId;    
  
  if(stubResult == E_OK && expectedResult == E_OK)
  {
    //Check if received data matches expected values.    
    if(!Equals(fullLen, gInternalServicePrimitiveEventParameters.ReceiveAndForwardTcpEvent.fullLen, "Stub_TcpReceiveAndForwardEvent", "Receive and check TCP data on DUT failed. Full length mismatch."))
      return kError;
    
    if(!Equals(payload
      , gInternalServicePrimitiveEventParameters.ReceiveAndForwardTcpEvent.payload
      , gInternalServicePrimitiveEventParameters.ReceiveAndForwardTcpEvent.payloadByteLength
      , "Stub_TcpReceiveAndForwardEvent"
      , "Receive and check TCP data on DUT failed. Payload mismatch."))
      return kError;
  }
  
  return Convert("Stub_TcpReceiveAndForward", stubResult, expectedResult);
}

/// <TcpStubFunctions>
enum StubFunctionResult Stub_TcpReceiveAndForwardMaxLengthImpl(word maxLength)
{
  enum TestabilityMessageResultIds stubResult;
  
  if( gSocketId[0] < 0)
  {
    testStepFail("Stub_TcpReceiveAndForward", "Invalid socket ID, please create socket first.");
    return kError;
  }

  stubResult = SP_Tcp_ReceiveAndForward(gSocketId[0], 0xFFFF, maxLength);
  
  if(stubResult == E_OK && maxLength != gInternalServicePrimitiveResponseParameters.ReceiveAndForwardResponse.dropCnt)
    testStepFail("Stub_TcpReceiveAndForward", "The expected amount of bytes was not read");
  
  return Convert(stubResult);
}

