byte Equals(int expected, int actual, char function[], char error[])
{
  if(expected == actual)
    return 1;
  
  testStepFail(function, "%s. Expected %d but received %d", error, expected, actual);
  return 0;    
}

byte Equals(char expected[], int actual, char function[], char error[])
{
  if(IsWildcard(expected))
    return 1;  
  return Equals(atol(expected), actual, function, error);
}

byte Equals(char payload[], byte actual[], int actualLen, char function[], char error[])
{
  int i;
  
  if(!isWildcard(payload))
  {
    if(strlen(payload) != actualLen)
    {
      testStepFail(function, "%s. Payload length %d doesn't match: expected %d", error, strlen(payload), actualLen);
      return 0;
    }
    
    for(i = 0; i < strlen(payload); i++)
    {
      if((byte)payload[i] != actual[i])
      {
        testStepFail(function, "Payload mismatch");
        return 0;
      }
    }
  }
  return 1;
}

byte IpEquals(char expected[], byte actual[], int actualLen, char function[], char error[])
{
  ip_Address expectedIp, actualIp;
  byte ipv4Buf[4];
  byte ipv6Buf[16];
  
  if(IsWildcard(expected))
    return 1;
  
  if(expectedIp.ParseAddressFromString(expected) != 0)
  {
    testStepFail(function, "Expected value %s is no valid IP address.", expected);
    return 0;
  }
  
  if(actualLen == 4)
  {
    memcpy(ipv4Buf, actual, 4);
    actualIp.SetAddressAsArray(ipv4Buf);
  }
  else if(actualLen == 16)
  {
    memcpy(ipv6Buf, actual, 16);
    actualIp.SetAddressAsArray(ipv6Buf);
  }
  else
  {
    testStepFail(function, "Actual value of length %d is no valid IP address.", actualLen);
    return 0;
  }
  
  if(expectedIp != actualIp)
  {
    testStepFail(function, error);
    return 0;
  }
  
  return 1;
}

/// <DhcpStubFunctions>
enum StubFunctionResult Stub_ReceiveIcmpDestUnreachableImpl(long timeoutMilliseconds, char srcIpAddress[], char destIpAddress[], enum IcmpDestUnreachableCodes code, char checksum[])
{  
  long result;
  
  result = testWaitForTextEvent(kInternalEventReceiveAndForward, timeoutMilliseconds);
  
  if(result == 1) // event occured
  {
    //Check if received data matches expected values.
    if(!IpEquals(srcIpAddress
      , gInternalServicePrimitiveEventParameters.ReceiveAndForwardICMPEvent.bSrcIpAddress
      , gInternalServicePrimitiveEventParameters.ReceiveAndForwardICMPEvent.ipAddressByteLength
      , "Stub_IcmpReceiveAndForwardEvent"
      , "Receive and check IPv4 data on DUT failed. Source IP mismatch."))
      return kError;
    
    if(!IpEquals(destIpAddress
      , gInternalServicePrimitiveEventParameters.ReceiveAndForwardICMPEvent.bDstIpAddress
      , gInternalServicePrimitiveEventParameters.ReceiveAndForwardICMPEvent.ipAddressByteLength
      , "Stub_IcmpReceiveAndForwardEvent"
      , "Receive and check IPv4 data on DUT failed. Destination IP mismatch."))
      return kError;
    
    if(!Equals(checksum, gInternalServicePrimitiveEventParameters.ReceiveAndForwardICMPEvent.wChecksum, "Stub_ReceiveIcmpDestUnreachable", "Receive and check IPv4 data on DUT failed. Checksum mismatch."))
      return kError;
    
    if(gInternalServicePrimitiveEventParameters.ReceiveAndForwardICMPEvent.ipAddressByteLength == 4) // IPv4
    {
      if(!Equals(code, gInternalServicePrimitiveEventParameters.ReceiveAndForwardICMPEvent.bCode, "Stub_ReceiveIcmpDestUnreachable", "Receive and check IPv4 data on DUT failed. ICMP Code mismatch."))
        return kError;
      
      if(!Equals(3 /* Destination Unreachable icmpv4 */, gInternalServicePrimitiveEventParameters.ReceiveAndForwardICMPEvent.bType, "Stub_ReceiveIcmpDestUnreachable", "Receive and check IPv4 data on DUT failed. ICMP Type mismatch."))
        return kError;      
    }
    else // IPv6
    {
      if(!Equals(1 /* Destination Unreachable icmpv6 */, gInternalServicePrimitiveEventParameters.ReceiveAndForwardICMPEvent.bType, "Stub_ReceiveIcmpDestUnreachable", "Receive and check IPv4 data on DUT failed. ICMP Type mismatch."))
        return kError;
    }
    
    testStepPass("Stub_IcmpReceiveAndForwardEvent", "ICMP message have been received by DUT.");    
    return kOk;
  }
  else //event didn't occur
  {
    testStepFail("Stub_IcmpReceiveAndForwardEvent", "No ICMP Destination Unreachable message was received");
    return kError;
  }
}

