/// <Ipv4AutoconfStubFunctions>
enum StubFunctionResult Stub_IpAddStaticRouteImpl(char ifName[], char subNet[], char netMask[], char gateway[])
{
  ip_Address subNetIp;
  ip_Address gatewayIp;
  long       netMsk;
  
  if(subNetIp.ParseAddressFromString(subNet) != 0)
  {
    testStepFail("Stub_IpAddStaticRoute", "Invalid input parameter subNet: %s", subNet);
    return kError;
  }
  
  if(gatewayIp.ParseAddressFromString(gateway) != 0)
  {
    testStepFail("Stub_IpAddStaticRoute", "Invalid input parameter gateway: %s", gateway);
    return kError;
  }
  
  netMsk = atol(netMask);
  
  if(netMsk == 0 || netMsk > 31)
  {
    testStepFail("Stub_IpAddStaticRoute", "Invalid input parameter netMask: %s", netMask);
    return kError;
  }
  
  return Convert(SP_Ipv4_StaticRoute(ifName, subNetIp, netMsk, gatewayIp));  
}

