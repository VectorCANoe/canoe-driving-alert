/// <TcpStubFunctions>
enum StubFunctionResult Stub_GetTcpStateImpl(enum TcpStateId expectedTcpState, int socketHandle)
{
  enum TestabilityMessageResultIds stubResult;
  byte actualTcpState;

  if( gSocketId[socketHandle] < 0)
  {
    testStepFail("Stub_GetTcpState", "Invalid socket ID, please create socket first.");
    return kError;
  }
  
  stubResult = SP_Tcp_GetState(gSocketId[socketHandle]);
  
  if(stubResult != E_OK)
    return Convert(stubResult);
    
  actualTcpState = gInternalServicePrimitiveResponseParameters.TcpGetStateResponse.tcpState;
    
  if (actualTcpState != expectedTcpState)
  {
    testStepFail("Stub_GetTcpState", "State missmatch. Expected=%s, Observed=%s", expectedTcpState.name(), ((enum TcpStateId)actualTcpState).name());
    return kError;
  }
  else
  {
    testStepPass("Stub_GetTcpState", "Get the Tcp State on DUT succeeded.");
    return kOk;
  }
}

