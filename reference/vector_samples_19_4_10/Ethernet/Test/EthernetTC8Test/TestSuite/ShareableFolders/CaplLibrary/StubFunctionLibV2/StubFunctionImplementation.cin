includes
{
  #include "..\TestabilityProtocolLib\Interface_TestabilityServices.cin"
}

variables
{
  enum StubFunctionResult
  {
    kOk             = 0,
    kNotImplemented = -99,
    kError          = -100
  };
  
  char[50] kStubErrorMessages[long, 20];
}

enum StubFunctionResult Convert(enum TestabilityMessageResultIds result)
{
  if(result != E_OK)
  {
    if(result == TIMEOUT)
    {
      testStepFail("", "Timeout: No Service Primitive Response received");
    }
    else if (kStubErrorMessages.containsKey(result))
    {
      testStepFail("", "Service Primitive returned code %s", kStubErrorMessages[result]);
    }
    else
    {
      testStepFail("", "Service Primitive returned code %d", result);
    }
  }
  return (result == E_OK) ? kOk : kError;
}

enum StubFunctionResult Convert(char functionName[], enum TestabilityMessageResultIds result, enum TestabilityMessageResultIds expectedResult)
{
  if(result != expectedResult)
  {
    if (kStubErrorMessages.containsKey(result) && kStubErrorMessages.containsKey(expectedResult))
      testStepFail(functionName, "%s: Service Primitive returned code %s, but expected code was %s", functionName, kStubErrorMessages[result], kStubErrorMessages[expectedResult]);
    else
      testStepFail(functionName, "%s: Service Primitive returned code %d, but expected code was %d", functionName, result, expectedResult);
    return kError;
  }
  
  if (kStubErrorMessages.containsKey(result) && kStubErrorMessages.containsKey(expectedResult))
    testStepPass(functionName, "%s: Service Primitive returned code %s", functionName, kStubErrorMessages[result]);
  else
    testStepPass(functionName, "%s: Service Primitive returned code %d", functionName, result);
  return (result == expectedResult) ? kOk : kError;
}

void InitStubErrorMessages()
{

 /* standard results */
  strncpy(kStubErrorMessages[E_OK],  "The service primitive has performed successfully", 50);
  strncpy(kStubErrorMessages[E_NOK], "General error", 50);

  /* testability specific */
  strncpy(kStubErrorMessages[E_NTF], "The requested service primitive was not found", 50);
  strncpy(kStubErrorMessages[E_PEN], "The Upper Tester or a service primitive is pending", 50);
  strncpy(kStubErrorMessages[E_ISB], "Insufficient buffer size", 50);
  strncpy(kStubErrorMessages[E_INV], "Invalid Input or Parameter", 50);

  /*  service primitve specific */
  strncpy(kStubErrorMessages[E_ISD],     "Invalid socket ID", 50);
  strncpy(kStubErrorMessages[E_UCS],     "Unable to create socket or no free socket", 50);
  strncpy(kStubErrorMessages[E_UBS],     "Unable to bind socket, port taken", 50);
  strncpy(kStubErrorMessages[E_IIF],     "Invalid network or virtual interface", 50);
  strncpy(kStubErrorMessages[E_TCP_PNA], "TCP error: \"precedence not allowed\"", 50);
  strncpy(kStubErrorMessages[E_TCP_FSU], "TCP error: \"foreign socket unspecified\"", 50);
  strncpy(kStubErrorMessages[E_TCP_ILP], "TCP error: \"connection illegal for this process\"", 50);
  strncpy(kStubErrorMessages[E_TCP_INR], "TCP error: \"insufficient resources\"", 50);
  strncpy(kStubErrorMessages[E_TCP_CAE], "TCP error: \"connection already exists\"", 50);
  strncpy(kStubErrorMessages[E_TCP_COC], "TCP error: \"connection closing\"", 50);
  strncpy(kStubErrorMessages[E_TCP_CNE], "TCP error: \"connection does not exist\"", 50);
  strncpy(kStubErrorMessages[E_TCP_CRE], "TCP error: \"connection reset\"", 50);
  strncpy(kStubErrorMessages[E_TCP_CAT], "TCP error: \"connection aborted due to user timeout\"", 50);
  strncpy(kStubErrorMessages[E_TCP_COR], "TCP Error: \"connection refused\"", 50);
}

