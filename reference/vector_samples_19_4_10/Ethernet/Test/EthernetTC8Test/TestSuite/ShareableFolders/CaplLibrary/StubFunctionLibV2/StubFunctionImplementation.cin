/// <UdpStubFunctions>
enum StubFunctionResult Stub_UdpConfigureSocketImpl(word paramId, word paramVal)
{
  byte data[2];
  int  dataLen;
  
  switch(paramId)
  {
    case 0:
    case 1:
    case 2:
    case 4:
    case 6:
    case 7:
      dataLen = 1;
      data[0] = paramVal & 0xFF;
      break;
    case 5:
    case 65534:
    case 65535:
      dataLen = 2;
      data[0] = paramVal >> 8 & 0xFF;
      data[1] = paramVal & 0xFF;
      break;
    default:
      testStepFail("Stub_UdpConfigureSocket", "Unexpected paramId.");
      return kError;
  }

  return Convert(SP_Udp_ConfigureSocket(gSocketId[0], paramId, data, dataLen));
}

/// <UdpStubFunctions>
enum StubFunctionResult Stub_UdpConfigureSocketImpl(word paramId, char paramVal[])
{
  char parameterTemp[5];
  byte data[0xFFFF], i;
  word dataLen;
  
  dataLen = strlen(paramVal);
  
  // Convert paramVal
  strncpy(parameterTemp, "0x", 3);
  
  for (i = 0; (i * 2) < dataLen; i++)
  {
    substr_cpy_off(parameterTemp, 2, paramVal, i * 2, 2, 5);
    data[i] = atol(parameterTemp);
  }
  
   if(gSocketId[0] < 0)
  {
    testStepFail("Stub_UdpConfigureSocket", "Invailid socket ID, please create socket first.");
    return kError;
  }
  
  return Convert(SP_Udp_ConfigureSocket(gSocketId[0], paramId, data, dataLen));
}

