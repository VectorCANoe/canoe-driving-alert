export testfunction ETS_CallMethodAndWaitForAllResults(dword methodId, dword numberOfCallRepetitions, dword repetitionDelayMs)
{
  dword methodCallHandle, callCounter;
  enum Bool expectResponse;
  
  gMultiCallExpectedNumberOfResponses = 1 + numberOfCallRepetitions;
  gMultiCallReceivedNumberOfResponses = 0;
  gMultiCallAllResponsesOk = kTrue;

  for(callCounter=0;callCounter<gMultiCallExpectedNumberOfResponses; ++callCounter)
  {
    if(CreateETSMethodCallAndProvideArguments(methodId, sysvar::TC8_ETS::ETS_TestVariant::Standard, methodCallHandle, expectResponse)==kFalse)
    {
      testStepFail("ETS_CallMethodAndWaitForAllResults", "CreateMethodHandle failed");
      return;
    }
    
    //SomeIpRegisterCallback(methodCallHandle, "OnResponse_MethodMultiCall");
    
    if(callCounter>0 && repetitionDelayMs>0)
      testWaitForTimeout(repetitionDelayMs);

//testWaitForTimeoutSilent(100);    
    if(SomeIpCallMethod(methodCallHandle)!=0)
    {
      ReportSomeIpError("Call failed");
      testStepFail("ETS_CallMethodAndWaitForAllResults", "Call failed");
      return;
    }
  }    

  if(WaitForTestMethodResult()!=1)
  {
    testStepFail("ETS_CallMethodAndWaitForAllResults", "Response not received");
  }
  else
  {
    if(gResultOfMethodCall!=sysvar::TC8_ETS::ETS_MethodResult::OK)
    {
      char expected[64], actualResult[64];
      sysGetVariableDescriptionForValue(sysvar::TC8_ETS::ETS_MethodResult,
        sysvar::TC8_ETS::ETS_MethodResult::OK, expected, elcount(expected));
      sysGetVariableDescriptionForValue(sysvar::TC8_ETS::ETS_MethodResult,
        gResultOfMethodCall, actualResult, elcount(actualResult));
      
      testStepFail("ETS_CallMethodAndWaitForAllResults", "Invalid result '%s', expected '%s'", actualResult, expected);
    }
    else
    {
      testStepPass("ETS_CallMethodAndWaitForAllResults", "Call results fit expectation");
    }
  }
}

export testfunction ETS_CallMethodWithPatchedHeaderAndCheckError(dword methodId, dword headerPatchVariant, dword expectedError, enum Bool errorIsOptional)
{
  dword oldExpectedNumberOfResponses;
  //write("### ETS_CallMethodWithPatchedHeaderAndCheckError calling %d", gMultiCallExpectedNumberOfResponses);

  oldExpectedNumberOfResponses = gMultiCallExpectedNumberOfResponses;
  if(TriggerETSMethodCall(methodId, sysvar::TC8_ETS::ETS_TestVariant::Standard, headerPatchVariant))
  {
    gMultiCallExpectedNumberOfResponses = oldExpectedNumberOfResponses; // message with patched header gets no SOME/IP-IL response callback
    ETS_InternalWaitForSOMEIPError("ETS_CallMethodWithPatchedHeaderAndCheckError", syspar::ParamListenTimeMs, methodId, expectedError, errorIsOptional);
  }
  else
  {
      testStepFail("ETS_CallMethodWithPatchedHeaderAndCheckError", "ETS call failed or not executed");
  }
}

export testfunction ETS_CallMethodWithPatchedHeaderAndCheckNoAnswere(dword methodId, dword headerPatchVariant)
{
  byte payload[1];
  char serviceIdStr[32], returnCodeStr[32], methodIdStr[32];
  
  if(TriggerETSMethodCall(methodId, sysvar::TC8_ETS::ETS_TestVariant::Standard, headerPatchVariant))
  {
    snprintf(serviceIdStr, elcount(serviceIdStr), "%d", syspar::SomeIp_ETS_ServiceId);
    snprintf(methodIdStr, elcount(methodIdStr), "%d", methodId);
  
    gMultiCallExpectedNumberOfResponses = gMultiCallReceivedNumberOfResponses = 0;  
    gMultiCallResults.clear();

    InternalWaitForSOMEIP(
      syspar::ParamListenTimeMs,
      syspar::Host1Mac,
      syspar::IpAddressTester,
      syspar::Wildcard,
      syspar::Wildcard,
      SomeIpMessageTypeError,
      SomeIpEntryNull,
      -1,
      syspar::Wildcard,
      serviceIdStr,
      syspar::Wildcard,
      methodIdStr,
      syspar::Wildcard, syspar::Wildcard, kEquals,
      syspar::Wildcard, syspar::Wildcard, kEquals,
      syspar::Wildcard, syspar::Wildcard, kEquals,
      syspar::Wildcard, syspar::Wildcard, kEquals,
      syspar::Wildcard, syspar::Wildcard, kEquals,
      syspar::Wildcard, syspar::Wildcard, kEquals,
      syspar::UdpProtocol,
      kNoAnswerExpected,
      payload,
      0,
      0
    );
  }
  else
  {
      testStepFail("ETS_CallMethodWithPatchedHeaderAndCheckNoAnswere", "ETS call failed or not executed");
  }
}

export testfunction ETS_CallMethodVariantAndCheckResult(dword methodId, dword testVariant, dword expectedResult)
{
  dword result;
  if(TriggerETSMethodCall(methodId, testVariant, sysvar::TC8_ETS::ETS_HeaderPatchVariant::Not_patched))
  {
    result = WaitForTestMethodResult();
    if(result!=1)
    {
      testStepFail("ETS_CallMethodVariantAndCheckResult", "Response not received");
    }
    else
    {
      if(gResultOfMethodCall!=expectedResult)
      {
        char expected[64], actualResult[64];
        sysGetVariableDescriptionForValue(sysvar::TC8_ETS::ETS_MethodResult, expectedResult, expected, elcount(expected));
        sysGetVariableDescriptionForValue(sysvar::TC8_ETS::ETS_MethodResult, gResultOfMethodCall, actualResult, elcount(actualResult));
        
        testStepFail("ETS_CallMethodVariantAndCheckResult", "Invalid result '%s', expected '%s'", actualResult, expected);
      }
      else
      {
        testStepPass("ETS_CallMethodVariantAndCheckResult", "Call result fits expectation");
      }
    }
  }
  else
  {
      testStepFail("ETS_CallMethodVariantAndCheckResult", "ETS call failed or not executed");
  }
}

export testfunction ETS_CallMethodVariantAndCheckError(dword methodId, dword testVariant, dword expectedError)
{
  dword result;
  
  #if (TOOL_MAJOR_VERSION < 14) 
    testStepInconclusive("Insufficent tool version. This test requires at least version 14");
    return;
  #endif
  
  if(TriggerETSMethodCall(methodId, testVariant, sysvar::TC8_ETS::ETS_HeaderPatchVariant::Not_patched))
  {
    result = WaitForTestMethodResult();
    if(result!=1)
    {
      testStepFail("ETS_CallMethodVariantAndCheckError", "Response not received");
    }
    else
    {
      if(gMessageTypeOfResultOfMethodCall!=E_MRT_ERROR)
      {
        testStepFail("ETS_CallMethodVariantAndCheckError", "Response has wrong Message Type, expected ERROR");
      }
      else if(gResultOfMethodCall!=expectedError)
      {
        char expected[64], actualResult[64];
        sysGetVariableDescriptionForValue(sysvar::TC8_ETS::ETS_MethodResult,
          expectedError, expected, elcount(expected));
        sysGetVariableDescriptionForValue(sysvar::TC8_ETS::ETS_MethodResult,
          gResultOfMethodCall, actualResult, elcount(actualResult));
        
        testStepFail("ETS_CallMethodVariantAndCheckError", "Invalid result '%s', expected '%s'", actualResult, expected);
      }
      else
      {
        testStepPass("ETS_CallMethodVariantAndCheckError", "Call result fits expectation");
      }
    }
  }
  else
  {
      testStepFail("ETS_CallMethodVariantAndCheckError", "ETS call failed or not executed");
  }
}

export testfunction ETS_CallMethodVariantAndCheckOptionalResult(dword methodId, dword testVariant, dword expectedResult)
{
  dword result;
  
  if(TriggerETSMethodCall(methodId, testVariant, sysvar::TC8_ETS::ETS_HeaderPatchVariant::Not_patched))
  {
    //++gMultiCallExpectedNumberOfResponses;
    result = WaitForTestMethodResult();
    if(result!=1)
    {
      write("Received no response, but response is optional");
      testStepPass("ETS_CallMethodVariantAndCheckOptionalResult", "Received no response, but response is optional");
    }
    else
    {
      if(gResultOfMethodCall!=expectedResult)
      {
        char expected[64], actualResult[64];
        sysGetVariableDescriptionForValue(sysvar::TC8_ETS::ETS_MethodResult,
          expectedResult, expected, elcount(expected));
        sysGetVariableDescriptionForValue(sysvar::TC8_ETS::ETS_MethodResult,
          gResultOfMethodCall, actualResult, elcount(actualResult));
        
        testStepFail("ETS_CallMethodVariantAndCheckOptionalResult", "Invalid result '%s', expected '%s'", actualResult, expected);
      }
      else
      {
        testStepPass("ETS_CallMethodVariantAndCheckOptionalResult", "Call result fits expectation");
      }
    }
  }
  else
  {
      testStepFail("ETS_CallMethodVariantAndCheckOptionalResult", "ETS call failed or not executed");
  }
}

export testfunction ETS_CallMethodAndCheckResult(dword methodId, dword expectedResult)
{
  ETS_CallMethodVariantAndCheckResult(methodId, sysvar::TC8_ETS::ETS_TestVariant::Standard, expectedResult);
}

dword WaitForTestMethodResult()
{
  dword result;
  if(gMultiCallExpectedNumberOfResponses>0 && gMultiCallExpectedNumberOfResponses>gMultiCallReceivedNumberOfResponses)
  {
    write("Start waiting for method call responses: %d", gMultiCallExpectedNumberOfResponses);
    gIsWaitingForETSCallResult = kTrue;
    result = testWaitForTextEvent("ETSCallResult", syspar::ParamListenTimeMs);
    gIsWaitingForETSCallResult = kFalse;
    if(result!=1)
      write("Received only %d of %d results", gMultiCallReceivedNumberOfResponses, gMultiCallExpectedNumberOfResponses);
    write("Finished waiting for method call responses");
  }
  else
    result = 1; // we already received all responses
  gMultiCallExpectedNumberOfResponses = gMultiCallReceivedNumberOfResponses = 0;  
  gMultiCallResults.clear();
  gMultiCallResultTypes.clear();
  gWaitForConnectionToDutEstablishedDone=kFalse;
  return result;
}

on timer gTestResultTimer
{
  testSupplyTextEvent("ETSCallResult");
}

enum Bool SetTestMethodError(dword result)
{
  SetTestMethodResult(result);
  return kFalse;
}

void SetTestMethodResult(dword result)
{
  SetTestMethodResult(result, E_MRT_RESPONSE);
}

void SetTestMethodResult(dword result, enum SomeIpResponseMessageType responseMessageType)
{
  //write("### >SetTestMethodResult, expected: %d, got: %d", gMultiCallExpectedNumberOfResponses, gMultiCallReceivedNumberOfResponses);
  if(gMultiCallExpectedNumberOfResponses>0 && gMultiCallExpectedNumberOfResponses>gMultiCallReceivedNumberOfResponses)
  {
    ++gMultiCallReceivedNumberOfResponses;
    if(gIsWaitingForETSCallResult==kFalse)
      write("Received response %d of %d at %.5f, but not yet waiting for it", gMultiCallReceivedNumberOfResponses, gMultiCallExpectedNumberOfResponses, timeNowFloat()/100000.0);
    else
      write("Received response %d of %d at %.5f", gMultiCallReceivedNumberOfResponses, gMultiCallExpectedNumberOfResponses, timeNowFloat()/100000.0);
    gMultiCallResults[result] = result;
    gMultiCallResultTypes[responseMessageType] = 1;
    if(gMultiCallResultTypes.size()>1)
      gResultOfMethodCall = sysvar::TC8_ETS::ETS_MethodResult::ResponsesWithDifferentRC;
    else if(gMultiCallResults.size()>1)
      gResultOfMethodCall = sysvar::TC8_ETS::ETS_MethodResult::ResponseHasWrongMessageType;
    else
      gResultOfMethodCall = result;
    gMessageTypeOfResultOfMethodCall = responseMessageType;
    if(gIsWaitingForETSCallResult && gMultiCallExpectedNumberOfResponses==gMultiCallReceivedNumberOfResponses)
    {
      setTimer(gTestResultTimer, 0);
    }
  }
  else
  {
    testStepFail("Received unexpected method response");
    write("Received unexpected method response at %.5f", timeNowFloat()/100000.0);
    gMultiCallExpectedNumberOfResponses = gMultiCallReceivedNumberOfResponses = 0;
  }
  //write("### <SetTestMethodResult, expected: %d, got: %d", gMultiCallExpectedNumberOfResponses, gMultiCallReceivedNumberOfResponses);
}

enum Bool ETS_waitForConnectionToDutEstablished()
{
  if(gWaitForConnectionToDutEstablishedDone==kFalse)
  {
    PrepareWaitForEthernet(syspar::DIface0MacAddr, syspar::MacAddressTester);
    PrepareWaitForIp(syspar::DIface0Ip, syspar::IpAddressTester, 0x06); /* TCP Protocol Type */
    
    InternalAddExpectedParameter("tcp", "destination", syspar::SomeIp_ETS_Port);
    InternalAddExpectedParameter("tcp", "flags", TcpFlagAck, kEquals);

    gObservingEthPackets = kTrue;
    StartObservationOfIncomingPackets(kAnswerExpected);
    
    if (WaitForIncomingPacket(kAnswerExpected, 150) != 0)
    {
      testStepFail("TCP connection for method call not established.");
      gObservingEthPackets = kFalse;
      return kFalse;
    }
    gObservingEthPackets = kFalse;
    
    InternalClearAllParameters();
    
    testWaitForTimeout(syspar::SomeIp_ETS_CSI_TCP_ReadyDelayMs); // Give SomeIp IL some time to process the packet
  }
  gWaitForConnectionToDutEstablishedDone=kTrue;
  return kTrue;
}

enum Bool CreateETSMethodCallAndProvideArguments(dword methodId, dword testVariant, dword & methodCallHandle, enum Bool & expectResponse)
{
  stack enum Bool result = kFalse;
  char errorCallbackName[32] = "OnMethodResponseTypeError";
  
  expectResponse = kTrue;
  
  switch(methodId)
  {
    case sysvar::TC8_ETS::ETS_Method::checkByteOrder:
      if(CreateMethodHandle(gClientServiceAepHandleUDP, methodId, testVariant, methodCallHandle, errorCallbackName))
        result = CheckResultOfProvideArgumentsCall("checkByteOrder", ProvideArgumentsForMethod_checkByteOrder(methodCallHandle));
      break;
    case sysvar::TC8_ETS::ETS_Method::echoBitfields:
      if(CreateMethodHandle(gClientServiceAepHandleUDP, methodId, testVariant, methodCallHandle, errorCallbackName))
        result = CheckResultOfProvideArgumentsCall("echoBitfields", ProvideArgumentsForMethod_echoBitfields(methodCallHandle));
      break;
    case sysvar::TC8_ETS::ETS_Method::echoCommonDatatypes:
      if(CreateMethodHandle(gClientServiceAepHandleUDP, methodId, testVariant, methodCallHandle, errorCallbackName))
        result = CheckResultOfProvideArgumentsCall("echoCommonDatatypes", ProvideArgumentsForMethod_echoCommonDatatypes(methodCallHandle));
      break;
    case sysvar::TC8_ETS::ETS_Method::echoENUM:
      if(CreateMethodHandle(gClientServiceAepHandleUDP, methodId, testVariant, methodCallHandle, errorCallbackName))
        result = CheckResultOfProvideArgumentsCall("echoENUM", ProvideArgumentsForMethod_echoENUM(methodCallHandle));
      break;
    case sysvar::TC8_ETS::ETS_Method::echoFLOAT64:
      if(CreateMethodHandle(gClientServiceAepHandleUDP, methodId, testVariant, methodCallHandle, errorCallbackName))
        result = CheckResultOfProvideArgumentsCall("echoFLOAT64", ProvideArgumentsForMethod_echoFLOAT64(methodCallHandle));
      break;
    case sysvar::TC8_ETS::ETS_Method::echoINT8:
      if(CreateMethodHandle(gClientServiceAepHandleUDP, methodId, testVariant, methodCallHandle, errorCallbackName))
        result = CheckResultOfProvideArgumentsCall("echoINT8", ProvideArgumentsForMethod_echoINT8(methodCallHandle));
      break;
    case sysvar::TC8_ETS::ETS_Method::echoStaticUINT8Array:
      if(CreateMethodHandle(gClientServiceAepHandleUDP, methodId, testVariant, methodCallHandle, errorCallbackName))
        result = CheckResultOfProvideArgumentsCall("echoStaticUINT8Array", ProvideArgumentsForMethod_echoStaticUINT8Array(methodCallHandle));
      break;
    case sysvar::TC8_ETS::ETS_Method::echoUINT8:
      if(CreateMethodHandle(gClientServiceAepHandleUDP, methodId, testVariant, methodCallHandle, errorCallbackName))
          result = CheckResultOfProvideArgumentsCall("echoUINT8", ProvideArgumentsForMethod_echoUINT8(methodCallHandle));
      break;
    case sysvar::TC8_ETS::ETS_Method::echoUINT8RELIABLE:
      if(CreateMethodHandle(gClientServiceAepHandleTCP, methodId, testVariant, methodCallHandle, errorCallbackName)==kTrue &&
         ETS_waitForConnectionToDutEstablished()==kTrue)
      {
        if(testVariant == sysvar::TC8_ETS::ETS_TestVariant::Standard)
          result = CheckResultOfProvideArgumentsCall("echoUINT8Reliable", ProvideArgumentsForMethod_echoUINT8Reliable(methodCallHandle));
        else if(testVariant == sysvar::TC8_ETS::ETS_TestVariant::ExtendedPayload)
          result = CheckResultOfProvideArgumentsCall("echoUINT8Reliable_ExtendedPayload", ProvideArgumentsForMethod_echoUINT8Reliable_ExtendedPayload(methodCallHandle));
      }
      break;
    case sysvar::TC8_ETS::ETS_Method::echoUINT8Array:
      if(CreateMethodHandle(gClientServiceAepHandleUDP, methodId, testVariant, methodCallHandle, errorCallbackName))
      {
        if(testVariant == sysvar::TC8_ETS::ETS_TestVariant::Standard)
          result = CheckResultOfProvideArgumentsCall("echoUINT8Array", ProvideArgumentsForMethod_echoUINT8Array(methodCallHandle));
        else if(testVariant == sysvar::TC8_ETS::ETS_TestVariant::EmptyArray)
          result = CheckResultOfProvideArgumentsCall("echoUINT8Array_EmptyArray", ProvideArgumentsForMethod_echoUINT8Array_EmptyArray(methodCallHandle));
        else if(testVariant == sysvar::TC8_ETS::ETS_TestVariant::Array_Length_too_long)
          result = CheckResultOfProvideArgumentsCall("echoUINT8Array_Array_Length_too_long", ProvideArgumentsForMethod_echoUINT8Array_Array_Length_too_long(methodCallHandle));
        else if(testVariant == sysvar::TC8_ETS::ETS_TestVariant::Array_Length_too_short)
          result = CheckResultOfProvideArgumentsCall("echoUINT8Array_Array_Length_too_short", ProvideArgumentsForMethod_echoUINT8Array_Array_Length_too_short(methodCallHandle));
        else if(testVariant == sysvar::TC8_ETS::ETS_TestVariant::ExtendedPayload)
          result = CheckResultOfProvideArgumentsCall("echoUINT8Array_ExtendedPayload", ProvideArgumentsForMethod_echoUINT8Array_ExtendedPayload(methodCallHandle));
      }
      break;
    case sysvar::TC8_ETS::ETS_Method::echoUINT8Array16BitLength:
      if(CreateMethodHandle(gClientServiceAepHandleUDP, methodId, testVariant, methodCallHandle, errorCallbackName))
        result = CheckResultOfProvideArgumentsCall("echoUINT8Array16BitLength", ProvideArgumentsForMethod_echoUINT8Array16BitLength(methodCallHandle));
      break;
    case sysvar::TC8_ETS::ETS_Method::echoUINT8Array8BitLength:
      if(CreateMethodHandle(gClientServiceAepHandleUDP, methodId, testVariant, methodCallHandle, errorCallbackName))
        result = CheckResultOfProvideArgumentsCall("echoUINT8Array8BitLength", ProvideArgumentsForMethod_echoUINT8Array8BitLength(methodCallHandle));
      break;
    case sysvar::TC8_ETS::ETS_Method::echoUINT8Array2Dim:
      if(CreateMethodHandle(gClientServiceAepHandleUDP, methodId, testVariant, methodCallHandle, errorCallbackName))
        result = CheckResultOfProvideArgumentsCall("echoUINT8Array2Dim", ProvideArgumentsForMethod_echoUINT8Array2Dim(methodCallHandle));
      break;
    case sysvar::TC8_ETS::ETS_Method::echoUINT8ArrayMinSize:
      if(CreateMethodHandle(gClientServiceAepHandleUDP, methodId, testVariant, methodCallHandle, errorCallbackName))
      {
        if(testVariant == sysvar::TC8_ETS::ETS_TestVariant::Standard)
          result = CheckResultOfProvideArgumentsCall("echoUINT8ArrayMinSize", ProvideArgumentsForMethod_echoUINT8ArrayMinSize(methodCallHandle));
        else if(testVariant == sysvar::TC8_ETS::ETS_TestVariant::ArrayMinSize_too_short)
          result = CheckResultOfProvideArgumentsCall("echoUINT8ArrayMinSize_ArrayMinSize_too_short", ProvideArgumentsForMethod_echoUINT8ArrayMinSize_ArrayMinSize_too_short(methodCallHandle));
      }
      break;
    case sysvar::TC8_ETS::ETS_Method::echoUNION:
      if(CreateMethodHandle(gClientServiceAepHandleUDP, methodId, testVariant, methodCallHandle, errorCallbackName))
      {
        if(testVariant == sysvar::TC8_ETS::ETS_TestVariant::Standard)
          result = CheckResultOfProvideArgumentsCall("echoUNION", ProvideArgumentsForMethod_echoUNION(methodCallHandle));
        else if(testVariant == sysvar::TC8_ETS::ETS_TestVariant::UnionLength_too_long_for_message)
          result = CheckResultOfProvideArgumentsCall("echoUNION_UnionLength_too_long_for_message", ProvideArgumentsForMethod_echoUNION_UnionLength_too_long_for_message(methodCallHandle));
        else if(testVariant == sysvar::TC8_ETS::ETS_TestVariant::UnionLength_too_long)
          result = CheckResultOfProvideArgumentsCall("echoUNION_UnionLength_too_long", ProvideArgumentsForMethod_echoUNION_UnionLength_too_long(methodCallHandle));
        else if(testVariant == sysvar::TC8_ETS::ETS_TestVariant::UnionLength_too_short)
          result = CheckResultOfProvideArgumentsCall("echoUNION_UnionLength_too_short", ProvideArgumentsForMethod_echoUNION_UnionLength_too_short(methodCallHandle));
      }
      break;
    case sysvar::TC8_ETS::ETS_Method::echoUTF16DYNAMIC:
      if(CreateMethodHandle(gClientServiceAepHandleUDP, methodId, testVariant, methodCallHandle, errorCallbackName))
      {
        if(testVariant == sysvar::TC8_ETS::ETS_TestVariant::Standard)
          result = CheckResultOfProvideArgumentsCall("echoUTF16DYNAMIC", ProvideArgumentsForMethod_echoUTF16DYNAMIC(methodCallHandle));
        else if(testVariant == sysvar::TC8_ETS::ETS_TestVariant::Length_too_long_for_String)
          result = CheckResultOfProvideArgumentsCall("echoUTF16DYNAMIC_Length_too_long_for_String", ProvideArgumentsForMethod_echoUTF16DYNAMIC_Length_too_long_for_String(methodCallHandle));
        else if(testVariant == sysvar::TC8_ETS::ETS_TestVariant::Length_too_short_for_malformed_String)
          result = CheckResultOfProvideArgumentsCall("echoUTF16DYNAMIC_Length_too_short_for_malformed_String", ProvideArgumentsForMethod_echoUTF16DYNAMIC_Length_too_short_for_malformed_String(methodCallHandle));
        else if(testVariant == sysvar::TC8_ETS::ETS_TestVariant::Length_too_short_for_String)
          result = CheckResultOfProvideArgumentsCall("echoUTF16DYNAMIC_Length_too_short_for_String", ProvideArgumentsForMethod_echoUTF16DYNAMIC_Length_too_short_for_String(methodCallHandle));
        else if(testVariant == sysvar::TC8_ETS::ETS_TestVariant::Odd_number_before_termination)
          result = CheckResultOfProvideArgumentsCall("echoUTF16DYNAMIC_Odd_number_before_termination", ProvideArgumentsForMethod_echoUTF16DYNAMIC_Odd_number_before_termination(methodCallHandle));
        else if(testVariant == sysvar::TC8_ETS::ETS_TestVariant::Odd_number_after_termination)
          result = CheckResultOfProvideArgumentsCall("echoUTF16DYNAMIC_Odd_number_after_termination", ProvideArgumentsForMethod_echoUTF16DYNAMIC_Odd_number_after_termination(methodCallHandle));
        else if(testVariant == sysvar::TC8_ETS::ETS_TestVariant::Wrong_BOM)
          result = CheckResultOfProvideArgumentsCall("echoUTF16DYNAMIC_Wrong_BOM", ProvideArgumentsForMethod_echoUTF16DYNAMIC_Wrong_BOM(methodCallHandle));
      }
      break;
    case sysvar::TC8_ETS::ETS_Method::echoUTF16FIXED:
      if(CreateMethodHandle(gClientServiceAepHandleUDP, methodId, testVariant, methodCallHandle, errorCallbackName))
      {
        if(testVariant == sysvar::TC8_ETS::ETS_TestVariant::Standard)
          result = CheckResultOfProvideArgumentsCall("echoUTF16FIXED", ProvideArgumentsForMethod_echoUTF16FIXED(methodCallHandle));
        else if(testVariant == sysvar::TC8_ETS::ETS_TestVariant::String_too_long)
          result = CheckResultOfProvideArgumentsCall("echoUTF16FIXED_String_too_long", ProvideArgumentsForMethod_echoUTF16FIXED_String_too_long(methodCallHandle));
        else if(testVariant == sysvar::TC8_ETS::ETS_TestVariant::String_too_short)
          result = CheckResultOfProvideArgumentsCall("echoUTF16FIXED_String_too_short", ProvideArgumentsForMethod_echoUTF16FIXED_String_too_short(methodCallHandle));
        else if(testVariant == sysvar::TC8_ETS::ETS_TestVariant::Odd_number_after_termination)
          result = CheckResultOfProvideArgumentsCall("echoUTF16FIXED_Odd_number_after_termination", ProvideArgumentsForMethod_echoUTF16FIXED_Odd_number_after_termination(methodCallHandle));

      }
      break;
    case sysvar::TC8_ETS::ETS_Method::echoUTF8DYNAMIC:
      if(CreateMethodHandle(gClientServiceAepHandleUDP, methodId, testVariant, methodCallHandle, errorCallbackName))
      {
        if(testVariant == sysvar::TC8_ETS::ETS_TestVariant::Standard)
          result = CheckResultOfProvideArgumentsCall("echoUTF8DYNAMIC", ProvideArgumentsForMethod_echoUTF8DYNAMIC(methodCallHandle));
        else if(testVariant == sysvar::TC8_ETS::ETS_TestVariant::Length_too_long_for_String)
          result = CheckResultOfProvideArgumentsCall("echoUTF8DYNAMIC_Length_too_long_for_String", ProvideArgumentsForMethod_echoUTF8DYNAMIC_Length_too_long_for_String(methodCallHandle));
        else if(testVariant == sysvar::TC8_ETS::ETS_TestVariant::Length_too_short_for_malformed_String)
          result = CheckResultOfProvideArgumentsCall("echoUTF8DYNAMIC_Length_too_short_for_malformed_String", ProvideArgumentsForMethod_echoUTF8DYNAMIC_Length_too_short_for_malformed_String(methodCallHandle));
        else if(testVariant == sysvar::TC8_ETS::ETS_TestVariant::Length_too_short_for_String)
          result = CheckResultOfProvideArgumentsCall("echoUTF8DYNAMIC_Length_too_short_for_String", ProvideArgumentsForMethod_echoUTF8DYNAMIC_Length_too_short_for_String(methodCallHandle));
        else if(testVariant == sysvar::TC8_ETS::ETS_TestVariant::Wrong_BOM)
          result = CheckResultOfProvideArgumentsCall("echoUTF8DYNAMIC_Wrong_BOM", ProvideArgumentsForMethod_echoUTF8DYNAMIC_Wrong_BOM(methodCallHandle));
      }
      break;
    case sysvar::TC8_ETS::ETS_Method::echoUTF8FIXED:
      if(CreateMethodHandle(gClientServiceAepHandleUDP, methodId, testVariant, methodCallHandle, errorCallbackName))
      {
        if(testVariant == sysvar::TC8_ETS::ETS_TestVariant::Standard)
          result = CheckResultOfProvideArgumentsCall("echoUTF8FIXED", ProvideArgumentsForMethod_echoUTF8FIXED(methodCallHandle));
        else if(testVariant == sysvar::TC8_ETS::ETS_TestVariant::String_too_long)
          result = CheckResultOfProvideArgumentsCall("echoUTF8FIXED_String_too_long", ProvideArgumentsForMethod_echoUTF8FIXED_String_too_long(methodCallHandle));
        else if(testVariant == sysvar::TC8_ETS::ETS_TestVariant::String_too_short)
          result = CheckResultOfProvideArgumentsCall("echoUTF8FIXED_String_too_short", ProvideArgumentsForMethod_echoUTF8FIXED_String_too_short(methodCallHandle));
      }
      break;        
    case sysvar::TC8_ETS::ETS_Method::clientServiceActivate:
      expectResponse = kFalse;
      result = CreateMethodHandleFireAndForget(gClientServiceAepHandleUDP, methodId, methodCallHandle);
      break;
    case sysvar::TC8_ETS::ETS_Method::resetInterface:
      expectResponse = kFalse;
      result = CreateMethodHandleFireAndForget(gClientServiceAepHandleUDP, methodId, methodCallHandle);
      break;
    case sysvar::TC8_ETS::ETS_Method::suspendInterface:
      expectResponse = kFalse;
      if(CreateMethodHandleFireAndForget(gClientServiceAepHandleUDP, methodId, methodCallHandle))
        result = CheckResultOfProvideArgumentsCall("suspendInterface", ProvideArgumentsForMethod_suspendInterface(methodCallHandle));
      break;
    case sysvar::TC8_ETS::ETS_Method::clientServiceGetLastValueOfEventTCP:
      result = CreateMethodHandle(gClientServiceAepHandleUDP, methodId, testVariant, methodCallHandle, errorCallbackName);
      break;
    case sysvar::TC8_ETS::ETS_Method::clientServiceGetLastValueOfEventUDPMulticast:
      result = CreateMethodHandle(gClientServiceAepHandleUDP, methodId, testVariant, methodCallHandle, errorCallbackName);
      break;
    case sysvar::TC8_ETS::ETS_Method::clientServiceGetLastValueOfEventUDPUnicast:
      result = CreateMethodHandle(gClientServiceAepHandleUDP, methodId, testVariant, methodCallHandle, errorCallbackName);
      break;
    case sysvar::TC8_ETS::ETS_Method::get_InterfaceVersion:
      result = CreateMethodHandle(gClientServiceAepHandleUDP, methodId, testVariant, methodCallHandle, errorCallbackName);
      break;
    case sysvar::TC8_ETS::ETS_Method::get_TestFieldUINT8:
      result = CreateMethodHandle(gClientServiceAepHandleUDP, methodId, testVariant, methodCallHandle, errorCallbackName);
      break;
    case sysvar::TC8_ETS::ETS_Method::set_TestFieldUINT8:
      if(CreateMethodHandle(gClientServiceAepHandleUDP, methodId, testVariant, methodCallHandle, errorCallbackName))
        result = CheckResultOfProvideArgumentsCall("set_TestFieldUINT8", ProvideArgumentsForMethod_set_TestFieldUINT8(methodCallHandle));
      break;
    case sysvar::TC8_ETS::ETS_Method::get_TestFieldUINT8Array:
      result = CreateMethodHandle(gClientServiceAepHandleUDP, methodId, testVariant, methodCallHandle, errorCallbackName);
      break;
    case sysvar::TC8_ETS::ETS_Method::set_TestFieldUINT8Array:
      if(CreateMethodHandle(gClientServiceAepHandleUDP, methodId, testVariant, methodCallHandle, errorCallbackName))
        result = CheckResultOfProvideArgumentsCall("set_TestFieldUINT8Array", ProvideArgumentsForMethod_set_TestFieldUINT8Array(methodCallHandle));
      break;
    case sysvar::TC8_ETS::ETS_Method::get_TestFieldUINT8Reliable:
      if(CreateMethodHandle(gClientServiceAepHandleTCP, methodId, testVariant, methodCallHandle, errorCallbackName)==kTrue &&
         ETS_waitForConnectionToDutEstablished()==kTrue)
        result = kTrue;
      break;
    case sysvar::TC8_ETS::ETS_Method::set_TestFieldUINT8Reliable:
      if(CreateMethodHandle(gClientServiceAepHandleTCP, methodId, testVariant, methodCallHandle, errorCallbackName)==kTrue &&
         ETS_waitForConnectionToDutEstablished()==kTrue)
        result = CheckResultOfProvideArgumentsCall("set_TestFieldUINT8Reliable", ProvideArgumentsForMethod_set_TestFieldUINT8Reliable(methodCallHandle));
      break;
    default:
      write("Error: Method is not supported");
      break;
  }
  
  return result;
}

enum Bool SendMessageWithPatchedHeader(DWORD methodCallHandle, dword headerPatchVariant)
{
  IP_Endpoint destAddr;
  byte messageBuffer[1600];
  dword messageLength;
  dword msgHandle;
  long res;
  //write("### SendMessageWithPatchedHeader");
  messageLength = SomeIpSerializeMessage(methodCallHandle, elCount(messageBuffer), messageBuffer);
  if(PatchSomeIpHeader(headerPatchVariant, elCount(messageBuffer), messageBuffer, messageLength)==kFalse)
  {
    write("#### Patching header failed ####");
    return kFalse;
  }
  InitEndpoint(destAddr, syspar::DIface0Ip, @sysvar::TC8_ETS_Config::ETS_Port);
  
  msgHandle = SomeIpCreateMessage(messageLength, messageBuffer);
  SomeIpOutputMessage(gClientServiceAepHandleUDP, destAddr, msgHandle);
  
  return kTrue;
}

enum Bool TriggerETSMethodCall(dword methodId, dword testVariant, dword headerPatchVariant)
{
  char methodName[64];
  DWORD methodCallHandle;
  enum Bool result, expectResponse;
  result = CreateETSMethodCallAndProvideArguments(methodId, testVariant, methodCallHandle, expectResponse);
  if(result==kTrue)
  {
    if(headerPatchVariant!=sysvar::TC8_ETS::ETS_HeaderPatchVariant::Not_patched)
    {
      result = SendMessageWithPatchedHeader(methodCallHandle, headerPatchVariant);
    }
    else
    {
//      testWaitForTimeoutSilent(100);    
      if(SomeIpCallMethod(methodCallHandle)!=0)
      {
        result = kFalse;
        ReportSomeIpError("Call failed");
      }
      else if(expectResponse)
      {
        ++gMultiCallExpectedNumberOfResponses;
      }
    }
  }
 
  sysGetVariableDescriptionForValue(sysvar::TC8_ETS::ETS_Method, methodId, methodName, elCount(methodName));
  if(result==kTrue)
    write("Triggered method call %s at %.5f", methodName, timeNowFloat()/100000.0);
  else
    write("Could not triggered method call %s at %.5f", methodName, timeNowFloat()/100000.0);
  return result;
}

enum Bool PatchSomeIpHeader(dword headerPatchVariant, dword messageBufferLength, byte messageBuffer[], dword & messageLength)
{
  dword headerLength;
  enum Bool result;
  result = kTrue;
  
  switch(headerPatchVariant)
  {
    case sysvar::TC8_ETS::ETS_HeaderPatchVariant::Length_equals_0:
      messageBuffer[4] = messageBuffer[5] = messageBuffer[6] = messageBuffer[7] = 0;
      break;
    case sysvar::TC8_ETS::ETS_HeaderPatchVariant::Length_smaller_than_8:
      messageBuffer[4] = messageBuffer[5] = messageBuffer[6] = 0;
      messageBuffer[7] = 7;
      break;
    case sysvar::TC8_ETS::ETS_HeaderPatchVariant::Length_way_too_long:
      messageBuffer[4] = messageBuffer[5] =  0;
      messageBuffer[6] = messageBuffer[7] = 0xff;
      break;
    case sysvar::TC8_ETS::ETS_HeaderPatchVariant::Invalid_interface_version:
      messageBuffer[13] = atol(syspar::UnknownIntfVerMajSi1);
      break;
    case sysvar::TC8_ETS::ETS_HeaderPatchVariant::Length_decremented:
      headerLength = (((messageBuffer[4] << 8) | messageBuffer[5]) << 8 | messageBuffer[6]) << 8 | messageBuffer[7] - 1;
      messageBuffer[7] = headerLength & 0xff;
      headerLength = headerLength >> 8;
      messageBuffer[6] = headerLength & 0xff;
      headerLength = headerLength >> 8;
      messageBuffer[5] = headerLength & 0xff;
      headerLength = headerLength >> 8;
      messageBuffer[4] = headerLength & 0xff;
      break;
    case sysvar::TC8_ETS::ETS_HeaderPatchVariant::Type_REQUEST_NO_RETURN:
      messageBuffer[14] = 0x01;
      break;
    case sysvar::TC8_ETS::ETS_HeaderPatchVariant::MethodId_Wrong:
      messageBuffer[2] = (atol(syspar::UnknownMethodId) >> 8) & 0xff;
      messageBuffer[3] = atol(syspar::UnknownMethodId) & 0xff;
      break;
    case sysvar::TC8_ETS::ETS_HeaderPatchVariant::ServiceID_Wrong:
      messageBuffer[0] = (atol(syspar::UnknownServiceId) >> 8) & 0xff;
      messageBuffer[1] = atol(syspar::UnknownServiceId) & 0xff;
      break;
    case sysvar::TC8_ETS::ETS_HeaderPatchVariant::ProtocolVersion_Wrong:
      messageBuffer[12] = 2;
      break;
    default:
      result = kFalse;
      write("HeaderPatchVariant not handled");
      break;
  }
  
  return result;
}

void ReportSomeIpError(char msg[])
{
  char buffer[1024];
  if((SomeIpGetLastErrorText(elcount(buffer),buffer)) != 0)
  {
     write("%.5f %s: %s. SOME/IP IL error: %s", timeNowFloat()/100000.0, gETSProcessName , msg, buffer);
  }
  else
  {
    write(msg);
  }
}

// Returns the instance id of the DUT ETS server
dword GetInstanceIdOfConsumedETS()
{
  return syspar::SomeIp_ETS_DUT_InstanceId;
}

enum Bool CreateMethodHandle(dword aepHandle, dword methodId, dword testVariant, dword & methodCallHandle, char onMethodResponseTypeErrorFunctionName[])
{
  dword csiHandle=0;
  char callbackName[128];
  char methodName[64];
  char variantName[64];
  long rc;
 
  csiHandle = ETS_SomeIpCreateConsumedServiceInstance(aepHandle, @sysvar::TC8_ETS_Config::ETS_ServiceId, @sysvar::TC8_ETS_Config::ETS_DUT_ServiceInstanceId); 
  if(csiHandle==0)
    return kFalse;

  sysGetVariableDescriptionForValue(sysvar::TC8_ETS::ETS_Method, methodId, methodName, elCount(methodName));
  if(testVariant==sysvar::TC8_ETS::ETS_TestVariant::Standard)
  {
    snprintf(callbackName, elCount(callbackName), "OnMethodResponse_%s", methodName);
  }
  else
  {
    rc = sysGetVariableDescriptionForValue(sysvar::TC8_ETS::ETS_TestVariant, testVariant, variantName, elCount(variantName));
    if(rc!=0)
    {
      write("Error: converting testVariant '%d' to string failed, rc: %ld", testVariant, rc);
      return kFalse;
    }
    snprintf(callbackName, elCount(callbackName), "OnMethodResponse_%s_%s", methodName, variantName);
  }
  //writeEx(-3,1, "### Callback name: %s , error callback name: %s", callbackName, onMethodResponseTypeErrorFunctionName);
  
  // CANoe 14 introduced a new variant of SomeIpCreateMethodCall
  // To prevent compile errors in earlier versions, we need to check for the version
  // The test might fail with earlier version (depending on the expectations of the testcase),
  // therefore the affected test needs this check too on a higher level to abort the test
  #if (TOOL_MAJOR_VERSION < 14) 
    methodCallHandle = SomeIpCreateMethodCall(csiHandle, methodId, callbackName);
  #else
    methodCallHandle = SomeIpCreateMethodCall(csiHandle, methodId, callbackName, onMethodResponseTypeErrorFunctionName);
  #endif
  
  if(SomeIpGetLastError()!=0)
  {
    ReportSomeIpError("Creation of method call handle failed");
    return kFalse;
  }

  return kTrue;
}

enum Bool CreateMethodHandleFireAndForget(dword aepHandle, dword methodId, dword & methodCallHandle)
{
  dword csiHandle;
  long rc;

  csiHandle = ETS_SomeIpCreateConsumedServiceInstance(aepHandle, @sysvar::TC8_ETS_Config::ETS_ServiceId, @sysvar::TC8_ETS_Config::ETS_DUT_ServiceInstanceId); 
  if(csiHandle==0)
    return kFalse;

  methodCallHandle = SomeIpCreateMethodCall(csiHandle, methodId); 
  if(SomeIpGetLastError()!=0)
  {
    ReportSomeIpError("Creation of method call handle failed");
    return kFalse;
  }

  return kTrue;
}

enum Bool CheckResultOfProvideArgumentsCall(char methodName[], enum Bool success)
{
  char buffer[128];
  if(success==kFalse)
  {
    snprintf(buffer, elcount(buffer), "Error: Provide arguments for method %s failed", methodName);
    ReportSomeIpError(buffer);
  }
  return success;
}

export testfunction ETS_WaitFor_ETSServiceStatusUp(dword timeoutMs)
{
  //writeEx(-3,1,"waiting for ETS service status up, timeout %d ms", timeoutMs);
  WaitForETSServiceStatus(1, timeoutMs);
  //writeEx(-3,1,"waiting for ETS service status up done");
}

export testfunction ETS_WaitFor_ETSServiceStatusDown(dword timeoutMs)
{
  WaitForETSServiceStatus(0, timeoutMs);
  testWaitForTimeout(50);  // give SOME/IP-IL some time before we continue to prevent race conditions
  releaseAllCreatedCSIs();
  testWaitForTimeout(syspar::SomeIp_ETS_WaitDurationForTcpConnectionClosed_ms);
}

void WaitForETSServiceStatus(LONG status, dword timeoutMs)
{
  char messagesOk[2][32]  = { "Service status down reached", "Service status up reached" };
  char messagesNOk[2][32] = { "Service status down not reached", "Service status up not reached" };
  long result;
  if(gETSStatus!=-1 && gETSStatus==status)
    return;  // status already reached
  
  gIsWaitingForETSService = 1;
  gETSExpectedStatus = status;
  result = testWaitForTextEvent("ETSAllWaitNotificationsReached", timeoutMs);
  gIsWaitingForETSService = 0;
 
  if(result!=1)
    testStepFail(messagesNOk[status]);
  else
    testStepPass(messagesOk[status]);
}

void OnSomeIpSDClientServiceStatusChanged(dword serviceId, dword instanceId, LONG status )
{
  if(serviceId==syspar::SomeIp_ETS_ServiceId)
    gETSStatus = status;
  if(gIsWaitingForETSService && serviceId==syspar::SomeIp_ETS_ServiceId && instanceId==@sysvar::TC8_ETS_Config::ETS_DUT_ServiceInstanceId &&
     status==gETSExpectedStatus && isTimerActive(gWaitConditionReachedTimer)==0)
  {
    setTimer(gWaitConditionReachedTimer, 0);
  }
}

