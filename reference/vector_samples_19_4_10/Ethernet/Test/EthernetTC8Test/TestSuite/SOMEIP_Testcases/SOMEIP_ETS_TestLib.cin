export testfunction ETS_SendNotification_Subscribe_WithIncrementedNbrOfOpt1(dword sessionId, dword instanceId, dword evgId, char ttl[], char destinationIP[])
{
  const dword IDX_NbrOfOpt1 = 11; // payload starts with field 'flags'
  int i;
  long dataLen;
  byte buffer[1500], nbrOfOpt1;
  dword handle;
  
  IP_Endpoint sourceEndpoint, destinationEndpoint;
  if(InitEndpoint(sourceEndpoint, syspar::IpAddressTester, atol(syspar::SomeIpServiceDiscoveryPort))!=kTrue ||
     InitEndpoint(destinationEndpoint, destinationIP, atol(syspar::SomeIpServiceDiscoveryPort))!=kTrue)
  {
    testStepFail("ETS_SendNotification_Subscribe_WithIncrementedNbrOfOpt1", "Creation of endpoints failed");
    return;
  }
  
  if(ETS_CreateSomeIpSDNotification(handle, sourceEndpoint.Address, syspar::SomeIp_ETS_ServiceId, syspar::Wildcard, "Subscribe",
    instanceId, syspar::Wildcard, ttl, syspar::Wildcard, sessionId, gPortForSubscribeWithoutCSI, "EventgroupID", evgId, getEndpointSelectorForEVG(evgId), kTrue)==kFalse)
  {
    testStepFail("ETS_SendNotification_Subscribe_WithIncrementedNbrOfOpt1", "Creation of notification failed");
    return;
  }

  dataLen = SomeIpGetData(handle, elcount(buffer), buffer);

  nbrOfOpt1 = (buffer[IDX_NbrOfOpt1] >> 4);
  nbrOfOpt1 += 1;
  buffer[IDX_NbrOfOpt1] = (nbrOfOpt1 << 4) | (buffer[IDX_NbrOfOpt1] & 0xF);
  
  SomeIpSetData(handle, dataLen, buffer);

  if(ETS_OutputSomeIpSDNotification(handle, sourceEndpoint, destinationEndpoint)==kFalse)
  {
    testStepFail("ETS_SendNotification_Subscribe_WithIncrementedNbrOfOpt1", "Sending of notification failed");
  }
}

export testfunction ETS_SendNotification_Subscribe(dword sessionId, dword instanceId, dword evgId, char destinationIP[],
  dword index1stOptions, dword index2ndOptions, dword numOfOptions1, dword numOfOptions2)
{
  dword IDX_Index1stOptions=9, IDX_Index2ndOptions=10, IDX_NbrOfOptions = 11; // payload starts with field 'flags'
  int i;
  long dataLen;
  byte buffer[1500], nbrOfOpt1;
  dword handle;
  
  IP_Endpoint sourceEndpoint, destinationEndpoint;
  if(InitEndpoint(sourceEndpoint, syspar::IpAddressTester, atol(syspar::SomeIpServiceDiscoveryPort))!=kTrue ||
     InitEndpoint(destinationEndpoint, destinationIP, atol(syspar::SomeIpServiceDiscoveryPort))!=kTrue)
  {
    testStepFail("ETS_SendNotification_Subscribe", "Creation of endpoints failed");
    return;
  }
  
  if(ETS_CreateSomeIpSDNotification(handle, sourceEndpoint.Address, syspar::SomeIp_ETS_ServiceId, syspar::Wildcard, "Subscribe",
    instanceId, syspar::Wildcard, syspar::SomeIp_ETS_Subscribe_TTL, syspar::Wildcard, sessionId, gPortForSubscribeWithoutCSI, "EventgroupID", evgId,
    getEndpointSelectorForEVG(evgId), kTrue)==kFalse)
  {
    testStepFail("ETS_SendNotification_Subscribe", "Creation of notification failed");
    return;
  }

  dataLen = SomeIpGetData(handle, elcount(buffer), buffer);

  buffer[IDX_Index1stOptions] = (index1stOptions & 0xFF);
  buffer[IDX_Index2ndOptions] = (index2ndOptions & 0xFF);
  buffer[IDX_NbrOfOptions] = ((numOfOptions1 & 0xF) << 4) | (numOfOptions2 & 0xF);
  
  SomeIpSetData(handle, dataLen, buffer);

  if(ETS_OutputSomeIpSDNotification(handle, sourceEndpoint, destinationEndpoint)==kFalse)
  {
    testStepFail("ETS_SendNotification_Subscribe", "Sending of notification failed");
  }
}

export testfunction ETS_SendNotification_Subscribe_WithInvalidOptionType(dword sessionId, dword instanceId, dword evgId, char destinationIP[])
{
  const dword OFFSET_FIELD_EntryLength = 4; // payload starts with field 'flags'
  const dword SIZE_FIELD_LengthOfEntriesArray = 4;
  const dword SIZE_FIELD_LengthOfOptionsArray = 4;
  const dword SIZE_FIELD_OptionLength = 2;
  int i;
  long dataLen;
  byte buffer[1500];
  dword handle, entriesLength, offsetOfFieldOptionType;
  
  IP_Endpoint sourceEndpoint, destinationEndpoint;
  if(InitEndpoint(sourceEndpoint, syspar::IpAddressTester, atol(syspar::SomeIpServiceDiscoveryPort))!=kTrue ||
     InitEndpoint(destinationEndpoint, destinationIP, atol(syspar::SomeIpServiceDiscoveryPort))!=kTrue)
  {
    testStepFail("Creation of endpoints failed");
    return;
  }
  
  if(ETS_CreateSomeIpSDNotification(handle, sourceEndpoint.Address, syspar::SomeIp_ETS_ServiceId, syspar::Wildcard, "Subscribe",
    instanceId, syspar::Wildcard, syspar::SomeIp_ETS_Subscribe_TTL, syspar::Wildcard, sessionId, gPortForSubscribeWithoutCSI, "EventgroupID", evgId,
    getEndpointSelectorForEVG(evgId), kTrue)==kFalse)
  {
    testStepFail("ETS_SendNotification_Subscribe_WithInvalidOptionType", "Creation of notification failed");
    return;
  }

  dataLen = SomeIpGetData(handle, elcount(buffer), buffer);

  entriesLength = getBigEndianDWORD(buffer, OFFSET_FIELD_EntryLength);

  offsetOfFieldOptionType = OFFSET_FIELD_EntryLength + SIZE_FIELD_LengthOfEntriesArray +
    entriesLength + SIZE_FIELD_LengthOfOptionsArray + SIZE_FIELD_OptionLength;
  buffer[offsetOfFieldOptionType] = 0x77;
  
  SomeIpSetData(handle, dataLen, buffer);

  if(ETS_OutputSomeIpSDNotification(handle, sourceEndpoint, destinationEndpoint)==kFalse)
  {
    testStepFail("ETS_SendNotification_Subscribe_WithInvalidOptionType", "Sending of notification failed");
  }
}

export testfunction ETS_SendNotification_Subscribe_WithUnreferencedOption(dword sessionId, dword instanceId, char destinationIP[])
{
  dword OPTION_FIELD_TYPE_OFFSET = 2, OPTION_FIELD_RESERVED_OFFSET=3, OPTION_FIELD_VALUE_OFFSET = 4, SIZE_FIELD_LengthOfOptionsArray = 4;
  byte OPTION_TYPE_CONFIGURATION = 0x01;
  dword evgId=2; 
  char cfgStr[6] = "abc=5";
  dword optionArrayLengthIndex, optionsLen, indexOfAppendedOption, addedSize;

  long payloadLen;
  byte payload[1500];
  dword handle;
  
  IP_Endpoint sourceEndpoint, destinationEndpoint;
  if(InitEndpoint(sourceEndpoint, syspar::IpAddressTester, atol(syspar::SomeIpServiceDiscoveryPort))!=kTrue ||
     InitEndpoint(destinationEndpoint, destinationIP, atol(syspar::SomeIpServiceDiscoveryPort))!=kTrue)
  {
    testStepFail("Creation of endpoints failed");
    return;
  }
  
  addedSize = OPTION_FIELD_VALUE_OFFSET + strlen(cfgStr) + 1;
  
  if(ETS_CreateSomeIpSDNotification(handle, sourceEndpoint.Address, syspar::SomeIp_ETS_ServiceId, syspar::Wildcard, "Subscribe",
    instanceId, syspar::Wildcard, syspar::SomeIp_ETS_Subscribe_TTL, syspar::Wildcard, sessionId, gPortForSubscribeWithoutCSI, "EventgroupID", evgId,
    getEndpointSelectorForEVG(evgId), kTrue)==kFalse)
  {
    testStepFail("ETS_SendNotification_Subscribe_WithUnreferencedOption", "Creation of notification failed");
    return;
  }  
  
  payloadLen = SomeIpGetData(handle, elcount(payload), payload);

  if(getIndexOfOptionsArrayLength(payload, payloadLen, optionArrayLengthIndex, optionsLen)==kFalse)
  {
    testStepFail("ETS_SendNotification_Subscribe_WithUnreferencedOption", "Failed to patch payload");
    return;
  }
  indexOfAppendedOption = optionArrayLengthIndex + optionsLen + SIZE_FIELD_LengthOfOptionsArray;
  // append a configuration option
  setBigEndianWORD(payload, indexOfAppendedOption, 1 + strlen(cfgStr) + 1);                              // length
  payload[indexOfAppendedOption + OPTION_FIELD_TYPE_OFFSET] = OPTION_TYPE_CONFIGURATION;                 // type
  payload[indexOfAppendedOption + OPTION_FIELD_RESERVED_OFFSET] = 0x00;                                  // reserved
  memcpy_off(payload, indexOfAppendedOption + OPTION_FIELD_VALUE_OFFSET, cfgStr, 0, strlen(cfgStr) + 1); // value
  // correct the length of the options array
  setBigEndianDWORD(payload, optionArrayLengthIndex, optionsLen + addedSize);
  
  SomeIpSetData(handle, payloadLen + addedSize, payload);

  if(ETS_OutputSomeIpSDNotification(handle, sourceEndpoint, destinationEndpoint)==kFalse)
  {
    testStepFail("ETS_SendNotification_Subscribe_WithUnreferencedOption", "Sending of notification failed");
  }
}

export testfunction ETS_SendNotification_Subscribe_WithUnusedOptionData(dword sessionId, dword instanceId, char destinationIP[], enum Bool correctLength)
{
  dword HEADER_FIELD_LENGTH_OFFSET = 4, HEADER_FIELD_OPTION_ARRAY_LENGTH_OFFSET = 40, HEADER_FIELD_MESSAGE_ID_LENGTH = 4, HEADER_FIELD_LENGTH_LENGTH = 4;
  byte extraPayload[5] = { 0x30, 0x30 , 0x3a, 0x30, 0x31 };
  dword addedPayloadSize = 5; // elcount(extraPayload);
  dword evgId = 2;
  byte messageBuffer[1600];
  dword messageLength, lengthValue;
  dword msgHandle;
  dword handle;
  
  IP_Endpoint sourceEndpoint, destinationEndpoint;
  if(InitEndpoint(sourceEndpoint, syspar::IpAddressTester, atol(syspar::SomeIpServiceDiscoveryPort))!=kTrue ||
     InitEndpoint(destinationEndpoint, destinationIP, atol(syspar::SomeIpServiceDiscoveryPort))!=kTrue)
  {
    testStepFail("Creation of endpoints failed");
    return;
  }
  
  if(ETS_CreateSomeIpSDNotification(handle, sourceEndpoint.Address, syspar::SomeIp_ETS_ServiceId, syspar::Wildcard, "Subscribe",
      instanceId, syspar::Wildcard, syspar::SomeIp_ETS_Subscribe_TTL, syspar::Wildcard, sessionId, gPortForSubscribeWithoutCSI, "EventgroupID", evgId,
      getEndpointSelectorForEVG(evgId), kTrue)==kFalse)
  {
    testStepFail("ETS_SendNotification_Subscribe_WithUnusedOptionData", "Creation of notification failed");
    if(handle)
      SomeIpReleaseMessage(handle);
    return;
  }

  messageLength = SomeIpSerializeMessage(handle, elCount(messageBuffer), messageBuffer);
  
  memcpy_off(messageBuffer, messageLength, extraPayload, 0, addedPayloadSize);
  messageLength += addedPayloadSize;
  
  if(correctLength)
  {
    lengthValue = getBigEndianDWORD(messageBuffer, HEADER_FIELD_LENGTH_OFFSET);
    setBigEndianDWORD(messageBuffer, HEADER_FIELD_LENGTH_OFFSET, lengthValue + addedPayloadSize);
  }
  
  msgHandle = SomeIpCreateMessage(messageLength, messageBuffer);
  //SomeIpOutputMessage(gClientServiceAepHandleUDP, ipGetAddressAsNumber(destinationIP), atol(syspar::SomeIpServiceDiscoveryPort), msgHandle);
  InitEndpoint(destinationEndpoint, destinationIP, atol(syspar::SomeIpServiceDiscoveryPort));
  SomeIpOutputMessage(gClientServiceAepHandleUDP, destinationEndpoint, msgHandle);

  SomeIpReleaseMessage(handle);

}

