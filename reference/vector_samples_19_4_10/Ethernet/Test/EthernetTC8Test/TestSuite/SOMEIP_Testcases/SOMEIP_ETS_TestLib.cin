export testfunction ETS_SendNotifications_FindService_WaitForOfferWithSessionIdWrapAround(dword instanceId)
{
  dword offerServiceSessionId;
  enum Bool success;
  char instanceIdStr[16];
  snprintf(instanceIdStr, elcount(instanceIdStr), "%d", instanceId);
  
  ETS_StartSendingNotifications_FindService_NoLimit(1, instanceId);
  
  do
  {
    success=WaitFor_OfferService_ExtractSessionId("ETS_SendNotifications_FindService_WaitForWrapAround", instanceIdStr);
    if(success)
      offerServiceSessionId=gExtractingParameters[0].Value;
  }
  while(success==kTrue && offerServiceSessionId<65535);
  
  if(success)
  {
    success=WaitFor_OfferService_ExtractSessionId("ETS_SendNotifications_FindService_WaitForWrapAround", instanceIdStr);
    offerServiceSessionId=gExtractingParameters[0].Value;
  }

  cancelTimer(gTriggerFindServiceTimer);

  if(success && offerServiceSessionId==1)
    testStepPass("ETS_SendNotifications_FindService_WaitForWrapAround", "SessionId wrap-around detected");
  else
    testStepFail("ETS_SendNotifications_FindService_WaitForWrapAround", "No sessionId wrap-around detected, expected sessionId: 1, instead of %d", offerServiceSessionId);
}

export testfunction ETS_WaitFor_AndDropSendingSubscribeNAck()
{
  gDropMatchingSomeIpMessage = 1;

  ETS_InternalWaitForSOMEIPNotification("ETS_WaitFor_AndDropSendingSubscribeNAck",
    syspar::ParamListenTimeMs,
    SomeIpMessageTypeNotification,
    SubscribeAck,
    syspar::SomeIp_ETS_ServiceId, // entryServiceId
    "0", // entryTTL
    syspar::Wildcard, // serviceId
    syspar::Wildcard, // returnCode
    syspar::Wildcard, // methodId
    "Entry[0].SubscribeAck.InstanceID", syspar::SomeIp_ETS_Tester_InstanceId, kEquals, // first token
    "DestinationAddress", syspar::DIface0Ip, kEquals, // second token
    syspar::UdpProtocol, syspar::Wildcard,
    kAnswerExpected
  );
  
  gDropMatchingSomeIpMessage = 0;
}

export testfunction ETS_OpenTcpEndpointFor_Offer(dword port)
{
  IP_Endpoint endpoint;
  
  InitEndpoint(endpoint, syspar::IpAddressTester, port);
  endpoint.SetToTcp();
  gTcpAepForOfferEvent = ETSOpenLocalApplicationEndpoint(endpoint);
  if(gTcpAepForOfferEvent==0)
  {
    ReportSomeIpError("ETS_OpenTcpEndpointFor_Offer open failed");
    testStepFail("ETS_OpenTcpEndpointFor_Offer", "SomeIp error");
    return;
  }
  else
  {
    SomeIpTCPListen(gTcpAepForOfferEvent);
  }
}

export testfunction ETS_CloseTcpEndpointFor_Offer()
{
  ETSCloseLocalApplicationEndpoint(gTcpAepForOfferEvent);
  gTcpAepForOfferEvent=0;
}

export testfunction ETS_OpenUdpEndpointFor_SendEvent(dword port)
{
  IP_Endpoint endpoint;
  if(gUdpAepForSendEvent)
    ETSCloseLocalApplicationEndpoint(gUdpAepForSendEvent);
  
  InitEndpoint(endpoint, syspar::IpAddressTester, port);
  endpoint.SetToUdp();
  gUdpAepForSendEvent =  ETSOpenLocalApplicationEndpoint(endpoint);
  if(gUdpAepForSendEvent==0)
  {
    ReportSomeIpError("ETS_OpenUdpEndpointFor_SendNotifications open failed");
    testStepFail("ETS_OpenUdpEndpointFor_SendNotifications", "SomeIp error");
    return;
  }
}

export testfunction ETS_CloseUdpEndpointFor_SendEvent()
{
  ETSCloseLocalApplicationEndpoint(gUdpAepForSendEvent);
  gUdpAepForSendEvent=0;
}

export testfunction ETS_SendEvent_TestEventUINT8_ToExtractedPort(dword sessionId, dword instanceId, char destinationIP[])
{
  IP_Endpoint destinationEndpoint;
  dword messageId, protocolVersion=0x01, interfaceVersion=0x01, messageType=SomeIpMessageTypeNotification, returnCode=0x00;
  dword requestId, notificationHandle;
  byte payload[1] = { 12 };
  long result;
  enum Bool isIpv6;
  byte ipv6Dest[16];

  requestId = (1 << 16) + sessionId;
  messageId = (syspar::SomeIp_ETS_ServiceId << 16) | (EVENT_ID_TestEventUINT8);
  
  notificationHandle = SomeIpCreateMessage(messageId, requestId, protocolVersion, interfaceVersion, messageType, returnCode);
  if(notificationHandle==0)
  {
    testStepFail("ETS_SendEvent_TestEventUINT8", "SomeIpCreateMessage failed");
    return;
  }

  SomeIpSetData(notificationHandle, elcount(payload), payload);
 
  SetBusContext(GetBusNameContext("Ethernet_1"));
  
  InitEndpoint(destinationEndpoint, destinationIP, gExtractedPort);
  result = SomeIpOutputMessage(gUdpAepForSendEvent, destinationEndpoint, notificationHandle);

  if(result!=0)
  {
    write("### Send TestEventUINT8 failed");
    testStepFail("ETS_SendEvent_TestEventUINT8", "Post message failed");
  }

  if(SomeIpReleaseMessage(notificationHandle)!=0)
  {
    testStepFail("ETS_SendEvent_TestEventUINT8", "Release message failed");
  }
  notificationHandle=0;
}
