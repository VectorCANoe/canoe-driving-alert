export testfunction ETS_CallMethod_ClientServiceSubscribeEventgroup(dword delaySeconds, dword durationSeconds)
{
  DWORD methodCallHandle, errorCode;
    
  if(CreateMethodHandleFireAndForget(gClientServiceAepHandleUDP, sysvar::TC8_ETS::ETS_Method::clientServiceSubscribeEventgroup, methodCallHandle)==kFalse)
  {
      testStepFail("ETS_CallMethod_ClientServiceSubscribeEventgroup", "Creation of method call handle failed");
      return;
  }
  
  if(SetMethodArgumentDWord(methodCallHandle, gMethodArgumentName_clientServiceSubscribeEventgroup_REQ_delay, delaySeconds, errorCode)==kFalse ||
     SetMethodArgumentDWord(methodCallHandle, gMethodArgumentName_clientServiceSubscribeEventgroup_REQ_duration, durationSeconds, errorCode)==kFalse )
  {
    testStepFail("ETS_CallMethod_ClientServiceSubscribeEventgroup", "Setting delay argument failed");
    return;
  }

  testWaitForTimeoutSilent(1);
      
  if(SomeIpCallMethod(methodCallHandle)!=0)
  {
    ReportSomeIpError("Call of ClientServiceSubscribeEventgroup failed");
    testStepFail("ETS_CallMethod_ClientServiceSubscribeEventgroup", "Method call ClientServiceSubscribeEventgroup failed");
  }
}
  
