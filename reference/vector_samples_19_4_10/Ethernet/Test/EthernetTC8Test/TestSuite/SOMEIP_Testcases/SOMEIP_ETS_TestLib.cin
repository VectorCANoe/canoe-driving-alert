export testfunction ETS_SendNotification_Subscribe_SetOptionReservedField(dword sessionId, dword instanceId, dword evgId, char destinationIP[])
{
  byte OPTION_SIZE_NOT_COVERED_BY_LENGTH=3, OPTION_RESERVED_FIELD_OFFSET=3;
  long dataLen;
  byte buffer[1500];
  enum Bool patched;
  dword handle;
  dword EventGroupID = 2;
  dword indexOfFirstOption, optionsLen, optionOffset, optionIndex, optionLength;
  
  IP_Endpoint sourceEndpoint, destinationEndpoint;
  if(InitEndpoint(sourceEndpoint, syspar::IpAddressTester, atol(syspar::SomeIpServiceDiscoveryPort))!=kTrue ||
     InitEndpoint(destinationEndpoint, destinationIP, atol(syspar::SomeIpServiceDiscoveryPort))!=kTrue)
  {
    testStepFail("ETS_SendNotification_Subscribe_SetOptionReservedField", "Creation of endpoints failed");
    return;
  }
  
  if(ETS_CreateSomeIpSDNotification(handle, sourceEndpoint.Address, syspar::SomeIp_ETS_ServiceId,
    syspar::Wildcard, "Subscribe", instanceId, syspar::Wildcard, syspar::SomeIp_ETS_Subscribe_TTL, syspar::Wildcard, sessionId,
    gPortForSubscribeWithoutCSI, "EventgroupID", EventGroupID, getEndpointSelectorForEVG(EventGroupID), kTrue)==kFalse)
  {
    testStepFail("ETS_SendNotification_Subscribe_SetOptionReservedField", "Creation of notification failed");
    if(handle)
      SomeIpReleaseMessage(handle);
    return;
  }

  dataLen = SomeIpGetData(handle, elcount(buffer), buffer);
  patched=kFalse;
  
  if(getIndexOfFirstOption(buffer, dataLen, indexOfFirstOption, optionsLen)==kTrue)
  {
    optionOffset=0;
    do
    {
      optionIndex = indexOfFirstOption + optionOffset;
      // search for the IPv4 or IPv6 option
      if(isOptionIPv4Endpoint(buffer, optionIndex)==kTrue || isOptionIPv6Endpoint(buffer, optionIndex)==kTrue)
      {
        buffer[optionIndex+OPTION_RESERVED_FIELD_OFFSET] = 0xFF;
        patched=kTrue;
      }
      else
      {
        optionLength = getBigEndianWORD(buffer, optionIndex);
        if(optionLength==0)
        {
          testStepFail("ETS_SendNotification_Subscribe_SetOptionReservedField", "Message contains option with length 0");
          return;
        }
        optionOffset += optionLength + OPTION_SIZE_NOT_COVERED_BY_LENGTH;
      }
    }
    while(patched==kFalse && optionOffset<optionsLen);
    
    if(patched==kFalse)
    {
      testStepFail("ETS_SendNotification_Subscribe_SetOptionReservedField", "IP Endpoint Option not found in message");
      return;
    } 
   
    SomeIpSetData(handle, dataLen, buffer);

    if(ETS_OutputSomeIpSDNotification(handle, sourceEndpoint, destinationEndpoint)==kFalse)
    {
      testStepFail("ETS_SendNotification_Subscribe_SetOptionReservedField", "Sending of notification failed");
    }
  }
  else
  {
    testStepFail("ETS_SendNotification_Subscribe_SetOptionReservedField", "Message contains no options");
    return;
  }

}

