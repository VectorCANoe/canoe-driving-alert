enum Bool ETS_waitForTCP(char sourceIP[], char destIP[], dword flags, enum CheckType check )
{
  long waitResult;
  
  SetBusContext(GetBusNameContext("Ethernet_1"));
  //PrepareWaitForIp(destIP, sourceIP, PROTOCOL_TCP);
  PrepareWaitForIp(destIP, sourceIP);
  InternalAddExpectedParameter("tcp", "flags", flags, check);

  gObservingEthPackets = kTrue;
  StartObservationOfIncomingPackets(kAnswerExpected);
  waitResult = WaitForIncomingPacket(kAnswerExpected, 150);
  gObservingEthPackets = kFalse;  
  InternalClearAllParameters();
  
  if(waitResult != 0)
    return kFalse;
   
  return kTrue;
}

