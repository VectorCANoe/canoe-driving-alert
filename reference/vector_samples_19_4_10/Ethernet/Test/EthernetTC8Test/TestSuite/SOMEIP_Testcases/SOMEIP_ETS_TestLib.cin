enum Bool WaitFor_OfferService_ExtractSessionId(char callerFunctionName[], char instanceIdStr[])
{
  return ETS_InternalWaitForSOMEIPNotification(callerFunctionName, syspar::ParamListenTimeMs,
      SomeIpMessageTypeNotification, OfferService, syspar::SomeIp_ETS_ServiceId, // entryServiceId
      syspar::Wildcard, // entryTTL
      syspar::Wildcard, // serviceId
      syspar::Wildcard, // returnCode
      syspar::Wildcard, // methodId
     "Entry[0].OfferService.InstanceID", instanceIdStr, kEquals, // first token
     "DestinationAddress", syspar::IpAddressTester, kEquals, // second token
    syspar::UdpProtocol, "SessionId",
    kAnswerExpected
  );
}

