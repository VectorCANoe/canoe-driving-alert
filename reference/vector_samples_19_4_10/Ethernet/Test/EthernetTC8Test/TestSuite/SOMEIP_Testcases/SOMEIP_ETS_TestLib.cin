enum Bool ETS_InternalWaitForSOMEIPNotification(char callerFunctionName[], 
  long timeout,
  enum SomeIpMessageType messageType,
  enum SomeIpEntryType entryType,
  int entryServiceId,
  char entryTTL[],
  char serviceId[],
  char returnCode[],
  char methodId[],
  char firstToken[],
  char firstTokenValue[],
  enum CheckType firstTokenCheckType,
  char secondToken[],
  char secondTokenValue[],
  enum CheckType secondTokenCheckType,
  int protocol,
  char extractSomeIpToken[],
  enum ExpectedResult expectedResult
  )
{
  return ETS_InternalWaitForSOMEIPNotification(callerFunctionName, timeout,
           messageType, entryType, entryServiceId, entryTTL,
           serviceId, returnCode, methodId,
           firstToken, firstTokenValue, firstTokenCheckType,
           secondToken, secondTokenValue, secondTokenCheckType,
           syspar::Wildcard, syspar::Wildcard, kEquals, // thirdToken
           protocol, extractSomeIpToken, expectedResult);
}

enum Bool ETS_InternalWaitForSOMEIPNotification(char callerFunctionName[], 
  long timeout,
  enum SomeIpMessageType messageType,
  enum SomeIpEntryType entryType,
  int entryServiceId,
  char entryTTL[],
  char serviceId[],
  char returnCode[],
  char methodId[],
  char firstToken[],
  char firstTokenValue[],
  enum CheckType firstTokenCheckType,
  char secondToken[],
  char secondTokenValue[],
  enum CheckType secondTokenCheckType,
  char thirdToken[],
  char thirdTokenValue[],
  enum CheckType thirdTokenCheckType,
  int protocol,
  char extractSomeIpToken[],
  enum ExpectedResult expectedResult
  )
{
  enum Bool result;
  char temp[100];

  gIsWaitingForSOMEIPMessage = 1;
  SetBusContext(GetBusNameContext("Ethernet_1"));
   
  InternalAddExpectedParameter("SOME/IP", "MessageType", messageType);
  
  if(!IsWildcard(extractSomeIpToken))
  {
    gExtractingParameters.clear();
    gExtractingParametersCount=0;
    InternalSetExtractedParameter("SOME/IP", extractSomeIpToken, kExtractInt64);
  }
  
  if(entryType != SomeIpEntryNull)
  {
    InternalAddExpectedParameter("SOME/IP", "ServiceId", 65535, kEquals);
    InternalAddExpectedParameter("SOME/IP", "Entry[0]", entryType);
    snprintf(temp, elcount(temp), "Entry[0].%s.TTL", entryType.name());
    if(IsWildcard(entryTTL))
    {
     InternalAddExpectedParameter("SOME/IP", temp, 0, kGreaterThan);
    }
    else
    {
      InternalAddExpectedParameter("SOME/IP", temp, ConvertStringValueToInt64(entryTTL));
    }
    if(entryServiceId != -1)
    {
      snprintf(temp, elcount(temp), "Entry[0].%s.ServiceID", entryType.name());
      InternalAddExpectedParameter("SOME/IP", temp, entryServiceId);
    }
  }

  if(!IsWildcard(serviceId))
  {
    InternalAddExpectedParameter("SOME/IP", "ServiceId", ConvertStringValueToInt64(serviceId));
  }
  if(!IsWildcard(methodId))
  {
    InternalAddExpectedParameter("SOME/IP", "MethodId", (0x7FFF & ConvertStringValueToInt64(methodId)));
  }
  if(!IsWildcard(returnCode))
  {
    InternalAddExpectedParameter("SOME/IP", "ReturnCode", ConvertStringValueToInt64(returnCode));
  }
  
  AddTokenAsExpectedParameter(firstToken, firstTokenValue, firstTokenCheckType);
  AddTokenAsExpectedParameter(secondToken, secondTokenValue, secondTokenCheckType);
  AddTokenAsExpectedParameter(thirdToken, thirdTokenValue, thirdTokenCheckType);
  
  StartObservationOfIncomingPackets(expectedResult);

  result = InternalWaitForIncomingPacket(callerFunctionName, timeout, expectedResult);

  InternalClearAllParameters();
  gIsWaitingForSOMEIPMessage = 0;  
  
  return result;
}

void ETS_InternalWaitForSOMEIPError(char callerFunctionName[], long timeout, dword methodId, dword expectedError, enum Bool errorIsOptional)
{
  dword aep;
  long result;
  char passVerb[32];
  char failVerb[32];
  dword port;
  char temp[100];
  enum ExpectedResult expectedResult;
  
  SetBusContext(GetBusNameContext("Ethernet_1"));

  //InternalAddExpectedParameter("SOME/IP", "ServiceId", syspar::SomeIp_ETS_ServiceId);
  //InternalAddExpectedParameter("SOME/IP", "MethodId", (0x7FFF & methodId));
  
  if(errorIsOptional)
  {
    // There are two types of unexpected messages
    // 1. wrong message type => group 0
    InternalAddExpectedParameter("SOME/IP", "ServiceId", syspar::SomeIp_ETS_ServiceId, kEquals, 0);
    InternalAddExpectedParameter("SOME/IP", "MethodId", (0x7FFF & methodId), kEquals, 0 );
    InternalAddExpectedParameter("SOME/IP", "MessageType", SomeIpMessageTypeError, kNotEquals, 0);
    
    // 2. correct message type, but wrong return code => group 1
    InternalAddExpectedParameter("SOME/IP", "ServiceId", syspar::SomeIp_ETS_ServiceId, kEquals, 1);
    InternalAddExpectedParameter("SOME/IP", "MethodId", (0x7FFF & methodId), kEquals, 1);
    InternalAddExpectedParameter("SOME/IP", "MessageType", SomeIpMessageTypeError, kEquals, 1);
    InternalAddExpectedParameter("SOME/IP", "ReturnCode", expectedError, kNotEquals, 1);
    expectedResult = kNoAnswerExpected;
  } 
  else // There is just one expected type of message
  {
    InternalAddExpectedParameter("SOME/IP", "MessageType", SomeIpMessageTypeError, kEquals);
    InternalAddExpectedParameter("SOME/IP", "ReturnCode", expectedError, kEquals);
    expectedResult = kAnswerExpected;
  }
  
  gIsWaitingForSOMEIPMessage = 1;
  StartObservationOfIncomingPackets(expectedResult);
  
  result = InternalWaitForIncomingPacket(callerFunctionName, timeout, expectedResult);

  InternalClearAllParameters();
  gIsWaitingForSOMEIPMessage = 0;  
}

void ETS_InternalWaitForNotificationWithMethodId(char callerFunctionName[], long timeout, dword instanceId, dword methodId, enum Bool answerExpected)
{
  enum SomeIpMessageType messageType = SomeIpMessageTypeNotification;
  enum ExpectedResult expectedResult;
  enum Bool result;
  char passVerb[32];
  char failVerb[32];
  char temp[100];
  
  expectedResult = (answerExpected==kFalse) ? kNoAnswerExpected : kAnswerExpected;
  
  gIsWaitingForSOMEIPMessage = 1;
  SetBusContext(GetBusNameContext("Ethernet_1"));

  InternalAddExpectedParameter("SOME/IP", "MessageType", messageType);
  InternalAddExpectedParameter("SOME/IP", "ServiceId", syspar::SomeIp_ETS_ServiceId);
  InternalAddExpectedParameter("SOME/IP", "MethodId", (0x7FFF & methodId));

  StartObservationOfIncomingPackets(expectedResult);
  
  result = InternalWaitForIncomingPacket(callerFunctionName, timeout, expectedResult);

  InternalClearAllParameters();
  gIsWaitingForSOMEIPMessage = 0;  
  return;
  
}

void ETS_InternalWaitForNotificationWithMethodIds(char callerFunctionName[], long timeout, dword instanceId, dword methodIds[], dword countMethodIds, enum Bool answerExpected)
{
  enum Bool success; 
  dword group;

  SetBusContext(GetBusNameContext("Ethernet_1"));

  for(group=0; group<countMethodIds; ++group)
  {
    InternalAddExpectedParameter("SOME/IP", "MessageType", SomeIpMessageTypeNotification, kEquals, group);
    InternalAddExpectedParameter("SOME/IP", "ServiceId", syspar::SomeIp_ETS_ServiceId, kEquals, group);
    InternalAddExpectedParameter("SOME/IP", "MethodId", (0x7FFF & methodIds[group]), kEquals, group);
  }
  
  gIsWaitingForSOMEIPMessage = 1;
  StartObservationOfIncomingPackets(kNoAnswerExpected);
  
  write("start waiting for SOME/IP message at %.5f", timeNowFloat()/100000.0);
  testWaitForTimeout(timeout);
  gObservingEthPackets = kFalse;
  gIsWaitingForSOMEIPMessage = 0; 

  if((answerExpected==kTrue && gReceivedMessagesPerChannel[1]!=countMethodIds) ||
     (answerExpected==kFalse && gReceivedMessagesPerChannel[1]!=0))
  {
    if(answerExpected)
      testStepFail(callerFunctionName, "Wrong number of field notifications recognized: %d, expected %d.", gReceivedMessagesPerChannel[1], countMethodIds);
    else
      testStepFail(callerFunctionName, "Unexpected field notification recognized.");
  }
  else
  {
    if(answerExpected)
    {
      success=kTrue;
      for(group=0; group<countMethodIds && success==kTrue; ++group)
      {
        if(gExpectedParametersMatches[group]!=1) // one match per group only
        {
          if(gExpectedParametersMatches[group]==0)
            testStepFail(callerFunctionName, "Expected field notifications have not been recognized.");
          else
            testStepFail(callerFunctionName, "Duplicated field notifications have not been recognized.");
          write("#### group: %d, expected: 1, matches: %d", group, gExpectedParametersMatches[group]);
          success=kFalse;
        }
      }
      
      if(success==kTrue)
        testStepPass(callerFunctionName, "Expected field notifications have been recognized.");
    }
    else
    {
      testStepPass(callerFunctionName, "No unexpected field notifications have been recognized.");
    }
  } 
  write("finished waiting for SOME/IP message at %.5f", timeNowFloat()/100000.0);

  InternalClearAllParameters();
}

/*
  When subscribing without a ConsumedServiceInstance, the specified port must be opened to receive the
  field notifications.
*/
export testfunction ETS_OpenLocalApplicationEndPointForSubscribeWithoutCSI()
{
  IP_Endpoint sourceEndpoint, destinationEndpoint;
  //write("#### >ETS_OpenLocalApplicationEndPointForSubscribeWithoutCSI at %.5f", timeNowFloat()/100000.0);

  if(InitEndpoint(sourceEndpoint, syspar::IpAddressTester, 0)!=kTrue)
  {
    testStepFail("ETS_OpenLocalApplicationEndPointForSubscribeWithoutCSI", "Invalid IP address: %s", syspar::IpAddressTester);
    return;
  }
    
  if(InitEndpoint(destinationEndpoint, syspar::DIface0Ip, syspar::SomeIp_ETS_Port)!=kTrue)
  {
    testStepFail("ETS_OpenLocalApplicationEndPointForSubscribeWithoutCSI", "Invalid IP address: %s", syspar::DIface0Ip);
    return;
  }

  sourceEndpoint.SetToTcp();
  destinationEndpoint.SetToTcp();
  gTcpAepForSubscribeWithoutCSI = ETSOpenLocalApplicationEndpoint(sourceEndpoint);
  
  if(gTcpAepForSubscribeWithoutCSI==0)
  {
    ReportSomeIpError("ETS_OpenLocalApplicationEndPointForSubscribeWithoutCSI open failed, tcp");
    testStepFail("ETS_OpenLocalApplicationEndPointForSubscribeWithoutCSI", "SomeIp error");
    return;
  }

  if(SomeIpEstablishTCPConnection (gTcpAepForSubscribeWithoutCSI, destinationEndpoint)>0 ||
     SomeIpGetLastError()>0 || WaitFor_NewTCPConnectionState(1000, kTCPConnectionEstablished)==kFalse)
  {
    ReportSomeIpError("ETS_OpenLocalApplicationEndPointForSubscribeWithoutCSI open failed, tcp");
    testStepFail("ETS_OpenLocalApplicationEndPointForSubscribeWithoutCSI", "Could not establish connection");
    //write("#### <ETS_OpenLocalApplicationEndPointForSubscribeWithoutCSI with error TCP");
    return;
  }
  gPortForSubscribeWithoutCSI = gLocalEndpointOfEstablishedConnection.PortNumber;
  sourceEndpoint.PortNumber = gPortForSubscribeWithoutCSI;
  sourceEndpoint.SetToUdp();
  gUdpAepForSubscribeWithoutCSI = ETSOpenLocalApplicationEndpoint(sourceEndpoint);
  if(gUdpAepForSubscribeWithoutCSI==0)
  {
    ReportSomeIpError("ETS_OpenLocalApplicationEndPointForSubscribeWithoutCSI open failed, udp");
    testStepFail("ETS_OpenLocalApplicationEndPointForSubscribeWithoutCSI", "SomeIp error");
    //write("#### <ETS_OpenLocalApplicationEndPointForSubscribeWithoutCSI with error UDP");
    return;
  }
  
  //write("#### <ETS_OpenLocalApplicationEndPointForSubscribeWithoutCSI at %.5f", timeNowFloat()/100000.0);
}

export testfunction ETS_CloseLocalApplicationEndPointForSubscribeWithoutCSI()
{
  testWaitForTimeout(50); // When the test has been aborted the AEP might be still in use
  if(gUdpAepForSubscribeWithoutCSI)
  {
    ETSCloseLocalApplicationEndpoint(gUdpAepForSubscribeWithoutCSI);
    gPortForSubscribeWithoutCSI = gUdpAepForSubscribeWithoutCSI = 0;
  }
  if(gTcpAepForSubscribeWithoutCSI)
  {
    SomeIpCloseEstablishedTCPConnection(gTcpAepForSubscribeWithoutCSI);
    WaitFor_NewTCPConnectionState(1000, kTCPConnectionClosed);
    ETSCloseLocalApplicationEndpoint(gTcpAepForSubscribeWithoutCSI);
    gTcpAepForSubscribeWithoutCSI = 0;
  }
}

export testfunction ETS_SendNotification_Subscribe_LengthPatchedVarA(dword sessionId, dword instanceId, char destinationIP[])
{
  dword HEADER_FIELD_LENGTH_OFFSET = 4, HEADER_FIELD_OPTION_ARRAY_LENGTH_OFFSET = 40, HEADER_FIELD_MESSAGE_ID_LENGTH = 4, HEADER_FIELD_LENGTH_LENGTH = 4;
  dword EXPECTED_VALUE_OF_HEADER_FIELD_LENGTH = 60; // message contains two IPv4 endpoint options
  dword EXPECTED_VALUE_OF_HEADER_FIELD_OPTION_ARRAY_LENGTH = 24; // The two IPv4 endpoint options
  dword EventGroupID = 2;
  byte messageBuffer[1600];
  dword messageLength, lengthValue;
  dword msgHandle;
  dword handle;
  
  IP_Endpoint sourceEndpoint, destinationEndpoint;
  if(InitEndpoint(sourceEndpoint, syspar::IpAddressTester, atol(syspar::SomeIpServiceDiscoveryPort))!=kTrue ||
     InitEndpoint(destinationEndpoint, destinationIP, atol(syspar::SomeIpServiceDiscoveryPort))!=kTrue)
  {
    testStepFail("ETS_SendNotification_Subscribe_LengthPatchedVarA", "Creation of endpoints failed");
    return;
  }
  
  if(ETS_CreateSomeIpSDNotification(handle, sourceEndpoint.Address, syspar::SomeIp_ETS_ServiceId,
    syspar::Wildcard, "Subscribe", instanceId, syspar::Wildcard, syspar::SomeIp_ETS_Subscribe_TTL, syspar::Wildcard, sessionId,
    gPortForSubscribeWithoutCSI, "EventgroupID", EventGroupID, getEndpointSelectorForEVG(EventGroupID), kTrue)==kFalse)
  {
    testStepFail("ETS_SendNotification_Subscribe_LengthPatchedVarA", "Creation of notification failed");
    if(handle)
      SomeIpReleaseMessage(handle);
    return;
  }

  messageLength = SomeIpSerializeMessage(handle, elCount(messageBuffer), messageBuffer);
  if(messageLength!=HEADER_FIELD_MESSAGE_ID_LENGTH+HEADER_FIELD_LENGTH_LENGTH+EXPECTED_VALUE_OF_HEADER_FIELD_LENGTH)
  {
    testStepFail("ETS_SendNotification_Subscribe_LengthPatchedVarA", "Patch not possible, wrong message size: %d", messageLength);
    return ;
  }
  
  lengthValue = getBigEndianDWORD(messageBuffer, HEADER_FIELD_LENGTH_OFFSET);
  if(lengthValue!=EXPECTED_VALUE_OF_HEADER_FIELD_LENGTH)
  {
    testStepFail("ETS_SendNotification_Subscribe_LengthPatchedVarA", "Patch not possible, wrong header length: %d, expected %d",
                 lengthValue, EXPECTED_VALUE_OF_HEADER_FIELD_LENGTH);
    return ;
  }
  setBigEndianDWORD(messageBuffer, HEADER_FIELD_LENGTH_OFFSET, 48);

  lengthValue = getBigEndianDWORD(messageBuffer, HEADER_FIELD_OPTION_ARRAY_LENGTH_OFFSET);
  if(lengthValue!=EXPECTED_VALUE_OF_HEADER_FIELD_OPTION_ARRAY_LENGTH)
  {
    testStepFail("ETS_SendNotification_Subscribe_LengthPatchedVarA", "Patch not possible, wrong option length: %d, expected %d",
                 lengthValue, EXPECTED_VALUE_OF_HEADER_FIELD_OPTION_ARRAY_LENGTH);
    return ;
  }
  setBigEndianDWORD(messageBuffer, HEADER_FIELD_OPTION_ARRAY_LENGTH_OFFSET, 12);

  msgHandle = SomeIpCreateMessage(messageLength, messageBuffer);
  InitEndpoint(destinationEndpoint, syspar::SomeIpServiceDiscoveryIpAddress, atol(syspar::SomeIpServiceDiscoveryPort));
  SomeIpOutputMessage(gClientServiceAepHandleUDP, destinationEndpoint, msgHandle);
  
  SomeIpReleaseMessage(handle);
}

export testfunction ETS_SendNotification_Subscribe_LengthShorted(dword sessionId, dword instanceId, char destinationIP[])
{
  dword HEADER_FIELD_MESSAGE_ID_SIZE = 4, HEADER_FIELD_LENGTH_OFFSET = 4,  HEADER_FIELD_LENGTH_SIZE = 4;
  dword HEADER_FIELD_LENGTH_DECREMENT_VALUE=10;
  dword EventGroupID = 2;
  byte messageBuffer[1600];
  dword messageLength, lengthValue;
  dword msgHandle;
  dword handle;
  
  IP_Endpoint sourceEndpoint, destinationEndpoint;
  if(InitEndpoint(sourceEndpoint, syspar::IpAddressTester, atol(syspar::SomeIpServiceDiscoveryPort))!=kTrue ||
     InitEndpoint(destinationEndpoint, destinationIP, atol(syspar::SomeIpServiceDiscoveryPort))!=kTrue)
  {
    testStepFail("ETS_SendNotification_Subscribe_LengthShorted", "Creation of endpoints failed");
    return;
  }
  
  if(ETS_CreateSomeIpSDNotification(handle, sourceEndpoint.Address, syspar::SomeIp_ETS_ServiceId,
    syspar::Wildcard, "Subscribe", instanceId, syspar::Wildcard, syspar::SomeIp_ETS_Subscribe_TTL, syspar::Wildcard, sessionId,
    gPortForSubscribeWithoutCSI, "EventgroupID", EventGroupID, getEndpointSelectorForEVG(EventGroupID), kTrue)==kFalse)
  {
    testStepFail("ETS_SendNotification_Subscribe_LengthPatchedVarA", "Creation of notification failed");
    if(handle)
      SomeIpReleaseMessage(handle);
    return;
  }

  messageLength = SomeIpSerializeMessage(handle, elCount(messageBuffer), messageBuffer);
  if(messageLength<HEADER_FIELD_MESSAGE_ID_SIZE+HEADER_FIELD_LENGTH_SIZE)
  {
    testStepFail("ETS_SendNotification_Subscribe_LengthPatchedVarA", "Patch not possible, wrong message size: %d", messageLength);
    return ;
  }
  
  lengthValue = getBigEndianDWORD(messageBuffer, HEADER_FIELD_LENGTH_OFFSET);
  if(lengthValue<HEADER_FIELD_LENGTH_DECREMENT_VALUE)
  {
    testStepFail("ETS_SendNotification_Subscribe_LengthPatchedVarA", "Patch not possible, wrong header length: %d, expected at least %d",
                 lengthValue, HEADER_FIELD_LENGTH_DECREMENT_VALUE);
    return ;
  }
  setBigEndianDWORD(messageBuffer, HEADER_FIELD_LENGTH_OFFSET, lengthValue-HEADER_FIELD_LENGTH_DECREMENT_VALUE);


  msgHandle = SomeIpCreateMessage(messageLength, messageBuffer);
  InitEndpoint(destinationEndpoint, syspar::SomeIpServiceDiscoveryIpAddress, atol(syspar::SomeIpServiceDiscoveryPort));
  SomeIpOutputMessage(gClientServiceAepHandleUDP, destinationEndpoint, msgHandle);
  //SomeIpOutputMessage(gClientServiceAepHandleUDP, ipGetAddressAsNumber(syspar::SomeIpServiceDiscoveryIpAddress), atol(syspar::SomeIpServiceDiscoveryPort), msgHandle);
  
  SomeIpReleaseMessage(handle);
}


enum Bool getIndexOfOptionsArrayLength(byte payload[], long payloadLen, dword & optionArrayLengthIndex, dword & optionsLen)
{
  byte HEADER_FIELD_ENTRY_LENGTH_OFFSET = 4, LENGTH_FIELD_SIZE = 4;
  dword lengthOfEntries;
  
  lengthOfEntries = getBigEndianDWORD(payload, HEADER_FIELD_ENTRY_LENGTH_OFFSET);
  optionArrayLengthIndex = HEADER_FIELD_ENTRY_LENGTH_OFFSET + lengthOfEntries + LENGTH_FIELD_SIZE;
  
  if(optionArrayLengthIndex+LENGTH_FIELD_SIZE<=payloadLen)
  {
    optionsLen = getBigEndianDWORD(payload, optionArrayLengthIndex);
    return kTrue;
  }
  return kFalse;
}

enum Bool getIndexOfFirstOption(byte payload[], long payloadLen, dword & optionIndex, dword & optionsLen)
{
  byte HEADER_FIELD_ENTRY_LENGTH_OFFSET = 4, LENGTH_FIELD_SIZE = 4;
  dword lengthOfEntries, optionLengthIndex;
  
  if(getIndexOfOptionsArrayLength(payload, payloadLen, optionLengthIndex, optionsLen)==kTrue)
  {
    optionIndex = optionLengthIndex + LENGTH_FIELD_SIZE;

    if(optionIndex+optionsLen<=payloadLen)
      return kTrue;
  }
  
  return kFalse;
}

export testfunction ETS_SendNotification_Subscribe_WithUdpOptionLength4(dword sessionId, dword instanceId, char destinationIP[])
{
  byte PROTOCOL_OFFSET_IPv4=9, PROTOCOL_OFFSET_IPv6=21, OPTION_SIZE_NOT_COVERED_BY_LENGTH=3;
  int i;
  long dataLen;
  byte buffer[1500];
  enum Bool patched;
  dword handle;
  dword EventGroupID = 2;
  dword indexOfFirstOption, optionsLen, optionOffset, optionIndex, optionLength;
  
  IP_Endpoint sourceEndpoint, destinationEndpoint;
  if(InitEndpoint(sourceEndpoint, syspar::IpAddressTester, atol(syspar::SomeIpServiceDiscoveryPort))!=kTrue ||
     InitEndpoint(destinationEndpoint, destinationIP, atol(syspar::SomeIpServiceDiscoveryPort))!=kTrue)
  {
    testStepFail("ETS_SendNotification_Subscribe_WithUdpOptionLength4", "Creation of endpoints failed");
    return;
  }
  
  if(ETS_CreateSomeIpSDNotification(handle, sourceEndpoint.Address, syspar::SomeIp_ETS_ServiceId,
    syspar::Wildcard, "Subscribe", instanceId, syspar::Wildcard, syspar::SomeIp_ETS_Subscribe_TTL, syspar::Wildcard, sessionId,
    gPortForSubscribeWithoutCSI, "EventgroupID", EventGroupID, getEndpointSelectorForEVG(EventGroupID), kTrue)==kFalse)
  {
    testStepFail("ETS_SendNotification_Subscribe_WithUdpOptionLength4", "Creation of notification failed");
    if(handle)
      SomeIpReleaseMessage(handle);
    return;
  }

  dataLen = SomeIpGetData(handle, elcount(buffer), buffer);
  patched=kFalse;
  
  if(getIndexOfFirstOption(buffer, dataLen, indexOfFirstOption, optionsLen)==kTrue)
  {
    optionOffset=0;
    do
    {
      optionIndex = indexOfFirstOption + optionOffset;
      // search for the IPv4 or IPv6 UDP option length data
      if((buffer[optionIndex]==0x00 && buffer[optionIndex+1]==0x09 && buffer[optionIndex+2]==0x04 && buffer[optionIndex+PROTOCOL_OFFSET_IPv4]==TP_UDP) ||
         (buffer[optionIndex]==0x00 && buffer[optionIndex+1]==0x15 && buffer[optionIndex+2]==0x06 && buffer[optionIndex+PROTOCOL_OFFSET_IPv6]==TP_UDP))
      {
        buffer[optionIndex+1] = 4;
        patched=kTrue;
      }
      else
      {
        optionLength = getBigEndianWORD(buffer, optionIndex);
        if(optionLength==0)
        {
          testStepFail("ETS_SendNotification_Subscribe_WithUdpOptionLength4", "Message contains option with length 0");
          return;
        }
        optionOffset += optionLength + OPTION_SIZE_NOT_COVERED_BY_LENGTH;
      }
    }
    while(patched==kFalse && optionOffset<optionsLen);
    
    if(patched==kFalse)
    {
      testStepFail("ETS_SendNotification_Subscribe_WithUdpOptionLength4", "UDP Endpoint Option not found in message");
      return;
    } 
   
    SomeIpSetData(handle, dataLen, buffer);

    if(ETS_OutputSomeIpSDNotification(handle, sourceEndpoint, destinationEndpoint)==kFalse)
    {
      testStepFail("ETS_SendNotification_Subscribe_WithUdpOptionLength4", "Sending of notification failed");
    }
  }
  else
  {
    testStepFail("ETS_SendNotification_Subscribe_WithUdpOptionLength4", "Message contains no options");
    return;
  }
}

enum Bool isOptionIpv4Endpoint(byte buffer[], dword optionIndex)
{
  byte PROTOCOL_OFFSET_IPv4=9, OPTION_TYPE_IPV4_ENDPOINT=0x04;

  if(buffer[optionIndex]==0x00 && buffer[optionIndex+1]==0x09 && buffer[optionIndex+2]==OPTION_TYPE_IPV4_ENDPOINT &&
      (buffer[optionIndex+PROTOCOL_OFFSET_IPv4]==TP_UDP || buffer[optionIndex+PROTOCOL_OFFSET_IPv4]==TP_TCP))
    return kTrue;
  return kFalse;
}

enum Bool isOptionIpv6Endpoint(byte buffer[], dword optionIndex)
{
  byte PROTOCOL_OFFSET_IPv6=21, OPTION_TYPE_IPv6_ENDPOINT=0x06;

  if(buffer[optionIndex]==0x00 && buffer[optionIndex+1]==0x15 && buffer[optionIndex+2]==OPTION_TYPE_IPv6_ENDPOINT &&
      (buffer[optionIndex+PROTOCOL_OFFSET_IPv6]==TP_UDP || buffer[optionIndex+PROTOCOL_OFFSET_IPv6]==TP_TCP))
    return kTrue;
  return kFalse;
}

export testfunction ETS_SendNotification_Subscribe_WithShortenedUnalignedOption(dword sessionId, dword instanceId, char destinationIP[])
{
  byte OPTION_SIZE_NOT_COVERED_BY_LENGTH=3, COUNT_BYTES_MOVED=5;
  int i;
  long dataLen;
  byte buffer[1500], patchBuffer;
  dword handle;
  dword EventGroupID = 2;
  dword indexOfFirstOption, optionsLen, optionOffset, optionIndex, optionLength;
  dword indexOfIPvXEndpointOptions[long], lengthOfIPvXEndpointOptions[long];
  
  IP_Endpoint sourceEndpoint, destinationEndpoint;
  if(InitEndpoint(sourceEndpoint, syspar::IpAddressTester, atol(syspar::SomeIpServiceDiscoveryPort))!=kTrue ||
     InitEndpoint(destinationEndpoint, destinationIP, atol(syspar::SomeIpServiceDiscoveryPort))!=kTrue)
  {
    testStepFail("ETS_SendNotification_Subscribe_WithShortenedUnalignedOption", "Creation of endpoints failed");
    return;
  }
  
  if(ETS_CreateSomeIpSDNotification(handle, sourceEndpoint.Address, syspar::SomeIp_ETS_ServiceId,
    syspar::Wildcard, "Subscribe", instanceId, syspar::Wildcard, syspar::SomeIp_ETS_Subscribe_TTL, syspar::Wildcard, sessionId,
    gPortForSubscribeWithoutCSI, "EventgroupID", EventGroupID, getEndpointSelectorForEVG(EventGroupID), kTrue)==kFalse)
  {
    testStepFail("ETS_SendNotification_Subscribe_WithShortenedUnalignedOption", "Creation of notification failed");
    if(handle)
      SomeIpReleaseMessage(handle);
    return;
  }

  dataLen = SomeIpGetData(handle, elcount(buffer), buffer);
  
  if(getIndexOfFirstOption(buffer, dataLen, indexOfFirstOption, optionsLen)==kTrue)
  {
    optionOffset=0;
    while(indexOfIPvXEndpointOptions.size()!=2 && optionOffset<optionsLen) // find the two IP Endpoints
    {
      optionIndex = indexOfFirstOption + optionOffset;
      optionLength = getBigEndianWORD(buffer, optionIndex);
      if(optionLength==0)
      {
        testStepFail("ETS_SendNotification_Subscribe_WithShortenedUnalignedOption", "Message contains option with length 0");
        return;
      }

      if(isOptionIpv4Endpoint(buffer, optionIndex)==kTrue || isOptionIpv6Endpoint(buffer, optionIndex))
      {
        indexOfIPvXEndpointOptions[indexOfIPvXEndpointOptions.size()] = optionIndex;
        lengthOfIPvXEndpointOptions[lengthOfIPvXEndpointOptions.size()] = optionLength;
      }
      
      optionOffset += optionLength + OPTION_SIZE_NOT_COVERED_BY_LENGTH;
    }
    
    if(indexOfIPvXEndpointOptions.size()!=2)
    {
      testStepFail("ETS_SendNotification_Subscribe_WithShortenedUnalignedOption", "Endpoint options not found in message");
      return;
    } 
   
    // move and cut data of second endpoint to the right
    for(i=indexOfIPvXEndpointOptions[1]+OPTION_SIZE_NOT_COVERED_BY_LENGTH+lengthOfIPvXEndpointOptions[1]-COUNT_BYTES_MOVED; i>=indexOfIPvXEndpointOptions[1]; --i)
      buffer[i+COUNT_BYTES_MOVED] = buffer[i];
    // change the length of both endpoints
    setBigEndianWORD(buffer, indexOfIPvXEndpointOptions[0], lengthOfIPvXEndpointOptions[0]+COUNT_BYTES_MOVED);
    setBigEndianWORD(buffer, indexOfIPvXEndpointOptions[1]+COUNT_BYTES_MOVED, lengthOfIPvXEndpointOptions[1]-COUNT_BYTES_MOVED);
      
    SomeIpSetData(handle, dataLen, buffer);

    if(ETS_OutputSomeIpSDNotification(handle, sourceEndpoint, destinationEndpoint)==kFalse)
    {
      testStepFail("ETS_SendNotification_Subscribe_WithShortenedUnalignedOption", "Sending of notification failed");
    }
  }
  else
  {
    testStepFail("ETS_SendNotification_Subscribe_WithShortenedUnalignedOption", "Message contains no options");
    return;
  }
  
}

