enum Bool WaitForOfferGetSessionId(long timeout, char instanceIdStr[], long & sessionId)
{
  if(ETS_InternalWaitForSOMEIPNotification("ETS_WaitForNotification_OfferService",
       timeout, SomeIpMessageTypeNotification, OfferService,
       syspar::SomeIp_ETS_ServiceId, // entryServiceId
       syspar::Wildcard, // entryTTL
       syspar::Wildcard, // serviceId
       syspar::Wildcard, // returnCode
       syspar::Wildcard, // methodId
       "Entry[0].OfferService.InstanceID", instanceIdStr, kEquals, // first token
       syspar::Wildcard, syspar::Wildcard, kEquals, // second token
       syspar::UdpProtocol,
       "SessionId", // extractSomeIpToken
       kAnswerExpected
      )==kFalse)
    return kFalse;
  
  sessionId = gExtractingParameters[0].Value;
  return kTrue;
}

export testfunction ETS_WaitForNotifications_OfferService_CheckIncreasingSessionId(long timeout, dword instanceId, dword countOffersToCheck)
{
  long lastSessionId, currentSessionId;
  dword i;
  char instanceIdStr[16];
  snprintf(instanceIdStr, elcount(instanceIdStr), "%d", instanceId);

  if(WaitForOfferGetSessionId(timeout, instanceIdStr, lastSessionId)==kFalse)
    return;

  i=1;
  while(i<countOffersToCheck)
  {
    if(WaitForOfferGetSessionId(timeout, instanceIdStr, currentSessionId)==kFalse)
      return;

    if(lastSessionId>=currentSessionId)
    {
      testStepFail("ETS_WaitForNotification_OfferService_CheckSessionId", "SessionId did not increase, OfferService[%d]: %d, OfferSercice[%d]: %d", i-1, lastSessionId, i, currentSessionId);
      return;
    }
    ++i;
  }
  
  testStepPass("ETS_WaitForNotification_OfferService_CheckSessionId", "SessionIds did increase");
}

