/// <Helper functions>
enum Bool HandleSomeIpCreateFieldConsumer(dword csiHandle, long notificationId, long getterId, long setterId, char onFieldNotificationCallback[], dword & handle)
{
  handle = SomeIpCreateFieldConsumer(csiHandle, notificationId, getterId, setterId, onFieldNotificationCallback);
  if(handle==0)
  {
    ReportSomeIpError("Creation of field consumer failed");
    write("Creation of field consumer failed. %s", onFieldNotificationCallback);
    return kFalse;
  }
  return kTrue;
}

enum Bool CreateAllFieldConsumer()
{
  if(HandleSomeIpCreateFieldConsumer(gCsiHandleUDP, FIELD_ID_InterfaceVersion, sysvar::TC8_ETS::ETS_Method::get_InterfaceVersion,
        -1, "Tester_OnFieldNotification_InterfaceVersion", gFieldConsumerHandle_InterfaceVersion)!=kTrue ||
     HandleSomeIpCreateFieldConsumer(gCsiHandleUDP, FIELD_ID_TestFieldUINT8, sysvar::TC8_ETS::ETS_Method::get_TestFieldUINT8,
        sysvar::TC8_ETS::ETS_Method::set_TestFieldUINT8, "Tester_OnFieldNotification_TestFieldUINT8",
        gFieldConsumerHandle_TestFieldUINT8)!=kTrue ||
     HandleSomeIpCreateFieldConsumer(gCsiHandleUDP, FIELD_ID_TestFieldUINT8Array, sysvar::TC8_ETS::ETS_Method::get_TestFieldUINT8Array,
        sysvar::TC8_ETS::ETS_Method::set_TestFieldUINT8Array, "Tester_OnFieldNotification_TestFieldUINT8Array",
        gFieldConsumerHandle_TestFieldUINT8Array)!=kTrue ||
     HandleSomeIpCreateFieldConsumer(gCsiHandleTCP, FIELD_ID_TestFieldUINT8Reliable, sysvar::TC8_ETS::ETS_Method::get_TestFieldUINT8Reliable,
        sysvar::TC8_ETS::ETS_Method::set_TestFieldUINT8Reliable, "Tester_OnFieldNotification_TestFieldUINT8Reliable",
        gFieldConsumerHandle_TestFieldUINT8Reliable)!=kTrue)
    return kFalse;
  return kTrue;
}

export testfunction ETS_SubscribeEventgroupOfDUT(int eventGroupId)
{
  IP_Endpoint endpoint;
  if(InitEndpoint(endpoint, syspar::IpAddressTester, 0)!=kTrue ||
     ActivateClientService("Tester_", endpoint)!=kTrue)
  {
    testStepFail("ETS_SubscribeEventgroupOfDUT", "ActivateClientService failed");
    return;
  }

  if(CreateAllFieldConsumer()!=kTrue)
  {
    ReportSomeIpError("ETS_SubscribeEventgroupOfDUT failed");
    ETS_UnsubscribeAllEventgroupsOfDUT();
    testStepFail("ETS_SubscribeEventgroupOfDUT", "SomeIpCreateFieldConsumer failed");
    return;
  }

  AddEventGroupConsumers(eventGroupId, gCegHandle1UDP, gCegHandle1TCP);
  
  if(SubscribeEventGroup(eventGroupId, gCegHandle1UDP, gCegHandle1TCP)!=kTrue)
  {
    testStepFail("ETS_SubscribeEventgroupOfDUT", "SubscribeEventGroup failed");
    return;
  }
 
  gWaitingForFieldNotificationsCount.clear();
  if(eventGroupId==EVENTGROUP_ID_EvgAll || eventGroupId==EVENTGROUP_ID_EvgUnreliableOnly)
  {
    gWaitingForFieldNotificationsCount[FIELD_ID_InterfaceVersion] = 1;
    gWaitingForFieldNotificationsCount[FIELD_ID_TestFieldUINT8] = 1;
    gWaitingForFieldNotificationsCount[FIELD_ID_TestFieldUINT8Array] = 1;
  }
  if(eventGroupId==EVENTGROUP_ID_EvgAll)
    gWaitingForFieldNotificationsCount[FIELD_ID_TestFieldUINT8Reliable] = 1;
}

export testfunction ETS_SubscribeAllEventgroupsOfDUT()
{
  IP_Endpoint endpoint;
  
  if(InitEndpoint(endpoint, syspar::IpAddressTester, 0)!=kTrue ||
     ActivateClientService("Tester_", endpoint)!=kTrue)
  {
    testStepFail("ETS_SubscribeAllEventgroupsOfDUT", "ActivateClientService failed");
    return;
  }

  AddEventGroupConsumers(EVENTGROUP_ID_EvgAll, gCegHandle1UDP, gCegHandle1TCP);
  AddEventGroupConsumers(EVENTGROUP_ID_EvgUnreliableOnly, gCegHandle2UDP, gCegHandle2TCP);
  AddEventGroupConsumers(EVENTGROUP_ID_EvgMulticast, gCegHandle3UDP, gCegHandle3TCP);
  if(CreateAllFieldConsumer()!=kTrue)
  {
    ReportSomeIpError("ETS_SubscribeAllEventgroupsOfDUT failed");
    ETS_UnsubscribeAllEventgroupsOfDUT();
    testStepFail("ETS_SubscribeAllEventgroupsOfDUT", "SomeIpCreateFieldConsumer failed");
    return;
  }
 
  if(SubscribeEventGroup(EVENTGROUP_ID_EvgAll, gCegHandle1UDP, gCegHandle1TCP)!=kTrue ||
     SubscribeEventGroup(EVENTGROUP_ID_EvgUnreliableOnly, gCegHandle2UDP, gCegHandle2TCP)!=kTrue ||
     SubscribeEventGroup(EVENTGROUP_ID_EvgMulticast, gCegHandle3UDP, gCegHandle3TCP)!=kTrue)
  {
    ReportSomeIpError("ETS_SubscribeAllEventgroupsOfDUT failed");
    ETS_UnsubscribeAllEventgroupsOfDUT();
    testStepFail("ETS_SubscribeAllEventgroupsOfDUT", "SubscribeEventGroup failed");
    return;
  }
  gWaitingForFieldNotificationsCount.clear();
  gWaitingForFieldNotificationsCount[FIELD_ID_InterfaceVersion] = 2;
  gWaitingForFieldNotificationsCount[FIELD_ID_TestFieldUINT8] = 2;
  gWaitingForFieldNotificationsCount[FIELD_ID_TestFieldUINT8Array] = 2;
  gWaitingForFieldNotificationsCount[FIELD_ID_TestFieldUINT8Reliable] = 1;
}

void UnsubscribeField(dword & fieldHandle, char name[])
{
  gSubscribedEventgroupId = -1;
  if(fieldHandle!=0)
  {
    if(SomeIpRemoveFieldConsumer(fieldHandle)>0)
    {
      write("UnsubscribeField failed for field: %s", name);
      ReportSomeIpError("UnsubscribeField failed");
    }
    fieldHandle = 0;
  }
}

void UnsubscribeEvent(dword & eventHandle, char name[])
{
  if(eventHandle!=0)
  {
    if(SomeIpRemoveEventConsumer(eventHandle)>0)
    {
      write("UnsubscribeEvent failed for event: %s", name);
      ReportSomeIpError("UnsubscribeEvent failed");
    }
    eventHandle = 0;
  }
}

export testfunction ETS_UnsubscribeAllEventgroupsOfDUT()
{
  UnsubscribeField(gFieldConsumerHandle_TestFieldUINT8Reliable, "TestFieldUINT8Reliable");
  UnsubscribeField(gFieldConsumerHandle_TestFieldUINT8Array, "TestFieldUINT8Array");
  UnsubscribeField(gFieldConsumerHandle_TestFieldUINT8, "TestFieldUINT8");
  UnsubscribeField(gFieldConsumerHandle_InterfaceVersion, "InterfaceVersion");
 
  RemoveEventGroupConsumers(gCegHandle1UDP, gCegHandle1TCP);
  RemoveEventGroupConsumers(gCegHandle2UDP, gCegHandle2TCP);
  RemoveEventGroupConsumers(gCegHandle3UDP, gCegHandle3TCP);

  testWaitForTimeout(1);
  DeactivateClientService();
}

