export testfunction ETS_CheckResponseValueOfSetter_TestFieldUINT8Array()
{
  dword i;
  if(gRequestedValues_SetterTestFieldUINT8Array.length != gResponseValues_SetterTestFieldUINT8Array.length)
    testStepFail("ETS_CheckResponseValueOfSetter_TestFieldUINT8Array", "Setter returned unexpected array length: %d, expected: %d",
                 gResponseValues_SetterTestFieldUINT8Array.length, gRequestedValues_SetterTestFieldUINT8Array.length);
  else
  {
    for(i=0; i<gRequestedValues_SetterTestFieldUINT8Array.length; ++i)
    {
      if(gRequestedValues_SetterTestFieldUINT8Array.values[i]!=gResponseValues_SetterTestFieldUINT8Array.values[i])
      {
        testStepFail("ETS_CheckResponseValueOfSetter_TestFieldUINT8Array", "Setter returned unexpected value at index %d: %d, expected: %d", i,
                 gResponseValues_SetterTestFieldUINT8Array.values[i], gRequestedValues_SetterTestFieldUINT8Array.values[i]);
        return;
      }
    }
    testStepPass("ETS_CheckResponseValueOfSetter_TestFieldUINT8Array", "Setter returned expected values");
  }
}

