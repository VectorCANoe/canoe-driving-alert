export testfunction ETS_SetEventUINT8Reliable(word value, dword preDelayMs, dword postDelayMs)
{
  if(preDelayMs>0)
    testWaitForTimeout(preDelayMs);
  gTestEventUINT8Reliable = value; // the function arguments gets set in the corresponding OnService_ETS_PrepareEvent_* function
  SomeIpTriggerEvent(gEventHandle_TestEventUINT8Reliable);
  if(SomeIpGetLastError()!=0)
  {
    ReportSomeIpError("Set event failed");
    testStepFail("ETS_SetEventUINT8Reliable", "Set event failed");
  }
  // Events are send asynchronously and delayed, to prevent race conditions with following calls
  // we try to ensure the send by waiting some time
  if(postDelayMs>0)
    testWaitForTimeout(postDelayMs);
}

