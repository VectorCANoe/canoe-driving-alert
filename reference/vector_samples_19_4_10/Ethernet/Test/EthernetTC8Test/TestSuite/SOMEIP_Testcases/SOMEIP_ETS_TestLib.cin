on timer gTriggerFindServiceTimer
{
  ETS_SendSomeIpSDNotification("ETS_SendNotification_FindService", gTriggerFindServiceTimerArgs.destinationIP, syspar::SomeIp_ETS_ServiceId, syspar::Wildcard, "FindService",
    gTriggerFindServiceTimerArgs.instanceId, gTriggerFindServiceTimerArgs.majorVersion, syspar::SomeIp_ETS_OfferService_TTL, gTriggerFindServiceTimerArgs.minorVersion,
    gTriggerFindServiceTimerArgs.sessionId++, syspar::SomeIp_ETS_Port, syspar::Wildcard, 0, gTriggerFindServiceTimerArgs.endpointSelector);
  gTriggerFindServiceTimerArgs.numberOfSendsDone++;
  if(gTriggerFindServiceTimerArgs.sessionId == 0)
    gTriggerFindServiceTimerArgs.sessionId = 1;
  if(gTriggerFindServiceTimerArgs.numberOfMessagesToSend==0 || // unlimited number of messages to send
     gTriggerFindServiceTimerArgs.numberOfSendsDone<gTriggerFindServiceTimerArgs.numberOfMessagesToSend)
    setTimer(gTriggerFindServiceTimer, 10);
}

