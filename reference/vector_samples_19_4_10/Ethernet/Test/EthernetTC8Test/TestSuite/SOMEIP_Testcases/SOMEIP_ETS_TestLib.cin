void OnSomeIpEstablishedTCPConnection(IP_Endpoint localIPEndpoint, IP_Endpoint remoteIPEndpoint)
{
  char localEndpointStr[128], remoteEndpointStr[128];
  localIPEndpoint.PrintEndpointToString(localEndpointStr);
  remoteIPEndpoint.PrintEndpointToString(remoteEndpointStr);
  //writeEx(-3,1,"### EstablishedTCPConnection lep: %s, rep: %s, at %.5f", localEndpointStr, remoteEndpointStr, timeNowFloat()/100000.0);
  
  if(gWaitingForNewTCPConnectionState==kTrue)
  {
    if(gWaitingForTCPConnectionState==kTCPConnectionReestablished)
    {
      gReestablishedEstablished=kTrue;
      testStepPass("ETS_WaitForNewTCPConnectionState", "TCP connection has been established.");
      if(gReestablishedClosed)
      {
        gLocalEndpointOfEstablishedConnection = localIPEndpoint;
        setTimer(gWaitConditionReachedTimer, 0);  // both wait conditions reached
      }
    }
    else if(gWaitingForTCPConnectionState==kTCPConnectionEstablished)
    {
      gLocalEndpointOfEstablishedConnection = localIPEndpoint;
      setTimer(gWaitConditionReachedTimer, 0);
    }
  }
}

void OnSomeIpClosedTCPConnection(IP_Endpoint localIPEndpoint, IP_Endpoint remoteIPEndpoint)
{
  //char localEndpointStr[128], remoteEndpointStr[128];
  //localIPEndpoint.PrintEndpointToString(localEndpointStr);
  //remoteIPEndpoint.PrintEndpointToString(remoteEndpointStr);
  //write("### ClosedTCPConnection lep: %s, rep: %s, at %.5f", localEndpointStr, remoteEndpointStr, timeNowFloat()/100000.0);

  if(gWaitingForNewTCPConnectionState==kTrue && gWaitingForTCPConnectionState==kTCPConnectionClosed)
    setTimer(gWaitConditionReachedTimer, 0);    
  if(gWaitingForNewTCPConnectionState==kTrue)
  {
    if(gWaitingForTCPConnectionState==kTCPConnectionReestablished)
    {
      gReestablishedClosed=kTrue;
      testStepPass("ETS_WaitForNewTCPConnectionState", "TCP connection has been closed.");
      if(gReestablishedEstablished)
        setTimer(gWaitConditionReachedTimer, 0);  // both wait conditions reached
    }
    else if(gWaitingForTCPConnectionState==kTCPConnectionClosed)
      setTimer(gWaitConditionReachedTimer, 0);
  }
}

enum Bool WaitFor_NewTCPConnectionState(dword timeoutMs, enum TCPConnectionState state)
{
  long result;
  gWaitingForTCPConnectionState=state;
  gReestablishedEstablished = gReestablishedClosed = kFalse;
  gWaitingForNewTCPConnectionState=kTrue; 
  result = testWaitForTextEvent("ETSAllWaitNotificationsReached", timeoutMs);
  gWaitingForNewTCPConnectionState=kFalse;
  if(result==1)
    return kTrue;
  else
    return kFalse;
}

export testfunction ETS_WaitFor_NewTCPConnectionState(dword timeoutMs, enum TCPConnectionState state)
{
  char messagesOk[3][64]  = { "TCP connection has been established.",     "TCP connection has been closed.", "TCP connection has been reestablished."};
  char messagesNOk[3][64] = { "TCP connection has not been established.", "TCP connection has not been closed", "TCP connection has not been reestablished." };

  if(WaitFor_NewTCPConnectionState(timeoutMs, state)==kTrue)
    testStepPass("ETS_WaitFor_NewTCPConnectionState", messagesOk[state]);
  else
    testStepFail("ETS_WaitFor_NewTCPConnectionState", messagesNOk[state]);
}

void ETS_SendSomeIpSDNotification(char callerFunctionName[],
  char destIp[], int serviceId, char flags[],
  char entryType[], word instanceId, char majorVersion[],
  char ttl[], char minorVersion[], word sessionId, dword portNumber,
  char additionalEntryFieldName[], dword additionalEntryFieldValue,
  enum EndpointSelector endpointSelector)
{
  ETS_SendSomeIpSDNotification(callerFunctionName, syspar::IpAddressTester, destIp, serviceId, flags, entryType,
    instanceId, majorVersion, ttl, minorVersion, sessionId, portNumber, additionalEntryFieldName, additionalEntryFieldValue,
    endpointSelector, kTrue);
}

enum Bool ETS_CreateSomeIpSDNotification(
  dword & handle,
  IP_Address sourceIpAddress,
  int serviceId,
  char flags[],
  char entryType[],
  word instanceId,
  char majorVersion[],
  char ttl[],
  char minorVersion[],
  word sessionId,
  dword portNumber,
  char additionalEntryFieldName[],
  dword additionalEntryFieldValue,
  enum EndpointSelector endpointSelector, enum Bool withEntry
  )
{
  dword messageId=0xFFFF8100, protocolVersion=0x01, interfaceVersion=0x01, messageType=SomeIpMessageTypeNotification, returnCode=0x00;
  dword numberOfOptions;
  long result;
  char tempstr[64];
  dword requestId,  errorCode;
  byte buffer[500];
  int i;
 
  tempstr[0] = '\0';    
  requestId = (0 << 16) + sessionId;
  
  handle = SomeIpCreateMessage(messageId, requestId, protocolVersion, interfaceVersion, messageType, returnCode);
  if(handle==0)
  {
    ReportSomeIpError("SomeIpCreateMessage failed");
    return kFalse;
  }
  
  if(SetMethodArgumentDWord(handle, "Flags", IsWildcard(flags) ? 0xC0 : atol(flags), errorCode)!=kTrue)
    return kFalse;
  
  if(withEntry==kTrue)
  {
    //Set Number of Entries
    if(SetMethodArgumentDWord(handle, "Entry", 1, errorCode) != kTrue)
      return kFalse;

    //Set ServiceId of Entry
    snprintf(tempstr, elCount(tempstr), "Entry[0].%s.ServiceID", entryType);
    if(SetMethodArgumentDWord(handle, tempstr, serviceId, errorCode) != kTrue)
      return kFalse;
  
    //Set InstanceId of Entry
    snprintf(tempstr, elCount(tempstr), "Entry[0].%s.InstanceID", entryType);
    if(SetMethodArgumentDWord(handle, tempstr, instanceId, errorCode) != kTrue)
      return kFalse;
  
    if(!IsWildcard(additionalEntryFieldName))
    {
      snprintf(tempstr, elCount(tempstr), "Entry[0].%s.%s", entryType, additionalEntryFieldName);
      if(SetMethodArgumentDWord(handle, tempstr, additionalEntryFieldValue, errorCode) != kTrue)
        return kFalse;
    }
  
    //Set Major Version of entry
    snprintf(tempstr, elCount(tempstr), "Entry[0].%s.MajorVersion", entryType);
    if(SetMethodArgumentDWord(handle, tempstr, IsWildcard(majorVersion) ? syspar::SdClientServiceMajorVersion : atol(majorVersion), errorCode) != kTrue)
      return kFalse;
  
    //Set TTL of entry
    snprintf(tempstr, elCount(tempstr), "Entry[0].%s.TTL", entryType);
    if(SetMethodArgumentDWord(handle, tempstr, IsWildcard(ttl) ? atol(syspar::ServiceId1TTL) : atol(ttl), errorCode) != kTrue)
      return kFalse;
  
    //Set Minor Version of entry
    if(!IsWildcard(minorVersion))
    {
     snprintf(tempstr, elCount(tempstr), "Entry[0].%s.MinorVersion", entryType);
     if(SetMethodArgumentDWord(handle, tempstr, ConvertStringValueToInt64(minorVersion), errorCode) != kTrue)
       return kFalse;
    }
  }
  
  if(endpointSelector!=Without_Endpoints)
  {
    numberOfOptions = (endpointSelector==UDP_and_TCP_Endpoint || endpointSelector==UDP_Endpoint_Twice) ? 2 : 1;
    if(withEntry)
    {
      //Set NumberOfOptions1 of Entry
      snprintf(tempstr, elCount(tempstr), "Entry[0].%s.NumberOfOptions1", entryType);
      if(SetMethodArgumentDWord(handle, tempstr, numberOfOptions, errorCode) != kTrue)
        return kFalse;
    }

    //Set Number of options
    if(SetMethodArgumentDWord(handle, "Option", numberOfOptions, errorCode) != kTrue)
      return kFalse;
    
    if(sourceIpAddress.IsIPv4Address())
    {
     
      if(endpointSelector==UDP_and_TCP_Endpoint)
      {
       if(SetOptionIPv4Address(handle, 0, entryType, sourceIpAddress.IPv4Address, portNumber, PROTOCOL_TCP) != kTrue)
          return kFalse;
      }
      else
      {
        if(SetOptionIPv4Address(handle, 0, entryType, sourceIpAddress.IPv4Address, portNumber, PROTOCOL_UDP) != kTrue)
          return kFalse;
      }            
    }
    else
    {
      byte addressArray[16];
      
      if(sourceIpAddress.GetAddressAsArray(addressArray)!=0)
        return kFalse;
      
      if(endpointSelector==UDP_and_TCP_Endpoint)
      {
        if(SetOptionIPv6Address(handle, 0, entryType, addressArray, portNumber, PROTOCOL_TCP) != kTrue)
          return kFalse;
      }
      else
      {
        if(SetOptionIPv6Address(handle, 0, entryType, addressArray, portNumber, PROTOCOL_UDP) != kTrue)
          return kFalse;
      }
    }
    
    if(numberOfOptions==2)
    {
      if(sourceIpAddress.IsIPv4Address())
      {
        if(SetOptionIPv4Address(handle, 1, entryType, sourceIpAddress.IPv4Address, portNumber, PROTOCOL_UDP) != kTrue)
          return kFalse;
      }
      else
      {
        byte addressArray[16];
      
        if(sourceIpAddress.GetAddressAsArray(addressArray)!=0 ||
          SetOptionIPv6Address(handle, 1, entryType, addressArray, portNumber, PROTOCOL_UDP) != kTrue)
          return kFalse;
      }
    }
  }

  return kTrue;
}

enum Bool SetOptionIPv4Address(dword handle, byte index, char entryType[], dword ipV4Address, dword port, dword protocol) 
{
  char optionIPv4Address[2][64] = {"Option[x].IPv4Endpoint.IPv4Address", "Option[x].IPv4Multicast.IPv4Address" };
  char optionPortNumber[2][64]  = {"Option[x].IPv4Endpoint.PortNumber",  "Option[x].IPv4Multicast.PortNumber"  };
  char optionL4Proto[2][64]     = {"Option[x].IPv4Endpoint.L4Proto",     "Option[x].IPv4Multicast.L4Proto"     };
  dword errorCode;
  byte isSubscribeAck;
  
  isSubscribeAck = strncmp(entryType, "SubscribeAck", 12)==0;
  optionIPv4Address[isSubscribeAck][7] = optionPortNumber[isSubscribeAck][7] = optionL4Proto[isSubscribeAck][7] = (48 + index);
  
  if(isSubscribeAck) // must use multicast address
  {
    IP_Endpoint optIpEndpoint;
    InitEndpoint(optIpEndpoint, syspar::SomeIpServiceDiscoveryIpAddress, atol(syspar::SomeIpServiceDiscoveryPort));
    ipV4Address = optIpEndpoint.Address.IPv4Address;
  }

  if(SetMethodArgumentDWord(handle, optionIPv4Address[isSubscribeAck], SwapDWord(ipV4Address), errorCode) != kTrue ||
     SetMethodArgumentDWord(handle, optionPortNumber[isSubscribeAck], port, errorCode) != kTrue ||
     SetMethodArgumentDWord(handle, optionL4Proto[isSubscribeAck], protocol, errorCode) != kTrue)
    return kFalse;
  return kTrue;
}

enum Bool SetOptionIPv6Address(dword handle, byte index, char entryType[], byte ipV6Address[], dword port, dword protocol) 
{
  char optionIPv6Address[2][64] = {"Option[x].IPv6Endpoint.IPv6Address", "Option[x].IPv6Multicast.IPv6Address" };
  char optionPortNumber[2][64]  = {"Option[x].IPv6Endpoint.PortNumber",  "Option[x].IPv6Multicast.PortNumber"  };
  char optionL4Proto[2][64]     = {"Option[x].IPv6Endpoint.L4Proto",     "Option[x].IPv6Multicast.L4Proto"     };
  dword errorCode;
  byte isSubscribeAck;
  
  isSubscribeAck = strncmp(entryType, "SubscribeAck", 12)==0;
  optionIPv6Address[isSubscribeAck][7] = optionPortNumber[isSubscribeAck][7] = optionL4Proto[isSubscribeAck][7] = (48 + index);
  
  if(isSubscribeAck) // must use multicast address
  {
    IP_Endpoint optIpEndpoint;
    InitEndpoint(optIpEndpoint, syspar::SomeIpServiceDiscoveryIpAddress, atol(syspar::SomeIpServiceDiscoveryPort));
    if(optIpEndpoint.Address.GetAddressAsArray(ipV6Address)!=0)
      return kFalse;
  }

  if(SetMethodArgumentArray(handle, optionIPv6Address[isSubscribeAck], ipV6Address, errorCode) != kTrue ||
     SetMethodArgumentDWord(handle, optionPortNumber[isSubscribeAck], port, errorCode) != kTrue ||
     SetMethodArgumentDWord(handle, optionL4Proto[isSubscribeAck], protocol, errorCode) != kTrue)
    return kFalse;
  return kTrue;
}

enum Bool ETS_CreateSomeIpSDNotification2Entries(
  dword & handle,
  IP_Address sourceIpAddress,//char srcIp[],
  int protocol,
  int serviceId,
  char flags[],
  char entryType[],
  word instanceId,
  char majorVersion[],
  char ttl[],
  char minorVersion[],
  word sessionId,
  dword udpPort,
  char additionalEntry0FieldName[],
  dword additionalEntry0FieldValue,
  char additionalEntry1FieldName[],
  dword additionalEntry1FieldValue
  )
{
  dword messageId=0xFFFF8100, protocolVersion=0x01, interfaceVersion=0x01, messageType=SomeIpMessageTypeNotification, returnCode=0x00;
  const NumberOfEntries=2;
  long result;
  char tempstr[64];
  dword requestId,  errorCode;
  byte buffer[500];
  int i;
 
  tempstr[0] = '\0';    
  requestId = (0 << 16) + sessionId;
  
  handle = SomeIpCreateMessage(messageId, requestId, protocolVersion, interfaceVersion, messageType, returnCode);
  if(handle==0)
  {
    ReportSomeIpError("SomeIpCreateMessage failed");
    return kFalse;
  }
  
  if(SetMethodArgumentDWord(handle, "Flags", IsWildcard(flags) ? 0xC0 : atol(flags), errorCode)!=kTrue)
    return kFalse;
  
    //Set Number of Entries
    if(SetMethodArgumentDWord(handle, "Entry", 2, errorCode) != kTrue)
      return kFalse;

  for(i=0;i<NumberOfEntries;++i)
  {
    //Set ServiceId of Entry
    snprintf(tempstr, elCount(tempstr), "Entry[%d].%s.ServiceID", i, entryType);
    if(SetMethodArgumentDWord(handle, tempstr, serviceId, errorCode) != kTrue)
      return kFalse;
  
    //Set InstanceId of Entry
    snprintf(tempstr, elCount(tempstr), "Entry[%d].%s.InstanceID", i, entryType);
    if(SetMethodArgumentDWord(handle, tempstr, instanceId, errorCode) != kTrue)
      return kFalse;
  
    if(!IsWildcard(additionalEntry0FieldName) && i==0)
    {
      snprintf(tempstr, elCount(tempstr), "Entry[0].%s.%s", entryType, additionalEntry0FieldName);
      if(SetMethodArgumentDWord(handle, tempstr, additionalEntry0FieldValue, errorCode) != kTrue)
        return kFalse;
    }
    if(!IsWildcard(additionalEntry1FieldName) && i==1)
    {
      snprintf(tempstr, elCount(tempstr), "Entry[1].%s.%s", entryType, additionalEntry1FieldName);
      if(SetMethodArgumentDWord(handle, tempstr, additionalEntry1FieldValue, errorCode) != kTrue)
        return kFalse;
    }
  
    //Set Major Version of entry
    snprintf(tempstr, elCount(tempstr), "Entry[%d].%s.MajorVersion", i, entryType);
    if(SetMethodArgumentDWord(handle, tempstr, IsWildcard(majorVersion) ? syspar::SdClientServiceMajorVersion : atol(majorVersion), errorCode) != kTrue)
      return kFalse;
  
    //Set TTL of entry
    snprintf(tempstr, elCount(tempstr), "Entry[%d].%s.TTL", i, entryType);
    if(SetMethodArgumentDWord(handle, tempstr, IsWildcard(ttl) ? atol(syspar::ServiceId1TTL) : atol(ttl), errorCode) != kTrue)
      return kFalse;
  
    //Set Minor Version of entry
    if(!IsWildcard(minorVersion))
    {
     snprintf(tempstr, elCount(tempstr), "Entry[%d].%s.MinorVersion", i, entryType);
     if(SetMethodArgumentDWord(handle, tempstr, ConvertStringValueToInt64(minorVersion), errorCode) != kTrue)
       return kFalse;
    }
  }
  
  for(i=0;i<NumberOfEntries;++i)
  {
    //Set NumberOfOptions1 of Entry
    snprintf(tempstr, elCount(tempstr), "Entry[%d].%s.NumberOfOptions1", i, entryType);
    if(SetMethodArgumentDWord(handle, tempstr, 2, errorCode) != kTrue)
      return kFalse;
  }

  if(SetMethodArgumentDWord(handle, "Option", 2, errorCode) != kTrue)
    return kFalse;
  
  if(sourceIpAddress.IsIPv4Address())
  {
    if(SetMethodArgumentDWord(handle, "Option[0].IPv4Endpoint.IPv4Address", SwapDWord(sourceIpAddress.IPv4Address), errorCode) != kTrue ||
       SetMethodArgumentDWord(handle, "Option[0].IPv4Endpoint.PortNumber", udpPort, errorCode) != kTrue ||
       SetMethodArgumentDWord(handle, "Option[0].IPv4Endpoint.L4Proto", PROTOCOL_UDP, errorCode) != kTrue ||
       SetMethodArgumentDWord(handle, "Option[1].IPv4Endpoint.IPv4Address", SwapDWord(sourceIpAddress.IPv4Address), errorCode) != kTrue ||
       SetMethodArgumentDWord(handle, "Option[1].IPv4Endpoint.PortNumber", udpPort, errorCode) != kTrue ||
       SetMethodArgumentDWord(handle, "Option[1].IPv4Endpoint.L4Proto", PROTOCOL_TCP, errorCode) != kTrue)
      return kFalse;
  }
  else
  {
    byte addressArray[16];
      
    if(sourceIpAddress.GetAddressAsArray(addressArray)!=0 ||
       SetMethodArgumentArray(handle, "Option[0].IPv6Endpoint.IPv6Address", addressArray, errorCode) != kTrue ||
       SetMethodArgumentDWord(handle, "Option[0].IPv6Endpoint.PortNumber", udpPort, errorCode) != kTrue ||
       SetMethodArgumentDWord(handle, "Option[0].IPv6Endpoint.L4Proto", PROTOCOL_UDP, errorCode) != kTrue ||
       SetMethodArgumentArray(handle, "Option[1].IPv6Endpoint.IPv6Address", addressArray, errorCode) != kTrue ||
       SetMethodArgumentDWord(handle, "Option[1].IPv6Endpoint.PortNumber", udpPort, errorCode) != kTrue ||
       SetMethodArgumentDWord(handle, "Option[1].IPv6Endpoint.L4Proto", PROTOCOL_TCP, errorCode) != kTrue)
      return kFalse;
  }
  
  return kTrue;
}

void ETS_SendSomeIpSDNotification(char callerFunctionName[],
  char srcIp[], char destIp[], int serviceId,
  char flags[], char entryType[], word instanceId,
  char majorVersion[], char ttl[], char minorVersion[],
  word sessionId, dword udpPort,
  char additionalEntryFieldName[], dword additionalEntryFieldValue,
  enum EndpointSelector endpointSelector, enum Bool withEntry
  )
{
  dword handle;
  
  IP_Endpoint sourceEndpoint, destinationEndpoint, sendEndpoint;
  if(InitEndpoint(sourceEndpoint, srcIp, atol(syspar::SomeIpServiceDiscoveryPort))!=kTrue ||
     InitEndpoint(destinationEndpoint, destIp, atol(syspar::SomeIpServiceDiscoveryPort))!=kTrue ||
     InitEndpoint(sendEndpoint, syspar::IpAddressTester, atol(syspar::SomeIpServiceDiscoveryPort))!=kTrue)
  {
    testStepFail("Creation of endpoints failed");
    return;
  }
  
  if(ETS_CreateSomeIpSDNotification(handle, sourceEndpoint.Address, serviceId, flags, entryType,
    instanceId, majorVersion, ttl, minorVersion, sessionId, udpPort, additionalEntryFieldName, additionalEntryFieldValue, endpointSelector, withEntry)==kFalse)
  {
    testStepFail(callerFunctionName, "Creation of notification failed");
    if(handle)
      SomeIpReleaseMessage(handle);
    return;
  }

  if(ETS_OutputSomeIpSDNotification(handle, sendEndpoint, destinationEndpoint)==kFalse)
  {
    testStepFail(callerFunctionName, "Sending of notification failed");
  }
}

void ETS_PostSomeIpSDNotification(char callerFunctionName[],
  char srcIp[], char destIp[], int protocol, int serviceId,
  char flags[], char entryType[], word instanceId,
  char majorVersion[], char ttl[], char minorVersion[],
  word sessionId, dword udpPort,
  char additionalEntryFieldName[], dword additionalEntryFieldValue,
  enum EndpointSelector endpointSelector, enum Bool withEntry
  )
{
  dword handle;
  
  IP_Endpoint sourceEndpoint, destinationEndpoint;
  if(InitEndpoint(sourceEndpoint, srcIp, atol(syspar::SomeIpServiceDiscoveryPort))!=kTrue ||
     InitEndpoint(destinationEndpoint, destIp, atol(syspar::SomeIpServiceDiscoveryPort))!=kTrue)
  {
    testStepFail("Creation of endpoints failed");
    return;
  }
  
  if(ETS_CreateSomeIpSDNotification(handle, sourceEndpoint.Address, serviceId, flags, entryType,
    instanceId, majorVersion, ttl, minorVersion, sessionId, udpPort, additionalEntryFieldName, additionalEntryFieldValue, endpointSelector, withEntry)==kFalse)
  {
    testStepFail(callerFunctionName, "Creation of notification failed");
    if(handle)
      SomeIpReleaseMessage(handle);
    return;
  }

  if(ETS_PostSomeIpSDNotification2(handle, sourceEndpoint, destinationEndpoint)==kFalse)
  {
    testStepFail(callerFunctionName, "Sending of notification failed");
  }
}

