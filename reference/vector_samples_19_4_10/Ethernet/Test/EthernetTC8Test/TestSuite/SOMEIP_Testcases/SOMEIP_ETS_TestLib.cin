enum EndpointSelector getEndpointSelectorForEVG(dword evgId)
{
  return evgId==2 ? UDP_and_TCP_Endpoint : UDP_Endpoint_Only;
}

export InitTestFixtureETS()
{
  SetBusContext(GetBusNameContext("Ethernet_1"));
  
  gSomeIpTestGroup = kSomeIpEts;
  strncpy(gSomeIpTestGroupName, "SOMEIP ETS", elcount(gSomeIpTestGroupName));
  Internal_InitTestFixture(gSomeIpTestGroup, "OnEthernetPacketSOMEIP_ETS");

  sysSetVariableInt(sysvar::TC8_ETS_Config::ETS_ServiceId, syspar::SomeIp_ETS_ServiceId);
  sysSetVariableInt(sysvar::TC8_ETS_Config::ETS_Port, syspar::SomeIp_ETS_Port);

  sysSetVariableInt(sysvar::TC8_ETS_Config::ETS_DUT_ServiceInstanceId, syspar::SomeIp_ETS_DUT_InstanceId);
  sysSetVariableInt(sysvar::TC8_ETS_Config::ETS_Tester_ServiceInstanceId, atol(syspar::SomeIp_ETS_Tester_InstanceId));
  sysSetVariableString(sysvar::TC8_ETS_Config::EventGroupId1Si1MulticastAddr, syspar::EventGroupId1Si1MulticastAddr);
  
  SomeIpSetVerbosity(3);
  SomeIpIlControlStart();

  SomeIpConsistencyCheck();
  
  testWaitForTimeout(5000); //Wait until IGMP messages have been sent
  OpenLocalApplicationEndPointsForETS();
}

void OpenLocalApplicationEndPointsForETS()
{
  IP_Endpoint endpoint;
  SetBusContext(GetBusNameContext("Ethernet_1"));
  
  if(InitEndpoint(endpoint, syspar::IpAddressTester, 0)!=kTrue)
  {
    testStepFail("UDP Server AEP init endpoint failed");
    return;
  }
  
  endpoint.SetToUdp();
  gClientServiceAepHandleUDP = ETSOpenLocalApplicationEndpoint(endpoint);
  if(gClientServiceAepHandleUDP==0)
  {
    ReportSomeIpError("Creation of UDP local application endpoint failed");
    return;
  }

  endpoint.SetToTcp();
  gClientServiceAepHandleTCP = ETSOpenLocalApplicationEndpoint(endpoint);
  if(gClientServiceAepHandleTCP==0)
  {
    ReportSomeIpError("Creation of TCP local application endpoint failed");
    return;
  }
}

void ReceivedEthPacketTcp(long channel, long dir, long packetHandle)
{
  if (gObservingEthPackets == kFalse)
  {
    //write("Ethernet packet received, but not observed at %.5f", timeNowFloat()/100000.0);
    return;
  } 

  if(CompareParameters(packetHandle, channel, gReportOnFailure))
    EthernetPacketReceived(channel);
}

enum Bool HasIpDestinationAddress(ethernetPacket * packet, IP_Address destination)
{
  IP_Address packetAddress;
  byte addressArray[16];
  if(packet.ipv4.IsAvailable())
  {
    return packet.ipv4.destination==destination.IPv4Address ? kTrue : kFalse;
  }
  else if(packet.ipv6.IsAvailable())
  {
    packet.ipv6.destination.GetData(0, addressArray, elcount(addressArray));
    packetAddress.SetAddressAsArray(addressArray);
    return packetAddress.MatchesAddress(destination) ? kTrue : kFalse;
  }
  return kFalse;
}

on ethernetPacket *
{
  byte NOTIFICATION_MESSAGE_SIZE = 16;
  byte buffer[1600], buffer2[1600];
  word bufferLength;
  dword destIp, messageHandle, msgLen, offset, msgType;
  
  // special handling necessary for SOME/IP messages which are addressed to another ip
  // because these packets are not processed by SOME/IP IL
  if(gObserveSomeIpMessageForOtherIp==kTrue && this.msgChannel==1 && this.dir==RX &&
     this.someip.isAvailable() && HasIpDestinationAddress(this, gObserveSomeIpMessageForOtherIp_Address)==kTrue)
  {
    bufferLength = this.someip.GetData(0, buffer, elcount(buffer));
    if(bufferLength)
    {
      offset=0;
      while(offset<bufferLength) // process all messages in that packet
      {
        messageHandle = SomeIpCreateMessage(bufferLength, buffer, offset); 
        if(messageHandle)
        {
          msgType = SomeIpGetMessageType(messageHandle);
          msgLen = SomeIpGetData(messageHandle, elcount(buffer2), buffer2);
          OnSomeIpProcessRxMessage(messageHandle, this.msgChannel);
          SomeIpReleaseMessage(messageHandle);
          if(msgType!=0x02) // Notification
          {
            write("############# unhandled SOME/IP message type %d ################", msgType);
            break;
          }
          offset += NOTIFICATION_MESSAGE_SIZE + msgLen;
        }
        else
          break;
      }
    }
  }
}

void OnEthernetPacketSOMEIP_ETS(long channel, long dir, long packetHandle)
{
  //
  char direction[2][16] = { "receiving", "sending" };
  long result;
  //write("> OnEthernetPacketSOMEIP_ETS at %.5f, dir: %s, channel %ld, isWaiting %d isObserving %d", timeNowFloat()/100000.0, direction[dir], channel, gIsWaitingForSOMEIPMessage, gObservingEthPackets);
  //
  AnswerArpRequestForHost1(packetHandle);
  AnswerNdpSolicitation(packetHandle);
  if(gIsWaitingForSOMEIPMessage==0) // SOME/IP packets must be handled by OnSomeIpProcessRxMessage
  {
    ReceivedEthPacketTcp(channel, dir, packetHandle);
  }
  //write("< OnEthernetPacketSOMEIP_ETS");
}

enum Bool ETS_PostSomeIpSDNotification2(dword & notificationHandle, IP_Endpoint sourceEndpoint, IP_Endpoint destinationEndpoint)
{
  dword aep;
  long result;
  enum Bool success;
  
  SetBusContext(GetBusNameContext("Ethernet_1"));
  
  success = kTrue;
  
  sourceEndpoint.SetToUdp();
  destinationEndpoint.SetToUdp();
  aep = ETSOpenLocalApplicationEndpoint(sourceEndpoint);
  if(aep==0)
  {
    ReportSomeIpError("SomeIpOpenLocalApplicationEndpoint failed");
    success = kFalse;
  }
  else
  {
    result = SomeIpPostMessage(aep, destinationEndpoint, notificationHandle);
    if(result!=0)
    {
      ReportSomeIpError("Post message failed");
      success = kFalse;
    }
  }
  
  if(SomeIpReleaseMessage(notificationHandle)!=0)
  {
    ReportSomeIpError("Release message failed");
    success = kFalse;
  }
  notificationHandle=0;
  
  if(aep && ETSCloseLocalApplicationEndpoint(aep))
  {
    ReportSomeIpError("SomeIpCloseLocalApplicationEndpoint failed");
    success = kFalse;
  }
  aep = 0;
  return success;
}

enum Bool ETS_OutputSomeIpSDNotification(dword & notificationHandle, IP_Endpoint sourceEndpoint, IP_Endpoint destinationEndpoint)
{
  dword aep;
  long result;
  enum Bool success;
  
  SetBusContext(GetBusNameContext("Ethernet_1"));
  
  success = kTrue;

  sourceEndpoint.SetToUdp();
  destinationEndpoint.SetToUdp();
  aep = ETSOpenLocalApplicationEndpoint(sourceEndpoint); //syspar::UdpProtocol, atol(syspar::SomeIpServiceDiscoveryPort));
  if(aep==0)
  {
    ReportSomeIpError("SomeIpOpenLocalApplicationEndpoint failed");
    success = kFalse;
  }
  else
  {
    result = SomeIpOutputMessage(aep, destinationEndpoint, notificationHandle);
    if(result!=0)
    {
      ReportSomeIpError("Output message failed");
      success = kFalse;
    }
  }
  
  if(SomeIpReleaseMessage(notificationHandle)!=0)
  {
    ReportSomeIpError("Release message failed");
    success = kFalse;
  }
  notificationHandle=0;
  
  if(aep && ETSCloseLocalApplicationEndpoint(aep))
  {
    ReportSomeIpError("SomeIpCloseLocalApplicationEndpoint failed");
    success = kFalse;
  }
  aep = 0;
  return success;
}

export testfunction ETS_StartServer2(enum Bool useMulticastEvents, enum Bool useExtendedSDBaseRepetitionDelay)
{
    if(gServiceCreatedETS==0)
    {
      char buf[100];
      int64 multicastThreshold;
      multicastThreshold = useMulticastEvents==kTrue ? 1 : 0;

      //writeEx(-3,1,"%s: ServiceID=%u", gProcessName, @sysvar::TC8_ETS_Config::ETS_ServiceId);
      gServiceCreatedETS = createETSService(atol(syspar::SomeIp_ETS_Tester_InstanceId), syspar::IpAddressTester, multicastThreshold);
      if(gServiceCreatedETS==kFalse)
      {
        testStepFail("ETS_StartServer2", "Instantiation of ETS server 2 failed");
        return;
      }
    }
    else
    {
      write("########### ETS Server still exists ################");
    }
    if(startETSService()==kFalse)
    {
      ReportSomeIpError("Start of ETS service failed");
      testStepFail("ETS_StartServer2", "Start of ETS service failed");
      return;
    }
    else
      testStepPass("ETS_StartServer2", "ETS service started");
    
    if(useExtendedSDBaseRepetitionDelay)
    {
      SomeIpSetProperty(gPsiUdp, "SDBaseRepetitionDelay", 5000);
      SomeIpSetProperty(gPsiTcp, "SDBaseRepetitionDelay", 5000);
    }
}

export testfunction ETS_StartServer2(enum Bool useMulticastEvents)
{
  ETS_StartServer2(useMulticastEvents, kFalse);
}

export testfunction ETS_StartServer2()
{
  ETS_StartServer2(kFalse, kFalse);
}

export testfunction ETS_StopServer2()
{
  if(gServiceCreatedETS==kTrue)
  {
    stopETSService();
    testWaitForTimeout(5);
    if(destroyETSService()==kFalse)
    {
      testStepFail("ETS_StopServer2", "ETS server not stopped");
    }
    gServiceCreatedETS=0;
  }
}

