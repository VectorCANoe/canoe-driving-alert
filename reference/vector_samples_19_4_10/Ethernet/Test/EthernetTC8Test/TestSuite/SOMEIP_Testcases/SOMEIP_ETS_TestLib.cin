    testStepFail("ETS_SendNotification_Subscribe_WithUnusedOptionData", "Creation of notification failed");
    if(handle)
      SomeIpReleaseMessage(handle);
    return;
  }

  messageLength = SomeIpSerializeMessage(handle, elCount(messageBuffer), messageBuffer);
  setBigEndianDWORD(messageBuffer, 0 , 0xFFEE8100); 
  
  msgHandle = SomeIpCreateMessage(messageLength, messageBuffer);
  //SomeIpOutputMessage(gClientServiceAepHandleUDP, ipGetAddressAsNumber(destinationIP), atol(syspar::SomeIpServiceDiscoveryPort), msgHandle);
  InitEndpoint(destinationEndpoint, destinationIP, atol(syspar::SomeIpServiceDiscoveryPort));
  SomeIpOutputMessage(gClientServiceAepHandleUDP, destinationEndpoint, msgHandle);
  
  SomeIpReleaseMessage(handle);

}


export testfunction ETS_SendNotification_Subscribe_WithInvalidL4Proto(dword sessionId, dword instanceId, dword evgId, char ttl[], char destinationIP[])
{
  const dword OFFSET_FIELD_EntryLength = 4; // payload starts with field 'flags'
  const dword SIZE_FIELD_LengthOfEntriesArray = 4;
  const dword SIZE_FIELD_LengthOfOptionsArray = 4;
  const dword REL_OFFSET_FIELD_L4Proto = 9;
  int i;
  long dataLen;
  byte buffer[1500];
  dword handle, entriesLength, offsetOfFieldL4Proto;
  
  IP_Endpoint sourceEndpoint, destinationEndpoint;
  if(InitEndpoint(sourceEndpoint, syspar::IpAddressTester, atol(syspar::SomeIpServiceDiscoveryPort))!=kTrue ||
     InitEndpoint(destinationEndpoint, destinationIP, atol(syspar::SomeIpServiceDiscoveryPort))!=kTrue)
  {
    testStepFail("Creation of endpoints failed");
    return;
  }
  
  if(ETS_CreateSomeIpSDNotification(handle, sourceEndpoint.Address, syspar::SomeIp_ETS_ServiceId, syspar::Wildcard, "Subscribe",
    instanceId, syspar::Wildcard, ttl, syspar::Wildcard, sessionId, gPortForSubscribeWithoutCSI, "EventgroupID", evgId, getEndpointSelectorForEVG(evgId), kTrue)==kFalse)
  {
    testStepFail("ETS_SendNotification_Subscribe_WithInvalidL4Proto", "Creation of notification failed");
    return;
  }

  dataLen = SomeIpGetData(handle, elcount(buffer), buffer);

  entriesLength = getBigEndianDWORD(buffer, OFFSET_FIELD_EntryLength);

  offsetOfFieldL4Proto = OFFSET_FIELD_EntryLength + SIZE_FIELD_LengthOfEntriesArray +
    entriesLength + SIZE_FIELD_LengthOfOptionsArray + REL_OFFSET_FIELD_L4Proto;
  buffer[offsetOfFieldL4Proto] = 0x00;
  
  SomeIpSetData(handle, dataLen, buffer);

  if(ETS_OutputSomeIpSDNotification(handle, sourceEndpoint, destinationEndpoint)==kFalse)
  {
    testStepFail("ETS_SendNotification_Subscribe_WithInvalidL4Proto", "Sending of notification failed");
  }
}

