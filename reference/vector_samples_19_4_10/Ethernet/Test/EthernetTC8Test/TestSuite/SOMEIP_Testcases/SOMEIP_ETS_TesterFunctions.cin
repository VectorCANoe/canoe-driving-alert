    gExpectedResult_echoUTF16FIXED[i] = 65 + (i%26);
  }
  gExpectedResult_echoUTF16FIXED[i] = 0;
  success = SetMethodArgumentStringUTF16(methodCallHandle, gMethodArgumentName_echoUTF16FIXED_REQ_UTF16String,
    gExpectedResult_echoUTF16FIXED, errorCode);

  if(success)
  {
    sizePayload = SomeIpGetData(methodCallHandle, elcount(buffer), buffer);
    // length of payload has to be patched
    sizePayload += 1;
    buffer[sizePayload-1] = 65;
    if(SomeIpSetData(methodCallHandle, sizePayload, buffer)!=0)
    {
      ReportSomeIpError("Setting payload failed");
      return kFalse;
    }
  }
  return success;
}

/// <echoUTF16FIXED>
void OnMethodResponse_echoUTF16FIXED_Odd_number_after_termination(dword methodCallHandle, dword messageResponseHandle)
{
  dword errorCode;
  if(CheckMethodResponse_echoUTF16(messageResponseHandle, gMethodArgumentName_echoUTF16FIXED_RES_UTF16String,
       gExpectedResult_echoUTF16FIXED, errorCode))
    SetTestMethodResult(sysvar::TC8_ETS::ETS_MethodResult::OK);
  else
    SetTestMethodResult(errorCode);
}

/// <echoUTF8DYNAMIC>
enum Bool ProvideArgumentsForMethod_echoUTF8DYNAMIC_Wrong_BOM(dword methodCallHandle)
{
  dword i, errorCode;
  BYTE buffer[200];
  dword sizePayload;
  enum Bool success;

  success = SetMethodArgumentStringUTF8(methodCallHandle, gMethodArgumentName_echoUTF8DYNAMIC_REQ_UTF8String,
    gExpectedResult_echoUTF8DYNAMIC, errorCode);

  if(success)
  {
    sizePayload = SomeIpGetData(methodCallHandle, elcount(buffer), buffer);
    for(i=0; i<4; i++) // length in payload has to be patched
    {
      if(buffer[i]==0)
        continue;

      buffer[i] -= 1;
      break;
    }

    for(i=6; i<sizePayload-1; ++i) // UTF16 BOM has just 2 bytes, remove one byte of the payload
    {
      buffer[i] = buffer[i+1];
    }
    buffer[4] = 0xFE; // write UTF16 BOM into payload
    buffer[5] = 0xFF;
    sizePayload -= 1;
    if(SomeIpSetData(methodCallHandle, sizePayload, buffer)!=0)
    {
      ReportSomeIpError("Setting payload failed");
      return kFalse;
    }
  
  }
  return success;
}

/// <echoUTF8DYNAMIC>
void OnMethodResponse_echoUTF8DYNAMIC_Wrong_BOM(dword methodCallHandle, dword messageResponseHandle)
{
  dword errorCode;
  if(CheckMethodResponse_echoUTF16(messageResponseHandle, gMethodArgumentName_echoUTF8DYNAMIC_RES_UTF8String,
       gExpectedResult_echoUTF8DYNAMIC, errorCode))
