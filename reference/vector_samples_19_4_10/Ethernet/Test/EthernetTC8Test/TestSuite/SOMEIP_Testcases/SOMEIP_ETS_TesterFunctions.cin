}

/// <echoUNION>
enum Bool ProvideArgumentsForMethod_echoUNION_UnionLength_too_long_for_message(dword methodCallHandle)
{
  byte payload[64];
  long payloadSize;
  byte LENGTH_INCREMENT = 10;

  if(ProvideArgumentsForMethod_echoUNION(methodCallHandle)==kFalse)
    return kFalse;

  payloadSize = SomeIpGetData(methodCallHandle, elcount(payload), payload);

  payload[3] += LENGTH_INCREMENT; // increment union length, but keep payload length
  
  if(SomeIpSetData(methodCallHandle, payloadSize, payload)!=0)
  {
    ReportSomeIpError("Setting payload failed");
    return kFalse;
  }
  return kTrue;
}

/// <echoUNION>
