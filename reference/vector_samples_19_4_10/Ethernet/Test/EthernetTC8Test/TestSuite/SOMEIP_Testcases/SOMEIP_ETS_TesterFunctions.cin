{
  dword i, errorCode;
  BYTE buffer[200];
  dword sizePayload;
  enum Bool success;

  success = SetMethodArgumentStringUTF16(methodCallHandle, gMethodArgumentName_echoUTF16DYNAMIC_REQ_UTF16String,
    gExpectedResult_echoUTF16DYNAMIC, errorCode);

  if(success)
  {
    sizePayload = SomeIpGetData(methodCallHandle, elcount(buffer), buffer);
    for(i=0; i<4; i++) // length in payload has to be patched
    {
      if(buffer[i]==0)
        continue;

      buffer[i] += 5;
