/// <Helper functions>
enum Bool AllFieldNotificationsReceived()
{
  for(long fieldId: gWaitingForFieldNotificationsCount)
  {
    if(gWaitingForFieldNotificationsCount[fieldId]>0)
      return kFalse;
  }
  return kTrue;
}

/// <Helper functions>
enum Bool AllEventNotificationsReceived()
{
  for(long eventId: gWaitingForEventNotificationsCount)
  {
    if(gWaitingForEventNotificationsCount[eventId]>0)
      return kFalse;
  }
  return kTrue;
}

on timer gWaitConditionReachedTimer
{
  testSupplyTextEvent("ETSAllWaitNotificationsReached");
}

/// <Event Notifications>
void EventNotificationReceived(dword eventId)
{
  if(gWaitingForEventNotifications && gWaitingForEventNotificationsCount.containsKey(eventId) && gWaitingForEventNotificationsCount[eventId]>0)
  {
    --gWaitingForEventNotificationsCount[eventId];
    if(AllEventNotificationsReceived() && isTimerActive(gWaitConditionReachedTimer)==0)
      setTimer(gWaitConditionReachedTimer, 0);
  }
}

/// <Event Notifications>
void Tester_EventReceived_TestEventUINT8(dword eventHandle, dword messageHandle)
{
  EventNotificationReceived(EVENT_ID_TestEventUINT8);
}

/// <Event Notifications>
void Tester_EventReceived_TestEventUINT8Array(dword eventHandle, dword messageHandle)
{
  EventNotificationReceived(EVENT_ID_TestEventUINT8Array);
}

/// <Event Notifications>
void Tester_EventReceived_TestEventUINT8Reliable(dword eventHandle, dword messageHandle)
{
  EventNotificationReceived(EVENT_ID_TestEventUINT8Reliable);
}

/// <Event Notifications>
void Tester_EventReceived_TestEventUINT8Multicast(dword eventHandle, dword messageHandle)
{
  EventNotificationReceived(EVENT_ID_TestEventUINT8Multicast);  
}

/// <Field Notifications>
void FieldNotificationReceived(dword fieldId)
{
  if(gWaitingForFieldNotifications && gWaitingForFieldNotificationsCount.containsKey(fieldId) && gWaitingForFieldNotificationsCount[fieldId]>0)
  {
    --gWaitingForFieldNotificationsCount[fieldId];
    if(AllFieldNotificationsReceived() && isTimerActive(gWaitConditionReachedTimer)==0)
      setTimer(gWaitConditionReachedTimer, 0);
  }
}

/// <Field Notifications>
void Tester_OnFieldNotification_InterfaceVersion(DWORD pfHandle, DWORD messageHandle)
{
  gFieldNotificationReceived_InterfaceVersion = kTrue;
  FieldNotificationReceived(FIELD_ID_InterfaceVersion);
}

/// <Field Notifications>
void Tester_OnFieldNotification_TestFieldUINT8(DWORD pfHandle, DWORD messageHandle)
{
  gFieldNotificationReceived_TestFieldUINT8 = kTrue;
  FieldNotificationReceived(FIELD_ID_TestFieldUINT8);
}

