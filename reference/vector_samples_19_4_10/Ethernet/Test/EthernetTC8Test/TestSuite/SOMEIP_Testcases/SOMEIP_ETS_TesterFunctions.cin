/// <TestFieldUINT8Array>
void OnMethodResponse_get_TestFieldUINT8Array(dword methodCallHandle, dword messageHandle )
{
  dword length, i, value, errorCode;
  char buffer[32];
  gResponseValues_GetterTestFieldUINT8Array.length = 0;
  if(SetMethodArgumentDWord(messageHandle, "", length, errorCode)==kTrue)
  {
    gResponseValues_GetterTestFieldUINT8Array.length = length;
    for(i=0; i<length; ++i)
    {
      snprintf(buffer, elcount(buffer), "[%d]", i);
      if(GetMethodArgumentDWord(messageHandle, buffer, value, errorCode)!=kTrue)
      {
        SetTestMethodResult(errorCode);
        return;
      }
      gResponseValues_GetterTestFieldUINT8Array.values[i] = value;
    }
    SetTestMethodResult(sysvar::TC8_ETS::ETS_MethodResult::OK);
  }
  else
    SetTestMethodResult(errorCode);
}

/// <TestFieldUINT8Array>
enum Bool ProvideArgumentsForMethod_set_TestFieldUINT8Array(dword methodCallHandle)
{
  dword i, errorCode;
  char buffer[32];
  
  if(SetMethodArgumentDWord(methodCallHandle, "", gRequestedValues_SetterTestFieldUINT8Array.length, errorCode)!=kTrue)
    return kFalse;
  
  for(i=0; i<gRequestedValues_SetterTestFieldUINT8Array.length; i++)
  {
    snprintf(buffer, elcount(buffer), "[%d]", i);
    if(SetMethodArgumentDWord(methodCallHandle, buffer, gRequestedValues_SetterTestFieldUINT8Array.values[i], errorCode)!=kTrue)
      return kFalse;
  }
  return kTrue;
}

/// <TestFieldUINT8Array>
void OnMethodResponse_set_TestFieldUINT8Array(dword methodCallHandle, dword messageResponseHandle)
{
  dword i, length, value, errorCode;
  char buffer[32];
  gResponseValues_SetterTestFieldUINT8Array.length = 0;

  if(CheckResponseReturnCode(messageResponseHandle, 0, errorCode) &&
     GetMethodArgumentDWord(messageResponseHandle, "", length, errorCode))
  {  
    for(i=0; i<length; i++)
    {
      snprintf(buffer, elcount(buffer), "[%d]", i);
      if(GetMethodArgumentDWord(messageResponseHandle, buffer, value, errorCode)!=kTrue)
      {
        SetTestMethodResult(errorCode);
        return;
      }
      gResponseValues_SetterTestFieldUINT8Array.values[i] = value;
    }
    gResponseValues_SetterTestFieldUINT8Array.length = length;
    SetTestMethodResult(sysvar::TC8_ETS::ETS_MethodResult::OK);
  }
  else
    SetTestMethodResult(errorCode);
}

/// <Helper functions>
void CallTriggerEventMethod(char testFunctionName[], dword methodId, dword eventId,
  char triggerEventDelayArgName[], dword triggerEventDelay,
  char triggerEventDurationArgName[], dword triggerEventDuration,
  char triggerEventDebounceTimeArgName[], dword triggerEventDebounceTime)
{
  DWORD methodCallHandle, errorCode, udpHandle;
  
  udpHandle = (gClientServiceAepHandleUDP ? gClientServiceAepHandleUDP : gUdpAepForSubscribeWithoutCSI);
  
  if(CreateMethodHandleFireAndForget(udpHandle, methodId, methodCallHandle)==kFalse)
  {
      testStepFail(testFunctionName, "Creation of method call handle failed");
      return;
  }

  if(SetMethodArgumentDWord(methodCallHandle, triggerEventDelayArgName, triggerEventDelay, errorCode)!=kTrue ||
     SetMethodArgumentDWord(methodCallHandle, triggerEventDurationArgName, triggerEventDuration, errorCode)!=kTrue ||
     SetMethodArgumentDWord(methodCallHandle, triggerEventDebounceTimeArgName, triggerEventDebounceTime, errorCode)!=kTrue)
  {
    testStepFail(testFunctionName, "Setting arguments failed");
    return;
  }

  testWaitForTimeoutSilent(100);    

  if(SomeIpCallMethod(methodCallHandle)!=0)
  {
    ReportSomeIpError("Call of triggerEvent* failed");
    testStepFail(testFunctionName, "Method call failed");
    return;
  }
  
  gWaitingForEventNotificationsCount[eventId] = 1; 
}

void OnMethodResponseTypeError(dword methodCallHandle, dword messageResponseHandle)
{
  SetTestMethodResult(SomeIpGetReturnCode(messageResponseHandle), E_MRT_ERROR);
}
