  if(CheckMethodResponse_echoUTF16(messageResponseHandle, gMethodArgumentName_echoUTF16DYNAMIC_RES_UTF16String,
       gExpectedResult_echoUTF16DYNAMIC, errorCode))
    SetTestMethodResult(sysvar::TC8_ETS::ETS_MethodResult::OK);
  else
    SetTestMethodResult(errorCode);
}

