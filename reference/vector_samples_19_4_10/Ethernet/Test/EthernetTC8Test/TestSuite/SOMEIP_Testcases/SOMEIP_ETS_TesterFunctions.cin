/// <echoUINT8Array2Dim>
enum Bool ProvideArgumentsForMethod_echoUINT8Array2Dim(dword methodCallHandle)
{
  dword errorCode;
  char reqBuffer[64];
  int row, col;
  for(row=0; row<gEchoUINT8Array2Dim_Length1; ++row)
  {
    for(col=0; col<gEchoUINT8Array2Dim_Length2; ++col)
    {
      gExpectedResult_echoUINT8Array2Dim[row][col] = ((row*10 + col) % 0xFF);
      snprintf(reqBuffer, elCount(reqBuffer), "%s[%d][%d]", gMethodArgumentName_echoUINT8Array2Dim_REQ_UINT8Array, row, col);
      if(SetMethodArgumentDWord(methodCallHandle, reqBuffer, gExpectedResult_echoUINT8Array2Dim[row][col], errorCode)==kFalse)
        return kFalse;
    }
  }
  return kTrue;
}

/// <echoUINT8Array2Dim>
void OnMethodResponse_echoUINT8Array2Dim(dword methodCallHandle, dword messageResponseHandle)
{
  dword row, col, countRows, countCols, errorCode;
  char resBuffer[64];
  dword value;

  if(CheckResponseReturnCode(messageResponseHandle, 0, errorCode) &&
     GetMethodArgumentDWord(messageResponseHandle, gMethodArgumentName_echoUINT8Array2Dim_RES_UINT8Array, countRows, errorCode)&&
     CheckResponseDataComparision(countRows==gEchoUINT8Array2Dim_Length1, errorCode))
  {
    for(row=0; row<countRows; ++row)
    {
      snprintf(resBuffer, elCount(resBuffer), "%s[%d]", gMethodArgumentName_echoUINT8Array2Dim_RES_UINT8Array, row);
      if(GetMethodArgumentDWord(messageResponseHandle, resBuffer, countCols, errorCode)==kFalse ||
         CheckResponseDataComparision(countCols==gEchoUINT8Array2Dim_Length2, errorCode)==kFalse)
      {
        SetTestMethodResult(errorCode);
        return;
      }
      
      for(col=0; col<countCols; ++col)
      {
        snprintf(resBuffer, elCount(resBuffer), "%s[%d][%d]", gMethodArgumentName_echoUINT8Array2Dim_RES_UINT8Array, row, col);
        if(GetMethodArgumentDWord(messageResponseHandle, resBuffer, value, errorCode)==kFalse ||
           CheckResponseDataComparision(value==gExpectedResult_echoUINT8Array2Dim[row][col], errorCode)==kFalse)
        {
          SetTestMethodResult(errorCode);
          return;
        }
      }
    }
    SetTestMethodResult(sysvar::TC8_ETS::ETS_MethodResult::OK);
  }
  else
    SetTestMethodResult(errorCode);
}

