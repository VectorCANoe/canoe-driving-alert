     GetMethodArgumentDWord(messageResponseHandle, gMethodArgumentName_echoUNION_RES_unionElement, validIndex, errorCode) &&
     CheckResponseDataComparision(validIndex==gExpectedResult_echoUNION_validIndex, errorCode) &&
     GetMethodArgumentDWord(messageResponseHandle, gMethodArgumentName_echoUNION_RES_unionMember3, response, errorCode) &&
     CheckResponseDataComparision(response==gExpectedResult_echoUNION, errorCode))
