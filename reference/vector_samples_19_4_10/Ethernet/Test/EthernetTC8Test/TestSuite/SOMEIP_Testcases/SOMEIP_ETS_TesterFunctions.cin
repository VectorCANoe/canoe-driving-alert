/// <echoStaticUINT8Array>
enum Bool ProvideArgumentsForMethod_echoStaticUINT8Array(dword methodCallHandle)
{
  dword errorCode;
  char reqBuffer[64];
  int i;
  
  for(i=0; i<gEchoStaticUINT8Array_Length; ++i)
  {
    gExpectedResult_echoStaticUINT8Array[i] = i + 42;
    snprintf(reqBuffer, elCount(reqBuffer), "%s[%d]", gMethodArgumentName_echoStaticUINT8Array_REQ_UINT8Array, i);
    if(SetMethodArgumentDWord(methodCallHandle, reqBuffer, gExpectedResult_echoStaticUINT8Array[i], errorCode)==kFalse)
      return kFalse;
  }

  return kTrue;
}

/// <echoStaticUINT8Array>
void OnMethodResponse_echoStaticUINT8Array(dword methodCallHandle, dword messageResponseHandle)
{
  dword response, errorCode;
  char resBuffer[64];
  int i;

  if(CheckResponseReturnCode(messageResponseHandle, 0, errorCode) &&
     CheckArraySize(messageResponseHandle, gMethodArgumentName_echoStaticUINT8Array_RES_UINT8Array,
       gEchoStaticUINT8Array_Length, errorCode))
  {  
    for(i=0; i<gEchoStaticUINT8Array_Length; ++i)
    {
      snprintf(resBuffer, elCount(resBuffer), "%s[%d]", gMethodArgumentName_echoStaticUINT8Array_RES_UINT8Array, i);
      if(GetMethodArgumentDWord(messageResponseHandle, resBuffer, response, errorCode)==kFalse ||
         CheckResponseDataComparision(ReportUnequal(response==gExpectedResult_echoStaticUINT8Array[i], resBuffer), errorCode)==kFalse)
      {
        SetTestMethodResult(errorCode);
        return;
      }
    }
    SetTestMethodResult(sysvar::TC8_ETS::ETS_MethodResult::OK);
  }
  else
    SetTestMethodResult(errorCode);
}

/// <echoUINT8Array>
enum Bool ProvideArgumentsForMethod_echoUINT8Array(dword methodCallHandle)
{
  return ProvideArgumentsForMethod_echoUINT8Array(methodCallHandle, gEchoUINT8Array_Length,
    gExpectedResult_echoUINT8Array, gMethodArgumentName_echoUINT8Array_REQ_UINT8Array);
}

