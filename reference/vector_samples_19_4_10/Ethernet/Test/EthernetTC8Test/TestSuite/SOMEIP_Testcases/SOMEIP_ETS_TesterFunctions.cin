/// <echoUINT8ArrayMinSize_ArrayMinSize_too_short>
enum Bool ProvideArgumentsForMethod_echoUINT8ArrayMinSize_ArrayMinSize_too_short(dword methodCallHandle)
{
  dword i;
  BYTE buffer[200];
  dword sizePayload;
  enum Bool success;

  success = ProvideArgumentsForMethod_echoUINT8Array(methodCallHandle, gEchoUINT8ArrayMinSize_MinLength-1,
    gExpectedResult_echoUINT8ArrayMinSize, gMethodArgumentName_echoUINT8ArrayMinSize_REQ_UINT8Array);

  if(success)
  {
    sizePayload = SomeIpGetData(methodCallHandle,elcount(buffer),buffer);
    for(i=0; i<4; i++) // array length in payload might not be what we need
    {
      if(buffer[i]==gEchoUINT8ArrayMinSize_MinLength-1) // array length is as required
        break;

      if(buffer[i]==gEchoUINT8ArrayMinSize_MinLength) // array length is still minLength and needs to be corrected
      {
        buffer[i] = gEchoUINT8ArrayMinSize_MinLength-1; // patch array length
        if(SomeIpSetData(methodCallHandle, sizePayload - 1, buffer)!=0)
        {
          ReportSomeIpError("Setting payload failed");
          return kFalse;
        }
        break;
      }
    }
  }
  return success;
}

