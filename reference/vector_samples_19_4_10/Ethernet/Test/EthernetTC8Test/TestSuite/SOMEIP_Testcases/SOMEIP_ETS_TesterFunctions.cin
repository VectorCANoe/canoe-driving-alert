/// <echoUTF16DYNAMIC>
enum Bool ProvideArgumentsForMethod_echoUTF16DYNAMIC_Wrong_BOM(dword methodCallHandle)
{
  dword i, errorCode;
  BYTE buffer[200];
  dword sizePayload;
  enum Bool success;

  success = SetMethodArgumentStringUTF16(methodCallHandle, gMethodArgumentName_echoUTF16DYNAMIC_REQ_UTF16String,
    gExpectedResult_echoUTF16DYNAMIC, errorCode);

  if(success)
  {
    sizePayload = SomeIpGetData(methodCallHandle, elcount(buffer), buffer);
    for(i=0; i<4; i++) // length in payload has to be patched
    {
      if(buffer[i]==0)
        continue;

      buffer[i] += 1;
      break;
    }

    for(i=sizePayload-1; i>5; --i) // make space for additional UTF8 BOM byte
    {
      buffer[i+1] = buffer[i];
    }
    buffer[4] = 0xEF; // write UTF8 BOM into payload
    buffer[5] = 0xBB;
    buffer[6] = 0xBF;
    sizePayload += 1;
    if(SomeIpSetData(methodCallHandle, sizePayload, buffer)!=0)
    {
      ReportSomeIpError("Setting payload failed");
      return kFalse;
    }
  
  }
  return success;
}

