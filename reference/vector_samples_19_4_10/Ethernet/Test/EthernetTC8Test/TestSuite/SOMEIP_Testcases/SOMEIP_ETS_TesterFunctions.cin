/// <echoUTF16DYNAMIC>
enum Bool ProvideArgumentsForMethod_echoUTF16DYNAMIC_Odd_number_before_termination(dword methodCallHandle)
{
  dword i, errorCode;
  BYTE buffer[200];
  dword sizePayload;

  if(SetMethodArgumentStringUTF16(methodCallHandle, gMethodArgumentName_echoUTF16DYNAMIC_REQ_UTF16String,
       gExpectedResult_echoUTF16DYNAMIC, errorCode))
  {
    sizePayload = SomeIpGetData(methodCallHandle, elcount(buffer), buffer);
    for(i=0; i<4; i++) // length in payload has to be patched
    {
      if(buffer[i]==0)
        continue;

      buffer[i] += 1;
      sizePayload += 1;
      buffer[sizePayload-3] = 65;
      buffer[sizePayload-2] = 0;
      buffer[sizePayload-1] = 0;
      if(SomeIpSetData(methodCallHandle, sizePayload, buffer)!=0)
      {
        ReportSomeIpError("Setting payload failed");
        return kFalse;
      }
      return kTrue;
    }
  }
  return kFalse;
}

