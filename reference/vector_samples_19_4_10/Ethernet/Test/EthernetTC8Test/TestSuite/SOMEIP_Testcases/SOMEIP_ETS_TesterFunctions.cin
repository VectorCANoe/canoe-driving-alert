/// <Helper functions>
void RestorePayloadStringTermination(dword payloadSize, byte payload[], byte terminationSize)
{
  int i;
  for(i=0; i<terminationSize; ++i)
    payload[payloadSize-i-1] = 0; // restore termination
}

enum Bool CheckMethodResponse_echoUTF16(dword messageResponseHandle, char argName[], char expectedResult[], dword & errorCode)
{
  char response[gUTFStringMaxLen];
  
  return (enum Bool)
    (CheckResponseReturnCode(messageResponseHandle, 0, errorCode) &&
     GetMethodArgumentStringUTF16(messageResponseHandle, argName, elcount(response), response, errorCode) &&
     CheckResponseDataComparision(strncmp(response, expectedResult, elcount(response))==0, errorCode));
}

/// <Helper functions>
enum Bool CheckMethodResponse_echoUTF8(dword messageResponseHandle, char argName[], char expectedResult[], dword & errorCode)
{
  char response[gUTFStringMaxLen];

  return (enum Bool)
    (CheckResponseReturnCode(messageResponseHandle, 0, errorCode) &&
     GetMethodArgumentStringUTF8(messageResponseHandle, argName, elcount(response), response, errorCode) &&
     CheckResponseDataComparision(strncmp(response, expectedResult, elcount(response))==0, errorCode));
}

/// <Helper functions>
enum Bool CheckResponseReturnCode(dword messageResponseHandle, dword expectedRC, dword & errorCode)
{
  dword returnCode;
  returnCode = SomeIpGetReturnCode(messageResponseHandle);
  if(returnCode!=expectedRC)
  {
    char expected[64], actualResult[64];
    sysGetVariableDescriptionForValue(sysvar::TC8_ETS::ETS_MethodResult, expectedRC, expected, elcount(expected));
    sysGetVariableDescriptionForValue(sysvar::TC8_ETS::ETS_MethodResult, returnCode, actualResult, elcount(actualResult));
    
    // Just set the result. No error message necessary. It will be handled by the function that triggered the call
    errorCode = returnCode;
    return kFalse;
  }
  return kTrue;
}

/// <Helper functions>
enum Bool CheckResponseDataComparision(dword dataIsEqual, dword & errorCode)
{
  if(dataIsEqual==0)
    errorCode = sysvar::TC8_ETS::ETS_MethodResult::InvalidMethodResponseData;

  return dataIsEqual==0 ? kFalse : kTrue;
}

/// <Helper functions>
enum Bool ProvideArgumentsForMethod_echoUINT8Array(dword methodCallHandle, byte arrayLength, byte result[], char argumentName[])
{
  dword count, errorCode;
  char reqBuffer[64];
  int i;
  
  for(i=0; i<arrayLength; ++i)
  {
    result[i] = i + 19;
    snprintf(reqBuffer, elCount(reqBuffer), "%s[%d]", argumentName, i);
    if(SetMethodArgumentDWord(methodCallHandle, reqBuffer, result[i], errorCode)==kFalse)
      return kFalse;
  }

  if(SetMethodArgumentDWord(methodCallHandle, argumentName, arrayLength, errorCode)==kFalse ||
     GetMethodArgumentDWord(methodCallHandle, argumentName, count, errorCode)==kFalse)
    return kFalse;

  if(count!=arrayLength)
  {
    //write("Error: Array size did not change");
    errorCode = sysvar::TC8_ETS::ETS_MethodResult::GeneralFailure;
    return kFalse;
  }

  return kTrue;
}

/// <Helper functions>
enum Bool CheckArraySize(dword messageResponseHandle, char arrayName[], dword expectedSize, dword & errorCode)
{
  dword arraySize;
  return (enum Bool)(
    GetMethodArgumentDWord(messageResponseHandle, arrayName, arraySize, errorCode) &&
    CheckResponseDataComparision(ReportUnequal(arraySize==expectedSize, "array size"), errorCode));
}

/// <Helper functions>
enum Bool CheckResponseOfMethod_echoUINT8Array(dword messageResponseHandle, byte arrayLength, byte expectedResult[],
  char resArgumentName[], dword expectedReturnCode, dword & errorCode)
{
  dword response;
  char resBuffer[64];
  int i;

  if(CheckResponseReturnCode(messageResponseHandle, expectedReturnCode, errorCode) &&
     CheckArraySize(messageResponseHandle, resArgumentName, arrayLength, errorCode))
  {
    for(i=0; i<arrayLength; ++i)
    {
      snprintf(resBuffer, elCount(resBuffer), "%s[%d]", resArgumentName, i);
      if(GetMethodArgumentDWord(messageResponseHandle, resBuffer, response, errorCode)==kFalse ||
         CheckResponseDataComparision(response==expectedResult[i], errorCode)==kFalse)
        return kFalse;
    }
    return kTrue;
  }
  return kFalse;
}

/// <checkByteOrder>
enum Bool ProvideArgumentsForMethod_checkByteOrder(dword methodCallHandle)
{
  dword errorCode;
  stack dword arg1 = 55;
  stack dword arg2 = 65500;
  gExpectedResult_checkByteOrder = arg1 + arg2;

  return (enum Bool)
    (SetMethodArgumentDWord(methodCallHandle, gMethodArgumentName_checkByteOrder_REQ_arg1, arg1, errorCode) &&
     SetMethodArgumentDWord(methodCallHandle, gMethodArgumentName_checkByteOrder_REQ_arg2, arg2, errorCode));
}

/// <checkByteOrder>
void OnMethodResponse_checkByteOrder(dword methodCallHandle, dword messageResponseHandle)
{
  dword value, errorCode;

  if(CheckResponseReturnCode(messageResponseHandle, 0, errorCode)==kFalse)
  {
    SetTestMethodResult(errorCode);
    return;
  }
  
  if(GetMethodArgumentDWord(messageResponseHandle, gMethodArgumentName_checkByteOrder_RES_arg1, value, errorCode) &&
     CheckResponseDataComparision(value==gExpectedResult_checkByteOrder, errorCode))
    SetTestMethodResult(sysvar::TC8_ETS::ETS_MethodResult::OK);
  else
    SetTestMethodResult(errorCode);
}

/// <echoBitfields>
enum Bool ProvideArgumentsForMethod_echoBitfields(dword methodCallHandle)
{
  dword args[3], errorCode;
  args[0] = 0x3F;
  args[1] = 0x7FE0;
  args[2] = 0x7F03E2E0;
  gExpectedResult_echoBitfields[0] = reverseBits(args[0], 8);
  gExpectedResult_echoBitfields[1] = reverseBits(args[1], 16);
  gExpectedResult_echoBitfields[2] = reverseBits(args[2], 32);
  
  return (enum Bool)
    (SetMethodArgumentDWord(methodCallHandle, gMethodArgumentName_echoBitfields_REQ_bitfield8,  args[0], errorCode) &&
     SetMethodArgumentDWord(methodCallHandle, gMethodArgumentName_echoBitfields_REQ_bitfield16, args[1], errorCode) &&
     SetMethodArgumentDWord(methodCallHandle, gMethodArgumentName_echoBitfields_REQ_bitfield32, args[2], errorCode));
}

/// <echoBitfields>
void OnMethodResponse_echoBitfields(dword methodCallHandle, dword messageResponseHandle)
{
  dword args[3], errorCode;
  
  if(CheckResponseReturnCode(messageResponseHandle, 0, errorCode) &&
     GetMethodArgumentDWord(messageResponseHandle, gMethodArgumentName_echoBitfields_RES_bitfield8, args[0], errorCode) &&
     GetMethodArgumentDWord(messageResponseHandle, gMethodArgumentName_echoBitfields_RES_bitfield16, args[1], errorCode) &&
     GetMethodArgumentDWord(messageResponseHandle, gMethodArgumentName_echoBitfields_RES_bitfield32, args[2], errorCode) &&
     CheckResponseDataComparision(args[0]==gExpectedResult_echoBitfields[0] &&
         args[1]==gExpectedResult_echoBitfields[1] && args[2]==gExpectedResult_echoBitfields[2], errorCode))
      SetTestMethodResult(sysvar::TC8_ETS::ETS_MethodResult::OK);
  else
    SetTestMethodResult(errorCode);
}


/// <echoCommonDatatypes>
enum Bool ProvideArgumentsForMethod_echoCommonDatatypes(dword methodCallHandle)
{
  dword errorCode;
  gExpectedResult_echoCommonDatatypes.booleanArg = 1;
  gExpectedResult_echoCommonDatatypes.unsignedArgs[0] = 18;
  gExpectedResult_echoCommonDatatypes.unsignedArgs[1] = 116;
  gExpectedResult_echoCommonDatatypes.unsignedArgs[2] = 132;
  gExpectedResult_echoCommonDatatypes.signedArgs[0] = -28;
  gExpectedResult_echoCommonDatatypes.signedArgs[1] = -23212;
  gExpectedResult_echoCommonDatatypes.signedArgs[2] = -134215;
  gExpectedResult_echoCommonDatatypes.float32Arg = interpretAsFloat(interpretAsDword(18.4)); // force float32 value
  gExpectedResult_echoCommonDatatypes.float64Arg = 29.4;

  return (enum Bool)
    (SetMethodArgumentDWord(methodCallHandle,
       gMethodArgumentName_echoCommonDatatypes_REQ_ARG1_BOOLEAN, gExpectedResult_echoCommonDatatypes.booleanArg, errorCode) &&
     SetMethodArgumentDWord(methodCallHandle,
       gMethodArgumentName_echoCommonDatatypes_REQ_ARG2_UINT8,  gExpectedResult_echoCommonDatatypes.unsignedArgs[0], errorCode) &&
     SetMethodArgumentDWord(methodCallHandle,
       gMethodArgumentName_echoCommonDatatypes_REQ_ARG3_UINT16, gExpectedResult_echoCommonDatatypes.unsignedArgs[1], errorCode) &&
     SetMethodArgumentDWord(methodCallHandle,
       gMethodArgumentName_echoCommonDatatypes_REQ_ARG4_UINT32, gExpectedResult_echoCommonDatatypes.unsignedArgs[2], errorCode) &&
     SetMethodArgumentLong(methodCallHandle,
       gMethodArgumentName_echoCommonDatatypes_REQ_ARG5_INT8,  gExpectedResult_echoCommonDatatypes.signedArgs[0], errorCode) &&
     SetMethodArgumentLong(methodCallHandle,
       gMethodArgumentName_echoCommonDatatypes_REQ_ARG6_INT16, gExpectedResult_echoCommonDatatypes.signedArgs[1], errorCode) &&
     SetMethodArgumentLong(methodCallHandle,
       gMethodArgumentName_echoCommonDatatypes_REQ_ARG7_INT32, gExpectedResult_echoCommonDatatypes.signedArgs[2], errorCode) &&
     SetMethodArgumentFloat(methodCallHandle,
       gMethodArgumentName_echoCommonDatatypes_REQ_ARG8_FLOAT32, gExpectedResult_echoCommonDatatypes.float32Arg, errorCode) &&
     SetMethodArgumentFloat(methodCallHandle,
       gMethodArgumentName_echoCommonDatatypes_REQ_ARG9_FLOAT64, gExpectedResult_echoCommonDatatypes.float64Arg, errorCode));  
}

/// <Helper functions>
dword ReportUnequal(dword isEqual, char descr[])
{
  if(isEqual==0)
    write("Method response contains wrong value: %s", descr);
  return isEqual;
}

/// <echoCommonDatatypes>
void OnMethodResponse_echoCommonDatatypes(dword methodCallHandle, dword messageResponseHandle)
{
  dword errorCode;
  struct _echoCommonDatatypesArgs response;
  if(CheckResponseReturnCode(messageResponseHandle, 0, errorCode) &&
     GetMethodArgumentFloat(messageResponseHandle, gMethodArgumentName_echoCommonDatatypes_RES_ARG1_FLOAT64, response.float64Arg, errorCode) &&
     GetMethodArgumentFloat(messageResponseHandle, gMethodArgumentName_echoCommonDatatypes_RES_ARG2_FLOAT32, response.float32Arg, errorCode) &&
     GetMethodArgumentLong(messageResponseHandle,  gMethodArgumentName_echoCommonDatatypes_RES_ARG3_INT32,   response.signedArgs[2], errorCode) &&
     GetMethodArgumentLong(messageResponseHandle,  gMethodArgumentName_echoCommonDatatypes_RES_ARG4_INT16,   response.signedArgs[1], errorCode) &&
     GetMethodArgumentLong(messageResponseHandle,  gMethodArgumentName_echoCommonDatatypes_RES_ARG5_INT8,    response.signedArgs[0], errorCode) &&
     GetMethodArgumentDWord(messageResponseHandle, gMethodArgumentName_echoCommonDatatypes_RES_ARG6_UINT32,  response.unsignedArgs[2], errorCode) &&
     GetMethodArgumentDWord(messageResponseHandle, gMethodArgumentName_echoCommonDatatypes_RES_ARG7_UINT16,  response.unsignedArgs[1], errorCode) &&
     GetMethodArgumentDWord(messageResponseHandle, gMethodArgumentName_echoCommonDatatypes_RES_ARG8_UINT8,   response.unsignedArgs[0], errorCode) &&
     GetMethodArgumentDWord(messageResponseHandle, gMethodArgumentName_echoCommonDatatypes_RES_ARG9_BOOLEAN, response.booleanArg, errorCode) &&
     CheckResponseDataComparision(
         response.booleanArg==gExpectedResult_echoCommonDatatypes.booleanArg &&
         response.unsignedArgs[0]==gExpectedResult_echoCommonDatatypes.unsignedArgs[0] &&
         response.unsignedArgs[1]==gExpectedResult_echoCommonDatatypes.unsignedArgs[1] &&
         response.unsignedArgs[2]==gExpectedResult_echoCommonDatatypes.unsignedArgs[2] &&
         response.signedArgs[0]==gExpectedResult_echoCommonDatatypes.signedArgs[0] &&
         response.signedArgs[1]==gExpectedResult_echoCommonDatatypes.signedArgs[1] &&
         response.signedArgs[2]==gExpectedResult_echoCommonDatatypes.signedArgs[2] &&
         ReportUnequal(response.float32Arg==gExpectedResult_echoCommonDatatypes.float32Arg, "float32 member") &&
         ReportUnequal(response.float64Arg==gExpectedResult_echoCommonDatatypes.float64Arg, "float64 member"), errorCode))
    SetTestMethodResult(sysvar::TC8_ETS::ETS_MethodResult::OK);
  else
    SetTestMethodResult(errorCode);
}

