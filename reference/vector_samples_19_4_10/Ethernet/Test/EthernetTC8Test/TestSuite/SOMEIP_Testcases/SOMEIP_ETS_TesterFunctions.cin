/// <echoUTF16FIXED>
enum Bool ProvideArgumentsForMethod_echoUTF16FIXED_String_too_long(dword methodCallHandle)
{
  dword errorCode;
  enum Bool result;
  byte payload[UTF16FIXED_ENCODED_SIZE + 20];
  long payloadSize;
  int i;

  for(i=0; i<elcount(gExpectedResult_echoUTF16FIXED)-1; ++i)
  {
    gExpectedResult_echoUTF16FIXED[i] = 65 + (i%26);
  }
  gExpectedResult_echoUTF16FIXED[i] = 0;
  
  result = SetMethodArgumentStringUTF16(methodCallHandle, gMethodArgumentName_echoUTF16FIXED_REQ_UTF16String,
      gExpectedResult_echoUTF16FIXED, errorCode);
  
  if(result)
  {
    payloadSize = SomeIpGetData(methodCallHandle, elcount(payload), payload);
    if(payloadSize!=UTF16FIXED_ENCODED_SIZE+UTF16BOM_SIZE || SomeIpGetLastError()!=0)
    {
      ReportSomeIpError("Payload problem");
      return kFalse;
    }
    
    for(i=payloadSize-UTF16TERMINATION_SIZE*2; i<elcount(payload)-UTF16TERMINATION_SIZE; i += 2)
    {
      payload[i] = payload[UTF8BOM_SIZE];     // fill the payload with the first encoded
      payload[i+1] = payload[UTF8BOM_SIZE+1]; // character
    }
    payloadSize = elcount(payload);
    
    RestorePayloadStringTermination(payloadSize, payload, UTF16TERMINATION_SIZE);    

    if(SomeIpSetData(methodCallHandle, elcount(payload), payload)!=0)
    {
      result = kFalse;
      ReportSomeIpError("Set data failed");
    }
  }
  return result;
}

