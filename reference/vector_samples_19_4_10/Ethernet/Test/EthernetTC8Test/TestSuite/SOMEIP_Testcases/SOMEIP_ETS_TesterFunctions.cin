  result = SetMethodArgumentDWord(methodCallHandle, gMethodArgumentName_echoUINT8Reliable_REQ_UINT8Value,
    gExpectedResult_echoUINT8Reliable, errorCode);
  if(result==kTrue)
  {
    byte payload[1600];
    dword payloadLength;
    payloadLength = SomeIpGetData(methodCallHandle, elcount(payload), payload);
    SomeIpSetData(methodCallHandle, payloadLength+1, payload);
  }
  return result;
}

