void OnSomeIpSDClientEventGroupStatusChanged( dword serviceId, dword instanceId, dword eventGroupId, long status )
{
  if(gWaitingForSubscribeAcks)
  {
    if(serviceId==syspar::SomeIp_ETS_ServiceId && instanceId==syspar::SomeIp_ETS_DUT_InstanceId &&
       gWaitingForSubscribeAckEventgroups.containsKey(eventGroupId))
    {
      if(status==1)
      {
        int i;
        
        gWaitingForSubscribeAckEventgroups[eventGroupId] = kFalse;
        
        for(long aKey: gWaitingForSubscribeAckEventgroups)
        {
          if(gWaitingForSubscribeAckEventgroups[aKey]==kTrue)
            return;
        }
        
        if(isTimerActive(gWaitConditionReachedTimer)==0)
          setTimer(gWaitConditionReachedTimer, 0);
      }
    }
  }
}

/// <InterfaceVersion>
void OnMethodResponse_get_InterfaceVersion(dword methodCallHandle, dword messageHandle )
{
  dword majorVersion, minorVersion, errorCode;
  if(GetMethodArgumentDWord(messageHandle, gFieldname_InterfaceVersion_majorVersion, majorVersion, errorCode)!=kOk &&
     GetMethodArgumentDWord(messageHandle, gFieldname_InterfaceVersion_minorVersion, minorVersion, errorCode)!=kOk)
  {
    gResponseValue_GetterInterfaceVersion.majorVersion = majorVersion;
    gResponseValue_GetterInterfaceVersion.minorVersion = minorVersion;
    SetTestMethodResult(sysvar::TC8_ETS::ETS_MethodResult::OK);
  }
  else
    SetTestMethodResult(errorCode);
}

