    <AR-PACKAGE>
      <SHORT-NAME>SystemMapping</SHORT-NAME>
      <ELEMENTS>
        <!-- /SystemMapping/System -->
        <SYSTEM>
          <SHORT-NAME>System</SHORT-NAME>
          <FIBEX-ELEMENTS>
            <FIBEX-ELEMENT-REF-CONDITIONAL>
              <FIBEX-ELEMENT-REF DEST="ETHERNET-CLUSTER">/Cluster/VehicleNetwork</FIBEX-ELEMENT-REF>
            </FIBEX-ELEMENT-REF-CONDITIONAL>
          </FIBEX-ELEMENTS>
          <MAPPINGS>
            <!-- /SystemMapping/System/SystemMapping -->
            <SYSTEM-MAPPING>
              <SHORT-NAME>SystemMapping</SHORT-NAME>
              <DATA-MAPPINGS>
                <SENDER-RECEIVER-TO-SIGNAL-MAPPING> 
                  <EVENT-HANDLER-REFS>
                    <EVENT-HANDLER-REF DEST="EVENT-HANDLER">/Cluster/VehicleNetwork/VLAN_Drive/EDRV_Drive_SOMEIP_AEP/EDRV_Drive_SOMEIP_AEP/DrivingPSI1/AllEvg</EVENT-HANDLER-REF>
                  </EVENT-HANDLER-REFS>
                  <SERVICE-INSTANCE-REFS>
                    <SERVICE-INSTANCE-REF DEST="PROVIDED-SERVICE-INSTANCE">/Cluster/VehicleNetwork/VLAN_Drive/EDRV_Drive_SOMEIP_AEP/EDRV_Drive_SOMEIP_AEP/DrivingPSI1</SERVICE-INSTANCE-REF>
                  </SERVICE-INSTANCE-REFS>
                  <DATA-ELEMENT-IREF>
                    <TARGET-DATA-PROTOTYPE-REF DEST='VARIABLE-DATA-PROTOTYPE'>/SystemMapping/SenderReceiver/MotorState</TARGET-DATA-PROTOTYPE-REF>
                  </DATA-ELEMENT-IREF>
                  <SYSTEM-SIGNAL-REF DEST='SYSTEM-SIGNAL'>/SystemSignal/MotorState</SYSTEM-SIGNAL-REF>
                </SENDER-RECEIVER-TO-SIGNAL-MAPPING>
                <SENDER-RECEIVER-TO-SIGNAL-MAPPING> 
                  <EVENT-HANDLER-REFS>
                    <EVENT-HANDLER-REF DEST="EVENT-HANDLER">/Cluster/VehicleNetwork/VLAN_Drive/EDRV_Drive_SOMEIP_AEP/EDRV_Drive_SOMEIP_AEP/DrivingPSI1/AllEvg</EVENT-HANDLER-REF>
                  </EVENT-HANDLER-REFS>
                  <SERVICE-INSTANCE-REFS>
                    <SERVICE-INSTANCE-REF DEST="PROVIDED-SERVICE-INSTANCE">/Cluster/VehicleNetwork/VLAN_Drive/EDRV_Drive_SOMEIP_AEP/EDRV_Drive_SOMEIP_AEP/DrivingPSI1</SERVICE-INSTANCE-REF>
                  </SERVICE-INSTANCE-REFS>
                  <DATA-ELEMENT-IREF>
                    <TARGET-DATA-PROTOTYPE-REF DEST='VARIABLE-DATA-PROTOTYPE'>/SystemMapping/SenderReceiver/Mode_Notifier</TARGET-DATA-PROTOTYPE-REF>
                  </DATA-ELEMENT-IREF>
                  <SYSTEM-SIGNAL-REF DEST='SYSTEM-SIGNAL'>/SystemSignal/Mode_Notifier</SYSTEM-SIGNAL-REF>
                </SENDER-RECEIVER-TO-SIGNAL-MAPPING>
                <CLIENT-SERVER-TO-SIGNAL-MAPPING>
                  <SERVICE-INSTANCE-REFS>
                    <SERVICE-INSTANCE-REF DEST="PROVIDED-SERVICE-INSTANCE">/Cluster/VehicleNetwork/VLAN_Drive/EDRV_Drive_SOMEIP_AEP/EDRV_Drive_SOMEIP_AEP/DrivingPSI1</SERVICE-INSTANCE-REF>
                  </SERVICE-INSTANCE-REFS>
                  <CALL-SIGNAL-REF DEST="SYSTEM-SIGNAL">/SystemSignal/PowerBoostRequest</CALL-SIGNAL-REF>
                  <CLIENT-SERVER-OPERATION-IREF>
                    <TARGET-OPERATION-REF DEST="CLIENT-SERVER-OPERATION">/ClientServerInterface/Driving/PowerBoost</TARGET-OPERATION-REF>
                  </CLIENT-SERVER-OPERATION-IREF>
                  <RETURN-SIGNAL-REF DEST="SYSTEM-SIGNAL">/SystemSignal/PowerBoostResponse</RETURN-SIGNAL-REF>
                </CLIENT-SERVER-TO-SIGNAL-MAPPING>
                <CLIENT-SERVER-TO-SIGNAL-MAPPING>
                  <SERVICE-INSTANCE-REFS>
                    <SERVICE-INSTANCE-REF DEST="PROVIDED-SERVICE-INSTANCE">/Cluster/VehicleNetwork/VLAN_Drive/EDRV_Drive_SOMEIP_AEP/EDRV_Drive_SOMEIP_AEP/DrivingPSI1</SERVICE-INSTANCE-REF>
                  </SERVICE-INSTANCE-REFS>
                  <CALL-SIGNAL-REF DEST="SYSTEM-SIGNAL">/SystemSignal/Mode_GetterRqst</CALL-SIGNAL-REF>
                  <CLIENT-SERVER-OPERATION-IREF>
                    <TARGET-OPERATION-REF DEST="CLIENT-SERVER-OPERATION">/ClientServerInterface/Driving/Mode_Getter</TARGET-OPERATION-REF>
                  </CLIENT-SERVER-OPERATION-IREF>
                  <RETURN-SIGNAL-REF DEST="SYSTEM-SIGNAL">/SystemSignal/Mode_GetterResp</RETURN-SIGNAL-REF>
                </CLIENT-SERVER-TO-SIGNAL-MAPPING>
                <CLIENT-SERVER-TO-SIGNAL-MAPPING>
                  <SERVICE-INSTANCE-REFS>
                    <SERVICE-INSTANCE-REF DEST="PROVIDED-SERVICE-INSTANCE">/Cluster/VehicleNetwork/VLAN_Drive/EDRV_Drive_SOMEIP_AEP/EDRV_Drive_SOMEIP_AEP/DrivingPSI1</SERVICE-INSTANCE-REF>
                  </SERVICE-INSTANCE-REFS>
                  <CALL-SIGNAL-REF DEST="SYSTEM-SIGNAL">/SystemSignal/Mode_SetterRqst</CALL-SIGNAL-REF>
                  <CLIENT-SERVER-OPERATION-IREF>
                    <TARGET-OPERATION-REF DEST="CLIENT-SERVER-OPERATION">/ClientServerInterface/Driving/Mode_Setter</TARGET-OPERATION-REF>
                  </CLIENT-SERVER-OPERATION-IREF>
                  <RETURN-SIGNAL-REF DEST="SYSTEM-SIGNAL">/SystemSignal/Mode_SetterResp</RETURN-SIGNAL-REF>
                </CLIENT-SERVER-TO-SIGNAL-MAPPING>
              </DATA-MAPPINGS>
            </SYSTEM-MAPPING>
          </MAPPINGS>
        </SYSTEM>
        <!-- /SystemMapping/SenderReceiver -->
        <SENDER-RECEIVER-INTERFACE>
          <SHORT-NAME>SenderReceiver</SHORT-NAME>
          <DATA-ELEMENTS>
            <!-- /SystemMapping/SenderReceiver/MotorState -->
            <VARIABLE-DATA-PROTOTYPE>
              <SHORT-NAME>MotorState</SHORT-NAME>
              <TYPE-TREF DEST='APPLICATION-RECORD-DATA-TYPE'>/ADT/MotorStateEvt</TYPE-TREF>
            </VARIABLE-DATA-PROTOTYPE>
            <!-- /SystemMapping/SenderReceiver/Mode_Notifier -->
            <VARIABLE-DATA-PROTOTYPE>
              <SHORT-NAME>Mode_Notifier</SHORT-NAME>
              <TYPE-TREF DEST='APPLICATION-PRIMITIVE-DATA-TYPE'>/ADT/DriveMode</TYPE-TREF>
            </VARIABLE-DATA-PROTOTYPE>
          </DATA-ELEMENTS>
        </SENDER-RECEIVER-INTERFACE>
      </ELEMENTS>
    </AR-PACKAGE>
    <AR-PACKAGE>
      <SHORT-NAME>ClientServerInterface</SHORT-NAME>
      <ELEMENTS>
        <!-- /ClientServerInterface/Driving -->
        <CLIENT-SERVER-INTERFACE>
          <SHORT-NAME>Driving</SHORT-NAME>
          <CATEGORY>CONTROL</CATEGORY>
          <IS-SERVICE>true</IS-SERVICE>
          <OPERATIONS>
            <!-- /ClientServerInterface/Driving/PowerBoost -->
            <CLIENT-SERVER-OPERATION>
              <SHORT-NAME>PowerBoost</SHORT-NAME>
              <ARGUMENTS>
                <!-- /ClientServerInterface/Driving/PowerBoost/Power -->
                <ARGUMENT-DATA-PROTOTYPE>
                  <SHORT-NAME>Power</SHORT-NAME>
                  <TYPE-TREF DEST='APPLICATION-PRIMITIVE-DATA-TYPE'>/ADT/Power</TYPE-TREF>
                  <DIRECTION>IN</DIRECTION>
                </ARGUMENT-DATA-PROTOTYPE>
                <!-- /ClientServerInterface/Driving/PowerBoost/ConfirmedPower -->
                <ARGUMENT-DATA-PROTOTYPE>
                  <SHORT-NAME>ConfirmedPower</SHORT-NAME>
                  <TYPE-TREF DEST='APPLICATION-PRIMITIVE-DATA-TYPE'>/ADT/Power</TYPE-TREF>
                  <DIRECTION>OUT</DIRECTION>
                </ARGUMENT-DATA-PROTOTYPE>
              </ARGUMENTS>
            </CLIENT-SERVER-OPERATION>
            <!-- /ClientServerInterface/Driving/Mode_Getter -->
            <CLIENT-SERVER-OPERATION>
              <SHORT-NAME>Mode_Getter</SHORT-NAME>
              <ARGUMENTS>
                <!-- /ClientServerInterface/Driving/Mode/Mode -->
                <ARGUMENT-DATA-PROTOTYPE>
                  <SHORT-NAME>Mode</SHORT-NAME>
                  <TYPE-TREF DEST='APPLICATION-PRIMITIVE-DATA-TYPE'>/ADT/DriveMode</TYPE-TREF>
                  <DIRECTION>OUT</DIRECTION>
                </ARGUMENT-DATA-PROTOTYPE>
              </ARGUMENTS>
            </CLIENT-SERVER-OPERATION>
            <!-- /ClientServerInterface/Driving/Mode_Setter -->
            <CLIENT-SERVER-OPERATION>
              <SHORT-NAME>Mode_Setter</SHORT-NAME>
              <ARGUMENTS>
                <!-- /ClientServerInterface/Driving/Mode/Mode -->
                <ARGUMENT-DATA-PROTOTYPE>
                  <SHORT-NAME>Mode</SHORT-NAME>
                  <TYPE-TREF DEST='APPLICATION-PRIMITIVE-DATA-TYPE'>/ADT/DriveMode</TYPE-TREF>
                  <DIRECTION>IN</DIRECTION>
                </ARGUMENT-DATA-PROTOTYPE>
              </ARGUMENTS>
            </CLIENT-SERVER-OPERATION>
          </OPERATIONS>
        </CLIENT-SERVER-INTERFACE>
      </ELEMENTS>
    </AR-PACKAGE>
    <AR-PACKAGE>
      <SHORT-NAME>ServiceInterface</SHORT-NAME>
      <ELEMENTS>
        <!-- /ServiceInterface/Driving -->
        <COLLECTION>
          <SHORT-NAME>Driving</SHORT-NAME>
          <CATEGORY>SET</CATEGORY>
          <ELEMENT-ROLE>SO_SERVICE_INTERFACE</ELEMENT-ROLE>
          <ELEMENT-REFS>
            <ELEMENT-REF DEST="VARIABLE-DATA-PROTOTYPE">/SystemMapping/SenderReceiver/MotorState</ELEMENT-REF>
            <ELEMENT-REF DEST="CLIENT-SERVER-OPERATION">/ClientServerInterface/Driving/PowerBoost</ELEMENT-REF>
            <ELEMENT-REF DEST="COLLECTION">/ServiceInterface/Mode</ELEMENT-REF>  
          </ELEMENT-REFS>
        </COLLECTION>
        <!-- /ServiceInterface/Mode -->
        <COLLECTION>
          <SHORT-NAME>Mode</SHORT-NAME>
          <CATEGORY>SET</CATEGORY>
          <ELEMENT-ROLE>SO_SERVICE_FIELD</ELEMENT-ROLE>
          <ELEMENT-REFS>
            <ELEMENT-REF DEST="VARIABLE-DATA-PROTOTYPE">/SystemMapping/SenderReceiver/Mode_Notifier</ELEMENT-REF>
            <ELEMENT-REF DEST="CLIENT-SERVER-OPERATION">/ClientServerInterface/Driving/Mode_Getter</ELEMENT-REF>
            <ELEMENT-REF DEST="CLIENT-SERVER-OPERATION">/ClientServerInterface/Driving/Mode_Setter</ELEMENT-REF>
          </ELEMENT-REFS>
        </COLLECTION>
      </ELEMENTS>
    </AR-PACKAGE>
    <AR-PACKAGE>
      <SHORT-NAME>ADT</SHORT-NAME>
      <ELEMENTS>
        <!-- /ADT/MotorStateEvt -->
        <APPLICATION-RECORD-DATA-TYPE>
