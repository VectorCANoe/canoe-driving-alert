        <!-- /ClientServerInterface/CameraObjectDetection -->
        <CLIENT-SERVER-INTERFACE>
          <SHORT-NAME>CameraObjectDetection</SHORT-NAME>
          <CATEGORY>CONTROL</CATEGORY>
          <IS-SERVICE>true</IS-SERVICE>
          <OPERATIONS>
            <!-- /ClientServerInterface/CameraObjectDetection/StartStop -->
            <CLIENT-SERVER-OPERATION>
              <SHORT-NAME>StartStop</SHORT-NAME>
              <ARGUMENTS>
                <!-- /ClientServerInterface/CameraObjectDetection/StartStop/Activate -->
                <ARGUMENT-DATA-PROTOTYPE>
                  <SHORT-NAME>Activate</SHORT-NAME>
                  <TYPE-TREF DEST='APPLICATION-PRIMITIVE-DATA-TYPE'>/ADT/Activate</TYPE-TREF>
                  <DIRECTION>IN</DIRECTION>
                </ARGUMENT-DATA-PROTOTYPE>
                <!-- /ClientServerInterface/CameraObjectDetection/StartStop/Result -->
                <ARGUMENT-DATA-PROTOTYPE>
                  <SHORT-NAME>Result</SHORT-NAME>
                  <TYPE-TREF DEST='APPLICATION-PRIMITIVE-DATA-TYPE'>/ADT/ActivateResult</TYPE-TREF>
                  <DIRECTION>OUT</DIRECTION>
                </ARGUMENT-DATA-PROTOTYPE>
              </ARGUMENTS>
            </CLIENT-SERVER-OPERATION>
            <!-- /ClientServerInterface/CameraObjectDetection/FrameRate_Getter -->
