                  <TYPE-TREF DEST='APPLICATION-PRIMITIVE-DATA-TYPE'>/ADT/FrameRateDT</TYPE-TREF>
                  <DIRECTION>OUT</DIRECTION>
                </ARGUMENT-DATA-PROTOTYPE>
              </ARGUMENTS>
            </CLIENT-SERVER-OPERATION>
            <!-- /ClientServerInterface/CameraObjectDetection/FrameRate_Setter -->
