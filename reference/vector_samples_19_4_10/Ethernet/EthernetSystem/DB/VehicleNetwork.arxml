    <AR-PACKAGE>
      <SHORT-NAME>CompuMethod</SHORT-NAME>
      <ELEMENTS>
        <COMPU-METHOD>
          <!-- /CompuMethod/DistanceCM -->
          <SHORT-NAME>DistanceCM</SHORT-NAME>
          <CATEGORY>LINEAR</CATEGORY>
          <UNIT-REF DEST='UNIT'>/Unit/DistanceUnit</UNIT-REF>
          <COMPU-INTERNAL-TO-PHYS>
            <COMPU-SCALES>
              <COMPU-SCALE>
                <COMPU-RATIONAL-COEFFS>
                  <COMPU-NUMERATOR>
                    <V>-1000</V>
                    <V>0.01</V>
                  </COMPU-NUMERATOR>
                </COMPU-RATIONAL-COEFFS>
              </COMPU-SCALE>
              <COMPU-SCALE>
                <LOWER-LIMIT INTERVAL-TYPE='CLOSED'>0</LOWER-LIMIT>
                <UPPER-LIMIT INTERVAL-TYPE='CLOSED'>0</UPPER-LIMIT>
                <COMPU-CONST>
                  <VT>NoDistance</VT>
                </COMPU-CONST>
              </COMPU-SCALE>
            </COMPU-SCALES>
          </COMPU-INTERNAL-TO-PHYS>
        </COMPU-METHOD>
        <COMPU-METHOD>
          <!-- /CompuMethod/ReliabilityCM -->
          <SHORT-NAME>ReliabilityCM</SHORT-NAME>
          <CATEGORY>LINEAR</CATEGORY>
          <UNIT-REF DEST='UNIT'>/Unit/ReliabilityUnit</UNIT-REF>
          <COMPU-INTERNAL-TO-PHYS>
            <COMPU-SCALES>
              <COMPU-SCALE>
                <COMPU-RATIONAL-COEFFS>
                  <COMPU-NUMERATOR>
                    <V>0</V>
                    <V>1</V>
                  </COMPU-NUMERATOR>
                </COMPU-RATIONAL-COEFFS>
              </COMPU-SCALE>
            </COMPU-SCALES>
          </COMPU-INTERNAL-TO-PHYS>
        </COMPU-METHOD>
        <COMPU-METHOD>
          <!-- /CompuMethod/SignKindCM -->
          <SHORT-NAME>SignKindCM</SHORT-NAME>
          <CATEGORY>LINEAR</CATEGORY>
          <COMPU-INTERNAL-TO-PHYS>
            <COMPU-SCALES>
              <COMPU-SCALE>
                <LOWER-LIMIT INTERVAL-TYPE='CLOSED'>0</LOWER-LIMIT>
                <UPPER-LIMIT INTERVAL-TYPE='CLOSED'>0</UPPER-LIMIT>
                <COMPU-CONST>
                  <VT>NoObject</VT>
                </COMPU-CONST>
              </COMPU-SCALE>
              <COMPU-SCALE>
                <LOWER-LIMIT INTERVAL-TYPE='CLOSED'>1</LOWER-LIMIT>
                <UPPER-LIMIT INTERVAL-TYPE='CLOSED'>1</UPPER-LIMIT>
                <COMPU-CONST>
                  <VT>NoLimit</VT>
                </COMPU-CONST>
              </COMPU-SCALE>
              <COMPU-SCALE>
                <LOWER-LIMIT INTERVAL-TYPE='CLOSED'>2</LOWER-LIMIT>
                <UPPER-LIMIT INTERVAL-TYPE='CLOSED'>2</UPPER-LIMIT>
                <COMPU-CONST>
                  <VT>NoPassingZoneSign</VT>
                </COMPU-CONST>
              </COMPU-SCALE>
              <COMPU-SCALE>
                <LOWER-LIMIT INTERVAL-TYPE='CLOSED'>3</LOWER-LIMIT>
                <UPPER-LIMIT INTERVAL-TYPE='CLOSED'>3</UPPER-LIMIT>
                <COMPU-CONST>
                  <VT>NoPassingZoneEndSign</VT>
                </COMPU-CONST>
              </COMPU-SCALE>
              <COMPU-SCALE>
                <LOWER-LIMIT INTERVAL-TYPE='CLOSED'>4</LOWER-LIMIT>
                <UPPER-LIMIT INTERVAL-TYPE='CLOSED'>4</UPPER-LIMIT>
                <COMPU-CONST>
                  <VT>HazardSign</VT>
                </COMPU-CONST>
              </COMPU-SCALE>
              <COMPU-SCALE>
                <LOWER-LIMIT INTERVAL-TYPE='CLOSED'>5</LOWER-LIMIT>
                <UPPER-LIMIT INTERVAL-TYPE='CLOSED'>5</UPPER-LIMIT>
                <COMPU-CONST>
                  <VT>HazardEndSign</VT>
                </COMPU-CONST>
              </COMPU-SCALE>
              <COMPU-SCALE>
                <LOWER-LIMIT INTERVAL-TYPE='CLOSED'>6</LOWER-LIMIT>
                <UPPER-LIMIT INTERVAL-TYPE='CLOSED'>6</UPPER-LIMIT>
                <COMPU-CONST>
                  <VT>RoadworkSign</VT>
                </COMPU-CONST>
              </COMPU-SCALE>
              <COMPU-SCALE>
                <LOWER-LIMIT INTERVAL-TYPE='CLOSED'>7</LOWER-LIMIT>
                <UPPER-LIMIT INTERVAL-TYPE='CLOSED'>7</UPPER-LIMIT>
                <COMPU-CONST>
                  <VT>RoadworkEndSign</VT>
                </COMPU-CONST>
              </COMPU-SCALE>
              <COMPU-SCALE>
                <LOWER-LIMIT INTERVAL-TYPE='CLOSED'>30</LOWER-LIMIT>
                <UPPER-LIMIT INTERVAL-TYPE='CLOSED'>30</UPPER-LIMIT>
                <COMPU-CONST>
                  <VT>SpeedLimit30Sign</VT>
                </COMPU-CONST>
              </COMPU-SCALE>
              <COMPU-SCALE>
                <LOWER-LIMIT INTERVAL-TYPE='CLOSED'>40</LOWER-LIMIT>
                <UPPER-LIMIT INTERVAL-TYPE='CLOSED'>40</UPPER-LIMIT>
                <COMPU-CONST>
                  <VT>SpeedLimit40Sign</VT>
                </COMPU-CONST>
              </COMPU-SCALE>
              <COMPU-SCALE>
                <LOWER-LIMIT INTERVAL-TYPE='CLOSED'>50</LOWER-LIMIT>
                <UPPER-LIMIT INTERVAL-TYPE='CLOSED'>50</UPPER-LIMIT>
                <COMPU-CONST>
                  <VT>SpeedLimit50Sign</VT>
                </COMPU-CONST>
              </COMPU-SCALE>
              <COMPU-SCALE>
                <LOWER-LIMIT INTERVAL-TYPE='CLOSED'>60</LOWER-LIMIT>
                <UPPER-LIMIT INTERVAL-TYPE='CLOSED'>60</UPPER-LIMIT>
                <COMPU-CONST>
                  <VT>SpeedLimit60Sign</VT>
                </COMPU-CONST>
              </COMPU-SCALE>
              <COMPU-SCALE>
                <LOWER-LIMIT INTERVAL-TYPE='CLOSED'>70</LOWER-LIMIT>
                <UPPER-LIMIT INTERVAL-TYPE='CLOSED'>70</UPPER-LIMIT>
                <COMPU-CONST>
                  <VT>SpeedLimit70Sign</VT>
                </COMPU-CONST>
              </COMPU-SCALE>
              <COMPU-SCALE>
                <LOWER-LIMIT INTERVAL-TYPE='CLOSED'>80</LOWER-LIMIT>
                <UPPER-LIMIT INTERVAL-TYPE='CLOSED'>80</UPPER-LIMIT>
                <COMPU-CONST>
                  <VT>SpeedLimit80Sign</VT>
                </COMPU-CONST>
              </COMPU-SCALE>
              <COMPU-SCALE>
                <LOWER-LIMIT INTERVAL-TYPE='CLOSED'>100</LOWER-LIMIT>
                <UPPER-LIMIT INTERVAL-TYPE='CLOSED'>100</UPPER-LIMIT>
                <COMPU-CONST>
                  <VT>SpeedLimit100Sign</VT>
                </COMPU-CONST>
              </COMPU-SCALE>
            </COMPU-SCALES>
          </COMPU-INTERNAL-TO-PHYS>
        </COMPU-METHOD>
        <COMPU-METHOD>
          <!-- /CompuMethod/ActivateCM -->
          <SHORT-NAME>ActivateCM</SHORT-NAME>
          <CATEGORY>LINEAR</CATEGORY>
          <COMPU-INTERNAL-TO-PHYS>
            <COMPU-SCALES>
              <COMPU-SCALE>
                <LOWER-LIMIT INTERVAL-TYPE='CLOSED'>0</LOWER-LIMIT>
                <UPPER-LIMIT INTERVAL-TYPE='CLOSED'>0</UPPER-LIMIT>
                <COMPU-CONST>
                  <VT>Deactivate</VT>
                </COMPU-CONST>
              </COMPU-SCALE>
              <COMPU-SCALE>
                <LOWER-LIMIT INTERVAL-TYPE='CLOSED'>1</LOWER-LIMIT>
                <UPPER-LIMIT INTERVAL-TYPE='CLOSED'>1</UPPER-LIMIT>
                <COMPU-CONST>
                  <VT>Activate</VT>
                </COMPU-CONST>
              </COMPU-SCALE>
            </COMPU-SCALES>
          </COMPU-INTERNAL-TO-PHYS>
        </COMPU-METHOD>
        <COMPU-METHOD>
          <!-- /CompuMethod/ActivateResultCM -->
          <SHORT-NAME>ActivateResultCM</SHORT-NAME>
          <CATEGORY>LINEAR</CATEGORY>
          <COMPU-INTERNAL-TO-PHYS>
            <COMPU-SCALES>
              <COMPU-SCALE>
                <LOWER-LIMIT INTERVAL-TYPE='CLOSED'>0</LOWER-LIMIT>
                <UPPER-LIMIT INTERVAL-TYPE='CLOSED'>0</UPPER-LIMIT>
                <COMPU-CONST>
                  <VT>Failed</VT>
                </COMPU-CONST>
              </COMPU-SCALE>
              <COMPU-SCALE>
                <LOWER-LIMIT INTERVAL-TYPE='CLOSED'>1</LOWER-LIMIT>
                <UPPER-LIMIT INTERVAL-TYPE='CLOSED'>1</UPPER-LIMIT>
                <COMPU-CONST>
                  <VT>Success</VT>
                </COMPU-CONST>
              </COMPU-SCALE>
            </COMPU-SCALES>
          </COMPU-INTERNAL-TO-PHYS>
        </COMPU-METHOD>
        <COMPU-METHOD>
          <!-- /CompuMethod/SpeedCM -->
          <SHORT-NAME>SpeedCM</SHORT-NAME>
          <CATEGORY>LINEAR</CATEGORY>
          <UNIT-REF DEST='UNIT'>/Unit/SpeedUnit</UNIT-REF>
          <COMPU-INTERNAL-TO-PHYS>
            <COMPU-SCALES>
              <COMPU-SCALE>
                <COMPU-RATIONAL-COEFFS>
                  <COMPU-NUMERATOR>
                    <V>-100</V>
                    <V>0.1</V>
                  </COMPU-NUMERATOR>
                </COMPU-RATIONAL-COEFFS>
              </COMPU-SCALE>
            </COMPU-SCALES>
          </COMPU-INTERNAL-TO-PHYS>
        </COMPU-METHOD>
        <COMPU-METHOD>
          <!-- /CompuMethod/DirectionCM -->
          <SHORT-NAME>DirectionCM</SHORT-NAME>
          <CATEGORY>LINEAR</CATEGORY>
          <COMPU-INTERNAL-TO-PHYS>
            <COMPU-SCALES>
              <COMPU-SCALE>
                <LOWER-LIMIT INTERVAL-TYPE='CLOSED'>1</LOWER-LIMIT>
                <UPPER-LIMIT INTERVAL-TYPE='CLOSED'>1</UPPER-LIMIT>
                <COMPU-CONST>
                  <VT>Forward</VT>
                </COMPU-CONST>
              </COMPU-SCALE>
              <COMPU-SCALE>
                <LOWER-LIMIT INTERVAL-TYPE='CLOSED'>2</LOWER-LIMIT>
                <UPPER-LIMIT INTERVAL-TYPE='CLOSED'>2</UPPER-LIMIT>
                <COMPU-CONST>
                  <VT>Backward</VT>
                </COMPU-CONST>
              </COMPU-SCALE>
            </COMPU-SCALES>
          </COMPU-INTERNAL-TO-PHYS>
        </COMPU-METHOD>
        <COMPU-METHOD>
          <!-- /CompuMethod/TemperatureCM -->
          <SHORT-NAME>TemperatureCM</SHORT-NAME>
          <CATEGORY>LINEAR</CATEGORY>
          <UNIT-REF DEST='UNIT'>/Unit/DegreeUnit</UNIT-REF>
          <COMPU-INTERNAL-TO-PHYS>
            <COMPU-SCALES>
              <COMPU-SCALE>
                <COMPU-RATIONAL-COEFFS>
                  <COMPU-NUMERATOR>
                    <V>-273</V>
                    <V>0.1</V>
                  </COMPU-NUMERATOR>
                </COMPU-RATIONAL-COEFFS>
              </COMPU-SCALE>
            </COMPU-SCALES>
          </COMPU-INTERNAL-TO-PHYS>
        </COMPU-METHOD>
        <COMPU-METHOD>
          <!-- /CompuMethod/CurrentCM -->
          <SHORT-NAME>CurrentCM</SHORT-NAME>
          <CATEGORY>LINEAR</CATEGORY>
          <UNIT-REF DEST='UNIT'>/Unit/CurrentUnit</UNIT-REF>
          <COMPU-INTERNAL-TO-PHYS>
            <COMPU-SCALES>
              <COMPU-SCALE>
                <COMPU-RATIONAL-COEFFS>
                  <COMPU-NUMERATOR>
                    <V>-1000</V>
                    <V>0.001</V>
                  </COMPU-NUMERATOR>
                </COMPU-RATIONAL-COEFFS>
              </COMPU-SCALE>
            </COMPU-SCALES>
          </COMPU-INTERNAL-TO-PHYS>
        </COMPU-METHOD>
        <COMPU-METHOD>
          <!-- /CompuMethod/PowerCM -->
          <SHORT-NAME>PowerCM</SHORT-NAME>
          <CATEGORY>LINEAR</CATEGORY>
          <UNIT-REF DEST='UNIT'>/Unit/PowerUnit</UNIT-REF>
          <COMPU-INTERNAL-TO-PHYS>
            <COMPU-SCALES>
              <COMPU-SCALE>
                <COMPU-RATIONAL-COEFFS>
                  <COMPU-NUMERATOR>
                    <V>-1000</V>
                    <V>0.001</V>
                  </COMPU-NUMERATOR>
                </COMPU-RATIONAL-COEFFS>
              </COMPU-SCALE>
            </COMPU-SCALES>
          </COMPU-INTERNAL-TO-PHYS>
        </COMPU-METHOD>
        <COMPU-METHOD>
          <!-- /CompuMethod/CapacityCM -->
          <SHORT-NAME>CapacityCM</SHORT-NAME>
          <CATEGORY>LINEAR</CATEGORY>
          <UNIT-REF DEST='UNIT'>/Unit/CapacityUnit</UNIT-REF>
          <COMPU-INTERNAL-TO-PHYS>
            <COMPU-SCALES>
              <COMPU-SCALE>
                <COMPU-RATIONAL-COEFFS>
                  <COMPU-NUMERATOR>
                    <V>0</V>
                    <V>0.001</V>
                  </COMPU-NUMERATOR>
                </COMPU-RATIONAL-COEFFS>
              </COMPU-SCALE>
            </COMPU-SCALES>
          </COMPU-INTERNAL-TO-PHYS>
        </COMPU-METHOD>
        <COMPU-METHOD>
          <!-- /CompuMethod/MinuteCM -->
          <SHORT-NAME>MinuteCM</SHORT-NAME>
          <CATEGORY>LINEAR</CATEGORY>
          <UNIT-REF DEST='UNIT'>/Unit/MinuteUnit</UNIT-REF>
          <COMPU-INTERNAL-TO-PHYS>
            <COMPU-SCALES>
            </COMPU-SCALES>
          </COMPU-INTERNAL-TO-PHYS>
        </COMPU-METHOD>
        <COMPU-METHOD>
          <!-- /CompuMethod/SecondCM -->
          <SHORT-NAME>SecondCM</SHORT-NAME>
