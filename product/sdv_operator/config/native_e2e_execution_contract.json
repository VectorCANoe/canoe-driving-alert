  "owner": "Dev1+Dev2",
  "status": "wave3_in_progress",
  "purpose": "Freeze the execution/evidence contract required to evolve verify batch into end-to-end native verification automation.",
  "current_state": {
    "native_tier_execute_from_product": true,
    "raw_evidence_auto_write": true,
    "official_report_cli_export": true,
