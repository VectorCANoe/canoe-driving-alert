  "run_metadata_contract": {
    "required_fields": [
      "run_id",
      "phase",
      "owner",
      "tier",
      "profile_id",
      "pack_id",
      "surface_scope"
    ],
    "target_delivery_modes": [
      "product-managed execution context",
      "CAPL helper injection",
      "sysvar handshake for execution status"
    ]
  },
  "planned_canoe_handshake": {
    "sysvars": [
      "Test::nativeExecRequest",
      "Test::nativeExecAck",
      "Test::nativeExecState",
      "Test::nativeExecVerdict",
      "Test::evidenceAutoWrite"
    ],
    "capl_hooks": [
      "ValidationHarness_SetExecutionContext",
      "ValidationHarness_ClearExecutionContext",
      "ValidationHarness_GetExecutionStatus"
    ]
  },
  "wave_sequence": [
    {
      "wave": "wave0",
      "goal": "freeze the execution/evidence contract"
    },
    {
      "wave": "wave1",
      "goal": "pilot product-driven native execute for ST_ACTIVE_BASELINE"
    },
    {
      "wave": "wave2",
      "goal": "dual-write EVIDENCE_IN/EVIDENCE_OUT into raw evidence file"
    },
    {
      "wave": "wave3",
      "goal": "inline collect/post-run into verify batch"
    },
    {
      "wave": "wave4",
      "goal": "expand end-to-end execution to UT/IT/FULL and CI"
    }
  ]
