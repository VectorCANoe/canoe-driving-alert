{
  "name": "sdv_operator",
  "display_name": "CANoe Test Verification Console",
  "role": "verification_console",
  "owner": "Dev2",
  "entrypoints": [
    "sdv",
    "python scripts/run.py"
  ],
  "public_surface": [
    "pyproject.toml",
    "sdv_cli.py",
    "scripts/run.py",
    "scripts/tui_app.py",
    "product/sdv_operator/README.md",
    "product/sdv_operator/config/cleanup_policy.json",
    "product/sdv_operator/config/surface_ecu_inventory.json",
    "product/sdv_operator/config/verification_phase_policy.json",
    "product/sdv_operator/config/surface_traceability_profile.json",
    "product/sdv_operator/config/verification_artifact_layout.json",
    "product/sdv_operator/mkdocs.yml",
    "product/sdv_operator/docs-src/index.md",
    "product/sdv_operator/docs-src/quickstart.md",
    "product/sdv_operator/docs-src/commands.md",
    "product/sdv_operator/docs-src/results.md",
    "product/sdv_operator/docs-src/ci-bridge.md",
    "product/sdv_operator/docs-src/packaging.md",
    "product/sdv_operator/docs-src/repo-surfaces.md",
    "product/sdv_operator/docs-src/maintenance.md",
    "product/sdv_operator/examples/Jenkinsfile.verify",
    "product/sdv_operator/config/campaign_profiles.json",
    "product/sdv_operator/docs-src/role-boundary.md",
    "product/sdv_operator/docs-src/campaign-profiles.md"
  ],
  "runtime_modules": [
    "scripts/cliops",
    "scripts/release"
  ],
  "backend_modules": [
    "scripts/gates",
    "scripts/quality"
  ],
  "excluded_from_product_surface": [
    "scripts/docs",
    "scripts/report",
    "scripts/canoe",
    "canoe/scripts",
    "canoe/tmp",
    "reference",
    "legacy_projects"
  ],
  "generated_outputs": [
    "canoe/tmp/reports/verification",
    "canoe/logging/evidence",
    "artifacts/verification_runs",
    "canoe/cfg/.run",
    "dist",
    "build",
    "product/sdv_operator/site"
  ],
  "release_artifacts": {
    "exe_onefolder": "dist/sdv_cli/sdv",
    "exe_onefile": "dist/sdv_cli/sdv.exe",
    "portable_folder": "dist/portable/sdv_portable",
    "portable_zip": "dist/portable/sdv_portable.zip",
    "pyinstaller_work": "build/pyinstaller",
    "pyinstaller_spec": "build/spec"
  },
  "packaging_scope_doc": "product/sdv_operator/docs/PACKAGING_SCOPE.md"
}
