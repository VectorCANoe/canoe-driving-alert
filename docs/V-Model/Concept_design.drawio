                <mxCell id="utDd3wTg1uHb87nq0AtO-42" value="&lt;div&gt;&lt;span style=&quot;text-align: center; background-color: transparent; color: light-dark(rgb(102, 102, 102), rgb(149, 149, 149));&quot;&gt;|&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(102, 102, 102), rgb(149, 149, 149));&quot;&gt;Bidirectional: Request-Response&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;text-align: center; background-color: transparent; color: light-dark(rgb(102, 102, 102), rgb(149, 149, 149));&quot;&gt;|&lt;/span&gt;&lt;span style=&quot;text-align: center;&quot;&gt;&amp;nbsp;CAN: Universal Backup&lt;/span&gt;&lt;/div&gt;| Security: Firewall + Access Control&lt;div&gt;|&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(102, 102, 102), rgb(149, 149, 149));&quot;&gt;Mirror: Trace Recording &amp;amp; Analysis&lt;/span&gt;&lt;/div&gt;&lt;div&gt;| Protocol: Raw CAN/CAN TP/UDS/TCP/UDP/SOME/IP/DoIP/FlexRay/MOST&lt;/div&gt;" style="text;html=1;align=left;fontSize=9;fontColor=#666666;shadow=0;" parent="1" vertex="1">
                    <mxGeometry x="1179" y="724" width="320" height="75" as="geometry"/>
                </mxCell>
                <mxCell id="utDd3wTg1uHb87nq0AtO-43" value="&lt;div style=&quot;text-align: center;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Vector CANoe Test Sequence&lt;/span&gt;&lt;/div&gt;───────────────────────────────────────────────────────────────────────────&lt;br&gt;One-way Test: (1) Vehicle ID → (2) TCP Handshake → (3) Routing Activation → (4) Diagnostic Message → (5) Output Verification&lt;br&gt;Two-way Test: (1) Vehicle ID ↔ (2) TCP Handshake ↔ (3) Routing Activation ↔ (5) UDS Request/Response ↔ (5) Feedback Verification&lt;br&gt;&lt;br&gt;&lt;div&gt;Latency Test: Measure Gateway Processing Time (Trace A → Trace B)&lt;br&gt;Security Test: Firewall Blocking Unauthorized Messages&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=9;fontStyle=2;align=left;" parent="1" vertex="1">
                    <mxGeometry x="450" y="714" width="680" height="80" as="geometry"/>
