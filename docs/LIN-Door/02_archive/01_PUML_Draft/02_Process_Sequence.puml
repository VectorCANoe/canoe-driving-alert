@startuml
title E2E 시나리오: Fault Detection → Diagnostics → OTA Update

skinparam participant {
    BackgroundColor White
    BorderColor Black
}

participant "가상노드 (Sim)" as SIM
participant "BCM (Body Control)" as BCM
participant "Gateway (CGW)" as GW
participant "Cluster (Instrument)" as CLU
participant "Tester (Diag)" as TEST
participant "OTA Server" as OTA

== Phase 1: 고장 감지 및 경고등 점등 (Fault Detection) ==
SIM -> BCM : [SysVar] overcurrentDetected = 1 (Fault Injection)
activate BCM
    BCM -> BCM : 과전류 감지 및 DTC B1234 생성
    BCM -> GW : CAN-LS: BCM_FaultStatus (0x500)\n[WindowMotorOvercurrent=1]
    activate GW
        GW -> CLU : CAN-HS: BCM_FaultStatus (Routed)
    deactivate GW
    activate CLU
        CLU -> CLU : RED 경고등 점등 (50ms 이내)
    deactivate CLU
deactivate BCM

== Phase 2: UDS 진단 및 DTC 처리 (Diagnostics) ==
TEST -> GW : CAN-LS: UDS 0x10 0x03 (Extended Session)
activate GW
    GW -> BCM : Forward Request
deactivate GW
activate BCM
    BCM -> GW : Response 0x50 0x03
deactivate BCM
activate GW
    GW -> TEST : Forward Response
deactivate GW

TEST -> GW : CAN-LS: UDS 0x19 0x02 (Read DTC)
activate GW
    GW -> BCM : Forward Request
deactivate GW
activate BCM
    BCM -> GW : Response 0x59 (DTC B1234 Active)
deactivate BCM
activate GW
    GW -> TEST : Forward Response
deactivate GW

TEST -> GW : CAN-LS: UDS 0x14 (Clear DTC)
activate GW
    GW -> BCM : Forward Request
deactivate GW
activate BCM
    BCM -> BCM : DTC 삭제 및 Fault 상태 해제
    BCM -> GW : Response 0x54 (Positive)
    activate GW
        GW -> CLU : [Signal] WarnLampRed = 0 (or via UDS response routing)
    deactivate GW
    activate CLU
        CLU -> CLU : 경고등 소등
    deactivate CLU
deactivate BCM
activate GW
    GW -> TEST : Forward Response
deactivate GW

== Phase 3: OTA 업데이트 (Firmware Update) ==
OTA -> GW : DoIP: Routing Activation (0xE001)
activate GW
    GW -> OTA : Response 0xE001 (Success)
deactivate GW

OTA -> GW : UDS 0x10 0x02 (Programming Session)
activate GW
    GW -> BCM : Forward (DoIP → CAN-LS)
deactivate GW
activate BCM
    BCM -> GW : Response 0x50 0x02
deactivate BCM
activate GW
    GW -> OTA : Forward (CAN-LS → DoIP)
deactivate GW

OTA -> GW : UDS 0x34 (Request Download)
activate GW
    GW -> BCM : Forward
deactivate GW
activate BCM
    BCM -> GW : Response 0x74 (MaxBlockLength)
deactivate BCM
activate GW
    GW -> OTA : Forward
deactivate GW

loop Data Transfer (4 Blocks)
    OTA -> GW : UDS 0x36 (Transfer Data)
    GW -> BCM : Forward
    BCM -> GW : Response 0x76
    GW -> OTA : Forward
end

OTA -> GW : UDS 0x37 (Request Transfer Exit)
activate GW
    GW -> BCM : Forward
deactivate GW
activate BCM
    BCM -> BCM : CRC-32 검증 및 재시작
    BCM -> GW : Response 0x77 (Success)
deactivate BCM
activate GW
    GW -> OTA : Forward
deactivate GW

@enduml
