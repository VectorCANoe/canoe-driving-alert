@startuml
title 2. Network Architecture (How) - Bus Topology
top to bottom direction
skinparam componentStyle rectangle
skinparam shadowing false
skinparam roundcorner 5

' --- Colors & Style ---
skinparam rectangle {
    BackgroundColor White
    BorderColor Black
    FontSize 14
    FontStyle bold
}
skinparam component {
    BackgroundColor White
    BorderColor Black
    FontSize 12
    FontStyle bold
}

' --- Bus Lines ---
interface "Ethernet (DoIP)\n<color:Blue>100 Mbps</color>"     as ETH_BUS #LightBlue
interface "CAN-HS\n<color:Red>500 kbps</color>"               as HS_BUS  #Pink
interface "CAN-LS\n<color:DarkGreen>125 kbps</color>"         as LS_BUS  #LightGreen
interface "LIN Bus\n<color:DarkOrange>19.2 kbps</color>"      as LIN_BUS #NavajoWhite

' --- Connectivity Domain ---
package "Connectivity Domain" {
    component "OTA Server" as OTA #LightBlue
}

' --- Gateway ---
package "Gateway & Backbone" {
    component "Central Gateway\n(CGW)" as GW #LightGray
}

' --- Body Domain ---
package "Body Domain" {
    component "Body Control Module\n(BCM  —  LIN Master)" as BCM #LightYellow

    package "LIN Slaves" {
        component "WindowMotorECU\n(LIN Slave 0x21 / 10ms)" as WMECU #NavajoWhite
        component "DoorModule FL/FR\n(LIN Slave 0x22~0x23 / 50ms)" as DOOR_F #NavajoWhite
        component "DoorModule RL/RR\n(LIN Slave 0x24~0x25 / 50ms)" as DOOR_R #NavajoWhite
    }
}

' --- Infotainment Domain ---
package "Infotainment Domain" {
    component "Cluster\n(CLU)" as CLU #MistyRose
}

' --- Diagnostics ---
package "Diagnostics" {
    component "Tester\n(Equipment)" as TESTER #LightYellow
}

' --- Connections ---
OTA     -down-> ETH_BUS   : "TCP/IP"
ETH_BUS -down-> GW

GW -left->  LS_BUS
GW -right-> HS_BUS

LS_BUS -down-> BCM    : "Tx Fault 0x500\nRx UDS 0x7DF/7E8"
LS_BUS -down-> TESTER : "Tx UDS Request"

HS_BUS -down-> CLU    : "Rx Warning 0x500"

' LIN Master-Slave
BCM     -down-> LIN_BUS
LIN_BUS -down-> WMECU  : "Motor_Current\n>50A → DTC B1234"
LIN_BUS -down-> DOOR_F : "Door_Position\nLock_Status"
LIN_BUS -down-> DOOR_R : "Door_Position\nLock_Status"

@enduml
