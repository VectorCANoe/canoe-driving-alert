@startuml
title 1. Concept Design (What) - Input → Control → Output
left to right direction
skinparam componentStyle rectangle
skinparam shadowing false
skinparam handwritten false
skinparam roundcorner 10
skinparam padding 5

' --- Colors & Style ---
skinparam package {
    BackgroundColor White
    BorderColor DimGray
    FontColor DimGray
}

skinparam component {
    BackgroundColor WhiteSmoke
    BorderColor Black
    FontSize 14
    FontStyle bold
}

skinparam note {
    BackgroundColor GhostWhite
    BorderColor Silver
    FontSize 11
}

' --- Elements ---
package "Input Layer (Trigger)\n<color:RoyalBlue>Who Starts?</color>" as INPUT {
    component "<color:Green>Tester (Diag)</color>" as TESTER
    component "<color:Green>Current Sensor</color>" as SENSOR
    component "<color:Green>OTA Cloud</color>" as CLOUD

    note bottom of TESTER : UDS Req (0x10, 0x19)\n(Simulated)
    note bottom of SENSOR : Exceed Limit (>50A)\n(Fault Inj.)
    note bottom of CLOUD : Firmware Bin\n(DoIP TCP)
}

package "Control Layer (Processing)\n<color:RoyalBlue>Who Decides?</color>" as CONTROL {
    component "<color:DarkBlue>Body Control (BCM)</color>" as BCM
    component "<color:DarkBlue>Gateway (CGW)</color>" as GW
    component "<color:DarkBlue>OTA Master</color>" as OTA

    note top of BCM : Logic: Overcurrent Check\nLogic: DTC Management
    note top of GW : Logic: Routing (LS↔HS)\nLogic: DoIP Session
    note top of OTA : Logic: Flash Sequence\nLogic: Rollback
}

package "Output Layer (Action)\n<color:RoyalBlue>What Happens?</color>" as OUTPUT {
    component "<color:FireBrick>Window Motor</color>" as MOTOR
    component "<color:FireBrick>Cluster HMI</color>" as CLUSTER

    note bottom of MOTOR : Action: Stop / Reverse\n(via LIN)
    note bottom of CLUSTER : Action: Red Lamp ON
}

' --- Connections (Hidden Lines for Layout) ---
' Adjust vertical alignment within packages
TESTER -[hidden]- SENSOR
SENSOR -[hidden]- CLOUD

BCM -[hidden]- GW
GW -[hidden]- OTA

MOTOR -[hidden]- CLUSTER

' --- Real Connections ---
TESTER --> GW : "Diag Request"
SENSOR --> BCM : "Current > 50A"
CLOUD --> OTA : "Firmware Data"

GW --> BCM : "UDS Forward"
OTA --> GW : "Update Request"

BCM --> GW : "Fault Status\n(0x500)"
BCM -right-> MOTOR : "LIN Control"

GW --> CLUSTER : "Warning Cmd\n(0x500 Routed)"

@enduml
