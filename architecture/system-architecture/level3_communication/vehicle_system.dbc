CM_ BU_ EMS "Engine Management System - Controls fuel injection, ignition timing, emission control";
CM_ BU_ TCU "Transmission Control Unit - Manages gear shifting and torque converter";
CM_ BU_ ESP "Electronic Stability Program - ABS, TCS, ESC, Hill Start Assist";
CM_ BU_ MDPS "Motor Driven Power Steering - Electric power steering with LKA actuation";
CM_ BU_ BCM "Body Control Module - Exterior/interior lighting, door locks, windows";
CM_ BU_ IVI "In-Vehicle Infotainment - Multimedia, navigation, ambient lighting, ADAS warnings";
CM_ BU_ Cluster "Instrument Cluster - Speedometer, tachometer, warning lights, ADAS status";
CM_ BU_ Camera "Front Camera ECU - LDW, AEB, FCW, traffic sign recognition";
CM_ BU_ Radar "Blind Spot Detection Radar - BSD, RCTA";
CM_ BU_ SCC "Smart Cruise Control - Adaptive cruise control, speed limit assist";
CM_ BU_ CGW "Central Gateway - CAN-CAN routing, firewall, diagnostics, OTA coordination";

CM_ BO_ 256 "Engine status including RPM, speed, torque, throttle position";
CM_ BO_ 257 "Engine temperature sensors (coolant, oil, intake air)";
CM_ BO_ 384 "Transmission gear position and status";
CM_ BO_ 512 "Wheel speed sensors for all four wheels";
CM_ BO_ 528 "ESP sensors: yaw rate, lateral acceleration, brake pressure";
CM_ BO_ 640 "Steering angle, torque, and rate from MDPS";
CM_ BO_ 768 "Lane Departure Warning and Automatic Emergency Braking status";
CM_ BO_ 784 "Camera-detected object information";
CM_ BO_ 832 "Blind Spot Detection radar data";
CM_ BO_ 896 "Smart Cruise Control status and settings";
CM_ BO_ 1024 "IVI ambient lighting control (RGB + brightness + theme)";
CM_ BO_ 1040 "IVI user profile and scenario parameters";
CM_ BO_ 1152 "Cluster display data (speed, RPM, gear, warnings)";
CM_ BO_ 1280 "Body Control Module door status";
CM_ BO_ 1296 "Body Control Module light control and ambient lighting feedback";
CM_ BO_ 1792 "Gateway status and network load monitoring";

