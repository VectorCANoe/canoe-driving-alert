@startuml level2_powertrain
!theme plain

title Level 2: Powertrain Domain Architecture\nEngine and Transmission Control Systems

skinparam component {
    BackgroundColor LightYellow
    BorderColor DarkOrange
    ArrowColor DarkGreen
}

package "Powertrain Domain" {

    component "EMS\n(Engine Management System)" as EMS {
        portin p_accelerator
        portin p_sensors
        portout p_engine_speed
        portout p_vehicle_speed
        portout p_torque
        portout p_fuel_consumption

        [Fuel Injection Control]
        [Ignition Timing Control]
        [Throttle Control]
        [Engine Diagnostics]
    }

    component "TCU\n(Transmission Control Unit)" as TCU {
        portin p_gear_request
        portin p_engine_rpm
        portout p_gear_position
        portout p_shift_status

        [Gear Selection Logic]
        [Shift Control]
        [Clutch Control]
        [Transmission Diagnostics]
    }

    component "OPI\n(Oil Pump Inverter)" as OPI {
        portin p_oil_demand
        portout p_oil_pressure
        portout p_pump_status

        [Inverter Control]
        [Oil Pressure Monitor]
    }

    component "LPI\n(LPG Injection)" as LPI {
        portin p_lpg_demand
        portout p_lpg_status

        [LPG Injection Control]
        [Fuel Mode Switch]
    }

    component "FPCM\n(Fuel Pump Control)" as FPCM {
        portin p_fuel_demand
        portout p_fuel_pressure

        [Fuel Pump Control]
        [Pressure Regulation]
    }

    component "REA\n(Rear Engine Actuator)" as REA {
        portin p_actuator_cmd
        portout p_actuator_status

        [Actuator Control]
    }

    component "AAF\n(Active Air Flap)" as AAF {
        portin p_cooling_demand
        portout p_flap_position

        [Flap Position Control]
        [Aerodynamics Optimization]
    }
}

cloud "CAN-HS #1\n500 kbps" as CAN1

' EMS Messages (OpenDBC)
EMS --> CAN1 : **EMS16 (0x316)**\n• Vehicle_Speed (km/h)\n• Engine_RPM (rpm)\n• Torque (Nm)\nCycle: 10ms, ASIL-D

EMS --> CAN1 : **EMS_EngineStatus**\n• Engine_State\n• Fuel_Consumption\n• Coolant_Temp\nCycle: 100ms

' TCU Messages
TCU --> CAN1 : **TCU11**\n• Gear_Position\n• Shift_Request\n• Clutch_Status\nCycle: 20ms, ASIL-C

CAN1 --> TCU : **EMS16**\n• Engine_RPM\n(for shift control)

' OPI Messages
OPI --> CAN1 : **OPI_Status**\n• Oil_Pressure\n• Pump_Speed\nCycle: 100ms

' LPI Messages
LPI --> CAN1 : **LPI_Status**\n• LPG_Mode\n• Fuel_Level\nCycle: 500ms

' FPCM Messages
FPCM --> CAN1 : **FPCM_Status**\n• Fuel_Pressure\n• Pump_Status\nCycle: 100ms

' REA Messages
REA --> CAN1 : **REA_Status**\n• Actuator_Position\nCycle: 100ms

' AAF Messages
AAF --> CAN1 : **AAF_Status**\n• Flap_Position\n• Cooling_Status\nCycle: 500ms

component "CGW\n(Central Gateway)" as CGW
CAN1 --> CGW : Route to other networks

note right of EMS
  **EMS Key Functions**
  • Fuel injection timing
  • Ignition control
  • Throttle position control
  • Engine diagnostics (DTC)

  **Safety Level**: ASIL-D
  **Cycle Time**: 10-100ms
end note

note right of TCU
  **TCU Key Functions**
  • Automatic gear selection
  • Shift timing optimization
  • Clutch engagement control

  **Safety Level**: ASIL-C
  **Cycle Time**: 20ms
end note

note bottom of CAN1
  **Powertrain CAN Messages**

  Critical Messages (10-20ms):
  • EMS16: Vehicle Speed, RPM, Torque
  • TCU11: Gear Position, Shift Request

  Status Messages (100-500ms):
  • Engine Status, Oil Pressure
  • Fuel Status, Actuator Status

  **Total Messages**: ~15 messages
  **ASIL Level**: B-D
end note

@enduml
