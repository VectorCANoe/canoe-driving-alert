@startuml
!theme materia-outline

title REQ_IVI_042-045: IVI Theme & Profile Management Sequence

actor "Driver" as USER
participant "IVI Touchscreen" as TOUCH
box "IVI Application" #f0f8ff
    participant "Theme_Selection_UI" as THEME_UI
    participant "Profile_Manager_UI" as PROFILE_UI
    participant "Theme_Manager" as THEME_MGR
    participant "Profile_Storage" as PROFILE_DB
    participant "CAN_Tx_Manager" as CAN_TX
end box
participant "CAN Bus" as CAN
box "vECU" #f9f9f9
    participant "Theme_Receiver" as VECU_THEME
    participant "Lighting_Controller" as LIGHTING
end box

== Driver Profile Login [REQ_IVI_043] ==

USER -> TOUCH : Select Profile 2\\n"Sport Driver"
activate TOUCH
TOUCH -> PROFILE_UI : Profile_Select(id=2)
activate PROFILE_UI

note right of PROFILE_UI
    **REQ_IVI_043 (QM)**
    Profile Load: <200ms
    Max 3 Profiles
end note

PROFILE_UI -> PROFILE_DB : Load Profile(id=2)
activate PROFILE_DB
PROFILE_DB -> PROFILE_DB : Read from Local Storage\\n{\\n  color: RED,\\n  brightness: 80%,\\n  alert_level: HIGH\\n}
PROFILE_DB --> PROFILE_UI : Profile Data
deactivate PROFILE_DB

note right: Load Time: 150ms\\n✓ PASS (<200ms)

PROFILE_UI -> THEME_MGR : Apply Profile Settings
activate THEME_MGR
THEME_MGR -> CAN_TX : Send Profile Data\\n(CAN 0x211)
activate CAN_TX
CAN_TX -> CAN : 0x211: Profile_Data\\n[id=2, color=RED, brightness=80]
deactivate CAN_TX
deactivate THEME_MGR

CAN -> VECU_THEME : Profile Command Received
activate VECU_THEME
VECU_THEME -> LIGHTING : Update Lighting Config
activate LIGHTING
LIGHTING -> LIGHTING : Set RGB(255,0,0)\\nSet Brightness(80%)
LIGHTING --> VECU_THEME : Applied
deactivate LIGHTING
VECU_THEME --> CAN : ACK
deactivate VECU_THEME

CAN --> PROFILE_UI : Profile Applied
PROFILE_UI --> TOUCH : Display "Profile 2 Loaded"
deactivate PROFILE_UI
TOUCH --> USER : Visual Confirmation
deactivate TOUCH

note over USER
    **Total Time: 180ms**
    ✓ PASS (<200ms)
end note

== Theme Selection [REQ_IVI_042] ==

USER -> TOUCH : Select "Sport Mode"
activate TOUCH
TOUCH -> THEME_UI : Theme_Select(mode=SPORT)
activate THEME_UI

note right of THEME_UI
    **REQ_IVI_042 (QM)**
    Theme Apply: <100ms
    Sport/Eco/Comfort Modes
end note

THEME_UI -> THEME_MGR : Load Sport Theme
activate THEME_MGR
THEME_MGR -> THEME_MGR : Get Theme Package\\n{\\n  color_scheme: RED_GRADIENT,\\n  brightness: 100%,\\n  effect: PULSE\\n}

note right: Package Load: 20ms

THEME_MGR -> CAN_TX : Send Theme Package\\n(CAN 0x210)
activate CAN_TX
CAN_TX -> CAN : 0x210: Theme_Package\\n[mode=SPORT, effect=PULSE]
deactivate CAN_TX
deactivate THEME_MGR

CAN -> VECU_THEME : Theme Command Received
activate VECU_THEME
VECU_THEME -> LIGHTING : Apply Sport Theme
activate LIGHTING
LIGHTING -> LIGHTING : Transition to Red Gradient\\nActivate Pulse Effect (500ms cycle)
LIGHTING --> VECU_THEME : Theme Active
deactivate LIGHTING
VECU_THEME --> CAN : ACK
deactivate VECU_THEME

CAN --> THEME_UI : Theme Applied
THEME_UI --> TOUCH : Display "Sport Mode Active"
deactivate THEME_UI
TOUCH --> USER : Visual Feedback
deactivate TOUCH

note over USER
    **Total Time: 85ms**
    ✓ PASS (<100ms)
end note

== Save Custom Preferences [REQ_IVI_043] ==

USER -> TOUCH : Adjust Brightness to 90%
activate TOUCH
TOUCH -> PROFILE_UI : Update_Brightness(90%)
activate PROFILE_UI

USER -> TOUCH : Click "Save to Profile 2"
TOUCH -> PROFILE_UI : Save_Profile(id=2)

note right of PROFILE_UI
    **REQ_IVI_043 (QM)**
    Profile Save: <150ms
end note

PROFILE_UI -> PROFILE_DB : Update Profile(id=2)
activate PROFILE_DB
PROFILE_DB -> PROFILE_DB : Write to Local Storage\\n{\\n  ...existing data,\\n  brightness: 90%\\n}
PROFILE_DB --> PROFILE_UI : Save Complete
deactivate PROFILE_DB

note right: Save Time: 120ms\\n✓ PASS (<150ms)

PROFILE_UI --> TOUCH : Display "Profile Saved"
deactivate PROFILE_UI
TOUCH --> USER : Confirmation Toast
deactivate TOUCH

note over USER
    **Total Time: 130ms**
    ✓ PASS (<150ms)
end note

== Error Scenario: CAN Communication Failure ==

USER -> TOUCH : Select "Eco Mode"
activate TOUCH
TOUCH -> THEME_UI : Theme_Select(mode=ECO)
activate THEME_UI
THEME_UI -> THEME_MGR : Load Eco Theme
activate THEME_MGR
THEME_MGR -> CAN_TX : Send Theme Package
activate CAN_TX
CAN_TX -> CAN : 0x210: Theme_Package
deactivate CAN_TX

note over CAN #Red
    **CAN Bus Error**
    Message Lost
end note

CAN_TX -> CAN_TX : Wait for ACK\\n(Timeout: 500ms)

alt ACK Timeout
    CAN_TX --> THEME_MGR : Transmission Failed
    deactivate THEME_MGR
    THEME_MGR --> THEME_UI : Error: CAN Timeout
    THEME_UI --> TOUCH : Display Error\\n"Unable to apply theme"
    deactivate THEME_UI
    TOUCH --> USER : Error Message
    deactivate TOUCH

    note over USER #Red
        **Fallback**:
        Keep current theme
        Log error for diagnostics
    end note
end

@enduml
